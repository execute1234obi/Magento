<?xml version="1.0"?>
<page xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
      xsi:noNamespaceSchemaLocation="urn:magento:framework:View/Layout/etc/page_configuration.xsd">
  <body>

    <!-- kill the original Luma header & footer -->
    <referenceContainer name="header.container" remove="true"/>
    <referenceContainer name="header.panel"     remove="true"/>
    <referenceContainer name="footer-container" remove="true"/>

    <!-- 1) override the built‑in wrapper to be fluid -->
    <referenceContainer name="page.wrapper.container">
      <arguments>
        <!-- change htmlClass from “container” to “container‑fluid” -->
        <argument name="htmlClass" xsi:type="string">container-fluid</argument>
      </arguments>
    </referenceContainer>

    <!-- 2) inject your own header -->
    <referenceContainer name="page.wrapper">
      <container name="custom.header"
                 as="customHeader"
                 htmlTag="header"
                 htmlClass="custom-page-header"
                 before="main.content">
        <block class="Magento\Framework\View\Element\Template"
               name="custom.header.block"
               template="Magento_Theme::html/custom-header.phtml"/>
      </container>
    </referenceContainer>

    <!-- (Magento’s regular <main /> will still render here) -->

    <!-- 3) your custom footer -->
    <referenceContainer name="page.wrapper">
      <container name="custom.footer"
                 as="customFooter"
                 htmlTag="footer"
                 htmlClass="custom-page-footer"
                 after="main.content">
        <block class="Magento\Framework\View\Element\Template"
               name="custom.footer.block"
               template="Magento_Theme::html/custom-footer.phtml"/>
      </container>
    </referenceContainer>

  </body>
</page>
