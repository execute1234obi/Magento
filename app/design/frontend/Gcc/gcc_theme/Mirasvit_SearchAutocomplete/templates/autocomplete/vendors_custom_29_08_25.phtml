<script type="text/html" id="vnecoms_vendors">
    <style>
        /* match Magento product listing look */
        .vendor-item.product-item {
            display: flex;
            align-items: flex-start;
            gap: 10px;
            padding: 10px 0;
            border-bottom: 1px solid #e0e0e0;
        }
        .vendor-item .product-item-photo {
            width: 75px;
            height: 75px;
            flex-shrink: 0;
            border: 1px solid #ddd;
            background: #fff;
            display: flex;
            align-items: center;
            justify-content: center;
        }
        .vendor-item .product-image-photo {
            width: 100%;
            height: 100%;
            object-fit: contain; /* prevent crop */
        }
        .vendor-item .product-item-details {
            flex-grow: 1;
        }
        .vendor-item .product-item-name {
            font-size: 14px;
            font-weight: 600;
            margin: 0 0 4px;
            color: #333;
        }
        .vendor-item .product-item-description {
            font-size: 12px;
            color: #777;
            line-height: 1.3;
        }
    </style>

    <li class="product-item vendor-item">
        <a class="product-item-photo" data-bind="attr: { href: url }">
            <!-- Vendor Logo -->
            <img data-bind="visible: logo, attr: { src: logo, alt: title }"
                 class="product-image-photo"/>

            <!-- Placeholder if no logo -->
            <img data-bind="visible: !logo"
                 src="<?= $block->escapeUrl($block->getViewFileUrl('Magento_Catalog::images/product/placeholder/thumbnail.jpg')) ?>"
                 alt="Placeholder"
                 class="product-image-photo"/>
        </a>

        <div class="product-item-details">
            <strong class="product-item-name">
                <a data-bind="attr: { href: url }, text: title"></a>
            </strong>
            <div class="product-item-description" data-bind="text: detail"></div>
        </div>
    </li>
</script>
