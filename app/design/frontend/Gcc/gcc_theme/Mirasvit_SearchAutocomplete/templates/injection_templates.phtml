<script id="searchAutocompleteWrapper" type="text/x-custom-template">
    <div class="mst-searchautocomplete__wrapper search-autocomplete-panel">
        <div class="mst-searchautocomplete__results search-autocomplete-panel__results" data-bind="visible: result().noResults == false">
            <div class="search-autocomplete-panel__scroll">
                <div data-bind="foreach: {
                        data: result().indexes ? result().indexes.slice().sort(function (left, right) {
                            var getWeight = function (index) {
                                if (index.identifier === 'magento_catalog_product') {
                                    return -1000;
                                }

                                return parseInt(index.position, 10) || 0;
                            };

                            return getWeight(left) - getWeight(right);
                        }) : [],
                        as: 'index'
                    }">
                    <section class="search-autocomplete-panel__section" data-bind="visible: index.totalItems">
                        <header class="search-autocomplete-panel__section-header">
                            <div class="search-autocomplete-panel__section-title" data-bind="text: index.title"></div>
                            <div class="search-autocomplete-panel__section-count" data-bind="text: index.totalItems + ' &quot;' + $parent.result().query + '&quot; related ' + (index.identifier === 'magento_catalog_product' ? 'products' : 'vendors') + ' found'"></div>
                        </header>

                        <div class="search-autocomplete-panel__empty-result" data-bind="visible: index.isMisspell == true">
                            <span data-bind="text: index.textMisspell"></span>
                            <span data-bind="text: index.textCorrected"></span>
                        </div>

                        <ul class="search-autocomplete-panel__list" data-bind="foreach: { data: index.items, as: 'item' }" aria-label="Search Autocomplete Result">
                            <li data-bind="
                                template: { name: index.identifier, data: item },
                                attr: {class: 'mst-searchautocomplete__item search-autocomplete-panel__item ' + index.identifier},
                                event: { mouseover: $parents[1].onMouseOver, mouseout: $parents[1].onMouseOut, mousedown: $parents[1].onClick },
                                css: {_active: $data.isActive}">
                            </li>
                        </ul>
                    </section>
                </div>
            </div>

            <div class="mst-searchautocomplete__show-all search-autocomplete-panel__show-all" data-bind="visible: result().urlAll && result().totalItems > 0">
                <a data-bind="attr: { href: result().urlAll, 'aria-label': result().textAll }">
                    <span class="search-autocomplete-panel__show-all-prefix">View All</span>
                    <span class="search-autocomplete-panel__show-all-count" data-bind="text: result().totalItems"></span>
                    <span class="search-autocomplete-panel__show-all-text">Results for</span>
                    <span class="search-autocomplete-panel__show-all-query" data-bind="text: '&quot;' + result().query + '&quot;'"></span>
                    <span class="search-autocomplete-panel__show-all-arrow" aria-hidden="true">&#8594;</span>
                </a>
            </div>
        </div>

        <div class="mst-searchautocomplete__empty-result search-autocomplete-panel__empty-result" data-bind="visible: result().noResults == true && !loading()">
            <span data-bind="text: result().textEmpty"></span>
        </div>
    </div>
</script>

