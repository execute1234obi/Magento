<?php
/** @var \Magento\ConfigurableProduct\Block\Product\View\Type\Configurable $block */
$product = $block->getProduct();
$attributes = $block->getAllowAttributes();

$configurableJsonConfig = $block->getJsonConfig();
$priceConfigData = $block->getJsonPriceConfig();

// Only render the script if it's a configurable product and data is available
if ($product->getTypeId() == \Magento\ConfigurableProduct\Model\Product\Type\Configurable::TYPE_CODE && $configurableJsonConfig && $priceConfigData) :
?>
<?php echo "<!-- CUSTOM CONFIGURABLE LOADED -->"; ?>
<script type="text/x-magento-init">
{
    "#product-options-wrapper": {
        "Magento_ConfigurableProduct/js/configurable": {
            "spConfig": <?= /* @noEscape */ $configurableJsonConfig ?>,
            "gallerySwitchStrategy": "replace",
            "chooseText": "Choose an Option..."
        }
    },
    "[data-role=priceBox][data-product-id='<?= $product->getId() ?>']": {
        "priceBox": {
            "priceConfig": <?= /* @noEscape */ $priceConfigData ?>
        }
    }
}
</script>
<?php endif; ?>

<style>
/* ... Your custom CSS ... */
</style>

<form class="product-info-main"
      id="product-options-wrapper"
      data-role="product-form"
      action="<?= $block->escapeUrl($block->getAddToCartUrl($product)) ?>"
      method="post"
      enctype="multipart/form-data">

    <?= $block->getBlockHtml('formkey') ?>

    <?php if (!empty($attributes)): ?>
        <?php foreach ($attributes as $attribute):
            $attributeLabel = $block->escapeHtml($attribute->getProductAttribute()->getStoreLabel());
            $attributeCode = $attribute->getProductAttribute()->getAttributeCode();
            $attributeOptions = $attribute->getOptions();
        ?>
        <div class="variation">
            <label><?= $attributeLabel ?></label>
            <div class="attribute-options" data-attribute-code="<?= $attributeCode ?>">
                <?php foreach ($attributeOptions as $option): ?>
                <button type="button"
                        class="option-btn"
                        data-attribute-code="<?= $attributeCode ?>"
                        data-option-id="<?= $block->escapeHtmlAttr($option['value_index'] ?? '') ?>">
                    <?= $block->escapeHtml($option['label'] ?? '') ?>
                </button>
                <?php endforeach; ?>
            </div>
            <select name="super_attribute[<?= $attributeCode ?>]"
                    class="super-attribute-select"
                    data-selector="super_attribute[<?= $attributeCode ?>]"
                    style="display:none;">
                <option value=""><?= __('Choose an option...') ?></option>
                <?php foreach ($attributeOptions as $option): ?>
                    <option value="<?= $block->escapeHtmlAttr($option['value_index']) ?>">
                        <?= $block->escapeHtml($option['label']) ?>
                    </option>
                <?php endforeach; ?>
            </select>
        </div>
        <?php endforeach; ?>
    <?php else: ?>
        <p>No configurable attributes found.</p>
    <?php endif; ?>

    <button type="submit"
            class="mt-6 w-full bg-blue-600 text-white py-2 rounded text-sm font-semibold hover:bg-blue-700 add-quote-btn"
            data-product-id="<?= (int) $product->getId() ?>">
        Add To Quote
    </button>
</form>

<script>
require([
    'jquery',
    'domReady!'
], function ($) {
    'use strict';
    // ... Your custom JS logic for button clicks ...
    $(document).on('click', '.option-btn', function () {
          console.log('✅ Button click event handler is called!'); 
        var $btn = $(this),
            attributeCode = $btn.data('attribute-code'),
            optionId = $btn.data('option-id'),
            $select = $('.super-attribute-select[name="super_attribute[' + attributeCode + ']"]');
        $btn.siblings('.option-btn[data-attribute-code="' + attributeCode + '"]').removeClass('active');
        $btn.addClass('active');
        $select.val(optionId);
        $select.trigger('change');
       // console.log('✅ Button click and change event triggered from mixin.');
               });

    $('.variation').each(function() {
        var $variation = $(this);
        var $firstOption = $variation.find('.option-btn').first();
        if ($firstOption.length && !$firstOption.hasClass('active')) {
            $firstOption.trigger('click');
        }
    });
});
</script>