<script>
$(document).ready(function(){

    var priceBox = $('[data-role=priceBox][data-product-id="<?= $product->getId() ?>"]');
    var priceText = priceBox.find('.price').text();

    if (priceText.includes('0.00')) {
        priceBox.hide();
    }

});
require(['jquery'], function($) {
    var spConfig = <?= /* @noEscape */ $configurableJsonConfig ?>;
    var selectedAttributes = {};

    function findMatchingProduct() {
        var matched = null;
        $.each(spConfig.index, function(productId, attrs) {
            var ok = true;
            $.each(selectedAttributes, function(attrId, valId) {
                if (attrs[attrId] != valId) {
                    ok = false;
                    return false;
                }
            });
            if (ok) {
                matched = productId;
                return false;
            }
        });
        return matched;
    }

    // function updatePrice(productId) {
    //     if (!productId) return;
    //     var prices = spConfig.optionPrices[productId];
    //     if (prices && prices.finalPrice && prices.finalPrice.amount) {
    //         var finalPrice = prices.finalPrice.amount;
    //         $('[data-role=priceBox][data-product-id="<?= $product->getId() ?>"] .price')
    //             .text('₹' + finalPrice.toFixed(2));
    //     }
    // }
    function updatePrice(productId) {
    if (!productId) return;

    var prices = spConfig.optionPrices[productId];

    if (prices && prices.finalPrice) {

        var finalPrice = parseFloat(prices.finalPrice.amount);

        var priceBox = $('[data-role=priceBox][data-product-id="<?= $product->getId() ?>"]');

        if (finalPrice > 0) {

            priceBox.show();

            priceBox.find('.price')
                .text('₹' + finalPrice.toFixed(2));

        } else {

            priceBox.hide(); // price 0 → hide

        }
    }
}
     function updateDescription(productId) {
        if (!productId) return;
        
        var productData = simpleProducts[productId];
        
        if (productData && productData.description) {
            $('#short-description p').html(productData.short_description);
            $('#full-description p').html(productData.description);
            
            // Also update the description in the tabs section
            $('#tab-desc p').html(productData.description);
        } else {
            // Fetch description via AJAX if not already loaded
            $.ajax({
                url: '<?= $block->getUrl('configurable/product/getdescription') ?>', // Make sure this URL is correct
                type: 'GET',
                data: { product_id: productId },
                showLoader: true,
                success: function(data) {
                    if (data.description) {
                        simpleProducts[productId] = {
                            description: data.description,
                            short_description: data.short_description
                        };
                        $('#short-description p').html(data.short_description);
                        $('#full-description p').html(data.description);
                        $('#tab-desc p').html(data.description);
                    }
                }
            });
        }
    }
    function rebuildThumbnails(productId) {
        if (!productId || !spConfig.images || !spConfig.images[productId]) return;

        var images = spConfig.images[productId];
        var $thumbTrack = $('#thumbTrack');
        $thumbTrack.empty(); // remove old thumbs

        // rebuild
        images.forEach(function(imgObj, idx) {
            var $img = $('<img />', {
                src: imgObj.img,
                alt: imgObj.label || '',
                'data-index': idx,
                class: 'thumb-image' + (idx === 0 ? ' active' : ''),
                'aria-selected': idx === 0 ? 'true' : 'false',
                role: 'tab'
            });
            $thumbTrack.append($img);
        });

        // re-bind thumb clicks
        bindThumbnailClicks(productId);
        // re-bind arrow buttons
        bindArrowButtons(productId);
    }

    function updateMainImage(productId) {
        if (!productId || !spConfig.images || !spConfig.images[productId]) return;

        var firstImg = spConfig.images[productId][0];
        if (firstImg && firstImg.full) {
            $('#mainImage').attr('src', firstImg.full);
        }
    }

    function bindThumbnailClicks(productId) {
        $('#thumbTrack').off('click', '.thumb-image').on('click', '.thumb-image', function() {
            var idx = $(this).data('index');
            var imgObj = spConfig.images[productId][idx];
            if (imgObj && imgObj.full) {
                $('#mainImage').attr('src', imgObj.full);
                $('.thumb-image').removeClass('active').attr('aria-selected', 'false');
                $(this).addClass('active').attr('aria-selected', 'true');
            }
        });
    }

    function bindArrowButtons(productId) {
        var $thumbs = $('#thumbTrack .thumb-image');
        if ($thumbs.length === 0) return;
        var currentIndex = 0;

        $('#prevBtn').off('click').on('click', function() {
            currentIndex = (currentIndex - 1 + $thumbs.length) % $thumbs.length;
            $thumbs.eq(currentIndex).trigger('click');
        });
        $('#nextBtn').off('click').on('click', function() {
            currentIndex = (currentIndex + 1) % $thumbs.length;
            $thumbs.eq(currentIndex).trigger('click');
        });
    }

    // initial binding for default product
    $(document).ready(function(){
        // optional setup if initial product has thumbs etc
        bindThumbnailClicks(<?= $product->getId() ?>);
        bindArrowButtons(<?= $product->getId() ?>);
    });

    // when user clicks .option-btn
    $(document).on('click', '.option-btn', function () {
        var $btn = $(this);
        var attributeCode = $btn.data('attribute-code');
        var optionId = $btn.data('option-id');

        // find attributeId from spConfig
        var attrId = null;
        $.each(spConfig.attributes, function(i, attr){
            if (attr.code === attributeCode) {
                attrId = attr.id;
            }
        });

        if (attrId) {
            selectedAttributes[attrId] = optionId;
            var productId = findMatchingProduct();

            if (productId) {
                updatePrice(productId);
                updateMainImage(productId);
                rebuildThumbnails(productId);
                updateDescription(productId);
            }
        }
    });
});
</script>
