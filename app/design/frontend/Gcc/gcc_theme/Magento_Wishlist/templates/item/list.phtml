<?php
/**
 * GCC themed wishlist item grid.
 */

/** @var \Magento\Wishlist\Block\Customer\Wishlist\Items $block */
$items = $block->getItems();
$imageHelper = $this->helper(\Magento\Catalog\Helper\Image::class);
$priceHelper = $this->helper(\Magento\Framework\Pricing\Helper\Data::class);
$objectManager = \Magento\Framework\App\ObjectManager::getInstance();
$wishlistHelper = $objectManager->get(\Magento\Wishlist\Helper\Data::class);
?>

<?php if ($items && count($items)) : ?>
    <div class="gcc-wishlist-grid">
        <?php foreach ($items as $item) : ?>
            <?php
                $_product = $item->getProduct();
                $productName = (string) $_product->getName();
                $productUrl = $wishlistHelper->getProductUrl($item);
                $removeParams = $wishlistHelper->getRemoveParams($item);
                $productImage = $imageHelper->init($_product, 'wishlist_thumbnail')->getUrl();
                $priceHtml = $priceHelper->currency((float) $_product->getFinalPrice(), true, false);
            ?>
            <article class="gcc-card gcc-wishlist-card" id="item_<?= $block->escapeHtmlAttr($item->getId()) ?>">
                <div class="gcc-card__media gcc-wishlist-card__media">
                    <a class="gcc-card__image-link gcc-wishlist-card__image-link"
                       href="<?= $block->escapeUrl($productUrl) ?>"
                       aria-label="<?= $block->escapeHtmlAttr($productName) ?>">
                        <img class="gcc-wishlist-card__image"
                             src="<?= $block->escapeUrl($productImage) ?>"
                             alt="<?= $block->escapeHtmlAttr($productName) ?>"
                             loading="lazy"
                             decoding="async">
                    </a>

                    <button class="vendor-trash gcc-wishlist-card__remove"
                            type="button"
                            data-role="remove"
                            data-post-remove='<?= /* @noEscape */ $removeParams ?>'
                            aria-label="<?= $block->escapeHtmlAttr(__('Remove from wishlist')) ?>"
                            title="<?= $block->escapeHtmlAttr(__('Remove from wishlist')) ?>">
                        <svg width="18" height="18" viewBox="0 0 24 24" fill="none" aria-hidden="true" focusable="false" xmlns="http://www.w3.org/2000/svg">
                            <path d="M3 6h18M8 6V4h8v2M19 6l-1 14H6L5 6" stroke="#ef4444" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"></path>
                            <path d="M10 11v6M14 11v6" stroke="#ef4444" stroke-width="1.8" stroke-linecap="round"></path>
                        </svg>
                    </button>
                </div>

                <div class="gcc-card__body gcc-wishlist-card__body">
                    <h3 class="gcc-card__name gcc-wishlist-card__title">
                        <a href="<?= $block->escapeUrl($productUrl) ?>">
                            <?= $block->escapeHtml($productName) ?>
                        </a>
                    </h3>
                    <div class="gcc-card__price gcc-wishlist-card__price">
                        <span class="gcc-card__price-amount"><?= /* @noEscape */ $priceHtml ?></span>
                    </div>
                </div>
            </article>
        <?php endforeach; ?>
    </div>
<?php endif; ?>
