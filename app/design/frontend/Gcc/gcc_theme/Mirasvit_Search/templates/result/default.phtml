<div class="search-result-list">
<?php foreach ($results as $result): ?>
    <?php
    $title = trim((string) $result->getTitle());
    $category = trim((string) $result->getCategory());
    $country = trim((string) $result->getCountry());
    $description = trim((string) $result->getShortDescription());
    $resultUrl = trim((string) $result->getUrl());
    $thumbnailUrl = trim((string) $result->getThumbnailUrl());
    $logoUrl = trim((string) $result->getData('upload_logo'));

    if ($logoUrl === '') {
        $logoUrl = trim((string) $result->getData('logo'));
    }

    if ($logoUrl === '') {
        $logoUrl = $thumbnailUrl;
    }

    $normalizeUrl = static function (string $url): string {
        if ($url === '') {
            return '';
        }

        $parts = parse_url($url);

        if ($parts === false) {
            return $url;
        }

        $scheme = isset($parts['scheme']) ? $parts['scheme'] . '://' : '';
        $host = $parts['host'] ?? '';
        $port = isset($parts['port']) ? ':' . $parts['port'] : '';
        $path = isset($parts['path']) ? preg_replace('#/+#', '/', $parts['path']) : '';
        $query = isset($parts['query']) ? '?' . $parts['query'] : '';
        $fragment = isset($parts['fragment']) ? '#' . $parts['fragment'] : '';

        if ($host === '') {
            return $path . $query . $fragment;
        }

        return $scheme . $host . $port . $path . $query . $fragment;
    };

    $thumbnailUrl = $normalizeUrl($thumbnailUrl);
    $logoUrl = $normalizeUrl($logoUrl);
    $imageUrl = $logoUrl !== '' ? $logoUrl : $thumbnailUrl;
    $flagUrl = preg_match('/^[a-z]{2}$/i', $country) ? 'https://flagcdn.com/w40/' . strtolower($country) . '.png' : '';
    $initial = $title !== '' ? strtoupper(substr($title, 0, 1)) : 'S';
    ?>

    <article class="search-vendor-card search-result-card">
        <div class="search-vendor-card__main">
            <a class="search-vendor-card__logo search-result-card__logo" href="<?= htmlspecialchars($resultUrl, ENT_QUOTES, 'UTF-8'); ?>" aria-label="<?= htmlspecialchars($title, ENT_QUOTES, 'UTF-8'); ?>">
                <?php if ($imageUrl !== ''): ?>
                    <img
                        src="<?= htmlspecialchars($imageUrl, ENT_QUOTES, 'UTF-8'); ?>"
                        alt="<?= htmlspecialchars($title, ENT_QUOTES, 'UTF-8'); ?>"
                        loading="lazy"
                        onerror="this.style.display='none';var fallback=this.nextElementSibling;if(fallback){fallback.style.display='flex';}"
                    >
                    <span
                        class="search-vendor-card__logo-fallback"
                        style="display:none;align-items:center;justify-content:center;width:100%;height:100%;color:#93a4b7;font-size:20px;font-weight:800;background:linear-gradient(180deg,#fbfcfe 0%,#f4f7fb 100%);"
                    >
                        <?= htmlspecialchars($initial, ENT_QUOTES, 'UTF-8'); ?>
                    </span>
                <?php else: ?>
                    <span style="display:flex;align-items:center;justify-content:center;width:100%;height:100%;color:#93a4b7;font-size:20px;font-weight:800;background:linear-gradient(180deg,#fbfcfe 0%,#f4f7fb 100%);">
                        <?= htmlspecialchars($initial, ENT_QUOTES, 'UTF-8'); ?>
                    </span>
                <?php endif; ?>
            </a>

            <div class="search-vendor-card__body">
                <div class="search-vendor-card__title-row">
                    <a class="search-vendor-card__title-link" href="<?= htmlspecialchars($resultUrl, ENT_QUOTES, 'UTF-8'); ?>">
                        <?= htmlspecialchars($title, ENT_QUOTES, 'UTF-8'); ?>
                    </a>
                </div>

                <?php if ($category !== ''): ?>
                    <div class="search-vendor-card__subtitle">
                        <?= htmlspecialchars($category, ENT_QUOTES, 'UTF-8'); ?>
                    </div>
                <?php endif; ?>

                <?php if ($description !== ''): ?>
                    <div class="search-vendor-card__description">
                        <?= htmlspecialchars($description, ENT_QUOTES, 'UTF-8'); ?>
                    </div>
                <?php endif; ?>
            </div>
        </div>

        <div class="search-vendor-card__aside">
            <?php if ($country !== ''): ?>
                <div class="search-vendor-card__country">
                    <?php if ($flagUrl !== ''): ?>
                        <img class="search-vendor-card__flag" src="<?= htmlspecialchars($flagUrl, ENT_QUOTES, 'UTF-8'); ?>" alt="<?= htmlspecialchars($country, ENT_QUOTES, 'UTF-8'); ?>">
                    <?php endif; ?>
                    <span><?= htmlspecialchars($country, ENT_QUOTES, 'UTF-8'); ?></span>
                </div>
            <?php endif; ?>

            <a class="search-vendor-card__button" href="<?= htmlspecialchars($resultUrl, ENT_QUOTES, 'UTF-8'); ?>">
                Visit Website
                <span aria-hidden="true">&#8599;</span>
            </a>
        </div>
    </article>
<?php endforeach; ?>
</div>
