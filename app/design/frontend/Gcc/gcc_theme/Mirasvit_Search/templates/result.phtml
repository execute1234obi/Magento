                            <?php if ($showCountBadge) : ?>
                                <span class="mst-search__tab-count"><?= $block->escapeHtml($size) ?></span>
                            <?php endif; ?>
                        </a>
                    </li>
                <?php else: ?>
                    <li role="tab" aria-selected="false">
                        <a href="<?= $block->escapeUrl($block->getIndexUrl($index)) ?>" aria-label="<?= $block->escapeHtmlAttr(__('Switch to %1 tab (%2 results)', $index->getTitle(), $size)) ?>">
