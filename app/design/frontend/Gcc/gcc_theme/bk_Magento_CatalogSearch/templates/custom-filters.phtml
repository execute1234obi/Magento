<!-- JavaScript -->
<script type="text/javascript">
require(['jquery', 'domReady!'], function($){

    // --- Phase 1: Filter Selection & Reload Logic ---
    function syncSelectState($select) {
        $select.toggleClass('is-placeholder', !$select.val());
    }

    function reloadPage(){
        var query = '<?= $block->escapeJs($block->getRequest()->getParam('q', '')) ?>';
        var country = $('#country').val();
        var verified = $('#verified-seller').val();
        var business = $('#business-type').val();

        var url = window.location.origin + window.location.pathname + '?q=' + encodeURIComponent(query) +
                  '&svendor_country_id=' + encodeURIComponent(country) +
                  '&svendor_is_verified=' + encodeURIComponent(verified) +
                  '&svendor_business_type=' + encodeURIComponent(business);

        window.location.href = url;
    }

    $('#country, #verified-seller, #business-type').on('change', function () {
        syncSelectState($(this));
        reloadPage();
    });


    // --- Phase 2: Vendor Tab Count Sync (🔥 MAIN FIX) ---
    function updateVendorTabCount() {
    
    var count = <?= (int)($block->getSearchCollection() ? $block->getSearchCollection()->getSize() : 0) ?>;

    $('.mst-search__result-tabs a').each(function () {
        var $tab = $(this);
        var label = $tab.find('.mst-search__tab-label').text().trim().toLowerCase();

        if (label.includes('vendor')) {
            // ONLY update count span
            $tab.find('.mst-search__tab-count').text(count);
        }
    });
}

    // --- Phase 3: Sidebar Hide/Show Logic ---
    function toggleSidebarByActiveTab() {
        var activeTab = $('.mst-search__result-tabs .mst-search__result-tab-item._active, .mst-search__result-tabs li[aria-selected="true"] a');
        var activeLabel = activeTab.length ? activeTab.text().trim() : '';

        var $productSidebar = $('.sidebar-main .block.filter, #layered-filter-block');
        var $vendorSidebar = $('#vendor-sidebar');

        if (activeLabel.toLowerCase().includes('vendor')) {
            $productSidebar.hide();
            $vendorSidebar.show().css('display', 'block');
        } else {
            $productSidebar.show();
            $vendorSidebar.hide();
        }
    }


    // --- INIT (Page Load) ---
    $(document).ready(function(){
        updateVendorTabCount();              // ✅ count sync
        setTimeout(toggleSidebarByActiveTab, 300); // ✅ sidebar sync
    });

    // --- Tab Click Sync ---
    $(document).on('click', '.mst-search__result-tabs .mst-search__result-tab-item, .mst-tab', function() {
        setTimeout(function(){
            toggleSidebarByActiveTab();      // sidebar update
            updateVendorTabCount();          // count update
        }, 150);
    });

});
</script>
