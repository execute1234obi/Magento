<div class="bg-white shadow-md rounded-lg p-4">
  <h2 class="text-xl font-bold mb-4">Filter</h2>

  <!-- Country Filter -->
  <div class="mb-4">
    <label for="country" class="block text-gray-700 text-sm font-bold mb-2">Country</label>
    <select id="country" class="block w-full bg-white border border-gray-300 rounded px-4 py-2 focus:outline-none focus:ring-2 focus:ring-blue-500">
      <option value=""><?php echo __('Please Select');?></option>
      <?php foreach($filters['countries'] as $country): ?>
        <option value="<?= $country ?>" <?= ($selected['country'] == $country) ? 'selected' : '' ?>>
          <?= $country ?>
        </option>
      <?php endforeach; ?>
    </select>
  </div>

  <!-- Verified Seller Filter -->
  <div class="mb-4">
    <label for="verified-seller" class="block text-gray-700 text-sm font-bold mb-2">Verified Seller</label>
    <select id="verified-seller" class="block w-full bg-white border border-gray-300 rounded px-4 py-2 focus:outline-none focus:ring-2 focus:ring-blue-500">
      <option value=""><?php echo __('Please Select');?></option>
      <?php foreach($filters['verified'] as $key => $label): ?>
        <option value="<?= $key ?>" <?= ($selected['verified'] == $key) ? 'selected' : '' ?>>
          <?= $label ?>
        </option>
      <?php endforeach; ?>
    </select>
