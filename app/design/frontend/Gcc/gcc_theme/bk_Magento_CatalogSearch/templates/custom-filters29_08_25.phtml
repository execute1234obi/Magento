</div>

<script type="text/javascript">
require(['jquery', 'domReady!'], function($){
    function reloadPage(){
        var query = '<?= $block->getRequest()->getParam('q', '') ?>';
        var country = $('#country').val();
        var verified = $('#verified-seller').val();
        var business = $('#business-type').val();
        var url = window.location.origin + window.location.pathname + '?q=' + encodeURIComponent(query) +
                  '&svendor_country_id=' + country +
                  '&svendor_is_verified=' + verified +
                  '&svendor_business_type=' + business;
        window.location.href = url;
    }

    $('#country, #verified-seller, #business-type').change(reloadPage);
});
require(['jquery', 'domReady!'], function($) {

    /**
     * Updates the Vendor tab text with the current count
     * @param {Number} count - Number of vendors matching the current filter
     */
    function updateVendorTab(count) {
        var vendorTab = $('li[role="tab"]:contains("Vendor") a');
        vendorTab.text('Vendor (' + count + ')');
    }

    /**
     * Fetches the vendor count dynamically and updates the tab
     * Replace the logic inside this function with your actual data source/API
     */
    function refreshVendorTab() {
        // Example: fetching count from your collection or API
        var count = <?= $block->getSearchCollection()->getSize() ?>;
        updateVendorTab(count);
    }

    // Run on filter change
    $('#country, #verified-seller, #business-type').on('change', function() {
        refreshVendorTab();
    });

    // Initial load
    refreshVendorTab();

});

</script>
