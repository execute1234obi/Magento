<?xml version="1.0"?>
<page xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
      xsi:noNamespaceSchemaLocation="urn:magento:framework:View/Layout/etc/page_configuration.xsd">
    <head>
        <css src="css/styles.css"/>
        <css src="css/search-pager.css"/>
        <!-- <css src="css/register.css"/> -->
    </head>
  <body>
     
    <!-- Remove original Luma header & footer -->
    <referenceContainer name="header.container" remove="true"/>
    <referenceContainer name="header.panel"     remove="true"/>
    <referenceContainer name="footer-container" remove="true"/>
    <referenceContainer name="footer" remove="true"/>
    <referenceBlock name="footer_links" remove="true"/>
    <referenceBlock name="top.search" remove="true"/>
      <!-- Top menu block remove -->
        <referenceBlock name="catalog.topnav" remove="true" />




    <!-- Custom Header -->
    <!-- <referenceContainer name="page.wrapper">
      <container name="custom.header"
                 as="customHeader"
                 htmlTag="header"
                 htmlClass="custom-page-header"
                 before="main.content">
        <block class="Magento\Framework\View\Element\Template"
               name="custom.header.block"
               template="Magento_Theme::html/custom_header.phtml" />
      </container>
    </referenceContainer> -->
    <referenceContainer name="page.wrapper" >
    <container name="custom.header"
               as="customHeader"
               htmlTag="header"
               htmlClass="custom-page-header"
               before="main.content">
        <block class="Gcc\Gcc_theme\Block\CustomHeader"
               name="custom.header.block"
               template="Magento_Theme::html/custom_header-arabic.phtml"
               cacheable="false"/>
    </container>
</referenceContainer>
 <!-- <referenceContainer name="page.top">
            <block class="Magento\Framework\View\Element\Template"
                   name="custom.search.box"
                   template="Magento_CatalogSearch::custom-search-box.phtml"
                   after="header.panel" />
        </referenceContainer> -->
    <!-- Custom Footer -->
    <referenceContainer name="page.wrapper">
      <container name="custom.footer"
                 as="customFooter"
                 htmlTag="footer"
                 htmlClass="custom-page-footer"
                 after="main.content">
        <block class="Magento\Framework\View\Element\Template"
               name="custom.footer.block"
               template="Magento_Theme::html/custom_footer-arabic.phtml"/>
      </container>
    </referenceContainer>

  </body>
</page>
