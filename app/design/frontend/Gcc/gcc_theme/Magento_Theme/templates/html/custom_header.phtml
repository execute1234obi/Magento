<script>
function toggleDropdown(id){
  const all=['vendorMenu','customerMenu','userMenuProfile'];
  all.forEach(menuId => {
    const el=document.getElementById(menuId);
    if(!el) return;
    (menuId===id)?el.classList.toggle('hidden'):el.classList.add('hidden');
  });
  const v=document.getElementById('vendorBtn'), c=document.getElementById('customerBtn'), u=document.getElementById('userProfileBtn');
  if(id==='vendorMenu'){ v?.classList.toggle('dropdown-active'); c?.classList.remove('dropdown-active'); u?.classList.remove('dropdown-active'); }
  if(id==='customerMenu'){ c?.classList.toggle('dropdown-active'); v?.classList.remove('dropdown-active'); u?.classList.remove('dropdown-active');}
   if(id==='userMenuProfile'){ u?.classList.toggle('dropdown-active'); v?.classList.remove('dropdown-active'); c?.classList.remove('dropdown-active'); }
  [ ['vendorMenu','vendorBtn'], ['customerMenu','customerBtn'], ['userMenuProfile','userProfileBtn'] ].forEach(([menuId, buttonId]) => {
    const menu=document.getElementById(menuId);
    const button=document.getElementById(buttonId);
    if(menu && button){
      button.setAttribute('aria-expanded', menu.classList.contains('hidden') ? 'false' : 'true');
    }
  });
}

window.addEventListener('click',e=>{
  if(!e.target.closest('.group')){
    document.getElementById('vendorMenu')?.classList.add('hidden');
    document.getElementById('customerMenu')?.classList.add('hidden');
    document.getElementById('userMenuProfile')?.classList.add('hidden');
    document.getElementById('vendorBtn')?.classList.remove('dropdown-active');
    document.getElementById('customerBtn')?.classList.remove('dropdown-active');
    document.getElementById('userProfileBtn')?.classList.remove('dropdown-active');
    document.getElementById('vendorBtn')?.setAttribute('aria-expanded', 'false');
    document.getElementById('customerBtn')?.setAttribute('aria-expanded', 'false');
    document.getElementById('userProfileBtn')?.setAttribute('aria-expanded', 'false');
  }
});

function toggleMobileMenu(){
  const m=document.getElementById('mobileMenu');
  const h=document.getElementById('hamburgerIcon');
  const c=document.getElementById('closeIcon');
  const isHidden = m?.classList.contains('hidden');
  m?.classList.toggle('hidden');
  h?.classList.toggle('hidden');
  c?.classList.toggle('hidden');
  document.body.style.overflow = isHidden ? 'hidden' : '';
}
function toggleMobileDropdown(id, button){
  const targetPanel = document.getElementById(id);
  if (!targetPanel) return;

  const willOpen = targetPanel.classList.contains('hidden');

  document.querySelectorAll('.mobile-menu-panel').forEach(panel => {
    if (panel !== targetPanel) {
      panel.classList.add('hidden');
    }
  });

  document.querySelectorAll('.mobile-menu-section-toggle').forEach(toggle => {
    if (toggle !== button) {
      toggle.classList.remove('is-open');
      toggle.setAttribute('aria-expanded', 'false');
    }
  });

  if (willOpen) {
    targetPanel.classList.remove('hidden');
    button?.classList.add('is-open');
    button?.setAttribute('aria-expanded', 'true');
  } else {
    targetPanel.classList.add('hidden');
    button?.classList.remove('is-open');
    button?.setAttribute('aria-expanded', 'false');
  }
}

/* language dropdown */
const langToggle=document.getElementById('langToggle');
const languageMenu=document.getElementById('languageMenu');
if(langToggle && languageMenu){
  langToggle.addEventListener('click',e=>{ e.stopPropagation(); languageMenu.classList.toggle('hidden');});
  document.addEventListener('click',e=>{ if(!langToggle.contains(e.target)&&!languageMenu.contains(e.target)){ languageMenu.classList.add('hidden'); }});
}

const mobileLangToggle = document.getElementById('mobileLangToggle');
const mobileLanguageMenu = document.getElementById('mobileLanguageMenu');
if (mobileLangToggle && mobileLanguageMenu) {
  mobileLangToggle.addEventListener('click', e => {
    e.stopPropagation();
    const willOpen = mobileLanguageMenu.classList.contains('hidden');
    mobileLanguageMenu.classList.toggle('hidden');
    mobileLangToggle.setAttribute('aria-expanded', willOpen ? 'true' : 'false');
  });

  document.addEventListener('click', e => {
    if (!mobileLangToggle.contains(e.target) && !mobileLanguageMenu.contains(e.target)) {
      mobileLanguageMenu.classList.add('hidden');
      mobileLangToggle.setAttribute('aria-expanded', 'false');
    }
  });
}
