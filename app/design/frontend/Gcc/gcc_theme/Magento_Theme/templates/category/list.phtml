<?php
$objectManager = \Magento\Framework\App\ObjectManager::getInstance();
$categoryFactory = $objectManager->get(\Magento\Catalog\Model\ResourceModel\Category\CollectionFactory::class);
$imageHelper = $objectManager->get(\Magento\Catalog\Helper\Image::class);

$categories = $categoryFactory->create()
    ->addAttributeToSelect(['name', 'url', 'is_active', 'image'])
    ->addIsActiveFilter()
    ->addLevelFilter(2) // main categories under default root
    ->addOrderField('position');
?>

<div style="display: grid; grid-template-columns: repeat(auto-fit, minmax(120px, 1fr)); gap: 16px;">
<?php foreach ($categories as $category): ?>
    <a href="<?= $category->getUrl() ?>" style="text-decoration: none;">
        <div style="
            display:flex;
            flex-direction:column;
            align-items:center;
            padding:16px;
            border:1px solid #e5e7eb;
            border-radius:8px;
            transition:box-shadow .2s;
            cursor:pointer;
        "
        onmouseover="this.style.boxShadow='0 4px 12px rgba(0,0,0,0.1)'"
        onmouseout="this.style.boxShadow='none'">
            <?php if ($category->getImageUrl()): ?>
                <img src="<?= $category->getImageUrl() ?>" alt="<?= $category->getName() ?>" style="width:48px;height:48px;margin-bottom:12px;">
            <?php else: ?>
                <img src="https://via.placeholder.com/48" alt="<?= $category->getName() ?>" style="width:48px;height:48px;margin-bottom:12px;">
            <?php endif; ?>

            <span style="font-size:0.875rem; font-weight:600; color:#1f2937;">
                <?= $category->getName() ?>
            </span>
        </div>
    </a>
<?php endforeach; ?>
</div>
