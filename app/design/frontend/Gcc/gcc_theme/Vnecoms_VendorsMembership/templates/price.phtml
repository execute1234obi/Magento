                    </ul>
                </li>

                <li class="button">
                    <a href="<?= $block->getUrl('vendors/membership/index/buy/', ['product' => $goldId, 'qty' => 1]); ?>">
                        Purchase
                    </a>
                </li>
            </ul>
        </li>

        <!-- SILVER PLAN -->
