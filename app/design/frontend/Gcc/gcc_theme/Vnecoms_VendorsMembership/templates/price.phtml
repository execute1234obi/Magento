                <li class="title">
                    <h2><?= $goldProduct->getName(); ?></h2>
                </li>

                <li class="price">
                    <p>
                        <?= $block->escapeHtml($goldProduct->getFinalPrice()); ?> AED
                        <span>/ Month</span>
                    </p>
                </li>

                <li>
