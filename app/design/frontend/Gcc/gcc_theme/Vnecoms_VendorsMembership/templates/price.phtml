<?php
/** @var $block \Magento\Framework\View\Element\Template */

// Product IDs for membership plans
$goldId   = 93;
$silverId = 94;

// Load products using ObjectManager (safe for PHTML)
$objectManager = \Magento\Framework\App\ObjectManager::getInstance();
$productRepository = $objectManager->get(\Magento\Catalog\Api\ProductRepositoryInterface::class);

try {
    $goldProduct   = $productRepository->getById($goldId);
    $silverProduct = $productRepository->getById($silverId);
} catch (\Exception $e) {
    echo "<div style='color:red;'>Membership products not found.</div>";
    return;
}

?>

<section id="pricePlans">
    <ul id="plans">

        <!-- GOLD PLAN -->
        <li class="plan">
