                if ($durationValue === '') {
                    $durationValue = '1|3';
                }
                $billingLabel = $selectedDuration ? $buildBillingLabel($selectedDuration) : __('N/A');
                $postParams = $block->getAddToCartPostParams($_package);
                $price = $block->formatPrice((float) $_package->getFinalPrice());
                $cardIcon = $iconMap[$index] ?? $fallbackIcon;
                ?>

