$normalizeText = static function ($value) {
    $value = html_entity_decode((string) $value, ENT_QUOTES, 'UTF-8');
    $value = strip_tags($value);
    $value = preg_replace('/\s+/u', ' ', $value);

    return trim((string) $value);
};

$extractFeatureItems = static function ($value) use ($normalizeText) {
    $decoded = html_entity_decode((string) $value, ENT_QUOTES, 'UTF-8');
    $items = [];

    if ($decoded !== '' && preg_match_all('/<li[^>]*>(.*?)<\/li>/si', $decoded, $matches)) {
        foreach ($matches[1] as $itemHtml) {
            $item = $normalizeText($itemHtml);
            if ($item !== '') {
                $items[] = $item;
            }
        }
    }

    if (!$items) {
        $plain = $normalizeText($decoded);
        if ($plain !== '') {
            $parts = preg_split('/\R+/u', $plain);
            if (is_array($parts)) {
                foreach ($parts as $part) {
                    $part = trim((string) $part, " \t\n\r\0\x0B-");
                    if ($part !== '') {
                        $items[] = $part;
                    }
                }
            }
        }
    }

    return $items;
};

$buildPlanTitle = static function (\Magento\Catalog\Model\Product $product) use ($normalizeText) {
    $name = $normalizeText($product->getName());
    $name = preg_replace('/\s*membership\s+plan$/i', '', $name);
    $name = preg_replace('/\s+membership$/i', '', $name);
    $name = preg_replace('/\s+plan$/i', '', $name);
    $name = trim((string) $name);

    if ($name === '') {
        $name = $normalizeText($product->getData('meta_title'));
    }

    return $name !== '' ? $name . ' plan' : __('Plan');
};

$buildSubtitle = static function (\Magento\Catalog\Model\Product $product) use ($normalizeText) {
    $subtitle = $normalizeText($product->getShortDescription());
    if ($subtitle !== '') {
        return rtrim($subtitle, ". \t\n\r\0\x0B");
    }

    $subtitle = $normalizeText($product->getData('meta_description'));
    if ($subtitle !== '') {
        return rtrim($subtitle, ". \t\n\r\0\x0B");
    }

    return __('Membership package');
};

$selectDurationOption = static function (array $durationOptions) {
    $selected = null;

    foreach ($durationOptions as $option) {
        if (!is_array($option) || !isset($option['price'])) {
            continue;
        }

        if ($selected === null) {
            $selected = $option;
            continue;
        }

        $currentPrice = (float) $option['price'];
        $selectedPrice = (float) $selected['price'];

        if ($currentPrice < $selectedPrice) {
            $selected = $option;
            continue;
        }

        if ($currentPrice === $selectedPrice) {
            $currentSort = isset($option['sort_order']) ? (int) $option['sort_order'] : PHP_INT_MAX;
            $selectedSort = isset($selected['sort_order']) ? (int) $selected['sort_order'] : PHP_INT_MAX;

            if ($currentSort < $selectedSort) {
                $selected = $option;
                continue;
            }

            if ($currentSort === $selectedSort) {
                $currentDuration = isset($option['duration']) ? (int) $option['duration'] : PHP_INT_MAX;
                $selectedDuration = isset($selected['duration']) ? (int) $selected['duration'] : PHP_INT_MAX;

                if ($currentDuration < $selectedDuration) {
                    $selected = $option;
                }
            }
        }
    }

    return $selected;
};

$buildBillingLabel = static function (array $durationOption) {
    $duration = isset($durationOption['duration']) ? (int) $durationOption['duration'] : 0;
    $unit = isset($durationOption['duration_unit']) ? (int) $durationOption['duration_unit'] : 0;
    $unitLabel = '';

    switch ($unit) {
        case DurationUnit::DURATION_DAY:
            $unitLabel = $duration === 1 ? 'day' : 'days';
            break;
        case DurationUnit::DURATION_WEEK:
            $unitLabel = $duration === 1 ? 'week' : 'weeks';
            break;
        case DurationUnit::DURATION_MONTH:
            $unitLabel = $duration === 1 ? 'month' : 'months';
            break;
        case DurationUnit::DURATION_YEAR:
            $unitLabel = $duration === 1 ? 'year' : 'years';
            break;
    }

    if ($unitLabel === '') {
        return __('N/A');
    }

    switch ($unit) {
        case DurationUnit::DURATION_DAY:
            return $duration === 1 ? __('Billed daily') : __('Billed every %1 days', $duration);
        case DurationUnit::DURATION_WEEK:
            return $duration === 1 ? __('Billed weekly') : __('Billed every %1 weeks', $duration);
        case DurationUnit::DURATION_MONTH:
            return $duration === 1 ? __('Billed monthly') : __('Billed every %1 months', $duration);
        case DurationUnit::DURATION_YEAR:
            return $duration === 1 ? __('Billed annually') : __('Billed every %1 years', $duration);
    }

    return $duration === 1
        ? __('per %1', $unitLabel)
        : __('per %1 %2', $duration, $unitLabel);
};

$planRows = [];
foreach ($block->getMembershipCollection() as $_package) {
    $_package->load($_package->getId());
    $planRows[] = [
        'product' => $_package,
        'price' => (float) $_package->getFinalPrice(),
        'sort_order' => (int) $_package->getData('vendor_membership_sort_order'),
        'name' => (string) $_package->getName(),
    ];
}

usort($planRows, function (array $a, array $b) {
    if ($a['price'] === $b['price']) {
        if ($a['sort_order'] === $b['sort_order']) {
            return strcmp($a['name'], $b['name']);
        }

        return $a['sort_order'] <=> $b['sort_order'];
    }

    return $a['price'] <=> $b['price'];
});

