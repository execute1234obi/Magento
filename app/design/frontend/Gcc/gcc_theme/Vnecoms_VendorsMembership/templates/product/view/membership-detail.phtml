<?php
/**
 * Membership product detail template.
 *
 * @var \Magento\Catalog\Block\Product\View $block
 */

$product = $block->getProduct();
$shortDescriptionHtml = trim((string) $product->getShortDescription());
$descriptionHtml = trim((string) $product->getDescription());

$featureItems = [];
if ($descriptionHtml !== '' && preg_match_all('/<li\b[^>]*>(.*?)<\/li>/si', $descriptionHtml, $matches)) {
    foreach ($matches[1] as $rawItem) {
        $featureText = trim(preg_replace('/\s+/', ' ', strip_tags(html_entity_decode($rawItem, ENT_QUOTES, 'UTF-8'))));
        if ($featureText !== '' && !in_array($featureText, $featureItems, true)) {
            $featureItems[] = $featureText;
        }
    }
}

if (!$featureItems && $shortDescriptionHtml !== '') {
    $featureItems[] = trim(preg_replace('/\s+/', ' ', strip_tags($shortDescriptionHtml)));
}

$detailHtml = $descriptionHtml;
if ($detailHtml !== '') {
    $detailHtml = preg_replace('/<ul\b[^>]*class="small-des-membership"[^>]*>.*?<\/ul>/si', '', $detailHtml);
    $detailHtml = trim((string) $detailHtml);
}

if ($detailHtml === '' || trim(strip_tags($detailHtml)) === '') {
    $detailHtml = $shortDescriptionHtml;
}

$overviewHtml = $shortDescriptionHtml !== '' ? $shortDescriptionHtml : $detailHtml;
if ($overviewHtml === '') {
    $overviewHtml = '<p>' . $block->escapeHtml(__('Choose a duration to continue with this membership plan.')) . '</p>';
}

$infoRows = [];
$infoFields = [
    'sku' => __('SKU'),
    'manufacturer' => __('Manufacturer'),
    'brand' => __('Brand'),
    'size' => __('Size'),
];

foreach ($infoFields as $code => $label) {
    $attributeValue = $product->getData($code);
    if ($attributeValue === null || $attributeValue === '') {
        continue;
    }

    $attribute = $product->getResource()->getAttribute($code);
    $displayValue = $attribute ? $attribute->getFrontend()->getValue($product) : $attributeValue;

    if (is_array($displayValue)) {
        $displayValue = implode(', ', array_map(static function ($item) {
            return is_scalar($item) ? (string) $item : '';
        }, $displayValue));
    } elseif (is_object($displayValue)) {
        $displayValue = method_exists($displayValue, '__toString') ? (string) $displayValue : '';
    }

    $displayValue = trim((string) $displayValue);
    if ($displayValue === '' || $displayValue === 'No') {
        continue;
    }

    $infoRows[] = [
        'label' => (string) $label,
        'value' => $displayValue,
    ];
}

$mainImage = $block->getImage($product, 'product_page_image_large');
$mainImageUrl = $mainImage ? $mainImage->getImageUrl() : '';
$mainImageLabel = $mainImage ? ($mainImage->getLabel() ?: $product->getName()) : $product->getName();

$galleryImages = [];
$seenUrls = [];
foreach ($product->getMediaGalleryImages() as $image) {
    $imageUrl = (string) $image->getUrl();
    if ($imageUrl === '' || isset($seenUrls[$imageUrl])) {
        continue;
    }

    $seenUrls[$imageUrl] = true;
    $galleryImages[] = [
        'url' => $imageUrl,
        'label' => $image->getLabel() ?: $product->getName(),
    ];
}

if ($mainImageUrl === '' && !empty($galleryImages)) {
    $mainImageUrl = $galleryImages[0]['url'];
    $mainImageLabel = $galleryImages[0]['label'];
}

$thumbnailImages = array_values(array_filter($galleryImages, static function (array $image) use ($mainImageUrl) {
    return $image['url'] !== $mainImageUrl;
}));

$priceHtml = $block->getProductPriceHtml($product, 'final_price');
$submitUrl = $block->getSubmitUrl($product);
$isSaleable = (bool) $product->isSaleable();

$membershipBlock = $block->getLayout()->createBlock(\Vnecoms\VendorsMembership\Block\Product\View\Type\Membership::class);
$membershipBlock->setProduct($product);
$membershipBlock->setTemplate('Vnecoms_VendorsMembership::product/view/type/options/membership.phtml');
$durationOptionsHtml = $membershipBlock->toHtml();

$breadcrumbsBlock = $block->getLayout()->getBlock('breadcrumbs');
?>

