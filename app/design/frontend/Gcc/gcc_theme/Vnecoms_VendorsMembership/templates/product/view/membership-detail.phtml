<script>
document.addEventListener('DOMContentLoaded', function () {
    var root = document.querySelector('.gcc-membership-page');
    if (!root) {
        return;
    }

    var mainImage = root.querySelector('[data-gcc-main-image]');
    var thumbs = Array.prototype.slice.call(root.querySelectorAll('[data-gcc-thumb]'));

    if (!mainImage || thumbs.length === 0) {
        return;
    }

    thumbs.forEach(function (thumb) {
        thumb.addEventListener('click', function () {
            var imageUrl = thumb.getAttribute('data-image-src');
            var imageLabel = thumb.getAttribute('data-image-label') || mainImage.getAttribute('alt');

            if (!imageUrl) {
                return;
            }

            mainImage.src = imageUrl;
            mainImage.alt = imageLabel;

            thumbs.forEach(function (item) {
                item.classList.remove('is-active');
            });

            thumb.classList.add('is-active');
        });
    });
});
</script>
