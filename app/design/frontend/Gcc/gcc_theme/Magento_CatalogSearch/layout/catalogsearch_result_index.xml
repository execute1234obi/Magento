<?xml version="1.0"?>
<page xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" layout="1column" xsi:noNamespaceSchemaLocation="urn:magento:framework:View/Layout/etc/page_configuration.xsd">
    <body>
        <referenceContainer name="content">
            <container name="gcc.search.wrapper" htmlTag="div" htmlClass="gcc-search-results gcc-search-results--with-sidebar" before="-">
                <container name="gcc.search.sidebar" htmlTag="aside" htmlClass="sidebar">
                    <container name="gcc.sidebar.inner.div" htmlTag="div">
                        <container name="vendor.sidebar.container" htmlTag="div" htmlId="vendor-sidebar">
                            <block class="Custom\SearchExtended\Block\Index\Vendors" name="custom.search.filters" template="Magento_CatalogSearch::custom-filters.phtml" cacheable="false"/>
                        </container>
                    </container>
                </container>

                <move element="mst.search.result" destination="gcc.search.wrapper" after="gcc.search.sidebar" />
            </container>
        </referenceContainer>
    </body>
</page>
