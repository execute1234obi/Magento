<?xml version="1.0"?>
<page xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
      layout="1column"
      xsi:noNamespaceSchemaLocation="urn:magento:framework:View/Layout/etc/page_configuration.xsd">

    <body>

        <!-- REMOVE DEFAULT -->
        <referenceBlock name="catalog.topnav" remove="true"/>
        <referenceBlock name="page.main.title" remove="true"/>
        <!-- <move element="catalogsearch.leftnav" destination="content" before="mst.search.result" />
        
        <move element="mst.navigation" destination="content" before="mst.search.result" /> -->
        <!-- <attribute name="class" value="page-with-filter"/> -->
        <!-- <referenceBlock name="catalogsearch.leftnav" remove="true"/> -->
          <!-- FULL WIDTH HEADER -->
         
        <referenceContainer name="content">
            <block class="Magento\Framework\View\Element\Template"
                   name="gcc.search.header"
                   template="Magento_CatalogSearch::search-header.phtml"
                   before="-"/>
                   <!-- <block class="Magento\Framework\View\Element\Template" 
                   name="custom_vendor_search_js_fix" 
                   template="Custom_SearchExtended::search_js_fix.phtml" 
                   after="-"/> -->
   </referenceContainer>
   <referenceBlock name="search_filters">
    <block class="Magento\LayeredNavigation\Block\Navigation\Search"
           name="custom.catalogsearch.leftnav"
           as="custom_catalog_filters"
           template="Magento_LayeredNavigation::layer/view.phtml">

        <block class="Magento\Framework\View\Element\Template" name="product_price_renderer" as="price_renderer" template="Magento_LayeredNavigation::layer/filter/price.phtml"/>

        <block class="Magento\LayeredNavigation\Block\Navigation\State"
               name="custom.catalogsearch.navigation.state"
               as="state"/>

        <block class="Magento\LayeredNavigation\Block\Navigation\FilterRenderer"
               name="custom.catalogsearch.navigation.renderer"
               as="renderer"
               template="Magento_LayeredNavigation::layer/filter.phtml">

            <arguments>
                <argument name="product_layer_view_model" xsi:type="object">
                    Magento\LayeredNavigation\ViewModel\Layer\Filter
                </argument>
            </arguments>
        </block>
    </block>
</referenceBlock>
        <!-- FILTERS INSIDE THE MAIN SEARCH RESULT BLOCK -->
        <referenceBlock name="mst.search.result">
          <block class="Custom\SearchExtended\Block\Index\Vendors"
                   name="search_filters"
                   as="search_filters"
                   template="Magento_CatalogSearch::custom-filters.phtml"
                   cacheable="false"/>
        </referenceBlock>
      
        <!-- NEWSLETTER -->
        <referenceContainer name="main">
            <container name="gcc.search-newsletter"
                       htmlTag="div"
                       htmlClass="gcc-search-newsletter"
                       after="content">
                <block class="Magento\Framework\View\Element\Template"
                       name="custom.newsletter.search"
                       template="Magento_Theme::html/newsletter.phtml"/>
            </container>
        </referenceContainer>
    </body>
</page>
