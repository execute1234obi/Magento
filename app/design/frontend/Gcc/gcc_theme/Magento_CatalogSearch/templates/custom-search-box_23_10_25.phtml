<script>
  // Show ⌘K on macOS and Ctrl K elsewhere
  (function(){
    const isMac = /Mac|iPhone|iPad/.test(navigator.platform);
    document.getElementById('shortcutHint').textContent = isMac ? '⌘K' : 'Ctrl K';

    // Focus the search when pressing the shortcut
    document.addEventListener('keydown', (e) => {
      const key = e.key.toLowerCase();
      if ((isMac && e.metaKey && key === 'k') || (!isMac && e.ctrlKey && key === 'k')) {
        e.preventDefault();
        document.getElementById('search').focus();
      }
    });

    // Optional: update breadcrumb query when submitting with Enter
    const input = document.getElementById('search');
    input.addEventListener('keydown', (e) => {
      if (e.key === 'Enter') {
        document.getElementById('qText').textContent = input.value || 'All';
      }
    });
  })();

</script>

<script>
(function () {
  // Utility: safe text content
  const txt = el => (el && (el.innerText || el.textContent) || '').trim().toLowerCase();

  // Find the element that currently holds blocks (skin-agnostic)
  function findHost(wrapper){
    return wrapper.querySelector('[class*="__blocks"]')
        || wrapper.querySelector('[class*="__content"]')
        || wrapper; // fallback
  }

  // Collect "blocks" by class fragment regardless of skin
  function findBlocks(host){
    // limit to immediate descendants first; fallback to deep search
    let blocks = Array.from(host.children).filter(n => n.className && String(n.className).includes('__block'));
    if (!blocks.length) blocks = Array.from(host.querySelectorAll('[class*="__block"]'));
    return blocks;
  }

  function buildTwoColumns(wrapper){
    if (!wrapper) return;

    const host = findHost(wrapper);
    const blocks = findBlocks(host);
    if (!blocks.length) return;

    // Already enhanced? If our grid exists, don't double nest
    if (host.querySelector('.ms-grid')) return;

    // Create grid shells
    const grid  = document.createElement('div'); grid.className = 'ms-grid';
    const left  = document.createElement('div'); left.className = 'ms-col';
    const right = document.createElement('div'); right.className = 'ms-col';
    const full  = document.createElement('div'); full.className = 'ms-full';

    // Route blocks by their title text (covers "Vendor (n)" / "Products (n)")
    blocks.forEach(block => {
      const title = block.querySelector('[class*="__title"]');
      const t = txt(title);
      if (t.includes('vendor')) {
        left.appendChild(block);
      } else if (t.includes('product')) {
        right.appendChild(block);
      } else {
        full.appendChild(block);
      }
    });

    if (!left.children.length)  left.style.display = 'none';
    if (!right.children.length) right.style.display = 'none';
    if (!full.children.length)  full.style.display = 'none';

    grid.appendChild(left);
    grid.appendChild(right);
    grid.appendChild(full);

    // Replace host contents with grid
    host.innerHTML = '';
    host.appendChild(grid);
  }

  // Enhance all visible wrappers
  function enhanceAll(){
    document.querySelectorAll('.mst-search-autocomplete__wrapper').forEach(buildTwoColumns);
  }

  // Trigger on input activity (Mirasvit re-renders per keystroke)
  const input = document.getElementById('search');
  if (input){
    ['focus','input','keyup'].forEach(ev => input.addEventListener(ev, () => setTimeout(enhanceAll, 50)));
  }

  // Also watch DOM changes globally (covers AJAX updates)
  const mo = new MutationObserver(() => enhanceAll());
  mo.observe(document.body, { childList:true, subtree:true });

  // First attempt (in case it is already open)
  enhanceAll();
})();

//for hiding double searchbox
require(['jquery'], function($) {
  $(document).ready(function() {

    // Function to hide all autocomplete overlays
    function hideAutocomplete() {
      $('.mst-search-autocomplete__typeahead-overlay').each(function() {
        $(this).hide(); // Hide existing overlay
      });
    }

    // Hide immediately if already rendered
    hideAutocomplete();

    // Observe DOM changes so even dynamically created overlays are hidden
    const observer = new MutationObserver(function() {
      hideAutocomplete();
    });

    // Start observing entire body for any new elements added dynamically
    observer.observe(document.body, { childList: true, subtree: true });

  });
});
</script>
