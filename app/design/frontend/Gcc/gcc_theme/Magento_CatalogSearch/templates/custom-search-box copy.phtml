<script>
  // Show ⌘K on macOS and Ctrl K elsewhere
  (function(){
    const isMac = /Mac|iPhone|iPad/.test(navigator.platform);
    document.getElementById('shortcutHint').textContent = isMac ? '⌘K' : 'Ctrl K';

    // Focus the search when pressing the shortcut
    document.addEventListener('keydown', (e) => {
      const key = e.key.toLowerCase();
      if ((isMac && e.metaKey && key === 'k') || (!isMac && e.ctrlKey && key === 'k')) {
        e.preventDefault();
        document.getElementById('search').focus();
      }
    });

    // Optional: update breadcrumb query when submitting with Enter
    const input = document.getElementById('search');
    input.addEventListener('keydown', (e) => {
      if (e.key === 'Enter') {
        document.getElementById('qText').textContent = input.value || 'All';
      }
    });
  })();

  require(['jquery'], function($) {
  $(document).ready(function() {

    // Function to hide all autocomplete overlays
    function hideAutocomplete() {
      $('.mst-search-autocomplete__typeahead-overlay').each(function() {
        $(this).hide(); // Hide existing overlay
      });
    }

    // Hide immediately if already rendered
    hideAutocomplete();

    // Observe DOM changes so even dynamically created overlays are hidden
    const observer = new MutationObserver(function() {
      hideAutocomplete();
    });

    // Start observing entire body for any new elements added dynamically
    observer.observe(document.body, { childList: true, subtree: true });

  });
});
</script>



