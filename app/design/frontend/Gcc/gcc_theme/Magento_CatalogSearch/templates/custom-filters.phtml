<script>
require(['jquery', 'domReady!'], function($){
    var searchSkeletonTimer = null;
    var searchSkeletonFallbackTimer = null;
    var searchSkeletonObserver = null;
    var searchSkeletonStartedAt = 0;
    var searchSkeletonMinMs = 200;
    var searchSkeletonHideDelay = 140;
    var searchSkeletonFallbackMs = 12000;
    var searchSkeletonActive = false;
    var searchSkeletonPersistUntilUnload = false;

    function getSearchSkeletonTarget() {
        var selectors = [
            '.gcc-search-layout',
            '.gcc-search-results',
            '.gcc-main-products-area',
            '.gcc-products-wrapper',
            '.search-products-wrapper',
            '.gcc-search-results__main',
            '.mst-search__result-index'
        ];

        for (var i = 0; i < selectors.length; i++) {
            var $target = $(selectors[i]).filter(':visible').first();

            if ($target.length) {
                return $target;
            }
        }

        return $();
    }

    function getSearchSkeletonContentTarget() {
        var selectors = [
            '.gcc-main-products-area',
            '.gcc-products-wrapper',
            '.search-products-wrapper',
            '.gcc-search-results__main',
            '.mst-search__result-index'
        ];

        for (var i = 0; i < selectors.length; i++) {
            var $target = $(selectors[i]).filter(':visible').first();

            if ($target.length) {
                return $target;
            }
        }

        return $();
    }

    function getSearchModeFromTab($tab) {
        var label = $tab.find('.mst-search__tab-label').text().trim().toLowerCase();

        if (!label) {
            label = $tab.text().replace(/\d+/g, ' ').replace(/\s+/g, ' ').trim().toLowerCase();
        }

        return label.indexOf('product') !== -1 ? 'products' : 'vendor';
    }

    function buildSearchSkeletonFilterGroup() {
        return [
            '<div class="gcc-search-skeleton__filter-group">',
                '<div class="gcc-search-skeleton__label gcc-skeleton-shimmer"></div>',
                '<div class="gcc-search-skeleton__input gcc-skeleton-shimmer"></div>',
            '</div>'
        ].join('');
    }

    function buildSearchSkeletonVendorCard() {
        return [
            '<article class="gcc-search-skeleton__vendor-card">',
                '<div class="gcc-search-skeleton__avatar gcc-skeleton-shimmer"></div>',
                '<div class="gcc-search-skeleton__vendor-content">',
                    '<div class="gcc-search-skeleton__vendor-title gcc-skeleton-shimmer"></div>',
                    '<div class="gcc-search-skeleton__vendor-subtitle gcc-skeleton-shimmer"></div>',
                '</div>',
                '<div class="gcc-search-skeleton__vendor-button gcc-skeleton-shimmer"></div>',
            '</article>'
        ].join('');
    }

    function buildSearchSkeletonProductCard() {
        return [
            '<article class="gcc-search-skeleton__product-card">',
                '<div class="gcc-search-skeleton__image gcc-skeleton-shimmer"></div>',
                '<div class="gcc-search-skeleton__product-title gcc-skeleton-shimmer"></div>',
                '<div class="gcc-search-skeleton__product-title gcc-search-skeleton__product-title--short gcc-skeleton-shimmer"></div>',
                '<div class="gcc-search-skeleton__price gcc-skeleton-shimmer"></div>',
                '<div class="gcc-search-skeleton__brand-row">',
                    '<div class="gcc-search-skeleton__brand-logo gcc-skeleton-shimmer"></div>',
                    '<div class="gcc-search-skeleton__brand-name gcc-skeleton-shimmer"></div>',
                '</div>',
                '<div class="gcc-search-skeleton__button gcc-skeleton-shimmer"></div>',
            '</article>'
        ].join('');
    }

    function buildSearchSkeletonMarkup(mode) {
        var isProducts = mode === 'products';
        var mainMarkup = isProducts ? [
            '<div class="gcc-search-skeleton__column gcc-search-skeleton__main">',
                '<div class="gcc-search-skeleton__tabs">',
                    '<div class="gcc-search-skeleton__tab gcc-skeleton-shimmer"></div>',
                    '<div class="gcc-search-skeleton__tab gcc-skeleton-shimmer"></div>',
                    '<div class="gcc-search-skeleton__tab-badge gcc-skeleton-shimmer"></div>',
                '</div>',
                '<div class="gcc-search-skeleton__product-grid">',
                    buildSearchSkeletonProductCard(),
                    buildSearchSkeletonProductCard(),
                    buildSearchSkeletonProductCard(),
                '</div>',
            '</div>'
        ].join('') : [
            '<div class="gcc-search-skeleton__column gcc-search-skeleton__main">',
                '<div class="gcc-search-skeleton__tabs">',
                    '<div class="gcc-search-skeleton__tab gcc-skeleton-shimmer"></div>',
                    '<div class="gcc-search-skeleton__tab gcc-skeleton-shimmer"></div>',
                    '<div class="gcc-search-skeleton__tab-badge gcc-skeleton-shimmer"></div>',
                '</div>',
                '<div class="gcc-search-skeleton__vendor-list">',
                    buildSearchSkeletonVendorCard(),
                    buildSearchSkeletonVendorCard(),
                '</div>',
            '</div>'
        ].join('');

        return [
            '<div class="gcc-search-skeleton" aria-hidden="true" data-mode="' + mode + '">',
                '<div class="gcc-search-skeleton__inner">',
                    '<div class="gcc-search-skeleton__column gcc-search-skeleton__sidebar">',
                        '<div class="gcc-search-skeleton__heading gcc-skeleton-shimmer"></div>',
                        '<div class="gcc-search-skeleton__filter-card">',
                            buildSearchSkeletonFilterGroup(),
                            buildSearchSkeletonFilterGroup(),
                            buildSearchSkeletonFilterGroup(),
                        '</div>',
                    '</div>',
                    mainMarkup,
                '</div>',
            '</div>'
        ].join('');
    }

    function ensureSearchSkeleton(mode) {
        var $target = getSearchSkeletonTarget();

        if (!$target.length) {
            return $();
        }

        var $overlay = $target.children('.gcc-search-skeleton');

        if ($overlay.length) {
            if ($overlay.attr('data-mode') !== mode) {
                $overlay.replaceWith(buildSearchSkeletonMarkup(mode));
            }
        } else {
            $target.append(buildSearchSkeletonMarkup(mode));
        }

        return $target.children('.gcc-search-skeleton').first();
    }

    function clearSearchSkeletonObserver() {
        if (searchSkeletonObserver) {
            searchSkeletonObserver.disconnect();
            searchSkeletonObserver = null;
        }
    }

    function hideSearchSkeletonNow() {
        clearTimeout(searchSkeletonTimer);
        clearTimeout(searchSkeletonFallbackTimer);
        clearSearchSkeletonObserver();
        searchSkeletonActive = false;
        searchSkeletonPersistUntilUnload = false;
        searchSkeletonStartedAt = 0;

        var $target = getSearchSkeletonTarget();

        if (!$target.length) {
            return;
        }

        $target.removeClass('is-skeleton-loading').removeAttr('aria-busy');
        $target.children('.gcc-search-skeleton').remove();
    }

    function scheduleSearchSkeletonHide() {
        if (!searchSkeletonActive) {
            return;
        }

        if (searchSkeletonPersistUntilUnload) {
            return;
        }

        clearTimeout(searchSkeletonTimer);

        var elapsed = Date.now() - searchSkeletonStartedAt;
        var wait = Math.max(searchSkeletonHideDelay, searchSkeletonMinMs - elapsed);

        searchSkeletonTimer = setTimeout(function () {
            hideSearchSkeletonNow();
        }, wait);
    }

    function startSearchSkeletonObserver() {
        var $contentTarget = getSearchSkeletonContentTarget();

        clearSearchSkeletonObserver();

        if (!$contentTarget.length || typeof MutationObserver === 'undefined') {
            return;
        }

        searchSkeletonObserver = new MutationObserver(function () {
            scheduleSearchSkeletonHide();
        });

        searchSkeletonObserver.observe($contentTarget[0], {
            attributes: true,
            childList: true,
            characterData: true,
            subtree: true
        });
    }

    function setSearchSkeleton(isLoading, mode, persistUntilUnload) {
        var $target = getSearchSkeletonTarget();

        if (!$target.length) {
            return;
        }

        if (isLoading) {
            searchSkeletonActive = true;
            searchSkeletonPersistUntilUnload = !!persistUntilUnload;
            searchSkeletonStartedAt = Date.now();

            clearTimeout(searchSkeletonTimer);
            clearTimeout(searchSkeletonFallbackTimer);
            clearSearchSkeletonObserver();

            $target.addClass('is-skeleton-loading').attr('aria-busy', 'true');
            ensureSearchSkeleton(mode);

            if (searchSkeletonPersistUntilUnload) {
                return;
            }

            startSearchSkeletonObserver();

            searchSkeletonFallbackTimer = setTimeout(function () {
                hideSearchSkeletonNow();
            }, searchSkeletonFallbackMs);
            return;
        }

        scheduleSearchSkeletonHide();
    }

    function navigateWithSearchSkeleton(url, mode) {
        setSearchSkeleton(true, mode, true);

        var $target = getSearchSkeletonTarget();

        if ($target.length) {
            $target[0].offsetHeight;
        }

        if (window.requestAnimationFrame) {
            window.requestAnimationFrame(function () {
                window.requestAnimationFrame(function () {
                    window.location.href = url;
                });
            });
        } else {
            window.setTimeout(function () {
                window.location.href = url;
            }, 48);
        }
    }

    /* ==============================
       MOVE SIDEBAR
    ============================== */
    if($('.sidebar-main').length && $('#custom-sidebar-wrapper').length){
        $('.sidebar-main').prepend($('#custom-sidebar-wrapper'));
    }

    /* ==============================
       TAB SWITCH LOGIC (UNCHANGED)
    ============================== */
    function toggleFiltersByTab(){

        var activeTab = $('.mst-search__result-tabs ._active, .mst-search__result-tabs .active, .mst-search__result-tabs li[aria-selected="true"]');
        var activeText = activeTab.text().trim().toLowerCase();

        var $vendorFilters = $('#vendor-sidebar-content');
        var $magentoFilters = $('#default-magento-filter');
        var $defaultMagentoBlock = $('.sidebar-main .block.filter');

        if(activeText.indexOf('vendor') !== -1){
            $vendorFilters.show();
            $magentoFilters.hide();
            $defaultMagentoBlock.hide();
        } else {
            $vendorFilters.hide();
            $magentoFilters.show();
            $defaultMagentoBlock.show();
        }

        updateTabCounts(); // 🔥 sync count on tab change
    }

    setTimeout(toggleFiltersByTab, 500);

    $(document).on('click', '.mst-search__result-tabs li, .mst-search__result-tabs a', function(){
        var $tab = $(this).closest('li');
        var mode = getSearchModeFromTab($tab.length ? $tab : $(this));

        var $link = $(this).is('a') ? $(this) : $(this).find('a').first();
        var href = ($link.attr('href') || '').trim();
        var persistUntilUnload = href && href !== '#';

        setSearchSkeleton(true, mode, persistUntilUnload);

        setTimeout(function(){
            toggleFiltersByTab();
        }, 300);
    });

    /* ==============================
       FILTER REDIRECT
    ============================== */
    $('#country, #verified-seller, #business-type').on('change', function(){
        var $activeTab = $('.mst-search__result-tabs ._active, .mst-search__result-tabs .active, .mst-search__result-tabs li[aria-selected="true"]').first();
        var $modeTab = $activeTab.length ? ($activeTab.is('li') ? $activeTab : $activeTab.closest('li')) : $activeTab;
        var mode = getSearchModeFromTab($modeTab);

        var query = '<?= $block->escapeJs($block->getRequest()->getParam('q', '')) ?>';

        var url = window.location.origin + window.location.pathname +
            '?q=' + encodeURIComponent(query) +
            '&svendor_country_id=' + encodeURIComponent($('#country').val()) +
            '&svendor_is_verified=' + encodeURIComponent($('#verified-seller').val()) +
            '&svendor_business_type=' + encodeURIComponent($('#business-type').val());

        navigateWithSearchSkeleton(url, mode);
    });

    $(window).on('pageshow', function (event) {
        if (event.originalEvent && event.originalEvent.persisted) {
            hideSearchSkeletonNow();
        }
    });

    /* ==============================
       CLEAR FILTER (FIXED)
    ============================== */
    $(document).on('click', '.clear-filter', function(e){
        e.preventDefault();

        let params = new URLSearchParams(window.location.search);
        let q = params.get('q');

        let newUrl = window.location.pathname;

        if(q){
            newUrl += '?q=' + encodeURIComponent(q);
        }

        window.location.href = newUrl;
    });

