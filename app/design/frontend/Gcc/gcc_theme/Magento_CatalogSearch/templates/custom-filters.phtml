function updateTabCounts() {

    // hidden input se total count
    var totalCount = $('#search-total-count').val() || 0;

    // vendor count (existing logic)
    var vendorCount = <?= (int)($block->getSearchCollection() ? $block->getSearchCollection()->getSize() : 0) ?>;

    $('.mst-search__result-tabs li').each(function () {

        var $tab = $(this);

        var label = $tab.find('.mst-search__tab-label')
            .text()
            .trim()
            .toLowerCase();

        /* =========================
           VENDOR TAB
        ========================= */
        if (label.includes('vendor')) {

            var $badge = $tab.find('.mst-search__tab-count');

            if ($badge.length) {

                $badge.text(vendorCount);

            } else {

                $tab.find('.mst-search__tab-label').after(
                    '<span class="mst-search__tab-count">' +
                    vendorCount +
                    '</span>'
                );
            }
        }

        /* =========================
           PRODUCT TAB
        ========================= */
        if (label.includes('product')) {

            var $badge = $tab.find('.mst-search__tab-count');

            if ($badge.length) {

                $badge.text(totalCount);

            } else {

                $tab.find('.mst-search__tab-label').after(
                    '<span class="mst-search__tab-count">' +
                    totalCount +
                    '</span>'
                );
            }
        }
    });
}

// run once page load
require(['jquery'], function ($) {

    $(document).ready(function () {
        updateTabCounts();
    });

});

    setTimeout(updateTabCounts, 500);

    $('#country, #verified-seller, #business-type').on('change', function(){
        setTimeout(updateTabCounts, 400);
    });

});

</script>

