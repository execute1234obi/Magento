<script type="text/javascript">
require(['jquery', 'domReady!'], function ($) {
    function syncSelectState($select) {
        $select.toggleClass('is-placeholder', !$select.val());
    }

    function reloadPage() {
        var query = '<?= $block->escapeJs($block->getRequest()->getParam('q', '')) ?>';
        var index = '<?= $block->escapeJs($block->getRequest()->getParam('index', '')) ?>';
        var country = $('#country').val();
        var verified = $('#verified-seller').val();
        var business = $('#business-type').val();
        var url = window.location.origin + window.location.pathname + '?';

        if (index) {
            url += 'index=' + encodeURIComponent(index) + '&';
        }

        url += 'q=' + encodeURIComponent(query) +
               '&svendor_country_id=' + encodeURIComponent(country) +
               '&svendor_is_verified=' + encodeURIComponent(verified) +
               '&svendor_business_type=' + encodeURIComponent(business);

        window.location.href = url;
    }

    function updateVendorTab(count) {
        $('.mst-search__result-tabs a').each(function () {
            var $tab = $(this);
            var label = $tab.find('.mst-search__tab-label').text().trim().toLowerCase();

            if (label.indexOf('vendor') !== -1) {
                $tab.find('.mst-search__tab-count').text(count);
            }
        });
    }

    function refreshVendorTab() {
        var count = <?= (int) ($block->getSearchCollection() ? $block->getSearchCollection()->getSize() : 0) ?>;
        updateVendorTab(count);
    }

    $('#country, #verified-seller, #business-type').each(function () {
        syncSelectState($(this));
    }).on('change', function () {
        syncSelectState($(this));
        reloadPage();
    });

    refreshVendorTab();
});
</script>
