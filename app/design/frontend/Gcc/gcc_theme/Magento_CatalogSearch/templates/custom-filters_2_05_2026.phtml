<script>
require(['jquery', 'domReady!'], function($){

    // Move everything into the main sidebar container
    if($('.sidebar-main').length && $('#custom-sidebar-wrapper').length){
        $('.sidebar-main').prepend($('#custom-sidebar-wrapper'));
    }

    function toggleFiltersByTab(){
        // Aapke active tab ka class '_active' hai ya 'active' check karein
        var activeTab = $('.mst-search__result-tabs ._active, .mst-search__result-tabs .active, .mst-search__result-tabs li[aria-selected="true"]');
        var activeText = activeTab.text().trim().toLowerCase();

        var $vendorFilters = $('#vendor-sidebar-content');
        var $magentoFilters = $('#default-magento-filter');
        var $defaultMagentoBlock = $('.sidebar-main .block.filter'); // Native block

        if(activeText.indexOf('vendor') !== -1){
            // VENDOR TAB: Show our dropdowns, hide default
            $vendorFilters.show();
            $magentoFilters.hide();
            $defaultMagentoBlock.hide();
        } else {
            // PRODUCT/OTHER TABS: Hide our dropdowns, show default
            $vendorFilters.hide();
            $magentoFilters.show();
            $defaultMagentoBlock.show();
        }
    }

    // Page Load par check karein
    setTimeout(toggleFiltersByTab, 500);

    // Tab click par check karein
    $(document).on('click', '.mst-search__result-tabs li, .mst-search__result-tabs a', function(){
        setTimeout(toggleFiltersByTab, 300);
    });

    // Dropdown Change Logic
    $('#country, #verified-seller, #business-type').on('change', function(){
        var query    = '<?= $block->escapeJs($block->getRequest()->getParam('q', '')) ?>';
        var url = window.location.origin + window.location.pathname +
            '?q=' + encodeURIComponent(query) +
            '&svendor_country_id=' + encodeURIComponent($('#country').val()) +
            '&svendor_is_verified=' + encodeURIComponent($('#verified-seller').val()) +
            '&svendor_business_type=' + encodeURIComponent($('#business-type').val());
        window.location.href = url;
    });
                  // Move to Sidebar
    if($('.sidebar-main').length && $('#custom-sidebar-wrapper').length){
        $('.sidebar-main').prepend($('#custom-sidebar-wrapper'));
    }

    // Accordion Logic - Conflict Free
    $(document).on('click', '#custom-sidebar-wrapper h3, .filter-options-title', function(){
        $(this).toggleClass('active');
        $(this).next().stop().slideToggle(300);
    });
});
</script>