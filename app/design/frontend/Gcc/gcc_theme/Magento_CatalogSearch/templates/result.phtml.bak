<?php
/** @var \Vendor\SearchEnhancer\Block\SearchData $dataBlock */
$dataBlock = $block->getChildBlock('custom.search.data');
$productBlock = $block->getChildBlock('product_search_data');
$filterBlock = $block->getChildBlock('filter_options');
$countries = [];

if ($filterBlock && method_exists($filterBlock, 'getCountryOptions')) {
    $countries = $filterBlock->getCountryOptions();
}
?>

<!-- Search Bar -->
<section class="bg-gray-100 py-4 px-6">
   <form action="/magento_gcc/catalogsearch/result" method="get">
  <div class="container mx-auto flex flex-col md:flex-row items-center justify-between gap-4">
    <input type="text" class="w-full md:w-2/3 p-2 border rounded" name="q" placeholder="Find your product or brand in the GCC">
    <button class="bg-blue-700 text-white px-4 py-2 rounded" type="submit">Search</button>
  </div>
  <form>
</section>

<!-- Breadcrumb -->
<div class="container mx-auto px-4 py-3 text-sm text-gray-600">
  Dashboard / Search Results for: <span class="text-black font-semibold"><?= $block->escapeHtml($block->getRequest()->getParam('q')) ?></span>
</div>

<!-- Main Section -->
<main class="container mx-auto px-4 flex flex-col md:flex-row gap-6 py-4">

  <!-- Filter Sidebar -->
  <aside class="w-full md:w-1/4 space-y-4">
    <div>
      <label class="block font-semibold mb-1">Country</label>
      <select class="w-full p-2 border rounded" name="country">
        <option value="">All</option>
        <?php foreach ($countries as $country): ?>
          <option value="<?= $block->escapeHtmlAttr($country['value']) ?>"><?= $block->escapeHtml($country['label']) ?></option>
        <?php endforeach; ?>
      </select>
    </div>

    <div>
      <label class="block font-semibold mb-1">Vendor Sector</label>
      <select class="w-full p-2 border rounded" name="sector">
        <option value="">All</option>
      </select>
    </div>

    <div>
      <label class="block font-semibold mb-1">Business Type</label>
      <select class="w-full p-2 border rounded" name="businesstype">
        <option value="">All</option>
      </select>
    </div>
  </aside>

  <!-- Results Section -->
  <section class="w-full md:w-3/4 space-y-6">
    <!-- Tabs -->
    <div class="flex border-b mb-4">
      <button class="tab-btn active px-4 py-2 font-semibold text-blue-700 border-b-2 border-blue-700" data-tab="vendor-tab">Vendor</button>
      <button class="tab-btn px-4 py-2 text-gray-600" data-tab="product-tab">Product</button>
    </div>

    <!-- Tab Contents -->
    <div id="vendor-tab" class="tab-content space-y-4">
      <?= $dataBlock ? $dataBlock->toHtml() : '' ?>
    </div>

    <div id="product-tab" class="tab-content space-y-4 hidden">
      <?= $productBlock ? $productBlock->toHtml() : '' ?>
    </div>

    <!-- Pagination (optional if needed) -->
    <div class="flex justify-between items-center pt-4">
      <span class="text-sm text-gray-600">Result per page: 5</span>
      <div class="flex space-x-2">
        <button class="px-2 border rounded">1</button>
        <button class="px-2 border rounded text-gray-400">2</button>
      </div>
    </div>
  </section>
</main>

<!-- Tab Switcher JS -->
<script>
  document.querySelectorAll('.tab-btn').forEach(btn => {
    btn.addEventListener('click', function () {
      document.querySelectorAll('.tab-btn').forEach(el => el.classList.remove('active', 'text-blue-700', 'border-blue-700'));
      document.querySelectorAll('.tab-content').forEach(el => el.classList.add('hidden'));

      this.classList.add('active', 'text-blue-700', 'border-blue-700');
      const tabId = this.getAttribute('data-tab');
      document.getElementById(tabId).classList.remove('hidden');
    });
  });
</script>

<!-- Newsletter CTA -->
<section class="bg-blue-50 py-10 text-center mt-10">
  <h2 class="text-xl font-bold mb-2">Get the Latest GCC Trade Updates</h2>
  <p class="text-gray-600 mb-4">Subscribe to get the latest trade news delivered to your inbox.</p>
