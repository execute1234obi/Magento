$objectManager = \Magento\Framework\App\ObjectManager::getInstance();

$layer = $objectManager->get(\Magento\Catalog\Model\Layer\Search::class);

$filterableAttributes = $objectManager->get(
    \Magento\Catalog\Model\Layer\Search\FilterableAttributeList::class
);

$filterList = $objectManager->create(
    \Magento\Catalog\Model\Layer\FilterList::class,
    ['filterableAttributes' => $filterableAttributes]
);

$blockNav = $block->getLayout()
    ->createBlock(\Magento\LayeredNavigation\Block\Navigation::class)
    ->setLayer($layer)
    ->setFilterList($filterList)
    ->setTemplate('Magento_LayeredNavigation::layer/view.phtml');

$filters = $blockNav->getFilters();

foreach ($filters as $filter) {

    echo '<h3>' . $filter->getName() . '</h3>';

    foreach ($filter->getItems() as $item) {

        echo 'Label: ' . $item->getLabel() . '<br>';
        echo 'Count: ' . $item->getCount() . '<br>';
        echo 'URL: ' . $item->getUrl() . '<br><br>';
    }
}

