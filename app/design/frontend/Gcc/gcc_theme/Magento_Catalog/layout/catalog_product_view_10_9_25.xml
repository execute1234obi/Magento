<?xml version="1.0"?>
<page xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" layout="1column" xsi:noNamespaceSchemaLocation="urn:magento:framework:View/Layout/etc/page_configuration.xsd">
    <head>
        <script src="Magento_ConfigurableProduct::js/configurable.js"/>
    </head>

    <body>
        <!-- Removing the original blocks -->
        <referenceBlock name="product.info.media" remove="true" />
        <referenceBlock name="product.info.main" remove="true" />
        <referenceBlock name="product.info.details" remove="true" />
        <referenceBlock name="product.info.overview" remove="true" />
        <referenceBlock name="product.info.addtocart" remove="true"/>
        <referenceBlock name="product.info.review" remove="true"/>
        <referenceBlock name="reviews.tab" remove="true"/>
         <referenceBlock name="product.info.options.configurable" template="Magento_ConfigurableProduct::product/view/type/options/custom_configurable.phtml"/>
    
        <referenceBlock name="product.info.options.wrapper">
            <action method="setTemplate">
                <argument name="template" xsi:type="string">Magento_Catalog::product/view/options/wrapper.phtml</argument>
            </action>
        </referenceBlock>
        <!-- Replace with custom block -->
        <referenceContainer name="content">
            <block class="Magento\Catalog\Block\Product\View"
                   name="custom.product.detail"
                   template="Magento_Catalog::product/view.phtml">
                <!-- Add the required child blocks here to be rendered in the template -->
                <block class="Magento\Catalog\Block\Product\View\Name" name="page.main.title" template="Magento_Catalog::product/view/name.phtml"/>
                 
                <!-- ✅ FINAL PRICE BLOCK with renderer -->
                <block class="Magento\Framework\Pricing\Render"
                       name="product.info.price"
                       template="Magento_Catalog::product/price/final_price.phtml">
                    <arguments>
                        <argument name="price_render" xsi:type="string">product.price.render.default</argument>
                        <argument name="price_type_code" xsi:type="string">final_price</argument>
                        <argument name="zone" xsi:type="string">item_view</argument>
                    </arguments>
                </block>

                <container name="product.info.media.container" as="product.info.media.container" label="Product Media" htmlTag="div" htmlClass="product media" after="-">
                    <block class="Magento\Catalog\Block\Product\View\Gallery" name="product.info.media.gallery" template="Magento_Catalog::product/view/gallery.phtml"/>
                </container>

                <block class="Magento\ConfigurableProduct\Block\Product\View\Type\Configurable" name="product.info.configurable" template="Magento_ConfigurableProduct::product/view/type/configurable.phtml"/>
                <block class="Magento\Catalog\Block\Product\View\Description"
                       name="product.info.description"
                       template="Magento_Catalog::product/view/description.phtml"
                       group="detailed_info" />
                <block class="Magento\Catalog\Block\Product\View\Attributes"
                       name="product.attributes"
                       template="Magento_Catalog::product/view/attributes.phtml"
                       group="detailed_info" />
                <block class="Magento\Review\Block\Product\View\ListView"
                       name="reviews.tab"
                       template="Magento_Review::product/view/list.phtml"
                       group="detailed_info" />
                 <block class="Magento\Catalog\Block\Product\View" name="product.info.addtocart" template="Magento_Catalog::product/view/addtocart.phtml"/>
            </block>
        </referenceContainer>
         <referenceBlock name="product.info.options.configurable">
      <action method="setTemplate">
        <argument name="template" xsi:type="string">Magento_ConfigurableProduct::product/view/type/options/custom_configurable.phtml</argument>
      </action>
    </referenceBlock>
    </body>
</page>
