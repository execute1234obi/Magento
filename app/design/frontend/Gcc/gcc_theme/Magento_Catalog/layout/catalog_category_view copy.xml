            <block class="Magento\Cms\Block\Block" 
                   name="vendor_nearby_static">
                <arguments>
                    <argument name="block_id" xsi:type="string">vendor_nearby_custom</argument>
                </arguments>
            </block>
        </referenceContainer> -->
        
    </body>
</page>
