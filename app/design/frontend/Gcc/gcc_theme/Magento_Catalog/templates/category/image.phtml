<?php
// Safe get category
$category = null;

if (method_exists($block, 'getCurrentCategory')) {
    $category = $block->getCurrentCategory();
}

if (!$category) {
    $objectManager = \Magento\Framework\App\ObjectManager::getInstance();
    $registry = $objectManager->get(\Magento\Framework\Registry::class);
    $category = $registry->registry('current_category');
}

// If still no category → STOP & avoid errors
if (!$category) {
    return; // Safe exit (does not break page)
}

// Generate image URL safely
$categoryImage = '';
$categoryImageName = $category->getImage();

if ($categoryImageName) {
    $objectManager = \Magento\Framework\App\ObjectManager::getInstance();
    $storeManager = $objectManager->get(\Magento\Store\Model\StoreManagerInterface::class);
    $mediaBaseUrl = $storeManager->getStore()->getBaseUrl(\Magento\Framework\UrlInterface::URL_TYPE_MEDIA);

    // Clean image path
    $categoryImageName = ltrim(str_replace(['pub/media/', 'media/'], '', $categoryImageName), '/');
    //$categoryImage = $mediaBaseUrl . "catalog/category/" . $categoryImageName;
    $categoryImage = $mediaBaseUrl . $categoryImageName;
    //echo $categoryImage;
}
