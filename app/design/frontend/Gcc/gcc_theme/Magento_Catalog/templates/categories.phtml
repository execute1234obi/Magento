<script>
document.addEventListener('DOMContentLoaded', function () {
    var root = document.querySelector('[data-gcc-sector-carousel]');

    if (!root) {
        return;
    }

    var viewport = root.querySelector('[data-sector-viewport]');
    var dotsContainer = root.querySelector('[data-sector-dots]');
    var prevButton = root.querySelector('[data-sector-prev]');
    var nextButton = root.querySelector('[data-sector-next]');
    var sourceCards = Array.prototype.slice.call(root.querySelectorAll('[data-sector-page] .gcc-sector-card')).map(function (card) {
        return card.cloneNode(true);
    });
    var currentPage = 0;
    var pages = [];
    var dots = [];
    var mobileQuery = window.matchMedia ? window.matchMedia('(max-width: 767px)') : {
        matches: false
    };

    if (!viewport || !dotsContainer || !sourceCards.length) {
        return;
    }

    function getPageSize() {
        return mobileQuery.matches ? 6 : 10;
    }

    function clearRenderedPages() {
        viewport.innerHTML = '';
        dotsContainer.innerHTML = '';
        pages = [];
        dots = [];
    }

    function updateNavState() {
        if (prevButton) {
            prevButton.disabled = currentPage === 0;
        }

        if (nextButton) {
            nextButton.disabled = currentPage === pages.length - 1;
        }
    }

    function setActivePage(pageIndex) {
        currentPage = Math.max(0, Math.min(pageIndex, pages.length - 1));

        pages.forEach(function (page, index) {
            var isActive = index === currentPage;
            page.hidden = !isActive;
            page.classList.toggle('is-active', isActive);
            page.setAttribute('aria-hidden', isActive ? 'false' : 'true');
        });

        dots.forEach(function (dot, index) {
            var isActive = index === currentPage;
            dot.classList.toggle('is-active', isActive);
            dot.setAttribute('aria-current', isActive ? 'true' : 'false');
        });

        updateNavState();
    }

    function renderCarousel() {
        var pageSize = getPageSize();
        var totalPages = Math.max(1, Math.ceil(sourceCards.length / pageSize));
        var preservedPage = currentPage;

        clearRenderedPages();

        currentPage = Math.min(preservedPage, totalPages - 1);

        for (var pageIndex = 0; pageIndex < totalPages; pageIndex++) {
            var start = pageIndex * pageSize;
            var end = start + pageSize;
            var page = document.createElement('div');
            var grid = document.createElement('div');
            var dot = document.createElement('button');

            page.className = 'gcc-sector-carousel__page';
            page.setAttribute('data-sector-page', '');
            page.setAttribute('data-page-index', String(pageIndex));
            page.hidden = pageIndex !== currentPage;
            page.setAttribute('aria-hidden', pageIndex === currentPage ? 'false' : 'true');
            page.classList.toggle('is-active', pageIndex === currentPage);

            grid.className = 'gcc-sector-carousel__grid';
            sourceCards.slice(start, end).forEach(function (card) {
                grid.appendChild(card.cloneNode(true));
            });
            page.appendChild(grid);
            viewport.appendChild(page);
            pages.push(page);

            dot.type = 'button';
            dot.className = 'gcc-sector-carousel__dot' + (pageIndex === currentPage ? ' is-active' : '');
            dot.setAttribute('data-sector-dot', '');
            dot.setAttribute('data-target-page', String(pageIndex));
            dot.setAttribute('aria-label', 'Show sector page ' + (pageIndex + 1));
            dot.setAttribute('aria-current', pageIndex === currentPage ? 'true' : 'false');
            dot.addEventListener('click', (function (targetPage) {
                return function () {
                    setActivePage(targetPage);
                };
            })(pageIndex));
            dotsContainer.appendChild(dot);
            dots.push(dot);
        }

        setActivePage(currentPage);
    }

    if (prevButton) {
        prevButton.addEventListener('click', function () {
            setActivePage(currentPage - 1);
        });
    }

    if (nextButton) {
        nextButton.addEventListener('click', function () {
            setActivePage(currentPage + 1);
        });
    }

    if (typeof mobileQuery.addEventListener === 'function') {
        mobileQuery.addEventListener('change', function () {
            renderCarousel();
        });
    } else if (typeof mobileQuery.addListener === 'function') {
        mobileQuery.addListener(function () {
            renderCarousel();
        });
    }

    renderCarousel();
});
</script>
