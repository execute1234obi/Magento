            <p>
                <?= $block->escapeHtml(__('Discover suppliers and products across various industries to meet your business needs efficiently and compliance with regional standards for optimal sourcing solutions.')); ?>
            </p>
        </header>

        <?php if (!empty($categoryPages)): ?>
            <div class="gcc-sector-carousel" data-gcc-sector-carousel>
                <div class="gcc-sector-carousel__viewport" data-sector-viewport>
                    <?php foreach ($categoryPages as $pageIndex => $pageCategories): ?>
                        <div class="gcc-sector-carousel__page<?= $pageIndex === 0 ? ' is-active' : ''; ?>"
                             data-sector-page
                             data-page-index="<?= (int)$pageIndex; ?>"
                             <?= $pageIndex === 0 ? '' : 'hidden'; ?>>
                            <div class="gcc-sector-carousel__grid">
                                <?php foreach ($pageCategories as $category): ?>
                                    <?php
                                    $categoryUrl = (string)$category->getUrl();
                                    $categoryName = (string)$category->getName();
                                    $categoryImage = $buildCategoryImage($category);
                                    ?>
                                    <a class="gcc-sector-card" href="<?= $block->escapeUrl($categoryUrl); ?>">
                                        <span class="gcc-sector-card__icon" aria-hidden="true">
                                            <img src="<?= $block->escapeUrl($categoryImage); ?>" alt="" loading="lazy">
                                        </span>
                                        <span class="gcc-sector-card__title"><?= $block->escapeHtml($categoryName); ?></span>
                                    </a>
