<?php
use Magento\Framework\UrlInterface;

$objectManager = \Magento\Framework\App\ObjectManager::getInstance();
$categoryCollectionFactory = $objectManager->get(\Magento\Catalog\Model\ResourceModel\Category\CollectionFactory::class);
$storeManager = $objectManager->get(\Magento\Store\Model\StoreManagerInterface::class);

$parentCategoryId = 2;

$categories = $categoryCollectionFactory->create()
    ->addAttributeToSelect(['name', 'image', 'url_key'])
    ->addIsActiveFilter()
    ->addAttributeToFilter('parent_id', $parentCategoryId)
    ->setOrder('position', 'ASC');

$categoryItems = iterator_to_array($categories, false);
$pageSize = 10;
$categoryPages = array_chunk($categoryItems, $pageSize);
$mediaBase = $storeManager->getStore()->getBaseUrl(UrlInterface::URL_TYPE_MEDIA);
$defaultCategoryImage = $block->getViewFileUrl('Magento_Catalog::images/default-category.png');

$normalizeCategoryImagePath = static function ($imagePath) {
    $imagePath = trim((string)$imagePath);

    if ($imagePath === '' || $imagePath === 'no_selection') {
        return '';
    }

    $imagePath = str_replace(['pub/media/', 'media/'], '', $imagePath);

    return ltrim($imagePath, '/');
};

$buildCategoryImage = static function ($category) use ($mediaBase, $defaultCategoryImage, $normalizeCategoryImagePath) {
    $imagePath = $normalizeCategoryImagePath($category->getImage());

    if ($imagePath !== '') {
        return rtrim($mediaBase, '/') . '/' . $imagePath;
    }

    return $defaultCategoryImage;
};
?>

