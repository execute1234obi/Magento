                            </div>
                        </div>
                    <?php endforeach; ?>
                </div>

                <div class="gcc-sector-carousel__controls">
                    <div class="gcc-sector-carousel__dots" data-sector-dots>
                        <?php foreach ($categoryPages as $pageIndex => $pageCategories): ?>
