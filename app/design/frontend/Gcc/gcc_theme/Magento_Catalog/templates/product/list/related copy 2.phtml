?>
<?php $items = $block->getItems(); ?>
<?php if (count($items)): ?>
<div class="block related">
    <div class="block-title">
        <strong><?php echo __('Similar Products'); ?></strong>
    </div>
    <div class="block-content">
        <div class="products-grid">
            <?php foreach ($items as $_item): ?>
                <?php
                $productImage = $block->getImage($_item, 'category_page_list')->getImageUrl();
                $brand = $_item->getAttributeText('manufacturer'); // or brand attribute
                $country = $_item->getData('country'); // if you have a custom 'country' attribute
                $price = $block->getProductPrice($_item);
                ?>
                <div class="similar-product-item">
    <div class="product-card">
        <a href="<?php echo $_item->getProductUrl(); ?>" class="product-image">
            <img src="<?php echo $productImage; ?>" 
                 alt="<?php echo $block->escapeHtml($_item->getName()); ?>" />
        </a>
        <div class="product-info">
            <h3 class="product-name"><?php echo $block->escapeHtml($_item->getName()); ?></h3>
            <div class="product-price"><?php echo $price; ?></div>
            
            <?php if($brand): ?>
                <div class="product-brand"><?php echo $block->escapeHtml($brand); ?></div>
            <?php endif; ?>
            
            <?php if($country): ?>
                <div class="product-country"><?php echo $block->escapeHtml($country); ?></div>
            <?php endif; ?>
        </div>
        <div class="product-actions">
            <button class="btn-add-quote"><?php echo __('Add to Quote'); ?></button>
        </div>
    </div>
</div>
            <?php endforeach; ?>
        </div>
    </div>
</div>

<?php endif; ?>

