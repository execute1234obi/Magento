<?php
/** @var \Magento\Catalog\Block\Product\ProductList\Related $block */
$items = $block->getItems();
?>

<?php if (count($items)): ?>
<div class="block related">
  <div class="block-title"><strong><?= __('Similar Products'); ?></strong></div>

  <div class="block-content">
    <div class="products-grid rp-grid">

      <?php foreach ($items as $_item): ?>
        <?php
          $imgUrl   = $block->getImage($_item, 'category_page_list')->getImageUrl();
          $brand    = $_item->getAttributeText('manufacturer'); // adjust if your brand attr differs
          $country  = $_item->getData('country');               // optional custom attr
          $priceHtml= $block->getProductPrice($_item);          // Magento price HTML
        ?>
        <div class="rp-cell">
          <article class="rp-card">
            <!-- image -->
            <a class="rp-thumb" href="<?= $_item->getProductUrl(); ?>"
               aria-label="<?= $block->escapeHtml($_item->getName()); ?>">
              <img src="<?= $imgUrl; ?>"
                   alt="<?= $block->escapeHtml($_item->getName()); ?>">
              <button class="rp-like" type="button" aria-label="<?= $block->escapeHtml(__('Save')); ?>">
                <svg viewBox="0 0 24 24" width="18" height="18" fill="none" stroke="currentColor" stroke-width="2">
                  <path d="M20.8 4.6a5.5 5.5 0 0 0-7.8 0L12 5.6l-1-1a5.5 5.5 0 0 0-7.8 7.8l1 1L12 21l7.8-7.6 1-1a5.5 5.5 0 0 0 0-7.8z"/>
                </svg>
              </button>
            </a>

            <!-- content -->
            <div class="rp-body">
              <h3 class="rp-name">
                <a href="<?= $_item->getProductUrl(); ?>">
                  <?= $block->escapeHtml($_item->getName()); ?>
                </a>
              </h3>

              <div class="rp-price-line">
                <span class="rp-price"><?= $priceHtml; ?></span>
                <span class="rp-per">/ 1 pcs</span>
              </div>

              <hr class="rp-divider">

              <?php if ($brand): ?>
                <div class="rp-meta">
                  <span class="rp-brand"><?= $block->escapeHtml($brand); ?></span>
                  <span class="rp-verified" aria-label="verified">
                    <svg viewBox="0 0 24 24" width="16" height="16" aria-hidden="true" focusable="false">
                      <path fill="#2A6FE3" d="M12 2l2.4 2 3-.7 1 2.9 2.9 1-1 2.9 2 2.4-2 2.4 1 2.9-2.9 1-1 2.9-3-.7L12 22l-2.4-2-3 .7-1-2.9-2.9-1 1-2.9L2 12l2-2.4-1-2.9 2.9-1 1-2.9 3 .7L12 2zm-1.2 12.7l5-5-1.4-1.4-3.6 3.6-1.6-1.6-1.4 1.4 3 3z"/>
                    </svg>
                  </span>
                </div>
              <?php endif; ?>

              <?php if ($country): ?>
                <div class="rp-meta">
                  <span class="rp-flag" aria-hidden="true">🌍</span>
                  <span class="rp-country"><?= $block->escapeHtml($country); ?></span>
                </div>
              <?php endif; ?>
            </div>

            <!-- footer -->
            <div class="rp-foot">
              <button class="rp-btn" type="button"><?= __('Add to Quote'); ?></button>
            </div>
          </article>
        </div>
      <?php endforeach; ?>

    </div>
  </div>
</div>
<?php endif; ?>


