<?php
/** @var \Magento\ConfigurableProduct\Block\Product\View\Type\Configurable $block */
$product = $block->getProduct();
$attributes = $block->getAllowAttributes();
?>

<div class="mt-4 configurable-options">
    <h4 class="font-medium">Product Variation</h4>

    <?php if (!empty($attributes)): echo "vrush"; ?>
        <?php foreach ($attributes as $attribute): 
            $attributeLabel = $attribute->getProductAttribute()->getStoreLabel();
            $attributeCode = $attribute->getProductAttribute()->getAttributeCode();
            $attributeOptions = $attribute->getOptions();
        ?>
        
        <div class="mt-2">
            <label class="block text-sm font-semibold"><?= $attributeLabel ?></label>
            <div class="flex space-x-2 mt-1 attribute-options" data-attribute-code="<?= $attributeCode ?>">
                <?php foreach ($attributeOptions as $option): 
                    $optionLabel = isset($option['label']) ? $option['label'] : '';
                    $optionValue = isset($option['value']) ? $option['value'] : '';

                   // echo "optionLabel".$optionLabel;
                     //echo "optionValue".$optionValue;
                    //if (!$optionLabel || !$optionValue) continue;
                ?>
                    <button 
                        type="button" 
                        class="border rounded px-3 py-1 text-sm option-btn" 
                        data-option-id="<?= $optionValue ?>">
                        <?= $optionLabel ?>
                    </button>
                <?php endforeach; ?>
            </div>
        </div>
        <?php endforeach; ?>
    <?php else: ?>
        <p>No configurable attributes found.</p>
    <?php endif; ?>

    <button 
        class="mt-6 w-full bg-blue-600 text-white py-2 rounded text-sm font-semibold hover:bg-blue-700 add-to-quote-btn"
        data-product-id="<?= $product->getId() ?>">
        Add To Quote
    </button>
</div>

<script>
require(['jquery'], function($){
    var selectedOptions = {};

    $('.attribute-options').on('click', '.option-btn', function(){
        var $btn = $(this);
        var $container = $btn.closest('.attribute-options');
        var attributeCode = $container.data('attribute-code');
        var optionId = $btn.data('option-id');

        $container.find('.option-btn').removeClass('bg-blue-100 border-blue-600');
        $btn.addClass('bg-blue-100 border-blue-600');

        selectedOptions[attributeCode] = optionId;
    });

    $('.add-to-quote-btn').on('click', function(){
        var productId = $(this).data('product-id');
        if(Object.keys(selectedOptions).length < $('.attribute-options').length){
            alert('Please select all options');
            return;
        }

        // Send AJAX request here to add to quote
        console.log('Product:', productId, 'Options:', selectedOptions);
        alert('Product added to quote!');
    });
});
</script>
