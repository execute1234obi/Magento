<?php
  //product listing page 
/** @var \Magento\Catalog\Block\Product\ListProduct $block */
$_productCollection = $block->getLoadedProductCollection();
$_imageHelper = $this->helper(\Magento\Catalog\Helper\Image::class);

/* Toolbar (pagination/sort) */
$toolbarBlock = $block->getLayout()->getBlock('product_list_toolbar');
if ($toolbarBlock) { $toolbarBlock->setCollection($_productCollection); echo $toolbarBlock->toHtml(); }

/* Vendor/brand helpers (adjust to your project) */
$om = \Magento\Framework\App\ObjectManager::getInstance();
/** Optional: manufacturer attribute as brand */
$getBrand = function($product) {
    $text = $product->getAttributeText('manufacturer');
    return is_array($text) ? reset($text) : ($text ?: '');
};
/** Optional: vendor verification helper (returns bool). Wrap in try/catch if not available. */
$vendorFactory = $om->create(\Vnecoms\Vendors\Model\VendorFactory::class);
$verifyHelper  = $om->get(\Business\VendorsVerification\Helper\Data::class);
?>

<?php if (!$_productCollection->getSize()): ?>
  <div><?= $block->escapeHtml(__('No products found.')) ?>
  </div>
<?php else: ?>
    <div class="u-grid">
    <?php foreach ($_productCollection as $_product): ?>
      <?php
        $imgUrl = $block->getImage($_product, 'product_page_image_large')->getImageUrl();
        $brand  = $getBrand($_product) ?: '—';
        /* vendor details (optional) */
        $vendorId   = (int) $_product->getVendorId();
        $vendorName = ''; $countryCode = ''; $isVerified = false;
        if ($vendorId) {
          try {
            $vendor = $vendorFactory->create()->load($vendorId);
            if ($vendor && $vendor->getId()) {
              //$vendorName = $vendor->getVendorName() ?: $vendor->getCName();
             $vendorName = $vendor->getData('b_name') ?: $vendor->getData('b_name');
             //echo $vendorName;
              $countryCode = $vendor->getCountryId() ?: '';
              $isVerified  = (bool) $verifyHelper->isVerifiedVendor($vendorId);
            }
          } catch (\Exception $e) { /* ignore */ }
        }
        /* Fallbacks */
        $displayBrand = $brand ?: ($vendorName ?: __('Brand'));
        $displayCountry = $countryCode ?: __('Saudi Arabia'); // change your default if needed
      ?>
      <article class="u-card">
        <a class="u-imgbox" href="<?= $_product->getProductUrl(); ?>">
          <img src="<?= $imgUrl; ?>"
               alt="<?= $block->escapeHtml($_product->getName()); ?>" />
         </a>
         <?php
$wishlistHelper = $this->helper(\Magento\Wishlist\Helper\Data::class);
$addToWishlistParams = $wishlistHelper->getAddParams($_product); // JSON for data-post
?>
         <!-- Wishlist heart (independent link, but positioned on top of image) -->
  <a href="#"
     class="u-fav action towishlist"
     title="<?= $block->escapeHtmlAttr(__('Add to Wishlist')) ?>"
     data-post='<?= /* @noEscape */ $block->getAddToWishlistParams($_product) ?>'>
    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8">
      <path d="M20.8 4.6a5.5 5.5 0 0 0-7.8 0L12 5.6l-1-1a5.5 5.5 0 1 0-7.8 7.8l1 1L12 21l7.8-7.6 1-1a5.5 5.5 0 0 0 0-7.8Z"/>
    </svg>
  </a>
        <h3 class="u-title"><?= $block->escapeHtml($_product->getName()); ?></h3>

        <div class="u-price">
          <?= /* price html already styled by Magento */ $block->getProductPrice($_product); ?>
          <span>/ 1 pcs</span>
        </div>

        <hr class="u-divider" />

        <div class="u-brand">
          <span><?= ucfirst($block->escapeHtml($vendorName));  ?></span>
          <?php if ($isVerified): ?>
            <span class="u-verified" title="<?= $block->escapeHtmlAttr(__('Verified vendor')); ?>">
              <!-- check -->
              <svg viewBox="0 0 24 24" fill="currentColor">
                <path d="M9.5 16.2 5.8 12.5l1.4-1.4 2.3 2.3 6.3-6.3 1.4 1.4-7.7 7.7z"/>
              </svg>
            </span>
          <?php endif; ?>
        </div>

        <div class="u-country">
          <span class="u-flag" aria-hidden="true"></span>
          <span><?= $block->escapeHtml($displayCountry); ?></span>
        </div>

        <button class="u-cta" type="button"><?= $block->escapeHtml(__('Add to Quote')); ?></button>
      </article>
    <?php endforeach; ?>
  </div>

  <?php if ($toolbarBlock) echo $toolbarBlock->toHtml(); ?>
<?php endif; ?>
