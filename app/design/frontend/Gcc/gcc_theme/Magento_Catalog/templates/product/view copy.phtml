use Magento\ConfigurableProduct\Model\Product\Type\Configurable;
use Magento\Framework\Pricing\Helper\Data as PriceHelper;

$objectManager = \Magento\Framework\App\ObjectManager::getInstance();
/** @var PriceHelper $priceHelper */
$priceHelper = $objectManager->get(PriceHelper::class);

if ($product->getTypeId() === Configurable::TYPE_CODE) {
    // Safe to get child products
    /** @var \Magento\ConfigurableProduct\Model\Product\Type\Configurable $typeInstance */
    $typeInstance = $product->getTypeInstance();
    $usedProducts = $typeInstance->getUsedProducts($product);

    $minPrice = null;

    foreach ($usedProducts as $childProduct) {
        if (!$childProduct->isSaleable()) {
            continue;
        }

        $price = $childProduct->getFinalPrice();
        if ($minPrice === null || $price < $minPrice) {
            $minPrice = $price;
        }
    }

    if ($minPrice !== null) {
        echo '<div class="product-price">From ' . $priceHelper->currency($minPrice, true, false) . '</div>';
    } else {
        echo '<div class="product-price">Price not available</div>';
    }
} else {
    // For simple, virtual, etc. products
    $finalPrice = $product->getFinalPrice();
    echo '<div class="product-price">' . $priceHelper->currency($finalPrice, true, false) . '</div>';
}
