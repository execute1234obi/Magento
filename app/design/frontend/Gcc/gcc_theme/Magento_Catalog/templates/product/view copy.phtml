<!-- Carousel + Tabs logic (vanilla JS) -->
<script>
document.addEventListener('DOMContentLoaded', () => {
    // --- Carousel logic ---
    const mainImage = document.getElementById('mainImage');
    const thumbTrack = document.getElementById('thumbTrack');
    const prevBtn = document.getElementById('prevBtn');
    const nextBtn = document.getElementById('nextBtn');
    const thumbs = Array.from(thumbTrack.querySelectorAll('img'));
    let currentIndex = 0;

    const setActiveThumb = (newIndex) => {
        currentIndex = newIndex;
        thumbs.forEach((t, idx) => {
            const isActive = idx === newIndex;
            t.classList.toggle('active', isActive);
            t.setAttribute('aria-selected', isActive ? 'true' : 'false');
        });
        const activeThumb = thumbs[newIndex];
        if (activeThumb) {
            mainImage.src = activeThumb.src;
            mainImage.alt = activeThumb.alt;
            activeThumb.scrollIntoView({ inline: 'center', behavior: 'smooth', block: 'nearest' });
        }
    };

    thumbs.forEach((t, i) => t.addEventListener('click', () => setActiveThumb(i)));
    prevBtn.addEventListener('click', () => {
        const newIndex = (currentIndex - 1 + thumbs.length) % thumbs.length;
        setActiveThumb(newIndex);
    });
    nextBtn.addEventListener('click', () => {
        const newIndex = (currentIndex + 1) % thumbs.length;
        setActiveThumb(newIndex);
    });
    
    // Listen for configurable product changes
    const configurableContainer = document.querySelector('.product-info');
    if (configurableContainer && typeof jQuery !== 'undefined' && configurableContainer.dataset.mageInit) {
        jQuery(configurableContainer).on('change', function(event) {
            const selectedImage = mainImage.src;
            let newIndex = 0;
            thumbs.forEach((thumb, idx) => {
                if (thumb.src === selectedImage) {
                    newIndex = idx;
                }
            });
            setActiveThumb(newIndex);
        });
    }

    // --- Tabs logic ---
    const tabsContainer = document.getElementById('productTabs');
    if (tabsContainer) {
        const tabButtons = tabsContainer.querySelectorAll('.tab-header button');
        const tabPanels = tabsContainer.querySelectorAll('.tab-panel');

        tabButtons.forEach(button => {
            button.addEventListener('click', () => {
                const targetPanelId = button.getAttribute('aria-controls');
                
                // Deactivate all tabs and panels
                tabButtons.forEach(btn => btn.classList.remove('active'));
                tabButtons.forEach(btn => btn.setAttribute('aria-selected', 'false'));
                tabPanels.forEach(panel => panel.classList.remove('active'));

                // Activate the selected tab and panel
                button.classList.add('active');
                button.setAttribute('aria-selected', 'true');
                document.getElementById(targetPanelId).classList.add('active');
            });
        });
    }
});
</script>
