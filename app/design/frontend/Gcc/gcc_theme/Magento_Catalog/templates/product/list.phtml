<script>
require(['jquery'], function($) {
  $(document).ready(function() {
    $('.u-country').each(function() {
      var $container = $(this);
      var countryCode = $container.data('code');
      var flagUrl = 'https://flagcdn.com/w40/' + countryCode + '.png';
      var altText = $container.find('span').last().text().trim();

      $container.find('.u-flag').css({
        'background-image': 'url(' + flagUrl + ')',
        'background-size': 'cover',
        'background-position': 'center'
      }).attr('alt', altText);
    });
  });
  //for ajax content load add to quote button click event
$(document).on('click', '.add-to-quote', function () {

    var button = $(this);
    var productId = button.data('product-id');

    $.ajax({
        url: '<?= $block->getUrl("quoterequest/index/create") ?>',
        type: 'POST',
        data: {
            product_id: productId
        },
        showLoader: true,

       success: function (response) {

    button.text('Added');
    button.prop('disabled', true);

    if (response.count !== undefined) {

        $('#quote-counter')
            .text(response.count)
            .show();

    }

},

        error: function (xhr) {
            console.log(xhr);
            alert('Error while adding to quote');
        }

    });

});
});

</script>
