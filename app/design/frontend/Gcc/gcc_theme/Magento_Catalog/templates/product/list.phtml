<?php
/** @var \Magento\Catalog\Block\Product\ListProduct $block */
$_productCollection = $block->getLoadedProductCollection();
$_imageHelper = $this->helper(\Magento\Catalog\Helper\Image::class);
$request = $block->getRequest();
$isSearchPage = $request && $request->getFullActionName() === 'catalogsearch_result_index';

/* Toolbar (pagination/sort) */
$toolbarBlock = $block->getToolbarBlock();
$toolbarBlock->setCollection($_productCollection);
if (!$isSearchPage) {
    echo $toolbarBlock->toHtml();
}

/* Vendor/brand helpers */
$om = \Magento\Framework\App\ObjectManager::getInstance();
$getBrand = function($product) {
    $text = $product->getAttributeText('manufacturer');
    return is_array($text) ? reset($text) : ($text ?: '');
};
$vendorFactory = $om->create(\Vnecoms\Vendors\Model\VendorFactory::class);
$verificationBlock = $om->get(\Vendor\VendorsVerification\Block\Vendors\Verification\View\Verification::class);
$mediaBaseUrl = $block->getBaseUrl(\Magento\Framework\UrlInterface::URL_TYPE_MEDIA);
$verificationIconUrl = $mediaBaseUrl . 'wysiwyg/VerificationBadgeIcon.png';
$defaultFlagUrl = $mediaBaseUrl . 'wysiwyg/SA_flag.PNG';
?>

<?php if (!$_productCollection->getSize()): ?>
    <div><?= $block->escapeHtml(__('No products found.')) ?></div>
<?php else: ?>
    <div class="products wrapper search-products-wrapper">
    <div class="u-grid">
    <?php foreach ($_productCollection as $_product): ?>
        
       <?php
        $imgUrl = $block->getImage($_product, 'product_page_image_large')->getImageUrl();
        $brand  = $getBrand($_product) ?: '—';

        $vendorId   = (int) $_product->getVendorId();
        $vendorName = ''; 
        $countryCode = ''; 
        $isVerified = false;
        
       //echo  $vendorId;exit;
        if ($vendorId) {
    //         echo "Vendor ID: " . $vendorId . " | Status: ";
    //          $isVerified  = (bool) $verificationBlock->isVerifiedVendor($vendorId);
    // var_dump($isVerified); 
    // echo "<br>";
    //  exit; //
            try {
                $vendor = $vendorFactory->create()->load($vendorId);
                if ($vendor && $vendor->getId()) {
                    $vendorName = $vendor->getData('b_name') ?: '';
                    $countryCode = $vendor->getCountryId() ?: '';
                    $isVerified = (bool) $verificationBlock->isVendorVerified($vendorId);
                   
                    
                }
            } catch (\Exception $e) { }
        }

        $displayBrand = $brand ?: ($vendorName ?: __('Brand'));
        $objectManager = \Magento\Framework\App\ObjectManager::getInstance();
        $countryFactory = $objectManager->get(\Magento\Directory\Model\CountryFactory::class);
        $country_id = $countryFactory->create()->loadByCode($countryCode);
        $country = $country_id->getName();
        $displayCountry = $country ?: 'SA'; // default country name if missing
        $flagCode = preg_match('/^[a-z]{2}$/i', (string) $countryCode) ? strtolower((string) $countryCode) : '';
        $flagUrl = $flagCode !== '' ? 'https://flagcdn.com/w40/' . $flagCode . '.png' : $defaultFlagUrl;
        
        ?>
        <article class="u-card">
            <a class="u-imgbox" href="<?= $_product->getProductUrl(); ?>">
                <img src="<?= $imgUrl; ?>" alt="<?= $block->escapeHtml($_product->getName()); ?>" />
            </a>

            <!-- Wishlist heart -->
            <a href="#"
               class="u-fav action towishlist"
               title="<?= $block->escapeHtmlAttr(__('Add to Wishlist')) ?>"
               data-post='<?= /* @noEscape */ $block->getAddToWishlistParams($_product) ?>'>
                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" aria-hidden="true">
                    <path d="M20.8 4.6a5.5 5.5 0 0 0-7.8 0L12 5.6l-1-1a5.5 5.5 0 1 0-7.8 7.8l1 1L12 21l7.8-7.6 1-1a5.5 5.5 0 0 0 0-7.8Z"/>
                </svg>
            </a>

            <h3 class="u-title"><?= $block->escapeHtml($_product->getName()); ?></h3>
            <div class="u-price">
                 <?php
                    $price = (float)$_product->getPrice();
                    $finalPrice = (float)$_product->getFinalPrice();
                    ?>

                    <?php if ($price > 0 || $finalPrice > 0): ?>
                        <?= $block->getProductPrice($_product); ?>
                        <span>/ 1 pcs</span>
                    <?php endif; ?>
            </div>

            <hr class="u-divider" />

            <div class="u-brand">
                <span><?= $block->escapeHtml($vendorName ?: $displayBrand); ?></span>
                <?php if ($isVerified): ?>
                    <span class="u-verified" title="<?= $block->escapeHtmlAttr(__('Verified vendor')); ?>">
                        <img src="<?= $block->escapeUrl($verificationIconUrl); ?>" alt="Verified" width="18" height="18">
                    </span>
                <?php endif; ?>
            </div>

            <!-- Country with flag -->
          <div class="u-country" data-code="<?= strtolower($countryCode); ?>">
                <span class="u-flag" aria-hidden="true">
                    <img class="country-flag" src="<?= $block->escapeUrl($flagUrl); ?>" alt="<?= $block->escapeHtmlAttr($displayCountry); ?> Flag">
                </span>
                <span><?= $block->escapeHtml($displayCountry); ?></span>
           </div>

            <!-- request quote functionality -->
                
            <button class="u-cta add-to-quote"
                data-product-id="<?= $_product->getId(); ?>"
                type="button">
                <?= __('Add to Quote') ?>
            </button>
        </article>
    <?php endforeach; ?>
    </div>
    </div>

    <?= $block->getChildBlock('toolbar')->setIsBottom(true)->toHtml() ?>
<?php endif; ?>

