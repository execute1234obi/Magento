/** @var \Magento\Catalog\Block\Product\ListProduct $block */
$_productCollection = $block->getLoadedProductCollection();
$_imageHelper = $this->helper(\Magento\Catalog\Helper\Image::class);

// Get the existing toolbar block from the layout
$toolbarBlock = $block->getLayout()->getBlock('product_list_toolbar');

// Check if the block exists before trying to use it
if ($toolbarBlock) {
    // Set the product collection on the toolbar
    $toolbarBlock->setCollection($_productCollection);
}

// Get the Object Manager for testing (not recommended for production)
// In a real module, you would use dependency injection in your Block class.
$objectManager = \Magento\Framework\App\ObjectManager::getInstance();

// Get the Vnecoms Vendor Factory
$vendorFactory = $objectManager->create(\Vnecoms\Vendors\Model\VendorFactory::class);
// Get the Vendors Verification Helper
// This is the line you need to add to fix the error
$vendorsVerificationHelper = $objectManager->get(\Business\VendorsVerification\Helper\Data::class);
?>

<?php
/** @var $block \Magento\Catalog\Block\Product\ListProduct */
$_productCollection = $block->getLoadedProductCollection();
$_imageHelper = $this->helper(\Magento\Catalog\Helper\Image::class);
?>
 <?php if ($toolbarBlock) { echo $toolbarBlock->toHtml(); } ?>
<?php if (!$_productCollection->count()): ?>
    <div class="p-6 text-center text-gray-600">
        <p><?= $block->escapeHtml(__('We can\'t find products matching the selection.')) ?></p>
    </div>
<?php else: ?>
    <div class="product-grid-container">
        <?php foreach ($_productCollection as $_product): ?>
        <?php
            $vendorId = $_product->getVendorId();
            $vendorName = '';
            $vendorLocation = '';
            
            if ($vendorId) {
                try {
                    // Create a new vendor model instance and load data by ID
                    $vendor = $vendorFactory->create()->load($vendorId);
                    if ($vendor && $vendor->getId()) {
                        // Use the correct methods to get the vendor's data
                        $vendorName = $vendor->getVendorName() ?: $vendor->getCName();
                        $vendorLocation = $vendor->getCountryId(); // Or another attribute like getCity()
                        $isVerified = $vendorsVerificationHelper->isVerifiedVendor($vendorId);
                    }
                } catch (NoSuchEntityException $e) {
            // This is a more specific exception for "not found"
            $this->messageManager->addErrorMessage('Vendor data not found.');
            return 'N/A';
        } catch (\Exception $e) {
            $this->messageManager->addErrorMessage('An error occurred while fetching vendor data.');
            return 'N/A';
        }
            }
            ?>


            <div class="product-card">
  <div class="product-image">
      <a href="<?= $_product->getProductUrl() ?>">
    <img src="<?= $block->getImage($_product, 'product_page_image_large')->getImageUrl(); ?>" 
                            alt="<?= $block->escapeHtml($_product->getName()); ?>" style="max-width:100%;height:auto;display:block;object-fit:cover;">
        </a>
</div>
  <div class="product-details">
    <h3 class="product-name"><?= $block->escapeHtml($_product->getName()); ?></h3>
    <div class="price-label">
  <span class="price"><?= $block->getProductPrice($_product); ?></span> / <span class="quantity">1 pcs</span>
</div>

<hr/>
     </div>
  <div class="vendor-info">
    <div class="vendor-name">
       <?= $block->escapeHtml($vendorName ?: 'N/A'); ?>
       <?php
// In your .phtml file
$mediaUrl = $block->getUrl('pub/media');
$varifyimageUrl = $mediaUrl . 'wysiwyg/varifiedicon.png';
$countryimageUrl = $mediaUrl . 'wysiwyg/SA_flag.png';
?>


      <span class="verified-icon">
         <?php 
          $isVerified = $vendorsVerificationHelper->isVerifiedVendor($vendorId);
          $isVerified = $isVerified ?? false; 
         if ($isVerified): ?>
        <img src="<?= $block->escapeUrl($varifyimageUrl) ?>" alt="Verified Icon">
        <?php endif; ?>
      </span>
    </div>
    <div class="vendor-location">
     <img src="<?= $block->escapeUrl($countryimageUrl) ?>" alt="country Icon">
       <?= $block->escapeHtml($vendorLocation ?: 'N/A'); ?>
