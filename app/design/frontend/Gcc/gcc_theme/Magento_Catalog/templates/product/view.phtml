<script type="text/javascript">

require(['jquery'], function($) {
    // This script block handles configurable product updates for price and image
    // You should use the Magento_Swatches/js/swatch-renderer if available, 
    // but this custom script simulates the necessary updates based on your original logic.

    // 1. Swatch Option Click (for basic swatch update)
    $(document).on('click', '.swatch-option', function() {
        let img = $(this).data('thumb');
        if (img) {
            // Find the main image element and update its source
            const mainImageElement = document.getElementById('mainImage');
            if (mainImageElement) {
                mainImageElement.style.opacity = '0.1';
                setTimeout(() => {
                    mainImageElement.src = img;
                    mainImageElement.style.opacity = '1';
                }, 100);
                
                // Remove 'active' from all thumbs and ensure the main image is not an active thumb
                document.querySelectorAll('#thumbTrack img').forEach(t => t.classList.remove('active'));
            }
        }
        
        // Price update (This relies on specific data-attributes on the swatch)
        let priceBox = $('.price-box');
        if ($(this).data('price-amount')) {
             // In a real Magento context, you should trigger reloadPrice or use knockout observables.
             // This is a minimal JS update, but the Magento price box might overwrite it.
             // For this custom template, we'll try to target the main price display.
             priceBox.find('.price').text($(this).data('price-amount'));
        }
    });

    // 2. Custom configurable update listener (triggered by Magento's configurable.js)
    require(['Magento_ConfigurableProduct/js/configurable'], function(){
        $('#product_addtocart_form').on('updateProductData', function(event, data){
            // Update main image on configurable option change
            if (data.images && data.images.length > 0) {
                var newImg = data.images[0].full;
                if (newImg) {
                     const mainImageElement = document.getElementById('mainImage');
                     if (mainImageElement) {
                         mainImageElement.style.opacity = '0.1';
                         setTimeout(() => {
                             mainImageElement.src = newImg;
                             mainImageElement.style.opacity = '1';
                         }, 100);
                         
                         // Remove active state from thumbnail track
                         document.querySelectorAll('#thumbTrack img').forEach(t => t.classList.remove('active'));
                     }
                }
            }
        });
    });
});
</script>
<?php endif; ?>

