<script>
document.addEventListener('DOMContentLoaded', () => {
    // --- Carousel logic ---
    const mainImage = document.getElementById('mainImage');
    const thumbTrack = document.getElementById('thumbTrack');
    const prevBtn = document.getElementById('prevBtn');
    const nextBtn = document.getElementById('nextBtn');
    const thumbs = Array.from(thumbTrack ? thumbTrack.querySelectorAll('img') : []);
    let currentIndex = 0;

    // Set initial index based on active thumb
    const initialActiveThumb = thumbs.find(t => t.classList.contains('active'));
    if (initialActiveThumb) {
        currentIndex = parseInt(initialActiveThumb.dataset.index) || 0;
    }

    const setActiveThumb = (newIndex) => {
        currentIndex = newIndex;
        thumbs.forEach((t, idx) => {
            const isActive = idx === newIndex;
            t.classList.toggle('active', isActive);
            t.setAttribute('aria-selected', isActive ? 'true' : 'false');
        });
        const activeThumb = thumbs[newIndex];
        if (activeThumb) {
            mainImage.style.opacity = '0.1'; // Fade out for transition
            setTimeout(() => {
                mainImage.src = activeThumb.src;
                mainImage.alt = activeThumb.alt;
                mainImage.style.opacity = '1'; // Fade back in
            }, 100);
            activeThumb.scrollIntoView({ inline: 'center', behavior: 'smooth', block: 'nearest' });
        }
    };
    thumbs.forEach((t, i) => t.addEventListener('click', () => setActiveThumb(i)));
    
    if (thumbs.length > 0) {
        prevBtn.addEventListener('click', () => {
            const newIndex = (currentIndex - 1 + thumbs.length) % thumbs.length;
            setActiveThumb(newIndex);
        });
        nextBtn.addEventListener('click', () => {
            const newIndex = (currentIndex + 1) % thumbs.length;
            setActiveThumb(newIndex);
        });
    } else {
         // Disable carousel if no images found
         if (prevBtn) prevBtn.disabled = true;
         if (nextBtn) nextBtn.disabled = true;
    }
    
    // --- Tabs logic ---
    const tabsContainer = document.getElementById('productTabs');
    if (tabsContainer) {
        const tabButtons = tabsContainer.querySelectorAll('.tab-header button');
        const tabPanels = tabsContainer.querySelectorAll('.tab-panel');
        tabButtons.forEach(button => {
            button.addEventListener('click', () => {
                const targetPanelId = button.getAttribute('aria-controls');
                
                // Deactivate all tabs and panels
                tabButtons.forEach(btn => {
                    btn.classList.remove('active');
                    btn.setAttribute('aria-selected', 'false');
                });
                tabPanels.forEach(panel => panel.classList.remove('active'));
                
                // Activate the selected tab and panel
                button.classList.add('active');
                button.setAttribute('aria-selected', 'true');
                const targetPanel = document.getElementById(targetPanelId);
                if (targetPanel) {
                    targetPanel.classList.add('active');
                }
            });
        });
    }

    // --- Description Toggle Logic (More/Less) ---
    // const descText = document.getElementById('descText');
    // const descToggle = document.getElementById('descToggle');

    // if (descText && descToggle) {
    //     // Function to check if content is actually clamped
    //     const isContentClamped = () => {
    //         // Must temporarily remove clamping to check full height
    //         descText.classList.remove('is-clamped');
    //         const isClamped = descText.scrollHeight > descText.clientHeight;
    //         descText.classList.add('is-clamped');
    //         return isClamped;
    //     };

    //     const updateToggleVisibility = () => {
    //         // Only show the toggle button if the content is actually cut off
    //         if (isContentClamped()) {
    //             descToggle.style.display = 'block';
    //         } else {
    //             descToggle.style.display = 'none';
    //         }
    //     };

    //     const toggleDescription = () => {
    //         const isClamped = descText.classList.contains('is-clamped');
    //         if (isClamped) {
    //             // Show more
    //             descText.classList.remove('is-clamped');
    //             descToggle.textContent = 'Less';
    //             descToggle.setAttribute('aria-expanded', 'true');
    //         } else {
    //             // Show less
    //             descText.classList.add('is-clamped');
    //             descToggle.textContent = 'More';
    //             descToggle.setAttribute('aria-expanded', 'false');
    //         }
    //     };

    //     descToggle.addEventListener('click', toggleDescription);
        
    //     // Initial check and on window resize
    //     updateToggleVisibility();
    //     window.addEventListener('resize', updateToggleVisibility);
    // }
});
document.addEventListener('DOMContentLoaded', function () {
  const text = document.getElementById('descText');
  const toggle = document.getElementById('descToggle');
  if (!text || !toggle) return;

  toggle.addEventListener('click', function (e) {
    e.preventDefault();
    const clamped = text.classList.contains('is-clamped');

    if (clamped) {
      text.classList.remove('is-clamped');      // expand
      toggle.textContent = 'Show less';
      toggle.setAttribute('aria-expanded', 'true');
    } else {
      text.classList.add('is-clamped');         // collapse
      toggle.textContent = 'More';
      toggle.setAttribute('aria-expanded', 'false');
    }
  });
});
</script>

