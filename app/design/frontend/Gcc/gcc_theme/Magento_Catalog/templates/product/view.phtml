document.addEventListener('DOMContentLoaded', () => {
    // --- Carousel logic ---
    const mainImage = document.getElementById('mainImage');
    const thumbTrack = document.getElementById('thumbTrack');
    const prevBtn = document.getElementById('prevBtn');
    const nextBtn = document.getElementById('nextBtn');
    const thumbs = Array.from(thumbTrack ? thumbTrack.querySelectorAll('img') : []);
    let currentIndex = 0;

    // Set initial index based on active thumb
    const initialActiveThumb = thumbs.find(t => t.classList.contains('active'));
    if (initialActiveThumb) {
        currentIndex = parseInt(initialActiveThumb.dataset.index) || 0;
    }

    const setActiveThumb = (newIndex) => {
        currentIndex = newIndex;
        thumbs.forEach((t, idx) => {
            const isActive = idx === newIndex;
            t.classList.toggle('active', isActive);
            t.setAttribute('aria-selected', isActive ? 'true' : 'false');
        });
        const activeThumb = thumbs[newIndex];
        if (activeThumb) {
            mainImage.style.opacity = '0.1'; // Fade out for transition
            setTimeout(() => {
                mainImage.src = activeThumb.src;
                mainImage.alt = activeThumb.alt;
                mainImage.style.opacity = '1'; // Fade back in
            }, 100);
            activeThumb.scrollIntoView({ inline: 'center', behavior: 'smooth', block: 'nearest' });
        }
    };
    thumbs.forEach((t, i) => t.addEventListener('click', () => setActiveThumb(i)));
    
    if (thumbs.length > 0) {
        prevBtn.addEventListener('click', () => {
            const newIndex = (currentIndex - 1 + thumbs.length) % thumbs.length;
            setActiveThumb(newIndex);
        });
        nextBtn.addEventListener('click', () => {
            const newIndex = (currentIndex + 1) % thumbs.length;
            setActiveThumb(newIndex);
        });
    } else {
         // Disable carousel if no images found
         if (prevBtn) prevBtn.disabled = true;
         if (nextBtn) nextBtn.disabled = true;
    }
    
    // --- Tabs logic ---
    const tabsContainer = document.getElementById('productTabs');
    if (tabsContainer) {
        const tabButtons = tabsContainer.querySelectorAll('.tab-header button');
        const tabPanels = tabsContainer.querySelectorAll('.tab-panel');
        tabButtons.forEach(button => {
            button.addEventListener('click', () => {
                const targetPanelId = button.getAttribute('aria-controls');
                
                // Deactivate all tabs and panels
                tabButtons.forEach(btn => {
                    btn.classList.remove('active');
                    btn.setAttribute('aria-selected', 'false');
                });
                tabPanels.forEach(panel => panel.classList.remove('active'));
                
                // Activate the selected tab and panel
                button.classList.add('active');
                button.setAttribute('aria-selected', 'true');
                const targetPanel = document.getElementById(targetPanelId);
                if (targetPanel) {
                    targetPanel.classList.add('active');
                }
            });
        });
    }

    // --- Description Toggle Logic (More/Less) ---
    // const descText = document.getElementById('descText');
    // const descToggle = document.getElementById('descToggle');

    // if (descText && descToggle) {
