});
document.addEventListener('DOMContentLoaded', function () {
  const text = document.getElementById('descText');
  const toggle = document.getElementById('descToggle');
  if (!text || !toggle) return;

  const clampClass = 'is-clamped';
  const collapsedLabel = toggle.dataset.collapsedLabel || 'More';
  const expandedLabel = toggle.dataset.expandedLabel || 'Show less';

  const measureClampedOverflow = () => {
    const wasClamped = text.classList.contains(clampClass);

    if (!wasClamped) {
      text.classList.add(clampClass);
    }

    const overflow = text.scrollHeight > text.clientHeight + 1;

    if (!wasClamped) {
      text.classList.remove(clampClass);
    }

    return overflow;
  };

  const refreshToggle = () => {
    const needsToggle = measureClampedOverflow();

    if (!needsToggle) {
      text.classList.remove(clampClass);
      toggle.hidden = true;
      toggle.setAttribute('aria-expanded', 'true');
      toggle.textContent = expandedLabel;
      return;
    }

    toggle.hidden = false;
    if (text.classList.contains(clampClass)) {
      toggle.textContent = collapsedLabel;
      toggle.setAttribute('aria-expanded', 'false');
    } else {
      toggle.textContent = expandedLabel;
      toggle.setAttribute('aria-expanded', 'true');
    }
  };

  toggle.addEventListener('click', function (e) {
    e.preventDefault();
    if (toggle.hidden) {
      return;
    }

    text.classList.toggle(clampClass);
    refreshToggle();
  });

  window.gccRefreshProductDescription = function (options) {
    if (!options || options.reset !== false) {
      text.classList.add(clampClass);
    }

    requestAnimationFrame(refreshToggle);
  };

  refreshToggle();
  window.addEventListener('resize', function () {
    requestAnimationFrame(refreshToggle);
  });
});
</script>

