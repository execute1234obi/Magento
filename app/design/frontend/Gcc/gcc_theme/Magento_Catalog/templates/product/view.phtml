$title = (string)$product->getName();

$summaryShortDescriptionHtml = trim((string) $product->getShortDescription());
$summaryFullDescriptionHtml = trim((string) $product->getDescription());
$summaryShortDescriptionText = trim(preg_replace('/\s+/', ' ', strip_tags($summaryShortDescriptionHtml)));
$summaryFullDescriptionText = trim(preg_replace('/\s+/', ' ', strip_tags($summaryFullDescriptionHtml)));

$summaryDescriptionHtml = $summaryShortDescriptionHtml;
