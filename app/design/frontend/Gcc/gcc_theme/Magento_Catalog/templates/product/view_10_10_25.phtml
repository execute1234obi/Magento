/**
 * @var \Magento\Catalog\Block\Product\View\AbstractView $block
 * @var \Magento\Framework\View\Helper\SecureHtmlRenderer $secureRenderer
 * @var \Magento\Catalog\Helper\Image $imageHelper
 * @var \Magento\Catalog\Model\Product $product
 */

$product = $block->getProduct();
//var_dump($product ? $product->getId() : 'No product');
//var_dump($product ? $product->getDescription() : 'No description');
$imageHelper = $this->helper(\Magento\Catalog\Helper\Image::class);

// Fetching configurable product data if available
$configurableData = '';
if ($product->getTypeId() == \Magento\ConfigurableProduct\Model\Product\Type\Configurable::TYPE_CODE) {
    $configurableData = $block->getJsonConfig();
}

// In a real module, you would use Dependency Injection.
$objectManager = \Magento\Framework\App\ObjectManager::getInstance();
$vendorFactory = $objectManager->create(\Vnecoms\Vendors\Model\VendorFactory::class);
$vendorsVerificationHelper = $objectManager->get(\Business\VendorsVerification\Helper\Data::class);

$vendor = null;
$isVerified = false;
$vendorName = 'N/A';
$vendorLocation = 'N/A';
$logoUrl = '';

if ($product->getVendorId()) {
    try {
        $vendor = $vendorFactory->create()->load($product->getVendorId());
        
        if ($vendor && $vendor->getId()) {
            $vendorName = $vendor->getVendorName() ?: $vendor->getCName() ?: $vendor->getData('name');
            $vendorLocation = $vendor->getCountryId() ?: $vendor->getData('country_id');
            $isVerified = $vendorsVerificationHelper->isVerifiedVendor($product->getVendorId());
            $mediaUrl = $block->getBaseUrl(\Magento\Framework\UrlInterface::URL_TYPE_MEDIA) . "pub/media/";
            
            $logoPath = $vendor->getData('upload_logo');
            $logoUrl = $logoPath ? $mediaUrl . $logoPath : '';
        }
    } catch (\Exception $e) {
        // Log this error in a production environment
    }
}
