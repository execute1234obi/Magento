<script type="text/javascript">
require([
  'jquery',
  'mage/url',
  'Magento_Catalog/js/catalog-add-to-cart'
], function ($, urlBuilder) {
  $('#add-to-quote-btn').on('click', function () {
    var $form = $('#product_addtocart_form');

    // 1) Add to cart via AJAX (respects configurable options, qty, etc.)
    $.ajax({
      type: 'POST',
      url: $form.attr('action'),
      data: $form.serialize(),
      showLoader: true
    }).done(function () {
      // 2) Send the shopper to create a Negotiable Quote from the cart
      window.location.href = urlBuilder.build('negotiable_quote/quote/create');
    }).fail(function () {
      // Fallback: if AJAX fails, submit normally
      $form.trigger('submit');
    });
  });
});
</script>

<script>
document.addEventListener('DOMContentLoaded', function () {
  const text = document.getElementById('descText');
  const toggle = document.getElementById('descToggle');
  if (!text || !toggle) return;

  toggle.addEventListener('click', function (e) {
    e.preventDefault();
    const clamped = text.classList.contains('is-clamped');

    if (clamped) {
      text.classList.remove('is-clamped');      // expand
      toggle.textContent = 'Show less';
      toggle.setAttribute('aria-expanded', 'true');
    } else {
      text.classList.add('is-clamped');         // collapse
      toggle.textContent = 'More';
      toggle.setAttribute('aria-expanded', 'false');
    }
  });
});
</script>
