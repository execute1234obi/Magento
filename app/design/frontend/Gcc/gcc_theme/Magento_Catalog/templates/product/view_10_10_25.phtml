            'brand',
            'color',
            'size',
            // 'tax_class_id',
            //'visibility',
            //'vendor_id',
            //'approval',
            //'search_weight',
            // Add more if needed
        ];
        ?>
        <?php
        $attributes = $product->getAttributes();
        foreach ($attributes as $attribute) {
            $attributeCode = $attribute->getAttributeCode();
            // Only allow attributes in whitelist
            if (!in_array($attributeCode, $whitelist)) {
                continue;
            }
            $label = $attribute->getStoreLabel();
            $value = $product->getData($attributeCode);
            // Skip if value is empty
            if ($value === null || $value === '') {
                continue;
            }
            $displayValue = $attribute->getFrontend()->getValue($product);
            // Handle arrays and objects safely
            if (is_array($displayValue)) {
                $displayValue = implode(', ', array_map(function ($item) {
                    return is_scalar($item) ? (string)$item : '[Complex Data]';
                }, $displayValue));
            } elseif (is_object($displayValue)) {
                $displayValue = method_exists($displayValue, '__toString') ? (string)$displayValue : '[Object]';
            }
            ?>
            <tr>
                <td class="py-2 px-4 border-b"><?= $block->escapeHtml(__($label)) ?>-</td>
                <td class="py-2 px-4 border-b"><?= $block->escapeHtml($displayValue) ?><br/></td>
            </tr>
        <?php } ?>
