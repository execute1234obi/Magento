<script>
require(['jquery'], function ($) {
    $(function () {
        var carouselId = '<?= $block->escapeHtmlAttr($carouselId) ?>';
        var $root = $('#' + carouselId);
        var $viewport = $root.find('.gcc-carousel__viewport');
        var $track = $root.find('.gcc-carousel__track');
        var $prev = $root.find('.gcc-carousel__prev');
        var $next = $root.find('.gcc-carousel__next');

        if (!$root.length) {
            return;
        }

        $root.find('.gcc-card__flag').each(function () {
            var code = String($(this).data('code') || '').trim().toLowerCase();

            if (code) {
                $(this).css({
                    'background-image': 'url(https://flagcdn.com/w40/' + code + '.png)'
                });
            }
        });

        function getGap() {
            var track = $track[0];

            if (!track) {
                return 16;
            }

            var styles = window.getComputedStyle(track);
            var gap = parseInt(styles.columnGap || styles.gap || '16', 10);

            return isNaN(gap) ? 16 : gap;
        }

        function getSlideWidth() {
            var $first = $root.find('.gcc-carousel__slide').first();

            return $first.length ? $first.outerWidth(true) : 330;
        }

        function getStep() {
            var viewportWidth = $viewport.innerWidth();
            var slideWidth = getSlideWidth();
            var gap = getGap();
            var perPage = Math.max(1, Math.floor(viewportWidth / (slideWidth + gap)));

            return perPage * (slideWidth + gap);
        }

        function updateNavState() {
            var track = $track[0];

            if (!track) {
                return;
            }

            var viewportWidth = $viewport.innerWidth();
            var maxScrollLeft = track.scrollWidth - viewportWidth - 1;
            var canScroll = track.scrollWidth > viewportWidth + 1;

            $prev.prop('disabled', !canScroll || track.scrollLeft <= 0);
            $next.prop('disabled', !canScroll || track.scrollLeft >= maxScrollLeft);
        }

        $prev.on('click', function () {
            var track = $track[0];

            if (!track) {
                return;
            }

            track.scrollBy({
                left: -getStep(),
                behavior: 'smooth'
            });

            window.setTimeout(updateNavState, 250);
        });

        $next.on('click', function () {
            var track = $track[0];

            if (!track) {
                return;
            }

            track.scrollBy({
                left: getStep(),
                behavior: 'smooth'
            });

            window.setTimeout(updateNavState, 250);
        });

        $track.on('scroll', updateNavState);
        $(window).on('resize', updateNavState);
        updateNavState();
    });
});

if (!window.__gccQuoteHandlerBound) {
    window.__gccQuoteHandlerBound = true;

    require(['jquery'], function ($) {
        var quoteUrl = <?= /* @noEscape */ json_encode($block->getUrl('quoterequest/index/create')); ?>;

        $(document).on('click', '.add-to-quote', function () {
            var button = $(this);
            var productId = button.data('product-id');

            if (!productId) {
                return;
            }

            $.ajax({
                url: quoteUrl,
                type: 'POST',
                data: {
                    product_id: productId
                },
                showLoader: true,
                success: function (response) {
                    button.text(<?= /* @noEscape */ json_encode((string) __('Added')); ?>);
                    button.prop('disabled', true);

                    if (response && response.count !== undefined) {
                        $('#quote-counter').text(response.count).show();
                    }
                },
                error: function (xhr) {
                    window.console && console.log(xhr);
                    alert(<?= /* @noEscape */ json_encode((string) __('Error while adding to quote')); ?>);
                }
            });
        });
    });
}
</script>
