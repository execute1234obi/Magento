<?php
/** @var \Magento\Catalog\Block\Product\ProductList\Related $block */
$items = $block->getItems();

$defaultCountry = 'Saudi Arabia';
$deriveBrand = static function (string $name): string {
    $parts = preg_split('/\s+/', trim($name)) ?: [];
    $parts = array_values(array_filter($parts));
    return $parts ? implode(' ', array_slice($parts, 0, min(2, count($parts)))) : 'Brand';
};

$buildFallbackImage = static function (string $label, string $accent): string {
    $svg = <<<SVG
<svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 640 360">
  <rect width="640" height="360" rx="28" fill="#f4f6fa"/>
  <ellipse cx="320" cy="245" rx="165" ry="22" fill="#dbe4f3"/>
  <path d="M162 206c20-44 75-95 162-95 65 0 126 29 168 77l31 35c11 12 10 31-2 41-14 12-43 24-92 27H250c-44 0-81-9-97-28-14-15-17-37-9-57l18-0z" fill="{$accent}"/>
  <path d="M176 206c24-38 75-82 154-82 63 0 120 26 158 69l24 24c8 9 7 23-3 30-13 9-35 18-71 20H248c-38 0-71-8-87-24-11-11-14-28-8-37l23 0z" fill="#ffffff"/>
  <path d="M345 149c32 0 63 9 92 27l-18 18c-24-12-49-18-74-18-45 0-87 19-121 52h-35c36-51 94-79 156-79z" fill="#111827" opacity=".9"/>
  <text x="320" y="320" text-anchor="middle" font-family="Arial, sans-serif" font-size="24" font-weight="700" fill="#111827">{$label}</text>
</svg>
SVG;

    return 'data:image/svg+xml;charset=UTF-8,' . rawurlencode($svg);
};

$fallbackCards = [
    [
        'name' => "Nike Air Zoom Pegasus 39 Women's Running Shoes",
        'brand' => 'Nike',
        'country' => $defaultCountry,
        'price_html' => '<span class="price">$2300</span>',
        'image' => $buildFallbackImage('Nike', '#ff7a59'),
    ],
    [
        'name' => "New Balance Fresh Foam 1080v11 Running Shoes Men",
        'brand' => 'New Balance',
        'country' => $defaultCountry,
        'price_html' => '<span class="price">$3000</span>',
        'image' => $buildFallbackImage('New Balance', '#2a6fe3'),
    ],
    [
        'name' => "Reebok Nano X1 Cross Trainer Shoes Women",
        'brand' => 'Reebok',
        'country' => $defaultCountry,
        'price_html' => '<span class="price">$6700</span>',
        'image' => $buildFallbackImage('Reebok', '#111827'),
