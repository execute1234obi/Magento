<script>
require(['jquery'], function($){
  $(function(){
    var carouselId = '<?= $block->escapeHtmlAttr($carouselId) ?>';
    var $root    = $('#' + carouselId);
    var $viewport= $root.find('.rp-viewport');
    var $track   = $root.find('.rp-track');
    var $prev    = $root.find('.rp-prev');
    var $next    = $root.find('.rp-next');

    if (!$root.length) return;

    function gap() {
      // Read computed gap (fallback 16)
      var g = parseInt(window.getComputedStyle($track[0]).columnGap || window.getComputedStyle($track[0]).gap || '16', 10);
      return isNaN(g) ? 16 : g;
    }
    function cardWidth() {
      var $first = $root.find('.rp-slide').first();
      return $first.length ? $first.outerWidth(true) : 330;
    }
    function step() {
      // Scroll by one full “page” of visible cards
      var cw = cardWidth(), g = gap();
      var per = Math.max(1, Math.floor($viewport.innerWidth() / (cw + g)));
      return per * (cw + g);
    }
    function updateDisabled() {
      var maxScroll = $track[0].scrollWidth - $viewport.innerWidth() - 1;
      $prev.prop('disabled', $track[0].scrollLeft <= 0);
      $next.prop('disabled', $track[0].scrollLeft >= maxScroll);
    }

    $prev.on('click', function(){ $track[0].scrollBy({left: -step(), behavior: 'smooth'}); setTimeout(updateDisabled, 300); });
    $next.on('click', function(){ $track[0].scrollBy({left:  step(), behavior: 'smooth'}); setTimeout(updateDisabled, 300); });

    $track.on('scroll', updateDisabled);
    $(window).on('resize', updateDisabled);
    updateDisabled();
  });
});
</script>
<script>
require(['jquery'], function($) {
  var carouselId = '<?= $block->escapeHtmlAttr($carouselId) ?>';

  // FLAG FIX
  $(document).ready(function(){
    $('#' + carouselId + ' .rp-flag').each(function(){
      var code = $(this).data('code');

      if (code) {
        code = code.toLowerCase().trim();

        var flagUrl = 'https://flagcdn.com/w40/' + code + '.png';

        $(this).css({
          'background-image': 'url(' + flagUrl + ')',
          'background-size': 'cover',
          'background-position': 'center',
          'display': 'inline-block'
        });
      }
    });
  });

  // ADD TO QUOTE FIX
  if (!window.__gccQuoteHandlerBound) {
    window.__gccQuoteHandlerBound = true;
    $(document).on('click', '.add-to-quote', function () {
      var button = $(this);
      var productId = button.data('product-id');

      if (!productId) {
        console.log('Product ID missing');
        return;
      }

      $.ajax({
        url: '<?= $block->getUrl("quoterequest/index/create") ?>',
        type: 'POST',
        data: {
          product_id: productId
        },
        showLoader: true,

        success: function (response) {
          button.text('Added');
          button.prop('disabled', true);

          if (response.count !== undefined) {
            $('#quote-counter').text(response.count).show();
          }
        },

        error: function (xhr) {
          console.log(xhr);
          alert('Error while adding to quote');
        }
      });
    });
  }

});

</script>

