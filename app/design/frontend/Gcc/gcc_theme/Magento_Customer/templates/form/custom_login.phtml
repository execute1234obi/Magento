<div class="form-container">
    <h2><?= __('Registered Customers') ?></h2>
    <p class="sign-in-text"><?= __('If you have an account, sign in with your email address.') ?></p>

    <form action="<?= $block->getUrl('customer/account/loginPost') ?>" method="post">
        <?= $block->getBlockHtml('formkey') ?>
       <input type="hidden" name="referer" value="<?= base64_encode($block->getUrl('')) ?>" />

        <div class="form-group">
            <label for="email"><?= __('Email') ?> <span class="required">*</span></label>
            <input type="email" id="email" name="login[username]" required />
        </div>

        <div class="form-group password-container">
            <label for="password"><?= __('Password') ?> <span class="required">*</span></label>
            <input type="password" id="password" name="login[password]" required />
            <!-- Eye icon with slashed eye for hidden -->
            <span class="eye-icon" id="toggle-password">👁️‍🗨️</span>
        </div>

        <div class="forgot-password">
            <a href="{{store url='customer/account/forgotpassword'}}"><?= __('Forgot Your Password?') ?></a>
        </div>

        <br />
        <button type="submit" class="submit-btn"><?= __('Sign In') ?></button>

        <div class="create-account">
            <p><?= __('Creating an account has many benefits') ?>
                <a href="<?= $block->getUrl('customer/account/create') ?>"><?= __('Create Account') ?></a>
            </p>
        </div>
    </form>
</div>

<script>
    const togglePassword = document.getElementById('toggle-password');
    const passwordField = document.getElementById('password');

    togglePassword.addEventListener('click', function () {
        const isPassword = passwordField.type === 'password';
        passwordField.type = isPassword ? 'text' : 'password';
        togglePassword.textContent = isPassword ? '👁️' : '👁️‍🗨️'; // Show / slashed eye
    });
</script>
