<div class="form-container">
    <h2>Registered Customers</h2>
    <p class="sign-in-text">If you have an account, sign in with your email address.</p>

    <!-- ✅ Use Magento login post action -->
    <form action="<?= $block->getUrl('customer/account/loginPost') ?>"
 method="post">
        <!-- Magento form key required -->
        <input type="hidden" name="form_key" value="{{form_key}}" />

        <div class="form-group">
            <label for="email">Email <span class="required">*</span></label>
            <input type="email" id="email" name="login[username]" required />
        </div>

        <div class="form-group password-container">
            <label for="password">Password <span class="required">*</span></label>
            <input type="password" id="password" name="login[password]" required />
            <span class="eye-icon" id="toggle-password"><i class="fas fa-eye"></i></span>
        </div>

        <!-- Forgot Password -->
        <div class="forgot-password">
            <a href="{{store url='customer/account/forgotpassword'}}">Forgot Your Password?</a>
        </div>

        <br/>
        <button type="submit" class="submit-btn">Sign In</button>

        <!-- Create Account -->
        <div class="create-account">
            <p>Creating an account has many benefits
                <a href="<?= $block->getUrl('customer/account/create') ?>">Create Account</a>
            </p>
        </div>
    </form>
</div>

<script>
    const togglePassword = document.getElementById('toggle-password');
    const passwordField = document.getElementById('password');

    togglePassword.addEventListener('click', function() {
        const type = passwordField.type === 'password' ? 'text' : 'password';
        passwordField.type = type;
    });
</script>
