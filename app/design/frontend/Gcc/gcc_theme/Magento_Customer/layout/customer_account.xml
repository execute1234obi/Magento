<page xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
      xsi:noNamespaceSchemaLocation="urn:magento:framework:View/Layout/etc/page_configuration.xsd">
    <head>
        <css src="css/customer-dashboard.css"/>
        <style>
        
        body.customer-account-index .page-main,
        body.customer-account .page-main {
            padding-top: 160px !important;
        }

        @media (max-width: 768px) {
            body.customer-account-index .page-main,
            body.customer-account .page-main {
                padding-top: 140px !important;
            }
        }

        @media (max-width: 480px) {
            body.customer-account-index .page-main,
            body.customer-account .page-main {
                padding-top: 120px !important;
            }
        }
        </style>
    </head>
    <body>
        <referenceBlock name="customer_account_navigation">
    
    <!-- Stored Payment Methods -->
     <!-- Remove Stored Payment Methods -->
            <referenceBlock name="customer-account-navigation-my-credit-cards-link" remove="true"/>

    <!-- My Reviews -->
     <!-- Remove My Shop Reviews -->
            <referenceBlock name="customer-account-navigation-vnecoms-review-link" remove="true"/>
    <!-- My Credit (custom module - name check karna padega) -->
     <!-- Remove My Credit -->
            <referenceBlock name="customer-account-navigation-vnecoms-credit-link" remove="true"/>
 <!-- Remove My product review-->
             <referenceBlock name="customer-account-navigation-product-reviews-link" remove="true"/>

</referenceBlock>
        <referenceBlock name="sidebar.main.account_nav" template="Magento_Theme::html/account-nav.phtml"/>
    </body>
</page>
