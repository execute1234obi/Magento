<?xml version="1.0"?>
<page layout="empty" xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
      xsi:noNamespaceSchemaLocation="urn:magento:framework:View/Layout/etc/page_configuration.xsd">
    <body>
        <referenceContainer name="page.wrapper">
            <container name="page.header" as="header" before="main.content"/>
            <container name="main.content" as="main" htmlTag="main" htmlId="maincontent" htmlClass="page-main">
                <container name="columns" as="columns" htmlTag="div" htmlClass="columns">
                    <container name="main" as="main" htmlTag="div" htmlClass="column main">
                        <block class="Magento\Framework\View\Element\Template"
                               name="vendor.full.profile"
                               template="Vnecoms_VendorsPage::profile.phtml" />
                    </container>
                </container>
            </container>
            <container name="page.footer" as="footer" htmlTag="footer" htmlClass="page-footer">
                <block class="Magento\Theme\Block\Html\Footer" name="footer" template="Magento_Theme::html/footer.phtml"/>
            </container>
        </referenceContainer>
    </body>
</page>