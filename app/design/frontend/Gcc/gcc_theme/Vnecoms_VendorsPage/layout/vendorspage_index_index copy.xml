<?xml version="1.0"?>
<page xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" layout="1column" xsi:noNamespaceSchemaLocation="urn:magento:framework:View/Layout/etc/page_configuration.xsd">
    <body>
        <referenceContainer name="sidebar.main" remove="true"/>
        <referenceContainer name="sidebar.additional" remove="true"/>

        <attribute name="class" value="vendor-home-page"/>

        <referenceContainer name="page.top">            
            <container name="vendor.home.banner.container" htmlTag="div" htmlClass="vendor-home-banner" before="vendor.profile.top">
                <block class="Vnecoms\VendorsPage\Block\Home\Banner" name="vendor.home.banner" template="Vnecoms_VendorsPage::home/banner.phtml" before="vendor.profile.top">
                    <block class="Vnecoms\Vendors\Block\Profile\Logo" name="vendor.menu.logo" as="small_logo" template="Vnecoms_Vendors::profile/logo.phtml">
                        <block class="Vnecoms\VendorsPage\Block\Profile\Link" name="vendor.menu.logo.link" />
                        <arguments>
                            <argument name="logo_width" xsi:type="number">75</argument>
                            <argument name="logo_height" xsi:type="number">75</argument>
                            <argument name="keep_transparency" xsi:type="boolean">true</argument>
                        </arguments>
                    </block>
                </block>
            </container>
            <block class="Vnecoms\VendorsPage\Block\Menu" name="vendor.menu.top" template="Vnecoms_VendorsPage::menu.phtml" after="vendor.profile.top">
                <container name="top_menu_before" />
                <container name="top_menu_after" />
                
                <action method="addLink" ifconfig="vendors/vendorspage/show_about">
                    <argument name="label" translate="true" xsi:type="string">About</argument>
                    <argument name="title" translate="true" xsi:type="string">About</argument>
                    <argument name="url" xsi:type="string">#vendor-about</argument>
                    <argument name="sort_order" xsi:type="number">10</argument>
                </action>
                <action method="addLink" ifconfig="vendors/vendorspage/show_contactinfo">
                    <argument name="label" translate="true" xsi:type="string">Contact Information</argument>
                    <argument name="title" translate="true" xsi:type="string">Contact Information</argument>
                    <argument name="url" xsi:type="string">#vendor-contact</argument>
                    <argument name="sort_order" xsi:type="number">30</argument>
                </action>
                <action method="addLink" ifconfig="vendors/vendorspage/show_certificates">
                    <argument name="label" translate="true" xsi:type="string">Certificates</argument>
                    <argument name="title" translate="true" xsi:type="string">Certificates</argument>
                    <argument name="url" xsi:type="string">#vendor-certificates</argument>
                    <argument name="sort_order" xsi:type="number">40</argument>
                </action>
                <action method="addLink" ifconfig="vendors/vendorspage/show_catalog">
                    <argument name="label" translate="true" xsi:type="string">Catalog</argument>
                    <argument name="title" translate="true" xsi:type="string">Catalog</argument>
                    <argument name="url" xsi:type="string">#vendor-catalogpdf</argument>
                    <argument name="sort_order" xsi:type="number">50</argument>
                </action>
                <action method="addLink" ifconfig="vendors/vendorspage/show_location">
                    <argument name="label" translate="true" xsi:type="string">Location</argument>
                    <argument name="title" translate="true" xsi:type="string">Location</argument>
                    <argument name="url" xsi:type="string">#vendor-locationmap</argument>
                    <argument name="sort_order" xsi:type="number">60</argument>
                </action>
                <action method="addLink">
                    <argument name="label" translate="true" xsi:type="string">Reviews</argument>
                    <argument name="title" translate="true" xsi:type="string">custom  Reviews</argument>
                    <argument name="url" xsi:type="string">#customvendor-reviews</argument>
                    <argument name="sort_order" xsi:type="number">100</argument>
                </action>
            </block>
        </referenceContainer>
        
        <referenceContainer name="content">
            <container name="vendor.home.about.container" htmlTag="div" htmlClass="vendor-home-about">
                <block class="Vnecoms\VendorsPage\Block\Home\About" name="vendor.home.about" template="Vnecoms_VendorsPage::home/about.phtml" />
            </container>
            
            <container name="vendor.home.items.container" htmlTag="div" htmlClass="vendor-home-items">
                <block class="Vnecoms\VendorsPage\Block\Product" name="vendor.products" template="Vnecoms_VendorsPage::products.phtml">
                    <block class="Vnecoms\VendorsPage\Block\Home\ListProduct" name="credit.products.list" as="product_list" template="Magento_Catalog::product/list.phtml">
                        <container name="category.product.list.additional" as="additional" />
                        <block class="Magento\Framework\View\Element\RendererList" name="category.product.type.details.renderers" as="details.renderers">
                            <block class="Magento\Framework\View\Element\Template" as="default"/>
                        </block>
                        <block class="Vnecoms\VendorsPage\Block\Home\ProductList\Toolbar" name="product_list_toolbar" template="Vnecoms_VendorsPage::home/product/list/toolbar.phtml">
                            <block class="Magento\Theme\Block\Html\Pager" name="product_list_toolbar_pager"/>
                        </block>
                        <action method="setToolbarBlockName">
                            <argument name="name" xsi:type="string">product_list_toolbar</argument>
                        </action>
                    </block>
                </block>
            </container>
            
            <!-- <container name="vendor.home.contact.container" htmlTag="div" htmlClass="vendor-home-contactinfo">
                <block class="Vnecoms\VendorsPage\Block\Home\Contact" name="vendor.home.contact" template="Vnecoms_VendorsPage::home/contact.phtml" />
            </container> -->
            
            <!-- <container name="vendor.home.certificates.container" htmlTag="div" htmlClass="vendor-home-certificates">
                <block class="Vnecoms\VendorsPage\Block\Home\Certificates" name="vendor.home.certificates" template="Vnecoms_VendorsPage::home/certificates.phtml" />
            </container> -->
            
            <!-- <container name="vendor.home.catalog.container" htmlTag="div" htmlClass="vendor-home-catalog">
                <block class="Vnecoms\VendorsPage\Block\Home\Catalog" name="vendor.home.catalog" template="Vnecoms_VendorsPage::home/catalog.phtml" />
            </container>
            
            <container name="vendor.home.locationmap.container" htmlTag="div" htmlClass="vendor-home-locationmap">
                <block class="Vnecoms\VendorsPage\Block\Home\Map" name="vendor.home.locationmap" template="Vnecoms_VendorsPage::home/location-map.phtml" />
            </container>
            
            <container name="vendor.home.review.container" htmlTag="div" htmlClass="vendor-home-review">
                <block class="Business\VendorsReview\Block\Form" name="vendor.home.businessreviewform" template="Business_VendorsReview::form.phtml" />
            </container> -->
        </referenceContainer>
    </body>
</page>