            ->addAttributeToFilter('visibility', ['neq' => \Magento\Catalog\Model\Product\Visibility::VISIBILITY_NOT_VISIBLE])
            ->setPageSize(10);

        $_imageHelper = $this->helper(\Magento\Catalog\Helper\Image::class);
        ?>

        <?php if ($collection->getSize()): ?>
            <?php foreach ($collection as $product): ?>
                <div class="border rounded-lg shadow-sm p-4 hover:shadow-md transition">
                    <a href="<?= $product->getProductUrl() ?>">
                        <?php
                        $imageUrl = $_imageHelper->init($product, 'category_page_grid')->getUrl();
                        ?>
                        <img src="<?= $imageUrl ?>"
                             alt="<?= $block->escapeHtml($product->getName()) ?>"
                             class="w-full h-40 object-contain"/>

                        <h3 class="text-sm font-medium mt-2">
                            <?= $block->escapeHtml($product->getName()) ?>
                        </h3>
                    </a>
                    <p class="text-blue-600 font-semibold mt-1">
                        <?= $block->getPriceHtml($product) ?>
                    </p>
                </div>
            <?php endforeach; ?>
        <?php else: ?>
            <p>No products found for this vendor.</p>
        <?php endif; ?>
