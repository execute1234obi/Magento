// Vendor data
$objectManager = \Magento\Framework\App\ObjectManager::getInstance();
$vendorFactory = $objectManager->get(\Vnecoms\Vendors\Model\VendorFactory::class);
$vendorParam = $block->getRequest()->getParam('vendor_id');
$vendorId = (int) str_replace('v', '', $vendorParam);
$vendor = $vendorFactory->create()->load($vendorId);

$mediaUrl = $block->getBaseUrl(\Magento\Framework\UrlInterface::URL_TYPE_MEDIA) ."pub/media/";
$logoPath = $vendor->getData('upload_logo');
$logoUrl = $logoPath ? $mediaUrl . $logoPath : '';

function showData($data) {
    return $data ? htmlspecialchars($data) : '-';
}

$name = $vendor->getData('company') ?: $vendor->getData('b_name');
$businessCategory = $vendor->getData('business_category');
$description = $vendor->getData('business_descriptions');
$contactName = $vendor->getData('c_name');
$email = $vendor->getData('b_email');
$telephone = $vendor->getData('telephone');
$street = $vendor->getData('street');
$city = $vendor->getData('city');
$region = $vendor->getData('region');
$postcode = $vendor->getData('postcode');
$country = $vendor->getData('country_id');
$fax = $vendor->getData('fax');
$certificatePath = $vendor->getData('certificate');
