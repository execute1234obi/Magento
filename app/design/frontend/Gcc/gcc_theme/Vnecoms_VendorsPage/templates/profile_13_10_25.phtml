  <nav class="u-pagination" aria-label="Product pagination">
    <!-- First -->
    <a class="u-page <?= $currentPage == 1 ? 'is-disabled' : '' ?>" href="<?= $currentPage == 1 ? 'javascript:void(0)' : $pageUrl(1) ?>" aria-label="First" tabindex="<?= $currentPage == 1 ? '-1' : '0' ?>">«</a>

    <!-- Prev -->
    <a class="u-page <?= $currentPage == 1 ? 'is-disabled' : '' ?>" href="<?= $currentPage == 1 ? 'javascript:void(0)' : $pageUrl($currentPage - 1) ?>" aria-label="Previous" tabindex="<?= $currentPage == 1 ? '-1' : '0' ?>">‹</a>

    <!-- Leading ellipsis -->
    <?php if ($start > 1): ?>
      <a class="u-page" href="<?= $pageUrl(1) ?>">1</a>
      <?php if ($start > 2): ?><span class="u-ellipsis">…</span><?php endif; ?>
    <?php endif; ?>

    <!-- Number window -->
    <?php for ($i = $start; $i <= $end; $i++): ?>
      <a class="u-page <?= $i == $currentPage ? 'is-active' : '' ?>" href="<?= $i == $currentPage ? 'javascript:void(0)' : $pageUrl($i) ?>" aria-current="<?= $i == $currentPage ? 'page' : 'false' ?>"><?= $i ?></a>
    <?php endfor; ?>

    <!-- Trailing ellipsis -->
    <?php if ($end < $totalPages): ?>
      <?php if ($end < $totalPages - 1): ?><span class="u-ellipsis">…</span><?php endif; ?>
      <a class="u-page" href="<?= $pageUrl($totalPages) ?>"><?= $totalPages ?></a>
    <?php endif; ?>

    <!-- Next -->
    <a class="u-page <?= $currentPage == $totalPages ? 'is-disabled' : '' ?>" href="<?= $currentPage == $totalPages ? 'javascript:void(0)' : $pageUrl($currentPage + 1) ?>" aria-label="Next" tabindex="<?= $currentPage == $totalPages ? '-1' : '0' ?>">›</a>

