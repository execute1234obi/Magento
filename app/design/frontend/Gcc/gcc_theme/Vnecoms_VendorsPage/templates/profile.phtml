}

/* create the underline, initially hidden */
.tab-link::after{
  content:"";
  position:absolute;
  left:0;
  bottom:-3px;            /* was -12px – moves the blue line up, nearer to the text */
  height:3px;
  width:0;
  background:#1f3ea6;
  border-radius:2px;
  transition: width .2s ease;
}

/* active underline spans the text width (not the whole row) */
.tab-link.active::after{
  width: 100%;
}

/* optional hover underline for non-active tabs */
.tab-link:not(.active):hover::after{
  width: 100%;
  opacity:.65;
}

