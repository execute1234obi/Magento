    <!-- Number window -->
    <?php for ($i = $start; $i <= $end; $i++): ?>
      <a class="u-page <?= $i == $currentPage ? 'is-active' : '' ?>" href="<?= $i == $currentPage ? 'javascript:void(0)' : $pageUrl($i) ?>" aria-current="<?= $i == $currentPage ? 'page' : 'false' ?>"><?= $i ?></a>
    <?php endfor; ?>

    <!-- Trailing ellipsis -->
    <?php if ($end < $totalPages): ?>
      <?php if ($end < $totalPages - 1): ?><span class="u-ellipsis">…</span><?php endif; ?>
      <a class="u-page" href="<?= $pageUrl($totalPages) ?>"><?= $totalPages ?></a>
    <?php endif; ?>

    <!-- Next -->
    <a class="u-page <?= $currentPage == $totalPages ? 'is-disabled' : '' ?>" href="<?= $currentPage == $totalPages ? 'javascript:void(0)' : $pageUrl($currentPage + 1) ?>" aria-label="Next" tabindex="<?= $currentPage == $totalPages ? '-1' : '0' ?>">›</a>

    <!-- Last -->
    <a class="u-page <?= $currentPage == $totalPages ? 'is-disabled' : '' ?>" href="<?= $currentPage == $totalPages ? 'javascript:void(0)' : $pageUrl($totalPages) ?>" aria-label="Last" tabindex="<?= $currentPage == $totalPages ? '-1' : '0' ?>">»</a>
  </nav>
<?php endif; ?>
</div>



