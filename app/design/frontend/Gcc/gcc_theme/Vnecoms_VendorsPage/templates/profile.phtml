use Magento\Framework\App\ObjectManager;
use Magento\Directory\Helper\Data as DirectoryHelper;

// Vendor data
$objectManager = \Magento\Framework\App\ObjectManager::getInstance();
$vendorFactory = $objectManager->get(\Vnecoms\Vendors\Model\VendorFactory::class);
$vendorParam = $block->getRequest()->getParam('vendor_id'); // gcc1

$collection = $vendorFactory->create()->getCollection();
$collection->addAttributeToSelect('*');
$collection->addFieldToFilter('vendor_id', $vendorParam);
$collection->addFieldToFilter(
    'status',
    \Vnecoms\Vendors\Model\Vendor::STATUS_APPROVED
);
$collection->setPageSize(1);

$vendor = $collection->getFirstItem();
$vendorId = (int) $vendor->getId();

$storemediaUrl = $block->getBaseUrl(\Magento\Framework\UrlInterface::URL_TYPE_MEDIA) ."pub/media/";
$mediaUrl = preg_replace('#/(en|ar|default)(/|$)#i', '/', $storemediaUrl);
$logoPath = $vendor->getData('upload_logo');
$logoUrl = $logoPath ? $mediaUrl . $logoPath : '';
$varify =$mediaUrl."wysiwyg/VerificationBadgeIcon.png";
function showData($data) {
    return $data ? htmlspecialchars($data) : '-';
}

$name = $vendor->getData('b_name') ?: $vendor->getData('b_name');
//business category fetching
$eavConfig = $objectManager->get(\Magento\Eav\Model\Config::class);
$attribute = $eavConfig->getAttribute(\Vnecoms\Vendors\Model\Vendor::ENTITY, 'business_category');
$businessCategoryId = $vendor->getData('business_category');
$businessCategoryLabel = $attribute->getSource()->getOptionText($businessCategoryId);
//echo "cate".$businessCategoryLabel;
// Website (try common keys, then fallback to VendorsConfig)
$websiteRaw =
    $vendor->getData('website') ?:
    $vendor->getData('b_website') ?:
    (function() use ($objectManager, $vendorId) {
        $cfg = $objectManager->create(\Vnecoms\VendorsConfig\Model\ResourceModel\Config\Collection::class)
            ->addFieldToFilter('vendor_id', $vendorId)
            // adjust if your path differs
            ->addFieldToFilter('path', 'page/general/website')
            ->setPageSize(1);
        return $cfg->getSize() ? $cfg->getFirstItem()->getValue() : null;
    })();

// Normalize (add scheme if vendor typed without http/https)
$website = $websiteRaw
    ? (preg_match('#^https?://#i', $websiteRaw) ? $websiteRaw : 'https://' . $websiteRaw)
    : null;

$description = $vendor->getData('business_descriptions');
$contactName = $vendor->getData('c_name');
$email = $vendor->getData('b_email');
$telephone = $vendor->getData('b_ph');
$street = $vendor->getData('street');
$city = $vendor->getData('city');
$region = $vendor->getData('region');
$postcode = $vendor->getData('postcode');
//for country name
$objectManager = \Magento\Framework\App\ObjectManager::getInstance();
$countryFactory = $objectManager->get(\Magento\Directory\Model\CountryFactory::class);

// Get the country code from vendor custom attribute
$countryCode = $vendor->getData('country_id'); // e.g., 'US'

// Load country model by code
$country_id = $countryFactory->create()->loadByCode($countryCode);
$country = $country_id->getName(); 
//$country = $vendor->getData('country_id');
//$fax = $vendor->getData('fax');
$certificatePath = $vendor->getData('certificate');
