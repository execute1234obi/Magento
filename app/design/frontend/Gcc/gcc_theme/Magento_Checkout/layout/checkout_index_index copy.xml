                       as="customCheckoutHeader"
                       htmlTag="header"
                       htmlClass="custom-page-header">
                <block class="Gcc\Gcc_theme\Block\CustomHeader"
                       name="custom.checkout.header.block"
                       template="Magento_Theme::html/custom_header.phtml"
                       cacheable="false"/>
            </container>
        </referenceContainer> -->

    </body>
</page>
