<?xml version="1.0"?>
<page xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
      xsi:noNamespaceSchemaLocation="urn:magento:framework:View/Layout/etc/page_configuration.xsd">
    <body>
        <referenceBlock name="mst.search.result">
            <block class="Custom\SearchExtended\Block\Index\Vendors"
                   name="vnecoms_vendors"
                   template="Custom_SearchExtended::index/vnecoms/vendors/vendors.phtml">
                <arguments>
                    <argument name="show_always" xsi:type="boolean">true</argument>
                </arguments>
                <!-- START: The Pager block that was missing -->
                <block class="Magento\Theme\Block\Html\Pager" name="pager" as="pager">
                    <arguments>
                        <argument name="template" xsi:type="string">Magento_Theme::html/pager.phtml</argument>
                    </arguments>
                </block>
                <!-- END: The Pager block that was missing -->
            </block>
        </referenceBlock>
        
        <referenceBlock name="mst.search.result.product">
            <arguments>
                <argument name="show_always" xsi:type="boolean">true</argument>
            </arguments>
        </referenceBlock>
    </body>
</page>

