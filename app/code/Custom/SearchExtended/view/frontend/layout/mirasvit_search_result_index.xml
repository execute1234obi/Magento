<?xml version="1.0"?>
<page xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" layout="2columns-left" xsi:noNamespaceSchemaLocation="urn:magento:framework:View/Layout/etc/page_configuration.xsd">
    <body>
    <!-- Add sidebars -->
<referenceContainer name="sidebar.main">
    <!-- Product (default) sidebar -->
    <container name="product.sidebar.wrapper" htmlTag="div" htmlId="default-sidebar" htmlClass="sidebar-wrapper">
        <block class="Magento\LayeredNavigation\Block\Navigation" name="catalog.leftnav" template="Magento_LayeredNavigation::layer/view.phtml"/>
    </container>

    <!-- Vendor (custom) sidebar -->
    <container name="vendor.sidebar.wrapper" htmlTag="div" htmlId="vendor-sidebar1" htmlClass="sidebar-wrapper" after="product.sidebar.wrapper">
        <block class="Custom\SearchExtended\Block\Sidebar\VendorSidebar" name="custom.vendor.sidebar" template="Custom_SearchExtended::sidebar/vendor.phtml"/>
    </container>
</referenceContainer>


        <referenceBlock name="mst.search.result">
            <!-- This block explicitly defines the Vendors tab and ensures it is always present. -->
            <block class="Custom\SearchExtended\Block\Index\Vendors" name="search.result.list.vendors" before="-" cacheable="false">
                <arguments>
                    <argument name="title" xsi:type="string" translate="true">Vendors</argument>
                    <argument name="template" xsi:type="string">Custom_SearchExtended::index/vendors.phtml</argument>
                    <argument name="show_always" xsi:type="boolean">true</argument>
                </arguments>
            </block>
        </referenceBlock>

        <!-- Use a different reference to ensure the product block is always configured. -->
        <referenceBlock name="mst.search.result.product">
            <arguments>
                <argument name="title" xsi:type="string" translate="true">Products</argument>
                <argument name="show_always" xsi:type="boolean">true</argument>
            </arguments>
        </referenceBlock>
    </body>
</page>
