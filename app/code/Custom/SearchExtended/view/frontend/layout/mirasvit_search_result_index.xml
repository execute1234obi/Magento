<?xml version="1.0"?>
<page xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" layout="1column" xsi:noNamespaceSchemaLocation="urn:magento:framework:View/Layout/etc/page_configuration.xsd">
    <body>
        <referenceBlock name="mst.search.result">
            <!-- This block explicitly defines the Vendors tab and ensures it is always present. -->
            <block class="Custom\SearchExtended\Block\Index\Vendors" name="search.result.list.vendors" before="-" cacheable="false">
                <arguments>
                    <argument name="title" xsi:type="string" translate="true">Vendors</argument>
                    <argument name="template" xsi:type="string">Custom_SearchExtended::index/vnecoms/vendors/vendors.phtml</argument>
                    <argument name="show_always" xsi:type="boolean">true</argument>
                </arguments>
                <block class="Magento\Theme\Block\Html\Pager"
                       name="pager"
                       as="pager">
                    <arguments>
                        <argument name="template" xsi:type="string">Magento_Theme::html/pager.phtml</argument>
                    </arguments>
                    </block>
                </block>
        </referenceBlock>

        <!-- Use a different reference to ensure the product block is always configured. -->
        <referenceBlock name="mst.search.result.product">
            <arguments>
                <argument name="title" xsi:type="string" translate="true">Products</argument>
                <argument name="show_always" xsi:type="boolean">true</argument>
            </arguments>
        </referenceBlock>
    </body>
</page>
