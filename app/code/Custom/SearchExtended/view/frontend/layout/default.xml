<?xml version="1.0"?>
<page xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
      xsi:noNamespaceSchemaLocation="urn:magento:framework:View/Layout/etc/page_configuration.xsd">
    <body>
        <referenceBlock name="mst.search.result">
            <!-- <block class="Custom\SearchExtended\Block\Vnecoms\Vendors" -->
            <block class="Custom\SearchExtended\Block\Index\Vendors"
                   name="vnecoms_vendors"
                   template="Custom_SearchExtended::index/vnecoms/vendors/vendors.phtml"/>
        </referenceBlock>

         <!-- This is the block for the autocomplete dropdown. -->
      <referenceContainer name="mst.search.autocomplete">
    <block class="Custom\SearchExtended\Block\Index\Vendors"
           name="autocomplete.vendors"
           template="Custom_SearchExtended::autocomplete/vendors.phtml"
           group="vnecoms_vendors"/>
</referenceContainer>

    </body>
</page>