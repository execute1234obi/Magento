      #vendors {
       margin: 0; /* Changed from auto to 0 to align left */
       padding-top: 15px; /* Added padding to the top */

    }
    .vendor-card {
      display: flex; justify-content: space-between; align-items: center;
      background: #fff; border-radius: 10px; padding: 20px;
