<?php if ($vendors && $vendors->getSize() > 0): ?>
  <div id="vendors" class="tab-content active">
    <?php foreach ($vendors as $vendor): ?>
       <?php
                // Get country and category from the vendor
                $country = $vendor->getData('country_id'); // Assuming 'country' is the field name
                $category = $vendor->getData('business_category');// Assuming 'category' is the field name
                $website = $vendor->getData('website');
                ?>
      <div class="vendor-card">
        <div class="vendor-left">
           <?php
           $vendorurl= $this->getBaseUrl() . 'shop/v' . $vendor->getId() 
            ?>
            <a href="<?= $block->escapeUrl($vendorurl) ?>">

          <div class="vendor-logo">
             <?php
                    $logo = $vendor->getData('upload_logo');
                    if ($logo):
                        $mediaUrl = $block->getUrl('pub/media/') . $logo;
                    ?>
                      <img src="<?= $block->escapeUrl($mediaUrl); ?>" alt="<?= $block->escapeHtml($block->getVendorName($vendor)); ?>">
                    <?php endif; ?>
            </div>
          </a>
          <div class="vendor-info">
            <h3><?= $block->escapeHtml($block->getVendorName($vendor)); ?></h3>
            <div class="vendor-meta"><?= $block->escapeHtml($category); ?></div>
            <div class="vendor-desc">
              <?= $block->escapeHtml($block->getBusinessDescriptions($vendor)); ?>
            </div>
          </div>
        </div>
        <div class="vendor-right">
          <div class="vendor-country"><img src="https://flagcdn.com/w20/cn.png"> <?= $block->escapeHtml($country); ?></div>
          <a href="<?= $block->escapeHtml($website); ?>">Visit Website ↗</a>
        </div>
      </div>
      <?php endforeach; ?>
      <div class="pagination">
          <?= $block->getPager(); ?>
        <button>Previous</button>
        <button class="active">1</button>
        <button>2</button>
        <button>Next</button>
      </div>
    </div>
  <?php else: ?>
    <div class="p-6 text-center text-gray-600">
        <p><?= $block->escapeHtml(__("We can't find vendors matching the selection.")) ?></p>
    </div>
<?php endif; ?>
  