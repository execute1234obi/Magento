<?php if ($vendors && $vendors->getSize() > 0): ?>
  <div id="vendors" class="tab-content active">
    <?php foreach ($vendors as $vendor): ?>
      <?php
        $country = $vendor->getData('country_id');
        $category = $vendor->getData('business_category');
        $website = $vendor->getData('website');
        $vendorUrl = $block->getBaseUrl() . 'shop/' . $vendor->getData('vendor_id');
        $logo = $vendor->getData('upload_logo');
       // $mediaUrl = $logo ? $block->getUrl('pub/media/') . $logo : '';
       $storemediaUrl = $block->getBaseUrl(\Magento\Framework\UrlInterface::URL_TYPE_MEDIA) ."pub/media/";
$mediaUrl = preg_replace('#/(en|ar|default)(/|$)#i', '/', $storemediaUrl);
$mediaUrl = $logo ? $mediaUrl . $logo : '';
      ?>
      <a href="<?= $block->escapeUrl($vendorUrl) ?>" class="vendor-card">
        <div class="vendor-left">
          <div class="vendor-logo">
            <?php if ($logo): ?>
              <img src="<?= $block->escapeUrl($mediaUrl); ?>" alt="<?= $block->escapeHtml($block->getVendorName($vendor)); ?>">
            <?php endif; ?>
          </div>
          <div class="vendor-info">
            <h3><?= ucfirst($block->escapeHtml($block->getVendorName($vendor))); ?></h3>
            <div class="vendor-meta"><?= $block->escapeHtml($category); ?></div>
            <div class="vendor-desc"><?= $block->escapeHtml($block->getBusinessDescriptions($vendor)); ?></div>
          </div>
        </div>
        <div class="vendor-right">
          <div class="vendor-country">
            <img class="country-flag" src="https://flagcdn.com/<?= strtolower($block->escapeHtml($country ?: 'N/A')) ?>.svg" alt="<?= strtolower($block->escapeHtml($country ?: 'N/A')) ?>"></span> <?= $block->escapeHtml($country); ?>
          </div>
          <span class="visit-link"><?= __("Visit Website") ?> ↗</span>
        </div>
      </a>
    <?php endforeach; ?>

    <!-- Dynamic Pagination -->
    <div class="pager">
      <?= $pager ?>
    </div>
  </div>
<?php else: ?>
  <div class="p-6 text-center text-gray-600">
    <p><?= $block->escapeHtml(__("We can't find vendors matching the selection.")) ?></p>
  </div>
<?php endif; ?>
<?php if ($vendors && $vendors->getSize() > 0): ?>
  <style>
    .message.notice {
      display: none;
