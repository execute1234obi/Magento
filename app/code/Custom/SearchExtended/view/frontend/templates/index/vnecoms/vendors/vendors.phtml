<?php if ($vendors && $vendors->getSize() > 0): ?>
    <div id="vendors" class="search-vendor-list">
        <?php foreach ($vendors as $vendor): ?>
            <?php
            $vendorId = (int) $vendor->getId();
            $vendorUrl = $this->getBaseUrl() . 'shop/v' . $vendorId;
            $vendorName = trim((string) $block->getVendorName($vendor));
            $countryCode = trim((string) $vendor->getData('country_id'));
            $countryName = trim((string) $block->getCountryName($countryCode));
            $countryFlag = trim((string) $block->getCountryFlagUrl($countryCode));
            $businessType = trim((string) $block->getBusinessTypeLabel($vendor));
            $description = trim((string) $block->getBusinessDescriptions($vendor));
            $websiteUrl = $block->getWebsiteUrl($vendor) ?: $vendorUrl;
            $logo = trim((string) $vendor->getData('upload_logo'));
            $logoPath = $logo !== ''
                ? preg_replace('#/+#', '/', preg_replace('#^(?:/?pub/media/|/?media/)#i', '', $logo))
                : '';
            $mediaUrl = $logoPath !== ''
                ? rtrim($mediaBaseUrl, '/') . '/' . ltrim((string) $logoPath, '/')
                : $logoPlaceholder;
            $isVerified = $block->isVerifiedVendor($vendorId);
            $isExternalWebsite = $websiteUrl !== $vendorUrl;
            ?>

            <article class="search-vendor-card">
                <div class="search-vendor-card__main">
                    <a class="search-vendor-card__logo" href="<?= $block->escapeUrl($vendorUrl) ?>" aria-label="<?= $block->escapeHtmlAttr($vendorName) ?>">
                        <img src="<?= $block->escapeUrl($mediaUrl) ?>"
                             alt="<?= $block->escapeHtmlAttr($vendorName) ?>"
                             loading="lazy"
                             decoding="async"
                             onerror="this.onerror=null;this.src='<?= $block->escapeUrl($logoPlaceholder) ?>';">
                    </a>

                    <div class="search-vendor-card__body">
                        <div class="search-vendor-card__title-row">
                            <a class="search-vendor-card__title-link"
                               href="<?= $block->escapeUrl($vendorUrl) ?>">
                                <?= $block->escapeHtml($vendorName) ?>
                            </a>

                            <?php if ($isVerified): ?>
                                <span class="search-vendor-card__verified"
                                      title="<?= $block->escapeHtmlAttr(__('Verified vendor')) ?>"
                                      aria-label="<?= $block->escapeHtmlAttr(__('Verified vendor')) ?>">&#10003;</span>
                            <?php endif; ?>
                        </div>

                        <?php if ($businessType !== ''): ?>
                            <div class="search-vendor-card__subtitle">
                                <?= $block->escapeHtml($businessType) ?>
                            </div>
                        <?php endif; ?>

                        <?php if ($description !== ''): ?>
                            <div class="search-vendor-card__description">
                                <?= $block->escapeHtml($description) ?>
                            </div>
                        <?php endif; ?>
                    </div>
                </div>

                <div class="search-vendor-card__aside">
                    <?php if ($countryName !== ''): ?>
                        <div class="search-vendor-card__country">
                            <?php if ($countryFlag !== ''): ?>
                                <img class="search-vendor-card__flag"
                                     src="<?= $block->escapeUrl($countryFlag) ?>"
                                     alt="<?= $block->escapeHtmlAttr($countryName) ?>">
                            <?php endif; ?>
                            <span><?= $block->escapeHtml($countryName) ?></span>
                        </div>
                    <?php endif; ?>

                    <a class="search-vendor-card__button"
                       href="<?= $block->escapeUrl($websiteUrl) ?>"
                       <?php if ($isExternalWebsite): ?>target="_blank" rel="noopener noreferrer"<?php endif; ?>>
                        <?= $block->escapeHtml(__('Visit Website')) ?>
                        <span aria-hidden="true">&#8599;</span>
                    </a>
                </div>
            </article>
        <?php endforeach; ?>

        <div class="search-vendor-pager">
            <?= $block->getPagerHtml(); ?>
        </div>
    </div>
<?php else: ?>
    <div class="search-vendor-empty">
        <p><?= $block->escapeHtml(__("We can't find vendors matching the selection.")) ?></p>
    </div>
<?php endif; ?>
