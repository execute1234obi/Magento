<?php
/** @var \Custom\SearchExtended\Block\Index\Vendors $block */

$vendors = $block->getSearchCollection();
$placeholder = $block->escapeUrl(
    $block->getViewFileUrl('Magento_Catalog::images/product/placeholder/thumbnail.jpg')
);
?>

<style>
  #vendors {
    padding-top: 20px;
  }

  .vendor-results {
    display: flex;
    flex-direction: column;
    gap: 12px;
  }

  .vendor-card {
    display: flex;
    align-items: center;
    gap: 10px;
    width: 100%;
    padding: 12px 12px 12px 8px;
    background: #fff;
    border: 1px solid #e5e7eb;
    border-radius: 12px;
    box-shadow: 0 2px 10px rgba(15, 23, 42, 0.04);
    transition: transform 0.2s ease, box-shadow 0.2s ease;
    text-decoration: none !important;
    color: inherit;
  }

  .vendor-card:hover {
    transform: translateY(-1px);
    box-shadow: 0 8px 18px rgba(15, 23, 42, 0.08);
    text-decoration: none !important;
  }

  .vendor-logo {
    width: 40px;
    height: 40px;
    flex: 0 0 40px;
    display: flex;
    align-items: center;
    justify-content: center;
    overflow: hidden;
    border: 1px solid #e5e7eb;
    border-radius: 8px;
    background: #fff;
  }

  .vendor-logo img {
    width: 100%;
    height: 100%;
    object-fit: contain;
    display: block;
  }

  .vendor-name {
    min-width: 0;
    flex: 1 1 auto;
    overflow: hidden;
    text-overflow: ellipsis;
    white-space: nowrap;
    color: #111827;
    font-size: 15px;
    line-height: 1.4;
    font-weight: 600;
  }

  .vendor-empty {
    padding: 20px;
    background: #fff;
    border: 1px solid #e5e7eb;
    border-radius: 12px;
    color: #6b7280;
  }

  .vendor-pager {
    margin-top: 24px;
  }

  @media (max-width: 768px) {
    .vendor-results {
      gap: 10px;
    }

    .vendor-card {
      padding: 10px 12px;
    }

    .vendor-name {
      font-size: 14px;
    }

    .vendor-pager {
      margin-top: 18px;
    }
  }
</style>

<?php if ($vendors && $vendors->getSize() > 0): ?>
    <div id="vendors" class="vendor-results">
        <?php foreach ($vendors as $vendor): ?>
            <?php
            $vendorUrl = $this->getBaseUrl() . 'shop/v' . $vendor->getId();
            $vendorName = $block->getVendorName($vendor);
            $logo = $vendor->getData('upload_logo');
            $mediaUrl = $logo ? $block->getUrl('pub/media/') . $logo : $placeholder;
            ?>

            <a class="vendor-card" href="<?= $block->escapeUrl($vendorUrl) ?>">
                <span class="vendor-logo">
                    <img src="<?= $block->escapeUrl($mediaUrl) ?>"
                         alt="<?= $block->escapeHtmlAttr($vendorName) ?>">
                </span>

                <span class="vendor-name"><?= $block->escapeHtml($vendorName) ?></span>
            </a>
        <?php endforeach; ?>

        <div class="vendor-pager">
            <?= $block->getPagerHtml(); ?>
        </div>
    </div>
<?php else: ?>
    <div class="vendor-empty">
        <p><?= $block->escapeHtml(__("We can't find vendors matching the selection.")) ?></p>
    </div>
<?php endif; ?>
