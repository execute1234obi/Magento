
<div class="mst-searchautocomplete__item vnecoms_vendors">
    <!-- Check if a logo URL exists and display it -->
    <div data-bind="if: item.upload_logo" class="vendor-logo-wrapper">
        <img data-bind="attr: { src: item.upload_logo, alt: item.name }" class="vendor-logo" />
    </div>

    <!-- The main content container -->
    <div class="vendor-content-wrapper">
        <a data-bind="attr: { href: item.url }">
            <!-- Display the vendor's name -->
            <div class="vendor-name" data-bind="text: item.name"></div>
        </a>
    </div>
</div>

<style>
    /* Add some basic styling to make it look clean */
    .mst-searchautocomplete__item {
        display: flex;
        align-items: center;
        padding: 8px 12px;
        border-bottom: 1px solid #e0e0e0;
    }
    .mst-searchautocomplete__item:hover {
        background-color: #f5f5f5;
    }
    .vendor-logo-wrapper {
        flex-shrink: 0;
        margin-right: 12px;
        width: 40px;
        height: 40px;
    }
    .vendor-logo {
        max-width: 100%;
        max-height: 100%;
        border-radius: 4px;
    }
    .vendor-content-wrapper {
        flex-grow: 1;
        overflow: hidden;
    }
    .vendor-name {
        font-weight: 600;
        color: #333;
        white-space: nowrap;
        overflow: hidden;
        text-overflow: ellipsis;
    }
    /* Add a nice hover effect to the link */
    .vendor-content-wrapper a {
        text-decoration: none;
    }
    .vendor-content-wrapper a:hover .vendor-name {
        text-decoration: underline;
    }
</style>
