    <!-- script for google map  -->

   <script>
function initGoogleMapForVendor() {
    console.log("Map Init Called");

    const mapDiv = document.getElementById("vendor_map_canvas");
    const input = document.getElementById("vendor_address");
    const latField = document.getElementById("vendor_vendor_lat");
    const lngField = document.getElementById("vendor_vendor_lng");

    if (!mapDiv || !input) {
        console.log("Map elements not found");
        return;
    }

    const defaultLocation = { lat: 18.5204, lng: 73.8567 };

    const map = new google.maps.Map(mapDiv, {
        center: defaultLocation,
        zoom: 13
    });

    const marker = new google.maps.Marker({
        map: map,
        position: defaultLocation,
        draggable: true
    });

    const autocomplete = new google.maps.places.Autocomplete(input);

    autocomplete.addListener("place_changed", function () {
        const place = autocomplete.getPlace();
        if (!place.geometry) return;

        map.setCenter(place.geometry.location);
        marker.setPosition(place.geometry.location);

        latField.value = place.geometry.location.lat();
        lngField.value = place.geometry.location.lng();
    });

    marker.addListener("dragend", function () {
        const pos = marker.getPosition();
        latField.value = pos.lat();
        lngField.value = pos.lng();

        console.log("Marker dragged to: ", pos.lat(), pos.lng());

        const mapField = document.getElementById('vendor_map');
        if (mapField) {
            mapField.value = lat + ',' + lng;
        }
        
    });
}
</script>

