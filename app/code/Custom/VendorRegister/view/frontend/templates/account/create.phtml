            function buildStepNav() {
    var stepsNav = $('#cr-nav-container');

    // Step numbers should always start from 1 (even for logged in user)
    var displayStep = 1;

    // Template for each step in navigation
    var template =
        '<li class="cr-nav-step cr-nav-step-<%- realStep %>">' +
            '<div class="cr-nav-step-number"><%- displayStep %></div>' +
            '<div class="cr-nav-step-title"><%- title %></div>' +
            '<div class="cr-nav-bar"></div>' +
        '</li>';

    var html = '<ul class="cr-nav cr-nav-' + $('.cr-step').length + 'cols">';

    $('.cr-step').each(function () {

        // Ignore steps hidden for logged-in users
        if ($(this).hasClass("cr-step-no-display")) {
            return true; // continue
        }

        var stepTitle = $(this).children('.cr-step-title').first().html();
        var realStep = $(this).data('step');

        var navStepTemplate = mageTemplate(template);

        html += navStepTemplate({
            title: stepTitle,
            realStep: realStep,      // actual step
            displayStep: displayStep // shown step numbering
        });

        displayStep++; // increase numbering only for visible steps
    });

    html += '</ul>';

    stepsNav.html(html);
}

            /**
             * Set current step
             */
            function setCurrentStep(step) {
                window.CURRENT_STEP = step;
                $('.cr-nav-step.current').removeClass('current');
                $('.cr-nav-step.complete').removeClass('complete');
                $('.cr-step.cr-step-active').removeClass('cr-step-active');

                $('.cr-nav-step-' + step).addClass('current');
                $('.cr-step-' + step).addClass('cr-step-active');


                for (var i = 1; i < step; i++) {
                    $('.cr-nav-step-' + i).addClass('complete');
                }

                var size = $('.cr-step').length;


                if (step == size) {
                    $('#cr-next-btn').hide();
                    $('.cr-confirm').addClass('complete');
                    $('#cr-submit-btn').css('display', 'inline-block');
                    $('#cr-submit-btn').removeAttr("type").attr("type", "submit");
                } else {
                    $('#cr-next-btn').css('display', 'inline-block');
                    $('.cr-confirm').removeClass('complete');
                    $('#cr-submit-btn').hide();
                    $('#cr-submit-btn').removeAttr("type").attr("type", "button");
                }
                 // ...existing code...
    if (step == 3) {
          addMapFieldsToStep3();

    let retry = setInterval(function () {
        const mapDiv = document.getElementById("vendor_map_canvas");

        if (typeof google !== 'undefined' && mapDiv) {
            initGoogleMapForVendor();
            clearInterval(retry);
        }
    }, 300);
    }
    // ...existing code...
                if (step == window.START_STEP) {
                    $('#cr-previous-btn').hide();
                } else {
                    $('#cr-previous-btn').css('display', 'inline-block');
                }
            }

            /**
             * Next step
             */
            function nextStep() {
                var step = window.CURRENT_STEP + 1;
                if (step > $('.cr-step').length) return;
                var isValid = true;
                $('.cr-step-' + (step - 1)).find('input,textarea,select').each(function () {
                    if (!$(this).is(":visible")) return true;
                    $(this).validation();
                    isValid = isValid && $(this).validation('isValid');
                });
                if (!isValid) return;
                 // Add custom check only when moving from step 4 to 5 for country code By VM
                if (window.CURRENT_STEP === 4) {
                    // Replace these selectors with actual names or IDs
                    var country1 = $('[name="vendor_data[country_code]"]').val();
                        var country3 = $('[name="vendor_data[c_code]"]').val();


                    if (country1 !== country3) {
                        alert('Country Code in Business Information and Business Contact must be the same.');
                        return; // stop going to next step
                    }
                }
                setCurrentStep(step);
            }

            /**
             * Previous step
             */
            function prevousStep() {
                var step = window.CURRENT_STEP - 1;
                if (step <= 0) return;

                setCurrentStep(step);
            }

            buildStepNav();

            setCurrentStep(window.START_STEP);

            $('#cr-next-btn').click(function () {
                nextStep();
            });

            $('#cr-previous-btn').click(function () {
                prevousStep();
            });

            $('.cr-nav-step-number').click(function () {
                if (!$(this).parent().hasClass('complete')) return;
                setCurrentStep(parseInt($(this).html()));
            });
        });
