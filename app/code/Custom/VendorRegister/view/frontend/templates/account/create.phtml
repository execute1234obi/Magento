<script>
require(['jquery'], function ($) {
    $(document).ready(function () {

        // 🌍 intlTelInput ka internal data
        var countryData = window.intlTelInputGlobals.getCountryData();

        function getDialCode(countryIso) {
            var result = countryData.find(function (item) {
                return item.iso2.toUpperCase() === countryIso;
            });

            return result ? + result.dialCode : '';
        }

        $('#vendor_country_id').on('change', function () {
            var country = $(this).val(); // IN, AE, US

            var code = getDialCode(country);

            // ✅ auto fill
            $('#vendor_c_code').val(code);
            $('[name="vendor_data[country_code]"]').val(code);

            console.log("✅ Country:", country, "Code:", code);
        });

        // ✅ page load pe bhi
        $('#vendor_country_id').trigger('change');

    });
});
</script>
<script>
require(['jquery'], function ($) {
