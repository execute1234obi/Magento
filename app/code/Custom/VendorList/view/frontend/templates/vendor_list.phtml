<script>
(function(){
  var root = document.getElementById('vendorsCarousel');
  if(!root) return;

  var track = root.querySelector('.vendors-track');
  var slides = Array.prototype.slice.call(root.querySelectorAll('.vc-slide'));
  var prev = root.querySelector('.vc-btn.prev');
  var next = root.querySelector('.vc-btn.next');
  var pager = root.querySelector('.vc-pagination');
  var currentIndex = 0;

  function slidesPerView(){
    var w = window.innerWidth;
    if (w < 576)  return 1.05;
    if (w < 768)  return 2;
    if (w < 1200) return 3;
    return 4;
  }

  function buildDots(){
    if (!pager) return;
    pager.innerHTML = '';
    slides.forEach(function(_, i){
      var dot = document.createElement('button');
      dot.type = 'button';
      dot.className = 'vc-dot' + (i === currentIndex ? ' active' : '');
      dot.addEventListener('click', function(){ snapTo(i, true); });
      pager.appendChild(dot);
    });
  }

  function updateDots(){
    if (!pager) return;
    var dots = pager.querySelectorAll('.vc-dot');
    for (var d = 0; d < dots.length; d++) {
      dots[d].classList.toggle('active', d === currentIndex);
    }
  }

  function updateActiveSlide(){
    slides.forEach(function(s, i){
      s.classList.toggle('is-active', i === currentIndex);
    });
  }

  function snapTo(i, smooth){
    if (!slides.length) return;
    i = Math.max(0, Math.min(i, slides.length - 1));
    currentIndex = i;
    var s = slides[i];
    var left = s.offsetLeft - track.offsetLeft;
    track.scrollTo({ left: left, behavior: smooth ? 'smooth' : 'auto' });
    updateDots();
    updateActiveSlide();
  }

  function visibleIndex(){
    if (!slides.length) return 0;
    var sl = track.scrollLeft + 8;
    var idx = 0, best = Infinity;
    slides.forEach(function(s, i){
      var dist = Math.abs(s.offsetLeft - sl);
      if (dist < best){ best = dist; idx = i; }
    });
    return idx;
  }

  function layout(){
    if (!slides.length) return;
    var spv = slidesPerView();
    var basis = (100 / spv) + '%';
    slides.forEach(function(s){ s.style.flex = '0 0 ' + basis; });
    buildDots();
    snapTo(Math.min(currentIndex, slides.length - 1), false);
  }

  next.addEventListener('click', function(){ snapTo(currentIndex + 1, true); });
  prev.addEventListener('click', function(){ snapTo(currentIndex - 1, true); });

  track.addEventListener('scroll', function(){
    currentIndex = visibleIndex();
    updateDots();
    updateActiveSlide();
  }, { passive: true });

  window.addEventListener('resize', layout);

  root.addEventListener('keydown', function(e){
    if (e.key === 'ArrowRight') next.click();
    if (e.key === 'ArrowLeft') prev.click();
  });

  layout();
})();
</script>
