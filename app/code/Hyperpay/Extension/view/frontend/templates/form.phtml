   jq331 = jQuery.noConflict(true);

function displayName(element) {
    jq331('.wpwl-brand-card').each(function () {
        jq331(element).append(this);
    });
}

let wpwlOptions = {
    locale: "<?php echo $block->getLang();?>",
    
    /** 🔥 Important: keeps the iframe open — do NOT use _top */
    paymentTarget: "_self",

    /** Prevent widget from removing the form after submit */
    preventCheckoutRedirect: true,

    style: "<?php echo $block->getStyle();?>",
    
    onReady: function () {
        jq331('.wpwl-wrapper-cardNumber').each(function () { displayName(this); });
        jq331('[name="form_key"]').remove();
        console.log("Widget Ready");
    },

    onSubmit: function() {
        console.log("Submitting...");
        // Keep UI visible while processing
        jq331('.wpwl-form, .wpwl-form-card').show();
        return true;
    },

    onComplete: function (response) {
        console.log("Payment Success:", response);

        // Force UI to stay visible
        jq331('.wpwl-form, .wpwl-form-card').show();
        jq331('.wpwl-wrapper, .wpwl-group, .wpwl-control').css("visibility", "visible");

        // stop auto close
        return false;
    },

    onError: function (error) {
        console.log("Payment Error:", error);

        // keep UI for retry
        jq331('.wpwl-form, .wpwl-form-card').show();

        return false;
    },

    applePay: {
        merchantCapabilities:["supports3DS"],
        supportedNetworks:["amex","masterCard","visa","mada","jcb"]
    },

    browser: {
        threeDChallengeWindow: 5
    }
};

</script>

