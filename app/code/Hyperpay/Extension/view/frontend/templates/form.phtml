<script>
jq331 = jQuery.noConflict(true);

function displayName(element) {
    jq331('.wpwl-brand-card').each(function () {
        jq331(element).append(this);
    });
}

let wpwlOptions = {
    locale: "<?php echo $block->getLang(); ?>",
    paymentTarget: "_self",              // keep iframe open
    preventCheckoutRedirect: true,       // avoid auto redirect
    style: "<?php echo $block->getStyle(); ?>",
    onReady: function () {
        jq331('.wpwl-wrapper-cardNumber').each(function () { displayName(this); });
        jq331('[name="form_key"]').remove();
        console.log("Widget Ready");
    },
    onSubmit: function () {
        console.log("Submitting...");
        jq331('.wpwl-form, .wpwl-form-card').show();
        return true;
    },
    onComplete: function (response) {
        console.log("Payment Success:", response);
        jq331('.wpwl-form, .wpwl-form-card').show();
        return false; // stop auto close
    },
    onError: function (error) {
        console.log("Payment Error:", error);
        jq331('.wpwl-form, .wpwl-form-card').show();
        return false;
    },
    applePay: {
        merchantCapabilities: ["supports3DS"],
        supportedNetworks: ["amex","masterCard","visa","mada","jcb"]
    },
    browser: {
        threeDChallengeWindow: 5
    }
};
</script>

<?php if ($block->getPaymentBrand() === 'CLICK_TO_PAY VISA MASTER') { ?>
<style>.wpwl-form-card { display: none; }</style>
<script>
wpwlOptions = {
    ...wpwlOptions,
    paymentTarget: "_top",
    style: "card",
    onError: function (e) {
        console.log(e);
        if (['not_enrolled', "add_new_card", "otp_channel_invalid"].includes(e.event)) {
            jq331('.wpwl-form-card').show();
            window.location.href = `#${jq331('.wpwl-container-card')[0].id}`;
        }
    },
    clickToPay: {
        cardList: { displayCardListByDefault: true, displayAddCard: true },
        otpScreen: { displayOtpScreenByDefault: false },
        srcMark: { height: '40', width: '200' }
    }
};
</script>
