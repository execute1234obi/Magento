<?xml version="1.0"?>
<page xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
      xsi:noNamespaceSchemaLocation="urn:magento:framework:View/Layout/etc/page_configuration.xsd">

    <body>
        <!-- <referenceBlock name="vendor.toplinks" template="Gcc_VendorStyles::page/toplinks.phtml"/> -->
        <referenceBlock name="menu" template="Gcc_VendorStyles::menu.phtml"/>
        <referenceBlock name="breadcrumbs" template="Gcc_VendorStyles::page/breadcrumbs.phtml"/>
        <referenceBlock name="user.info.panel" remove="true"/>
        <referenceBlock name="avatar.user.info.default" remove="true"/>
        <referenceBlock name="vendor.mobile.sidebar.toggle" remove="true"/>
        <referenceBlock name="vendor.mobile.sidebar.toggle.handle" remove="true"/>

        <referenceContainer name="after.body.start">
            <block class="Magento\Framework\View\Element\Template"
                   name="custom_vendor_css"
                   template="Gcc_VendorStyles::custom-css.phtml"/>
        </referenceContainer>
    </body>
</page>
