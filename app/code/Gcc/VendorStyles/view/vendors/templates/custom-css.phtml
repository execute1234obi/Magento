<link rel="stylesheet" type="text/css" 
      href="<?= $block->getViewFileUrl('Gcc_VendorStyles::css/CustomAdminLTE.css'); ?>" />
<link rel="stylesheet" type="text/css" 
      href="<?= $block->getViewFileUrl('Gcc_VendorStyles::css/CustomAdminLTE.min.css'); ?>" />
<link rel="stylesheet" type="text/css" 
      href="<?= $block->getViewFileUrl('Gcc_VendorStyles::css/_all-skins.min.css'); ?>" />

<button
    type="button"
    class="vendor-mobile-sidebar-toggle-fixed"
    aria-label="<?= $block->escapeHtmlAttr(__('Open sidebar menu')); ?>"
    aria-expanded="false"
>
    <span class="vendor-mobile-sidebar-toggle-bar"></span>
</button>
<div class="vendor-mobile-sidebar-overlay"></div>

<style>
@media (max-width: 767px) {
    .vendor-topbar {
        height: auto !important;
    }

    .vendor-topbar__inner {
        padding: 10px 12px !important;
        height: auto !important;
        min-height: 56px;
    }

    .vendor-topbar__inner > ul {
        display: flex !important;
        flex-wrap: wrap;
        align-items: center;
        justify-content: flex-start;
        gap: 8px 10px;
        width: 100%;
        margin: 0;
        padding: 0;
    }

    .vendor-topbar__inner > ul > li,
    .vendor-topbar__inner > ul .vendor-mobile-sidebar-toggle-item {
        display: inline-flex;
        align-items: center;
        min-width: 0;
        list-style: none;
    }

    .vendor-topbar__inner > ul > li > a,
    .vendor-topbar__inner > ul > li > span,
    .vendor-topbar__inner > ul > li .action,
    .vendor-topbar__inner > ul > li .admin__action-dropdown {
        display: inline-flex;
        align-items: center;
        white-space: nowrap;
    }

    .vendor-mobile-sidebar-toggle-fixed {
        display: inline-flex;
        position: static;
        align-items: center;
        justify-content: center;
        width: 34px;
        height: 34px;
        padding: 0;
        border: 0;
        border-radius: 6px;
        background: #1e56a0;
        color: #ffffff;
        vertical-align: middle;
        box-shadow: none;
    }

    .vendor-mobile-sidebar-toggle-bar,
    .vendor-mobile-sidebar-toggle-bar::before,
    .vendor-mobile-sidebar-toggle-bar::after {
        display: block;
        width: 18px;
        height: 2px;
        background: currentColor;
        border-radius: 999px;
        content: "";
    }

    .vendor-mobile-sidebar-toggle-bar {
        position: relative;
    }

    .vendor-mobile-sidebar-toggle-bar::before {
        position: absolute;
        left: 0;
        top: -6px;
    }

    .vendor-mobile-sidebar-toggle-bar::after {
        position: absolute;
        left: 0;
        top: 6px;
    }

    .vendor-mobile-sidebar-overlay {
        position: fixed;
        inset: 0;
        z-index: 99990;
        background: rgba(15, 24, 43, 0.45);
        opacity: 0;
        visibility: hidden;
        transition: opacity .25s ease, visibility .25s ease;
    }

    .main-sidebar,
    .left-side {
        position: fixed !important;
        top: 0;
        left: 0;
        bottom: 0;
        width: 260px !important;
        max-width: 82vw;
        overflow-y: auto;
        transform: translateX(-100%);
        transition: transform .28s ease;
        z-index: 99995 !important;
        box-shadow: 10px 0 30px rgba(16, 42, 86, 0.2);
    }

    body.vendor-mobile-sidebar-open .main-sidebar,
    body.vendor-mobile-sidebar-open .left-side {
        transform: translateX(0);
    }

    body.vendor-mobile-sidebar-open .vendor-mobile-sidebar-overlay {
        opacity: 1;
        visibility: visible;
    }

    .content-wrapper,
    .right-side,
    .main-footer,
    .main-header .navbar,
    .main-header .logo {
        margin-left: 0 !important;
    }
}
</style>

<script>
document.addEventListener('DOMContentLoaded', function () {
    var button = document.querySelector('.vendor-mobile-sidebar-toggle-fixed');
    var overlay = document.querySelector('.vendor-mobile-sidebar-overlay');
    var sidebar = document.querySelector('.main-sidebar, .left-side');
    var topbarInner = document.querySelector('.vendor-topbar__inner');
    var topbarList = topbarInner ? topbarInner.querySelector('ul') : null;

    if (!button || !overlay || !sidebar || !topbarInner) {
        return;
    }

    if (topbarList && !topbarList.querySelector('.vendor-mobile-sidebar-toggle-item')) {
        var toggleItem = document.createElement('li');
        toggleItem.className = 'vendor-mobile-sidebar-toggle-item';
        toggleItem.appendChild(button);
        topbarList.appendChild(toggleItem);
    }

    button.addEventListener('click', function () {
        var isOpen = document.body.classList.toggle('vendor-mobile-sidebar-open');
        button.setAttribute('aria-expanded', isOpen ? 'true' : 'false');
    });

    overlay.addEventListener('click', function () {
        document.body.classList.remove('vendor-mobile-sidebar-open');
        button.setAttribute('aria-expanded', 'false');
    });

    window.addEventListener('resize', function () {
        if (window.innerWidth > 767) {
            document.body.classList.remove('vendor-mobile-sidebar-open');
            button.setAttribute('aria-expanded', 'false');
        }
    });
});
</script>
