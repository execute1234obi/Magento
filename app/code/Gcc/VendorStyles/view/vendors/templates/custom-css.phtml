                    ? element.parentElement
                    : null;

                if (element.id === 'add_product_form_btn' || elementText === 'quick new product' || elementText.indexOf('quick new product') !== -1) {
                    element.classList.add('vendor-product-grid-hide-quick');

                    if (element.parentElement) {
                        element.parentElement.classList.add('vendor-product-grid-hide-quick');
                    }

                    if (directWrapper) {
                        directWrapper.classList.add('vendor-product-grid-hide-quick');
                    }

                    if (element.closest('.actions-split')) {
                        element.closest('.actions-split').classList.add('vendor-product-grid-hide-quick');
                    }
                }
            });
        }

        if (referenceActions) {
            realAddButton = findVisibleVendorProductAddButton(referenceActions);
            fallbackReferenceAction = referenceActions.querySelector('.vendor-product-grid-page-actions--fallback');

            if (realAddButton) {
                if (fallbackReferenceAction) {
                    fallbackReferenceAction.remove();
                }
            } else {
                if (!fallbackReferenceAction) {
                    fallbackActionShell = createVendorProductFallbackAddAction();

                    if (fallbackActionShell) {
                        referenceActions.appendChild(fallbackActionShell);
                    }
                }
            }
        }

        actionWrap = findVendorProductHeaderControl(scope, '.action-select-wrap');
        searchWrap = findVendorProductHeaderControl(scope, '.data-grid-search-control-wrap');
        filterWrap = findVendorProductHeaderControl(scope, '.data-grid-filters-actions-wrap');

        if (actionWrap) {
            actionWrap.classList.add('vendor-product-grid-reference-control', 'vendor-product-grid-reference-control--action');
        }

        if (searchWrap) {
            searchWrap.classList.add('vendor-product-grid-reference-control', 'vendor-product-grid-reference-control--search');
        }

        if (filterWrap) {
            filterWrap.classList.add('vendor-product-grid-reference-control', 'vendor-product-grid-reference-control--filter');
        }

        if (actionWrap && referenceControls && actionWrap.parentNode !== referenceControls) {
            referenceControls.appendChild(actionWrap);
        }

        if (searchWrap && referenceControls && searchWrap.parentNode !== referenceControls) {
            referenceControls.appendChild(searchWrap);
        }

        if (filterWrap && referenceControls && filterWrap.parentNode !== referenceControls) {
            referenceControls.appendChild(filterWrap);
        }

        actionButton = referenceControls ? referenceControls.querySelector('.action-select') : null;
        actionLabel = actionButton ? actionButton.querySelector('span') : null;

        if (actionLabel) {
            actionLabel.textContent = 'Action';
        }

        if (actionButton) {
            if (!actionLabel) {
                actionButton.textContent = 'Action';
            }

            actionButton.setAttribute('title', 'Action');
        }

        searchInput = referenceControls ? referenceControls.querySelector('.data-grid-search-control') : null;

        if (searchInput) {
            searchInput.setAttribute('placeholder', 'Search Product');
            searchInput.setAttribute('aria-label', 'Search Product');
        }

        filterButton = referenceControls ? referenceControls.querySelector('.data-grid-filters-action-wrap .action-default') : null;

        if (filterButton) {
            filterButton.textContent = 'Filters';
        }

        Array.prototype.forEach.call(scope.querySelectorAll('.action-select-wrap .action-select span'), function (element) {
            var labelText = (element.textContent || '').replace(/\s+/g, ' ').trim().toLowerCase();

            if (labelText === 'actions') {
                element.textContent = 'Action';
            }
        });

        resultCount = getVendorProductGridResultCount(header || scope);

        if (referenceResults) {
            referenceResults.textContent = resultCount ? resultCount + ' Results' : '';
        }

        if (header) {
            header.classList.add('vendor-product-grid-header-shell');
        }
    }

    function normalizeVendorProductGridHeader() {
        Array.prototype.forEach.call(document.querySelectorAll('.admin__data-grid-header'), function (header) {
            var toolbarRow;
            var meta;
            var controls;
            var sourceRows;
            var actionWrap;
            var searchWrap;
            var filterWrap;
            var actionButton;
            var actionLabel;
            var searchInput;
            var filterButton;
            var resultCount;
            var controlsFound;

            if (header.closest('.sticky-header')) {
                return;
            }

            if (!document.querySelector('.admin__data-grid-wrap table.data-grid')) {
                return;
            }

            if (document.querySelector('.vendor-product-grid-reference-header')) {
                toolbarRow = header.querySelector('.vendor-product-grid-toolbar-row');

                if (toolbarRow) {
                    toolbarRow.remove();
                }

                header.classList.add('vendor-product-grid-header-shell');
                return;
            }

            toolbarRow = header.querySelector('.vendor-product-grid-toolbar-row');

            if (!toolbarRow) {
                toolbarRow = document.createElement('div');
                toolbarRow.className = 'vendor-product-grid-toolbar-row';

                meta = document.createElement('div');
                meta.className = 'vendor-product-grid-toolbar-meta';
                toolbarRow.appendChild(meta);

                controls = document.createElement('div');
                controls.className = 'vendor-product-grid-toolbar-controls';
                toolbarRow.appendChild(controls);

                header.insertBefore(toolbarRow, header.firstChild);
            } else {
                meta = toolbarRow.querySelector('.vendor-product-grid-toolbar-meta');
                controls = toolbarRow.querySelector('.vendor-product-grid-toolbar-controls');
            }

            sourceRows = Array.prototype.slice.call(header.querySelectorAll('.admin__data-grid-header-row'));
            actionWrap = header.querySelector('.action-select-wrap');
            searchWrap = header.querySelector('.data-grid-search-control-wrap');
            filterWrap = header.querySelector('.data-grid-filters-actions-wrap');
            controlsFound = 0;

            if (actionWrap && actionWrap.parentNode !== controls) {
                controls.appendChild(actionWrap);
            }

            if (actionWrap) {
                controlsFound++;
            }

            if (searchWrap && searchWrap.parentNode !== controls) {
                controls.appendChild(searchWrap);
            }

            if (searchWrap) {
                controlsFound++;
            }

            if (filterWrap && filterWrap.parentNode !== controls) {
                controls.appendChild(filterWrap);
            }

            if (filterWrap) {
                controlsFound++;
            }

            actionButton = header.querySelector('.action-select');
            actionLabel = actionButton ? actionButton.querySelector('span') : null;

            if (actionLabel) {
                actionLabel.textContent = 'Action';
            }

            if (actionButton) {
                actionButton.setAttribute('title', 'Action');
            }

            searchInput = header.querySelector('.data-grid-search-control');

            if (searchInput) {
                searchInput.setAttribute('placeholder', 'Search Product');
                searchInput.setAttribute('aria-label', 'Search Product');
            }

            filterButton = header.querySelector('.data-grid-filters-action-wrap .action-default');

            if (filterButton) {
                filterButton.textContent = 'Filters';
            }

            resultCount = getVendorProductGridResultCount(header);
            meta.textContent = resultCount ? resultCount + ' Results' : '';

            if (controlsFound || resultCount) {
                header.classList.add('vendor-product-grid-header-ready');
            }

            sourceRows.forEach(function (row) {
                if (!row || row.parentNode !== header) {
                    return;
                }

                row.classList.add('vendor-product-grid-toolbar-source-row');

                if (header.classList.contains('vendor-product-grid-header-ready')) {
                    row.style.display = 'none';
                }
            });

            if (!controlsFound && !resultCount) {
                header.classList.remove('vendor-product-grid-header-ready');
            }
        });
    }

    function normalizeVendorProductNameCells() {
        var gridTable = Array.prototype.slice.call(document.querySelectorAll('.admin__data-grid-wrap table.data-grid')).find(function (candidate) {
            return candidate &&
                !candidate.closest('[data-role="sticky-el-root"]') &&
                candidate.querySelector('tbody tr');
        }) || null;
        var headerIndex = -1;

        if (!isVendorProductGridPage || !gridTable) {
            return;
        }

        Array.prototype.slice.call(gridTable.querySelectorAll('thead th')).some(function (cell, index) {
            var labelText = (cell.textContent || '').replace(/\s+/g, ' ').trim().toLowerCase();

            if (labelText === 'name') {
                headerIndex = index;
                return true;
            }

            return false;
        });

        Array.prototype.forEach.call(gridTable.querySelectorAll('tbody tr'), function (row) {
            var cells = Array.prototype.filter.call(row.children, function (cell) {
                return cell && cell.tagName === 'TD';
            });
            var cell = row.querySelector('td[data-column="name"], td[data-index="name"], td.col-name') || (headerIndex > -1 ? cells[headerIndex] : null);
            var contentTarget = cell ? (cell.querySelector('[data-grid-cell-content]') || cell.querySelector('.data-grid-cell-content') || cell) : null;
            var existingWrapper = contentTarget ? contentTarget.querySelector('.vendor-product-grid-name-wrap') : null;
            var fullText = cell ? (cell.getAttribute('data-vendor-product-name-full') || '') : '';
            var expanded = cell ? cell.getAttribute('data-vendor-product-name-expanded') === 'true' : false;
            var shortText;
            var wrapper;
            var textNode;
            var toggle;

            if (!cell || !contentTarget) {
                return;
            }

            if (!fullText) {
                fullText = (contentTarget.textContent || '')
                    .replace(/\s+/g, ' ')
                    .replace(/\s*Read\s+(more|less)\s*$/i, '')
                    .trim();
            }

            if (!fullText) {
                return;
            }

            cell.setAttribute('data-vendor-product-name-full', fullText);

            if (fullText.length <= 10) {
                if (existingWrapper) {
                    contentTarget.textContent = fullText;
                }
                cell.classList.remove('vendor-product-grid-name-cell');
                cell.removeAttribute('data-vendor-product-name-expanded');
                return;
            }

            shortText = fullText.slice(0, 10) + '...';
            cell.classList.add('vendor-product-grid-name-cell');

            if (!existingWrapper) {
                contentTarget.textContent = '';

                wrapper = document.createElement('span');
                wrapper.className = 'vendor-product-grid-name-wrap';

                textNode = document.createElement('span');
                textNode.className = 'vendor-product-grid-name-text';
                wrapper.appendChild(textNode);

                toggle = document.createElement('button');
                toggle.type = 'button';
                toggle.className = 'vendor-product-grid-name-toggle';
                toggle.addEventListener('mousedown', function (event) {
                    event.stopPropagation();
                });
                toggle.addEventListener('click', function (event) {
                    var isExpanded;

                    event.preventDefault();
                    event.stopPropagation();

                    isExpanded = cell.getAttribute('data-vendor-product-name-expanded') === 'true';
                    cell.setAttribute('data-vendor-product-name-expanded', isExpanded ? 'false' : 'true');
                    textNode.textContent = isExpanded ? shortText : fullText;
                    toggle.textContent = isExpanded ? 'Read more' : 'Read less';
                    toggle.setAttribute('aria-expanded', isExpanded ? 'false' : 'true');
                });
                wrapper.appendChild(toggle);

                contentTarget.appendChild(wrapper);
                existingWrapper = wrapper;
            }

            textNode = existingWrapper.querySelector('.vendor-product-grid-name-text');
            toggle = existingWrapper.querySelector('.vendor-product-grid-name-toggle');

            if (!textNode || !toggle) {
                contentTarget.textContent = fullText;
                cell.removeAttribute('data-vendor-product-name-expanded');
                return;
            }

            textNode.textContent = expanded ? fullText : shortText;
            toggle.textContent = expanded ? 'Read less' : 'Read more';
            toggle.setAttribute('aria-expanded', expanded ? 'true' : 'false');
        });
    }

    function ensureVendorProductSelectionColumn() {
        var gridTable = Array.prototype.slice.call(document.querySelectorAll('.admin__data-grid-wrap table.data-grid')).find(function (candidate) {
            return candidate &&
                !candidate.closest('[data-role="sticky-el-root"]') &&
                candidate.querySelector('tbody tr');
        }) || null;

        function revealSelectionCells() {
            if (!gridTable) {
                return;
            }

            Array.prototype.forEach.call(
                gridTable.querySelectorAll('thead th.data-grid-multicheck-cell, tbody td.data-grid-checkbox-cell, tbody td.data-grid-multicheck-cell'),
                function (cell) {
                    cell.style.display = 'table-cell';
                    cell.style.visibility = 'visible';
                    cell.hidden = false;
                }
            );

            Array.prototype.forEach.call(
                gridTable.querySelectorAll('.data-grid-checkbox-cell .admin__control-checkbox, .data-grid-multicheck-cell .admin__control-checkbox'),
                function (checkbox) {
                    checkbox.style.position = 'static';
                    checkbox.style.opacity = '1';
                    checkbox.style.visibility = 'visible';
                }
            );
        }

        if (!isVendorProductGridPage) {
            return;
        }

        revealSelectionCells();

        if (!window.require) {
            return;
        }

        try {
            window.require(['uiRegistry'], function (registry) {
                registry.get('vendor_product_listing.vendor_product_listing.product_columns.ids', function (column) {
                    try {
                        if (column) {
                            if (typeof column.visible === 'function') {
                                column.visible(true);
                            } else {
                                column.visible = true;
                            }

                            if (typeof column.set === 'function') {
                                column.set('visible', true);
                            }

                            if (typeof column.disabled === 'function') {
                                column.disabled(false);
                            }
                        }
                    } catch (error) {
                        return;
                    }

                    setTimeout(revealSelectionCells, 50);
                });

                registry.get('vendor_product_listing.vendor_product_listing.listing_top.bookmarks', function (bookmarks) {
                    try {
                        if (!bookmarks || !bookmarks.current) {
                            return;
                        }

                        bookmarks.current.columns = bookmarks.current.columns || {};
                        bookmarks.current.columns.ids = Object.assign({}, bookmarks.current.columns.ids || {}, {
                            visible: true
                        });

                        if (typeof bookmarks.saveState === 'function') {
                            bookmarks.saveState();
                        }
                    } catch (error) {
                        return;
                    }
                });
            });
        } catch (error) {
            return;
        }
    }

    function renderVendorProductGridFooterControls(footer, state) {
        var pagerWrap = footer.querySelector('.vendor-product-grid-footer-controls');
        var sizeContainer;
        var sizeLabel;
        var sizeSelect;
        var pager;
        var previousButton;
        var nextButton;
        var pageList;

        if (!pagerWrap) {
            pagerWrap = document.createElement('div');
            pagerWrap.className = 'admin__data-grid-pager-wrap vendor-product-grid-footer-controls';
            footer.appendChild(pagerWrap);
        }

        sizeContainer = pagerWrap.querySelector('.vendor-product-grid-size');

        if (!sizeContainer) {
            sizeContainer = document.createElement('div');
            sizeContainer.className = 'vendor-product-grid-size';
            pagerWrap.appendChild(sizeContainer);
        }

        sizeLabel = sizeContainer.querySelector('label');

        if (!sizeLabel) {
            sizeLabel = document.createElement('label');
            sizeLabel.id = 'per-page-text';
            sizeLabel.textContent = 'Show';
            sizeContainer.appendChild(sizeLabel);
        }

        sizeSelect = sizeContainer.querySelector('.vendor-product-grid-size-select');

        if (!sizeSelect) {
            sizeSelect = document.createElement('select');
            sizeSelect.className = 'vendor-product-grid-size-select';
            sizeContainer.appendChild(sizeSelect);
        }

        sizeSelect.innerHTML = '';
        state.pageSizes.forEach(function (pageSize) {
            var option = document.createElement('option');

            option.value = pageSize;
            option.textContent = pageSize;
            option.selected = Number(pageSize) === Number(state.pageSize);
            sizeSelect.appendChild(option);
        });

        sizeSelect.onchange = function () {
            state.setPageSize(this.value);
        };

        pager = pagerWrap.querySelector('.admin__data-grid-pager');

        if (!pager) {
            pager = document.createElement('div');
            pager.className = 'admin__data-grid-pager';
            pagerWrap.appendChild(pager);
        }

        previousButton = pager.querySelector('.action-previous');

        if (!previousButton) {
            previousButton = document.createElement('button');
            previousButton.type = 'button';
            previousButton.className = 'action-previous';
            previousButton.title = 'Previous Page';
            pager.appendChild(previousButton);
        }

        previousButton.disabled = Number(state.current) <= 1;
        previousButton.onclick = function () {
            state.prev();
        };

        pageList = pager.querySelector('.vendor-product-grid-page-list');

        if (!pageList) {
            pageList = document.createElement('div');
            pageList.className = 'vendor-product-grid-page-list';
            pager.appendChild(pageList);
        }

        renderVendorProductGridPages(state, pageList);

        nextButton = pager.querySelector('.action-next');

        if (!nextButton) {
            nextButton = document.createElement('button');
            nextButton.type = 'button';
            nextButton.className = 'action-next';
            nextButton.title = 'Next Page';
            pager.appendChild(nextButton);
        }

        nextButton.disabled = Number(state.current) >= Number(state.pages);
        nextButton.onclick = function () {
            state.next();
        };
    }

    function findVendorProductGridScope(gridWrap) {
        var current = gridWrap ? gridWrap.parentElement : null;

        while (current && current !== document.body) {
            if (
                current.querySelector('.admin__data-grid-header') &&
                current.querySelector('.admin__data-grid-wrap table.data-grid')
            ) {
                return current;
            }

            if (
                current.querySelector('.admin__data-grid-pager-wrap') &&
                current.querySelector('table.data-grid')
            ) {
                return current;
            }

            current = current.parentElement;
        }

        return gridWrap ? gridWrap.parentElement : null;
    }

    function findVendorProductPagerWrap(scope) {
        var candidates;
        var index;

        if (scope) {
            candidates = scope.querySelectorAll('.admin__data-grid-pager-wrap');

            for (index = 0; index < candidates.length; index++) {
                if (!candidates[index].closest('.vendor-product-grid-footer')) {
                    return candidates[index];
                }
            }
        }

        candidates = document.querySelectorAll('.admin__data-grid-header .admin__data-grid-pager-wrap, .admin__data-grid-pager-wrap');

        for (index = 0; index < candidates.length; index++) {
            if (!candidates[index].closest('.vendor-product-grid-footer')) {
                return candidates[index];
            }
        }

        return null;
    }

    function syncVendorProductGridFooterForWrap(gridWrap) {
        var scope;
        var pagerWrap;
        var footer;
        var state;
        var stateKey;

        if (!gridWrap) {
            return;
        }

        if (gridWrap.getAttribute('data-role') === 'sticky-el-root') {
            return;
        }

        scope = findVendorProductGridScope(gridWrap);

        if (!scope && !gridWrap.parentElement) {
            return;
        }

        footer = scope ? scope.querySelector('.vendor-product-grid-footer') : null;
        pagerWrap = findVendorProductPagerWrap(scope);

        if (!pagerWrap && footer) {
            pagerWrap = footer.querySelector('.admin__data-grid-pager-wrap');
        }

        if (pagerWrap && pagerWrap.classList.contains('vendor-product-grid-footer-controls')) {
            pagerWrap = null;
        }

        state = buildVendorProductGridState(pagerWrap);

        if (!state) {
            return;
        }

        if (!footer) {
            footer = document.createElement('div');
            footer.className = 'vendor-product-grid-footer';
        }

        if (footer.parentNode !== gridWrap.parentNode || gridWrap.nextElementSibling !== footer) {
            gridWrap.insertAdjacentElement('afterend', footer);
        }

        gridWrap.classList.add('vendor-product-grid-has-footer');
        stateKey = [state.current, state.pages, state.pageSize].join(':');

        if (footer.dataset.vendorPagerState === stateKey) {
            return;
        }

        renderVendorProductGridFooterControls(footer, state);
        footer.dataset.vendorPagerState = stateKey;
    }

    function syncVendorProductGridFooter() {
        Array.prototype.forEach.call(document.querySelectorAll('.admin__data-grid-wrap'), function (gridWrap) {
            var table = gridWrap.querySelector('table.data-grid');

            if (!table) {
                return;
            }

            if (gridWrap.getAttribute('data-role') === 'sticky-el-root') {
                return;
            }

            if (gridWrap.offsetParent === null && !gridWrap.classList.contains('vendor-product-grid-has-footer')) {
                return;
            }

            syncVendorProductGridFooterForWrap(gridWrap);
        });
    }

    function initVendorProductGridFooter() {
        var syncTimer;
        var observer;

        if (!isVendorProductGridPage) {
            return;
        }

        function scheduleSync() {
            clearTimeout(syncTimer);
            syncTimer = setTimeout(function () {
                normalizeVendorProductPageActions();
                normalizeVendorProductReferenceHeader();
                normalizeVendorProductGridHeader();
                ensureVendorProductSelectionColumn();
                normalizeVendorProductNameCells();
                syncVendorProductGridFooter();
            }, 80);
        }

        loadVendorProductPagingComponents(scheduleSync);
        scheduleSync();
        setTimeout(scheduleSync, 300);
        setTimeout(scheduleSync, 900);

        observer = new MutationObserver(scheduleSync);
        observer.observe(document.body, {
            childList: true,
            subtree: true,
            characterData: true
        });

        window.addEventListener('resize', scheduleSync);
    }

    initVendorProductGridFooter();

    if (!sidebar) {
        return;
    }

    if (toggleButton && !toggleButton.dataset.vendorMobileBound) {
        toggleButton.dataset.vendorMobileBound = 'true';
        toggleButton.addEventListener('click', function (event) {
            event.preventDefault();
            event.stopPropagation();
            setSidebarState(!body.classList.contains('vendor-mobile-sidebar-open'));
        });
    }

    if (closeButton && !closeButton.dataset.vendorMobileBound) {
        closeButton.dataset.vendorMobileBound = 'true';
        closeButton.addEventListener('click', function (event) {
            event.preventDefault();
            event.stopPropagation();
            setSidebarState(false);
        });
    }

    if (overlay && !overlay.dataset.vendorMobileBound) {
        overlay.dataset.vendorMobileBound = 'true';
        overlay.addEventListener('click', function () {
            setSidebarState(false);
            closeDropdowns();
        });
    }

    document.addEventListener('click', function (event) {
        var toggle = event.target.closest('[data-dd-btn]');

        if (toggle) {
            var item = toggle.closest('[data-dd]');
            var shouldOpen = item && !item.classList.contains('is-open');

            closeDropdowns();

            if (item && shouldOpen) {
                item.classList.add('is-open');
                toggle.setAttribute('aria-expanded', 'true');
            }

            event.preventDefault();
            event.stopPropagation();
            return;
        }

        if (!event.target.closest('[data-dd]')) {
            closeDropdowns();
        }

        if (window.innerWidth <= 767 && event.target.closest('.main-sidebar a')) {
            setSidebarState(false);
        }
    });

    document.addEventListener('keydown', function (event) {
        if (event.key === 'Escape') {
            closeDropdowns();
            setSidebarState(false);
        }
    });

    window.addEventListener('resize', function () {
        if (window.innerWidth > 767) {
            setSidebarState(false);
            closeDropdowns();
        }
    });
});
</script>
