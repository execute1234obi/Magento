<?php
$vendorProductFallbackAddUrl = '';
$vendorProductFallbackAddSet = 0;
$vendorProductFallbackAddType = '';

try {
    $objectManager = \Magento\Framework\App\ObjectManager::getInstance();
    $productHelper = $objectManager->get(\Vnecoms\VendorsProduct\Helper\Data::class);
    $productFactory = $objectManager->get(\Magento\Catalog\Model\ProductFactory::class);
    $productTypeFactory = $objectManager->get(\Magento\Catalog\Model\Product\TypeFactory::class);
    $attributeSetCollectionFactory = $objectManager->get(\Magento\Eav\Model\ResourceModel\Entity\Attribute\Set\CollectionFactory::class);

    $product = $productFactory->create();
    $defaultAttributeSetId = (int)$product->getDefaultAttributeSetId();
    $attributeSetRestrictions = $productHelper->getAttributeSetRestriction();
    $productTypeRestrictions = $productHelper->getProductTypeRestriction();
    $types = $productTypeFactory->create()->getTypes();
    $allowedTypes = [];

    if (in_array($defaultAttributeSetId, $attributeSetRestrictions)) {
        $attributeSetCollection = $attributeSetCollectionFactory->create()
            ->setEntityTypeFilter($product->getResource()->getTypeId())
            ->addFieldToFilter('attribute_set_id', ['nin' => $attributeSetRestrictions]);

        if ($attributeSetCollection->count()) {
            $defaultAttributeSetId = (int)$attributeSetCollection->getFirstItem()->getId();
        }
    }

    uasort($types, function ($left, $right) {
        return ($left['sort_order'] < $right['sort_order']) ? -1 : 1;
    });

    foreach ($types as $typeId => $type) {
        if (in_array($typeId, $productTypeRestrictions)) {
            continue;
        }

        $allowedTypes[] = $typeId;
    }

    if ($defaultAttributeSetId && !empty($allowedTypes)) {
        $defaultType = in_array(\Magento\Catalog\Model\Product\Type::DEFAULT_TYPE, $allowedTypes, true)
            ? \Magento\Catalog\Model\Product\Type::DEFAULT_TYPE
            : reset($allowedTypes);
        $vendorProductFallbackAddSet = (int)$defaultAttributeSetId;
        $vendorProductFallbackAddType = (string)$defaultType;

        $vendorProductFallbackAddUrl = $block->getUrl(
            'catalog/product/new',
            ['set' => $defaultAttributeSetId, 'type' => $defaultType]
        );
    }
} catch (\Throwable $exception) {
    $vendorProductFallbackAddUrl = '';
    $vendorProductFallbackAddSet = 0;
    $vendorProductFallbackAddType = '';
}
