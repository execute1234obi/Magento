        var pages = [];
        var start;
        var end;
        var page;

        if (total <= 4) {
            for (page = 1; page <= total; page++) {
                pages.push(page);
            }

            return pages;
        }

        pages.push(1);

        if (current > 3) {
            pages.push('ellipsis-start');
        }

        start = Math.max(2, current - 1);
        end = Math.min(total - 1, current + 1);

        if (current <= 2) {
            end = Math.min(total - 1, 2);
        }

        if (current >= total - 1) {
            start = Math.max(2, total - 1);
        }

        for (page = start; page <= end; page++) {
            pages.push(page);
        }

        if (current < total - 2) {
            pages.push('ellipsis-end');
        }

        pages.push(total);

        return pages;
    }

