<style>
@media (max-width: 767px) {
    .main-header,
    .main-header .navbar,
    .main-header .navbar-static-top {
        margin-left: 0 !important;
        background: transparent !important;
        min-height: 0 !important;
    }

    .main-header .logo {
        display: none !important;
    }

    .vendor-topbar {
        margin-left: 0 !important;
        background: transparent;
        border-bottom: 0;
        box-shadow: none;
    }

    .vendor-mobile-topbar {
        display: block;
        padding: 0;
        background: #ffffff;
        border-bottom: 1px solid #e6edf5;
        position: relative;
        z-index: 1200;
    }

    .vendor-mobile-topbar__row--primary {
        min-height: 48px;
        padding: 10px 16px;
        gap: 16px;
        background: #4b78b3;
    }

    .vendor-mobile-topbar__actions {
        flex: 1 1 auto;
        justify-content: flex-end;
        gap: 18px;
        min-width: 0;
    }

    .vendor-mobile-topbar__actions .vendor-topbar__item,
    .vendor-mobile-topbar__row--secondary .vendor-topbar__item {
        z-index: 1202;
    }

    .vendor-topbar__item.is-open {
        z-index: 1206;
    }

    .vendor-mobile-topbar__row--primary .vendor-topbar__btn {
        padding: 0;
        color: #ffffff;
        background: transparent !important;
    }

    .vendor-mobile-topbar__row--primary .vendor-topbar__btn--compact {
        gap: 8px;
    }

    .vendor-mobile-topbar__row--primary .vendor-ico {
        color: #ffffff;
    }

    .vendor-mobile-topbar__row--primary .vendor-caret {
        color: rgba(255, 255, 255, 0.86);
    }

    .vendor-mobile-topbar__row--primary .vendor-badge {
        top: -7px;
        right: -7px;
        border-color: #4b78b3;
    }

    .vendor-mobile-topbar__row--secondary {
        min-height: 56px;
        padding: 0 16px;
        gap: 12px;
        background: #ffffff;
        border-top: 0;
    }

    .vendor-mobile-topbar__page-title {
        font-size: 18px;
        color: #163172;
    }

    .vendor-mobile-topbar__row--secondary .vendor-topbar__btn {
        padding: 0;
        color: #163172;
        background: transparent !important;
    }

    .vendor-mobile-topbar__row--secondary .vendor-ico {
        color: #2f6fed;
    }

    .vendor-mobile-topbar__row--secondary .vendor-caret {
        color: #163172;
    }

    .vendor-mobile-nav-toggle {
        width: 20px;
        height: 20px;
        background: transparent;
        border-radius: 0;
        color: #ffffff;
        box-shadow: none;
    }

    .vendor-mobile-nav-toggle__bar,
    .vendor-mobile-nav-toggle__bar::before,
    .vendor-mobile-nav-toggle__bar::after {
        width: 18px;
    }

    .vendor-avatar--mobile {
        width: 28px;
        height: 28px;
        flex: 0 0 28px;
        border-radius: 999px;
        border: 1px solid rgba(255, 255, 255, 0.28);
        overflow: hidden;
        background: rgba(255, 255, 255, 0.16);
    }

    .vendor-avatar--mobile img {
        width: 100%;
        height: 100%;
        object-fit: cover;
        display: block;
    }

    .vendor-mobile-topbar__vendor-name {
        max-width: 100px;
        color: #ffffff;
        font-weight: 600;
    }

    .vendor-dropdown--mobile {
        position: fixed;
        top: 56px;
        right: 12px;
        z-index: 1205;
    }

    .vendor-dropdown--wallet {
        top: 104px;
    }

    .vendor-mobile-sidebar-overlay {
        position: fixed;
        inset: 0;
        display: block;
        opacity: 0;
        visibility: hidden;
        background: rgba(15, 23, 42, 0.42);
        transition: opacity 0.25s ease, visibility 0.25s ease;
        z-index: 1198;
    }

    .main-sidebar,
    .left-side {
        position: fixed !important;
        top: 0 !important;
        left: 0 !important;
        bottom: 0 !important;
        display: block !important;
        width: 236px !important;
        max-width: 82vw;
        margin: 0 !important;
        padding-top: 0 !important;
        overflow-y: auto;
        visibility: hidden;
        opacity: 0;
        transform: translate3d(-100%, 0, 0);
        transition: transform 0.28s ease, opacity 0.2s ease, visibility 0.2s ease;
        z-index: 1199 !important;
        box-shadow: 12px 0 36px rgba(16, 42, 86, 0.26);
    }

    body.vendor-mobile-sidebar-open .main-sidebar,
    body.vendor-mobile-sidebar-open .left-side,
    body.sidebar-open .main-sidebar,
    body.sidebar-open .left-side {
        visibility: visible;
        opacity: 1;
        transform: translate3d(0, 0, 0);
    }

    body.vendor-mobile-sidebar-open .vendor-mobile-sidebar-overlay,
    body.sidebar-open .vendor-mobile-sidebar-overlay {
        opacity: 1;
        visibility: visible;
    }

    .vendor-mobile-sidebar-head {
        display: flex;
        align-items: center;
        justify-content: space-between;
        gap: 12px;
        padding: 16px 18px;
        background: #4b78b3;
        position: sticky;
        top: 0;
        z-index: 2;
    }

    .sidebar {
        padding-top: 0;
    }

    .sidebar .header,
    .sidebar .user-panel,
    .sidebar .divider {
        display: none !important;
    }

    .sidebar-menu {
        padding: 0 0 14px;
    }

    .sidebar-menu > li > a {
        padding: 14px 18px;
        font-size: 15px;
        font-weight: 500;
        line-height: 1.35;
        color: #ffffff !important;
    }

    .sidebar-menu > li > a > span {
        display: inline-block;
        max-width: calc(100% - 48px);
        vertical-align: middle;
    }

    .sidebar-menu > li.active > a,
    .skin-blue .sidebar-menu > li.active > a {
        background: #1e56a0 !important;
        color: #ffffff !important;
    }

    .treeview-menu > li > a {
        padding-left: 42px;
    }

    .vendor-pagehead {
        display: none !important;
    }

    .page-content,
    .content-wrapper,
    .right-side,
    .main-footer,
    .page-footer {
        margin-left: 0 !important;
    }
}
</style>
<script>
document.addEventListener('DOMContentLoaded', function () {
    var body = document.body;
    var toggleButton = document.querySelector('.vendor-mobile-nav-toggle');
    var closeButton = document.querySelector('.vendor-mobile-sidebar-close');
    var overlay = document.querySelector('.vendor-mobile-sidebar-overlay');
    var sidebar = document.querySelector('.main-sidebar, .left-side');

    function closeDropdowns() {
        Array.prototype.forEach.call(document.querySelectorAll('[data-dd].is-open'), function (item) {
            item.classList.remove('is-open');

            Array.prototype.forEach.call(item.querySelectorAll('[data-dd-btn]'), function (button) {
                button.setAttribute('aria-expanded', 'false');
            });
        });
    }

    function setSidebarState(isOpen) {
        body.classList.toggle('vendor-mobile-sidebar-open', isOpen);
        body.classList.toggle('sidebar-open', isOpen);

        if (!isOpen) {
            body.classList.remove('sidebar-collapse');
        }

        if (toggleButton) {
            toggleButton.setAttribute('aria-expanded', isOpen ? 'true' : 'false');
        }
    }

    if (!sidebar) {
        return;
    }

    if (toggleButton && !toggleButton.dataset.vendorMobileBound) {
        toggleButton.dataset.vendorMobileBound = 'true';
        toggleButton.addEventListener('click', function (event) {
            event.preventDefault();
            event.stopPropagation();
            setSidebarState(!body.classList.contains('vendor-mobile-sidebar-open'));
        });
    }

    if (closeButton && !closeButton.dataset.vendorMobileBound) {
        closeButton.dataset.vendorMobileBound = 'true';
        closeButton.addEventListener('click', function (event) {
            event.preventDefault();
            event.stopPropagation();
            setSidebarState(false);
        });
    }

    if (overlay && !overlay.dataset.vendorMobileBound) {
        overlay.dataset.vendorMobileBound = 'true';
        overlay.addEventListener('click', function () {
            setSidebarState(false);
            closeDropdowns();
        });
    }

    document.addEventListener('click', function (event) {
        var toggle = event.target.closest('[data-dd-btn]');

        if (toggle) {
            var item = toggle.closest('[data-dd]');
            var shouldOpen = item && !item.classList.contains('is-open');

            closeDropdowns();

            if (item && shouldOpen) {
                item.classList.add('is-open');
                toggle.setAttribute('aria-expanded', 'true');
            }

            event.preventDefault();
            event.stopPropagation();
            return;
        }

        if (!event.target.closest('[data-dd]')) {
            closeDropdowns();
        }

        if (window.innerWidth <= 767 && event.target.closest('.main-sidebar a')) {
            setSidebarState(false);
        }
    });

    document.addEventListener('keydown', function (event) {
        if (event.key === 'Escape') {
            closeDropdowns();
            setSidebarState(false);
        }
    });

    window.addEventListener('resize', function () {
        if (window.innerWidth > 767) {
            setSidebarState(false);
            closeDropdowns();
        }
    });
});
</script>
