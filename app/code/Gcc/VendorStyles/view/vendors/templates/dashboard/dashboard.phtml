}

.gcc-dashboard-table-card__head{
    display:block;
    padding:22px 22px 0;
    border-bottom:0;
}

.gcc-dashboard-table-card__title{
    margin:0 0 18px;
    color:#173574;
    font-size:19px;
    font-weight:800;
    line-height:1.2;
}

.gcc-dashboard-table-card__toolbar{
    display:flex;
    align-items:center;
    justify-content:space-between;
    gap:18px;
    min-height:78px;
    padding:18px 22px;
    margin:0 -22px;
