<?php if ($mostViewedProducts && count($mostViewedProducts) > 0): ?>
<script>
document.addEventListener('DOMContentLoaded', function () {
    var root = document.querySelector('[data-gcc-dashboard-table]');

    if (!root) {
        return;
    }

    var tbody = root.querySelector('[data-role="rows"]');
    var searchInput = root.querySelector('[data-role="search"]');
    var sortSelect = root.querySelector('[data-role="sort"]');
    var pageSizeSelect = root.querySelector('[data-role="page-size"]');
    var pagination = root.querySelector('[data-role="pagination"]');
    var resultsCount = root.querySelector('[data-role="results-count"]');
    var headerSortButtons = Array.prototype.slice.call(root.querySelectorAll('[data-role="header-sort"]'));
    var allRows = Array.prototype.slice.call(tbody.querySelectorAll('tr[data-row]'));
    var currentPage = 1;
    var activeSort = {
        key: 'views',
        direction: 'desc'
    };

    function compareNumbers(left, right, direction) {
        if (direction === 'asc') {
            return left - right;
        }

        return right - left;
    }

    function compareText(left, right, direction) {
        var comparison = left.localeCompare(right);

        if (direction === 'asc') {
            return comparison;
        }

        return comparison * -1;
    }

    function compareRows(a, b, key, direction) {
        if (key === 'position') {
            return compareNumbers(parseFloat(a.dataset.position || '0'), parseFloat(b.dataset.position || '0'), direction);
        }

        if (key === 'image') {
            return compareText(a.dataset.name || '', b.dataset.name || '', direction);
        }

        if (key === 'price') {
            return compareNumbers(parseFloat(a.dataset.price || '0'), parseFloat(b.dataset.price || '0'), direction);
        }

        if (key === 'rating') {
            return compareNumbers(parseFloat(a.dataset.rating || '0'), parseFloat(b.dataset.rating || '0'), direction);
        }

        if (key === 'views') {
            return compareNumbers(parseFloat(a.dataset.views || '0'), parseFloat(b.dataset.views || '0'), direction);
        }

        return compareText(a.dataset.name || '', b.dataset.name || '', direction);
    }

    function applySortFromSelect() {
        var sortMode = sortSelect.value || 'popular';

        if (sortMode === 'price_high') {
            activeSort = {key: 'price', direction: 'desc'};
            return;
        }

        if (sortMode === 'price_low') {
            activeSort = {key: 'price', direction: 'asc'};
            return;
        }

        if (sortMode === 'name') {
            activeSort = {key: 'name', direction: 'asc'};
            return;
        }

        activeSort = {key: 'views', direction: 'desc'};
    }

    function syncSortSelect() {
        if (activeSort.key === 'price' && activeSort.direction === 'desc') {
            sortSelect.value = 'price_high';
            return;
        }

        if (activeSort.key === 'price' && activeSort.direction === 'asc') {
            sortSelect.value = 'price_low';
            return;
        }

        if (activeSort.key === 'name' && activeSort.direction === 'asc') {
            sortSelect.value = 'name';
            return;
        }

        if (activeSort.key === 'views' && activeSort.direction === 'desc') {
            sortSelect.value = 'popular';
        }
    }

    function renderHeaderSortState() {
        headerSortButtons.forEach(function (button) {
            var key = button.getAttribute('data-sort-key') || '';
            var isActive = key === activeSort.key;
            var headerCell = button.closest('th');

            button.classList.toggle('is-active', isActive);
            button.classList.toggle('is-asc', isActive && activeSort.direction === 'asc');
            button.classList.toggle('is-desc', isActive && activeSort.direction === 'desc');

            if (headerCell) {
                headerCell.setAttribute('aria-sort', isActive ? (activeSort.direction === 'asc' ? 'ascending' : 'descending') : 'none');
            }
        });
    }

    function appendPageButton(pageNumber) {
        var item = document.createElement(pageNumber === currentPage ? 'span' : 'button');

        item.textContent = String(pageNumber);
        item.className = pageNumber === currentPage ? 'gcc-dashboard-table-card__page-current' : 'gcc-dashboard-table-card__page';

        if (pageNumber !== currentPage) {
            item.type = 'button';
            item.setAttribute('data-page', String(pageNumber));
            item.addEventListener('click', function (event) {
                currentPage = parseInt(event.currentTarget.getAttribute('data-page'), 10);
                render();
            });
        }

        pagination.appendChild(item);
    }

    function appendEllipsis() {
        var ellipsis = document.createElement('span');
        ellipsis.className = 'gcc-dashboard-table-card__ellipsis';
        ellipsis.textContent = '...';
        pagination.appendChild(ellipsis);
    }

    function renderPagination(totalPages) {
        pagination.innerHTML = '';

        if (totalPages <= 1) {
            var single = document.createElement('span');
            single.className = 'gcc-dashboard-table-card__page-current';
            single.textContent = '1';
            pagination.appendChild(single);
            return;
        }

        var prev = document.createElement('button');
        prev.type = 'button';
        prev.className = 'gcc-dashboard-table-card__page';
        prev.textContent = '‹';
        prev.disabled = currentPage === 1;
        prev.addEventListener('click', function () {
            if (currentPage > 1) {
                currentPage -= 1;
                render();
            }
        });
        pagination.appendChild(prev);

        if (totalPages <= 5) {
            for (var page = 1; page <= totalPages; page++) {
                appendPageButton(page);
            }
        } else if (currentPage <= 3) {
            appendPageButton(1);
            appendPageButton(2);
            appendPageButton(3);
            appendEllipsis();
            appendPageButton(totalPages);
        } else if (currentPage >= totalPages - 2) {
            appendPageButton(1);
            appendEllipsis();
            appendPageButton(totalPages - 2);
            appendPageButton(totalPages - 1);
            appendPageButton(totalPages);
        } else {
            appendPageButton(1);
            appendEllipsis();
            appendPageButton(currentPage - 1);
            appendPageButton(currentPage);
            appendPageButton(currentPage + 1);
            appendEllipsis();
            appendPageButton(totalPages);
        }

        var next = document.createElement('button');
        next.type = 'button';
        next.className = 'gcc-dashboard-table-card__page';
        next.textContent = '›';
        next.disabled = currentPage === totalPages;
        next.addEventListener('click', function () {
            if (currentPage < totalPages) {
                currentPage += 1;
                render();
            }
        });
        pagination.appendChild(next);
    }

    function render() {
        var query = (searchInput.value || '').toLowerCase().trim();
        var pageSize = parseInt(pageSizeSelect.value, 10) || 10;
        var rows = allRows.filter(function (row) {
            return !query || (row.dataset.name || '').indexOf(query) !== -1;
        });

        rows.sort(function (a, b) {
            return compareRows(a, b, activeSort.key, activeSort.direction);
        });

        rows.forEach(function (row) {
            tbody.appendChild(row);
            row.style.display = 'none';
        });

        var totalPages = Math.max(1, Math.ceil(rows.length / pageSize));

        if (currentPage > totalPages) {
            currentPage = totalPages;
        }

        var start = (currentPage - 1) * pageSize;
        var end = start + pageSize;

        rows.slice(start, end).forEach(function (row) {
            row.style.display = '';
        });

        if (resultsCount) {
            var resultsLabel = resultsCount.getAttribute('data-results-label') || 'Results';
            resultsCount.textContent = String(rows.length) + ' ' + resultsLabel;
        }

        syncSortSelect();
        renderHeaderSortState();
        renderPagination(totalPages);
    }

    root.addEventListener('click', function (event) {
        var toggle = event.target.closest('[data-role="product-toggle"]');

        if (!toggle || !root.contains(toggle)) {
            return;
        }

        event.preventDefault();
        event.stopPropagation();

        var productWrap = toggle.closest('.gcc-dashboard-table__product-wrap');
        var text = productWrap ? productWrap.querySelector('[data-role="product-text"]') : null;

        if (!text) {
            return;
        }

        var isExpanded = text.getAttribute('data-expanded') === '1';
        text.textContent = isExpanded ? (text.getAttribute('data-short-name') || '') : (text.getAttribute('data-full-name') || '');
        text.setAttribute('data-expanded', isExpanded ? '0' : '1');
        toggle.textContent = isExpanded ? (toggle.getAttribute('data-more-label') || 'Read more') : (toggle.getAttribute('data-less-label') || 'Read less');
    });

    headerSortButtons.forEach(function (button) {
        button.addEventListener('click', function () {
            var sortKey = button.getAttribute('data-sort-key') || 'views';
            var defaultDirection = button.getAttribute('data-default-direction') || 'asc';

            if (activeSort.key === sortKey) {
                activeSort.direction = activeSort.direction === 'asc' ? 'desc' : 'asc';
            } else {
                activeSort.key = sortKey;
                activeSort.direction = defaultDirection;
            }

            currentPage = 1;
            render();
        });
    });

    searchInput.addEventListener('input', function () {
        currentPage = 1;
        render();
    });

    sortSelect.addEventListener('change', function () {
        applySortFromSelect();
        currentPage = 1;
        render();
    });

    pageSizeSelect.addEventListener('change', function () {
        currentPage = 1;
        render();
    });

    applySortFromSelect();
    render();
});
</script>
<?php endif; ?>
