<script>
document.addEventListener('DOMContentLoaded',function(){var root=document.querySelector('[data-gcc-dashboard-table]');if(!root){return}var tbody=root.querySelector('[data-role="rows"]');var searchInput=root.querySelector('[data-role="search"]');var sortSelect=root.querySelector('[data-role="sort"]');var pageSizeSelect=root.querySelector('[data-role="page-size"]');var pagination=root.querySelector('[data-role="pagination"]');var allRows=Array.prototype.slice.call(tbody.querySelectorAll('tr[data-row]'));var currentPage=1;function compareRows(a,b,mode){if(mode==='price_high'){return parseFloat(b.dataset.price||'0')-parseFloat(a.dataset.price||'0')}if(mode==='price_low'){return parseFloat(a.dataset.price||'0')-parseFloat(b.dataset.price||'0')}if(mode==='name'){return(a.dataset.name||'').localeCompare(b.dataset.name||'')}return parseFloat(b.dataset.views||'0')-parseFloat(a.dataset.views||'0')}function renderPagination(totalPages){pagination.innerHTML='';if(totalPages<=1){var single=document.createElement('span');single.className='gcc-dashboard-table-card__page-current';single.textContent='1';pagination.appendChild(single);return}var prev=document.createElement('button');prev.type='button';prev.className='gcc-dashboard-table-card__page';prev.textContent='<';prev.disabled=currentPage===1;prev.addEventListener('click',function(){if(currentPage>1){currentPage-=1;render()}});pagination.appendChild(prev);for(var page=1;page<=totalPages;page++){var item=document.createElement(page===currentPage?'span':'button');item.textContent=String(page);item.className=page===currentPage?'gcc-dashboard-table-card__page-current':'gcc-dashboard-table-card__page';if(page!==currentPage){item.type='button';item.setAttribute('data-page',String(page));item.addEventListener('click',function(event){currentPage=parseInt(event.currentTarget.getAttribute('data-page'),10);render()})}pagination.appendChild(item)}var next=document.createElement('button');next.type='button';next.className='gcc-dashboard-table-card__page';next.textContent='>';next.disabled=currentPage===totalPages;next.addEventListener('click',function(){if(currentPage<totalPages){currentPage+=1;render()}});pagination.appendChild(next)}function render(){var query=(searchInput.value||'').toLowerCase().trim();var sortMode=sortSelect.value||'popular';var pageSize=parseInt(pageSizeSelect.value,10)||10;var rows=allRows.filter(function(row){return!query||(row.dataset.name||'').indexOf(query)!==-1});rows.sort(function(a,b){return compareRows(a,b,sortMode)});rows.forEach(function(row){tbody.appendChild(row);row.style.display='none'});var totalPages=Math.max(1,Math.ceil(rows.length/pageSize));if(currentPage>totalPages){currentPage=totalPages}var start=(currentPage-1)*pageSize;var end=start+pageSize;rows.slice(start,end).forEach(function(row,rowIndex){var indexCell=row.querySelector('[data-role="index"]');row.style.display='';if(indexCell){indexCell.textContent=String(start+rowIndex+1)}});renderPagination(totalPages)}searchInput.addEventListener('input',function(){currentPage=1;render()});sortSelect.addEventListener('change',function(){currentPage=1;render()});pageSizeSelect.addEventListener('change',function(){currentPage=1;render()});render()});
</script>
