}

.gcc-dashboard-table-card__actions{
    margin-left:auto;
    justify-content:flex-end;
    gap:12px;
}

.gcc-dashboard-table-card__search input{
    height:40px;
    border-color:#d9e6f6;
    border-radius:8px;
    color:#173574;
}

.gcc-dashboard-table-card__sort{
    height:40px;
    min-width:156px;
    width:156px;
    flex-basis:156px;
    border-color:#d9e6f6;
    border-radius:8px;
    background:#eef5fd;
    color:#2a59a3;
    font-size:14px;
    font-weight:700;
}

.gcc-dashboard-table-card__body{
    overflow-x:hidden;
    background:#ffffff;
}

.gcc-dashboard-table{
    border-collapse:separate;
    border-spacing:0;
}

.gcc-dashboard-table th{
    padding:16px 14px;
    border-bottom:1px solid #edf3fb;
    border-right:1px solid #edf3fb;
    background:#f9fbfe;
    color:#1e3c83;
    font-size:13px;
    font-weight:800;
}

.gcc-dashboard-table th:last-child{
    border-right:0;
}

.gcc-dashboard-table td{
    padding:18px 14px;
    border-bottom:1px solid #edf3fb;
    border-right:1px solid #edf3fb;
    color:#4a67a1;
    font-size:14px;
    background:#ffffff;
}

.gcc-dashboard-table td:last-child{
    border-right:0;
}

.gcc-dashboard-table tbody tr:last-child td{
    border-bottom:0;
}

.gcc-dashboard-table tbody tr:hover td{
    background:#fcfdff;
}

.gcc-dashboard-table__sort-trigger{
    color:#1e3c83;
}

.gcc-dashboard-table__sort-trigger:hover{
    color:#234f94;
}

.gcc-dashboard-table__index,
.gcc-dashboard-table__price,
.gcc-dashboard-table__rating{
    color:#203b84;
}

.gcc-dashboard-table__product a,
.gcc-dashboard-table__product-link{
    color:#4b63a7;
}

.gcc-dashboard-table__product-toggle{
    color:#2e5ea8;
}

.gcc-dashboard-table__views{
    color:#5b76ae;
}

.gcc-dashboard-table-card__foot{
    padding:16px 20px 18px;
    border-top:1px solid #edf3fb;
    background:#ffffff;
}

@media (max-width:991px){
    .gcc-dashboard-table-card__toolbar{
        flex-direction:column;
        align-items:stretch;
        padding:16px 18px;
        margin:0 -20px;
        gap:14px;
    }

    .gcc-dashboard-table-card__results{
        order:1;
    }

    .gcc-dashboard-table-card__actions{
        order:2;
        margin-left:0;
        justify-content:flex-start;
    }
}

@media (max-width:767px){
    .gcc-dashboard-table-card__head{
