try {
    // Naya updated path Dashboard folder ke saath
    $mostViewedBlock = $block->getLayout()->createBlock(\Gcc\VendorStyles\Block\Dashboard\MostViewed::class);
    $mostViewedProducts = $mostViewedBlock->getMostViewedProducts();
} catch (\Exception $e) {
    $mostViewedProducts = [];
}


try {
    $profileVisitorBlock = $block->getLayout()
        ->createBlock(\Business\VendorVisitorReport\Block\Dashboard\ProfileVisitor::class);
    $profileVisitorCount = (int)$profileVisitorBlock->getTotalVisitors();
} catch (\Exception $e) {
    $profileVisitorCount = 0;
}

$formatMetric = static function ($value) {
    return number_format((float)$value, 0, '.', '.');
};

$truncateDashboardProductName = static function ($value, $limit = 10) {
    $value = (string)$value;

    if (mb_strlen($value) <= $limit) {
        return $value;
    }

    return mb_substr($value, 0, $limit) . '...';
};

$mostViewedTotalCount = $mostViewedProducts ? count($mostViewedProducts) : 0;
