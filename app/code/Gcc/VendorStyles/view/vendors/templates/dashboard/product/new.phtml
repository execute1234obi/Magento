<?php
$truncateRecentText = static function ($value, $limit = 10) {
    $value = trim((string)$value);

    if ($value === '') {
        return '';
    }

    if (mb_strlen($value) <= $limit) {
        return $value;
    }

    return mb_substr($value, 0, $limit) . '...';
};
?>

