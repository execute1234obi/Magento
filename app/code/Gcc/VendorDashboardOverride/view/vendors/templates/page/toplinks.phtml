<?php
/** @var $block \Vnecoms\Vendors\Block\Vendors\Page\Toplinks */

$objectManager = \Magento\Framework\App\ObjectManager::getInstance();
$storeManager = $objectManager->get(\Magento\Store\Model\StoreManagerInterface::class);
$mediaUrl = $storeManager->getStore()->getBaseUrl(\Magento\Framework\UrlInterface::URL_TYPE_MEDIA);
$vendorSession = $objectManager->get(\Vnecoms\Vendors\Model\Session::class);

// --- Initialization with Fallbacks ---
$title = '';
$titleBlock = $block->getLayout()->getBlock('vendor.page.title');
if ($titleBlock) {
    $title = (string)$titleBlock->getTitle();
}

$langLabel = 'Eng';
$avatarUrl = $block->getViewFileUrl('Vnecoms_Vendors::images/user.png');
$vendorName = (string)__('Vendor'); // Default Fallback Name

// ================== VENDOR SESSION CHECK (FIX) ==================
$vendor = $vendorSession->getVendor();
if ($vendor && $vendor->getId()) {
    $vendorName = $vendor->getName();
    $logo = $vendor->getData('upload_logo');
    if ($logo) {
        $avatarUrl = $mediaUrl . $logo;
    }
}

// ================== MESSAGES & NOTIFICATIONS ==================
$messagesBlock = $block->getLayout()->getBlock('vendor.toplinks.messages');
$messagesCount = 0;
$messagesCollection = [];
if ($messagesBlock) {
    $messagesCount = method_exists($messagesBlock, 'getUnreadMessageCount') ? $messagesBlock->getUnreadMessageCount() : 0;
    $messagesCollection = method_exists($messagesBlock, 'getUnreadMessageCollection') ? $messagesBlock->getUnreadMessageCollection() : [];
}

$notificationsBlock = $block->getLayout()->getBlock('vendor.toplinks.notifications');
$notificationsCount = 0;
$notifications = [];
if ($notificationsBlock) {
    $notificationsCount = method_exists($notificationsBlock, 'getNotifiationCount') ? $notificationsBlock->getNotifiationCount() : 0;
    $notifications = method_exists($notificationsBlock, 'getNotificationCollection') ? $notificationsBlock->getNotificationCollection() : [];
}

// ================== WALLET ==================
$walletAmount = '0.00';
$walletBlock = $block->getLayout()->getBlock('vendor.toplinks.credit');
if ($walletBlock && method_exists($walletBlock, 'getCredit')) {
    $walletAmount = $walletBlock->formatCredit($walletBlock->getCredit());
}

// ================== LINKS ==================
$userLinksBlock = $block->getChildBlock('vendor.toplinks.users');
$accountUrl = $userLinksBlock ? $userLinksBlock->getMyAccountLink() : $block->getUrl('account/index');
$buyerDashboardUrl = $block->getBaseUrl() . 'customer/account';
$logoutUrl = $block->getBaseUrl() . 'customer/account/logout/';

// --- Store Switcher Logic ---
$stores = $storeManager->getStores();
$currentStore = $storeManager->getStore();
$currentStoreName = $currentStore->getName();
$currentUrl = $block->getUrl('*/*/*', ['_use_rewrite' => true]);

$homeUrl = '#';
$homepageBlock = $block->getLayout()->getBlock('vendor.toplinks.homepage');
if ($homepageBlock && method_exists($homepageBlock, 'getHomePageUrl')) {
    $homeUrl = $homepageBlock->getHomePageUrl();
}
?>

<nav class="vendor-topbar" aria-label="<?= $block->escapeHtmlAttr(__('Vendor top navigation')); ?>">
    <div class="vendor-topbar__inner">
        <div class="vendor-topbar__desktop">
            <h1 class="vendor-topbar__title"><?= $block->escapeHtml($title); ?></h1>

            <ul class="vendor-topbar__nav">
                <li class="vendor-topbar__item" data-dd>
                    <button class="vendor-topbar__btn" type="button" data-dd-btn>
                        <span class="vendor-lang-badge"><?= $block->escapeHtml(substr($currentStoreName, 0, 2)); ?></span>
                        <span><?= $block->escapeHtml($currentStoreName); ?></span>
                    </button>
                    <div class="vendor-dropdown vendor-dropdown--menu" data-dd-panel>
                        <ul class="vendor-menu">
                            <?php foreach ($stores as $store): ?>
                                <?php if (!$store->isActive() || strtolower($store->getName()) == 'vendor panel') continue; ?>
                                <li>
                                    <a href="<?= $block->escapeUrl($currentUrl . 'config/index/switchlanguage/locale/' . $store->getCode()); ?>">
                                        <?= $block->escapeHtml($store->getName()); ?>
                                    </a>
                                </li>
                            <?php endforeach; ?>
                        </ul>
                    </div>
                </li>

                <li class="vendor-topbar__item">
                    <a class="vendor-topbar__btn vendor-topbar__btn--icon-only" href="<?= $block->escapeUrl($homeUrl); ?>" target="_blank">
                        <span class="vendor-ico"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor"><path d="M3 11l9-8 9 8M5 10v11h14V10" stroke-width="2"/></svg></span>
                    </a>
                </li>

                <li class="vendor-topbar__divider"></li>

                <li class="vendor-topbar__item" data-dd>
                    <button class="vendor-topbar__btn vendor-topbar__btn--icon-only" type="button" data-dd-btn>
                        <span class="vendor-ico"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor"><path d="M4 4h16v16H4V4zM4 7l8 6 8-6" stroke-width="2"/></svg></span>
                        <?php if ($messagesCount > 0): ?>
                            <span class="vendor-badge vendor-badge--green"><?= (int)$messagesCount; ?></span>
                        <?php endif; ?>
                    </button>
                    <div class="vendor-dropdown" data-dd-panel>
                        <div class="vendor-dropdown__head">
                            <div class="vendor-dropdown__title"><?= __('Messages'); ?></div>
                        </div>
                        <ul class="vendor-dropdown__list">
                            <?php if (empty($messagesCollection) || (is_object($messagesCollection) && !$messagesCollection->getSize())): ?>
                                <li><div class="vendor-dropdown__row"><?= __('No messages found'); ?></div></li>
                            <?php else: ?>
                                <?php foreach ($messagesCollection as $message): ?>
                                    <?php $detail = $message->getLastMessageDetail(); ?>
                                    <li>
                                        <a class="vendor-dropdown__row" href="<?= $messagesBlock ? $block->escapeUrl($messagesBlock->getViewMessageUrl($message)) : '#' ?>">
                                            <div class="vendor-row__main">
                                                <div class="vendor-row__name"><?= $block->escapeHtml($detail->getSenderName()); ?></div>
                                                <div class="vendor-row__desc"><?= $block->escapeHtml($detail->getSubject()); ?></div>
                                            </div>
                                        </a>
                                    </li>
                                <?php endforeach; ?>
                            <?php endif; ?>
                        </ul>
                    </div>
                </li>
                <!-- ================== NOTIFICATIONS ================== -->
                <li class="vendor-topbar__item" data-dd>

                    <button class="vendor-topbar__btn vendor-topbar__btn--icon-only"
                            type="button"
                            data-dd-btn
                            aria-haspopup="true"
                            aria-expanded="false"
                            aria-label="<?= $block->escapeHtmlAttr(__('Notifications')); ?>">

                        <!-- ICON -->
                        <span class="vendor-ico" aria-hidden="true">
                            <svg viewBox="0 0 24 24" fill="none">
                                <path d="M18 8a6 6 0 10-12 0c0 7-3 7-3 7h18s-3 0-3-7"
                                    stroke-width="2"
                                    stroke-linecap="round"
                                    stroke-linejoin="round"></path>
                                <path d="M13.73 21a2 2 0 01-3.46 0"
                                    stroke-width="2"
                                    stroke-linecap="round"></path>
                            </svg>
                        </span>

                        <!-- BADGE COUNT -->
                        <?php if ($notificationsCount > 0): ?>
                            <span class="vendor-badge vendor-badge--orange">
                                <?= (int)$notificationsCount; ?>
                            </span>
                        <?php endif; ?>

                    </button>

                    <!-- DROPDOWN -->
                    <div class="vendor-dropdown" data-dd-panel>

                        <!-- HEADER -->
                        <div class="vendor-dropdown__head">
                            <div class="vendor-dropdown__title">
                                <?= $block->escapeHtml(__('Notifications')); ?>
                            </div>

                            <?php if ($notificationsBlock): ?>
                                <a class="vendor-dropdown__action"
                                href="<?= $notificationsBlock->getMarkAllAsReadUrl(); ?>">
                                    <?= $block->escapeHtml(__('Mark all as read')); ?>
                                </a>
                            <?php endif; ?>
                        </div>

                        <!-- LIST -->
                        <ul class="vendor-dropdown__list">

                            <?php if (!count($notifications)): ?>
                                <li>
                                    <div class="vendor-dropdown__row">
                                        <?= $block->escapeHtml(__('You have no notifications')); ?>
                                    </div>
                                </li>
                            <?php endif; ?>

                            <?php foreach ($notifications as $notification): ?>
                                <?php $type = $notification->getNotificationType(); ?>

                                <li class="<?= !$notification->getData('is_read') ? 'unread' : '' ?>">
                                    <a class="vendor-dropdown__row"
                                    href="<?= $notificationsBlock->getViewUrl($notification); ?>">

                                        <div class="vendor-row__icon" aria-hidden="true">
                                            <i class="<?= $type->getIconClass(); ?>"></i>
                                        </div>

                                        <div class="vendor-row__main">
                                            <div class="vendor-row__top">

                                                <div class="vendor-row__name">
                                                    <?= $type->getTitle() ?: __('Notification'); ?>
                                                </div>

                                                <div class="vendor-row__time">
                                                    <?= __('Now'); ?>
                                                </div>

                                            </div>

                                            <div class="vendor-row__desc">
                                                <?= $type->getMessage(); ?>
                                            </div>
                                        </div>

                                    </a>
                                </li>
                            <?php endforeach; ?>

                        </ul>

                        <!-- FOOTER -->
                        <div class="vendor-dropdown__footer">
                            <?php if ($notificationsBlock): ?>
                                <a href="<?= $notificationsBlock->getViewAllUrl(); ?>">
                                    <?= $block->escapeHtml(__('View All Notifications')); ?>
                                </a>
                            <?php endif; ?>
                        </div>

                    </div>

                </li>
                <li class="vendor-topbar__item" data-dd>
                    <button class="vendor-topbar__btn" type="button" data-dd-btn>
                        <span class="vendor-ico"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor"><path d="M3 7h18v14H3V7ZM3 7l2-4h16v4M16 14h5" stroke-width="2"/></svg></span>
                        <span class="vendor-wallet-value"><?= $block->escapeHtml($walletAmount); ?></span>
                    </button>
                    <div class="vendor-dropdown vendor-dropdown--menu" data-dd-panel>
                        <ul class="vendor-menu">
                            <?= $walletBlock ? $walletBlock->getChildHtml('credit_dropdown_item') : '<li><span>No Data</span></li>'; ?>
                        </ul>
                    </div>
                </li>

                <li class="vendor-topbar__item" data-dd>
                    <button class="vendor-topbar__btn" type="button" data-dd-btn>
                        <span class="vendor-avatar"><img src="<?= $block->escapeUrl($avatarUrl) ?>" alt=""></span>
                        <span><?= $block->escapeHtml($vendorName) ?></span>
                    </button>
                    <div class="vendor-dropdown vendor-dropdown--menu" data-dd-panel role="menu">
                        <ul class="vendor-menu">
                            <li><a href="<?= $block->escapeUrl($accountUrl) ?>">Vendor Information</a></li>
                            <li><a href="<?= $block->escapeUrl($buyerDashboardUrl) ?>">Buyer Dashboard</a></li>
                            <li><hr class="vendor-menu-divider"></li>
                            <li><a href="<?= $block->escapeUrl($logoutUrl) ?>" style="color:#ef4444;">Logout</a></li>
                        </ul>
                    </div>
                </li>
            </ul>
        </div>
        
        <div class="vendor-mobile-topbar">
            </div>
    </div>
</nav>