<script>
require(['jquery'], function ($) {
  const $doc = $(document);

  function closeAll() {
    $('[data-dd]').removeClass('is-open')
      .find('[data-dd-btn]').attr('aria-expanded', 'false');
  }

  $doc.on('click', '[data-dd-btn]', function (e) {
    e.preventDefault();
    e.stopPropagation();

    const $item = $(this).closest('[data-dd]');
    const isOpen = $item.hasClass('is-open');

    closeAll();
    if (!isOpen) {
      $item.addClass('is-open');
      $(this).attr('aria-expanded', 'true');
    }
  });

  $doc.on('click', function (e) {
    if ($(e.target).closest('[data-dd]').length === 0) closeAll();
  });

  $doc.on('keydown', function (e) {
    if (e.key === 'Escape') closeAll();
  });
});
</script>
