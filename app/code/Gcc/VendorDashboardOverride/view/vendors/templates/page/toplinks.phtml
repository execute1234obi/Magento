$messagesCount = 0;

if ($messagesBlock) {
    $messagesCount = (int)$messagesBlock->getUnreadMessageCount();
}

// ================== NOTIFICATIONS ==================
$notificationsBlock = $block->getLayout()->getBlock('vendor.toplinks.notifications');
$notificationsCount = 0;

if ($notificationsBlock) {
    // method name module ke hisaab se change ho sakta hai
    if (method_exists($notificationsBlock, 'getUnreadNotificationCount')) {
        $notificationsCount = (int)$notificationsBlock->getUnreadNotificationCount();
    } elseif (method_exists($notificationsBlock, 'getUnreadCount')) {
        $notificationsCount = (int)$notificationsBlock->getUnreadCount();
    }
}

// ================== WALLET ==================
$walletBlock = $block->getLayout()->getBlock('vendor.toplinks.wallet');
$walletAmount = '';

if ($walletBlock) {
    if (method_exists($walletBlock, 'getFormattedBalance')) {
        $walletAmount = $walletBlock->getFormattedBalance();
    } elseif (method_exists($walletBlock, 'getBalance')) {
        $walletAmount = $walletBlock->getBalance();
    }
}
$langLabel = 'Eng';

$userLinksBlock = $block->getChildBlock('vendor.toplinks.users');
$vendorName = (string)__('Vendor');
$accountUrl = $block->getUrl('account');
$buyerDashboardUrl = $block->getBaseUrl() . 'customer/account';
$logoutUrl = $block->getUrl('account/logout');

if ($userLinksBlock) {
    $vendor = $userLinksBlock->getVendor();
    $user = $userLinksBlock->getUser();

    if ($vendor && $vendor->getName()) {
        $vendorName = (string)$vendor->getName();
    } elseif ($user && $user->getName()) {
        $vendorName = (string)$user->getName();
    }

    $accountUrl = $userLinksBlock->getMyAccountLink();
    $logoutUrl = $userLinksBlock->getLogoutLink();

    if ($userLinksBlock->canShowBuyerDashboardLink()) {
        $buyerDashboardUrl = $userLinksBlock->getBuyerDashboardUrl();
    }
}

$avatarUrl = $block->getViewFileUrl('Vnecoms_Vendors::images/user.png');
$vendorInitials = '';
$vendorWords = preg_split('/\s+/', trim((string)$vendorName));

foreach ($vendorWords as $vendorWord) {
    if ($vendorWord === '') {
        continue;
    }

    $vendorInitials .= strtoupper(substr($vendorWord, 0, 1));
    if (strlen($vendorInitials) >= 2) {
        break;
    }
}

if ($vendorInitials === '') {
    $vendorInitials = strtoupper(substr(preg_replace('/[^A-Za-z0-9]/', '', (string)$vendorName), 0, 2));
}
