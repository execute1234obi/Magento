<script>
require(['jquery'], function ($) {
  function setSelectedName($field, fileName) {
    var $selected = $field.find('[data-upload-selected]');
    if ($selected.length) {
      $selected.text(fileName || '');
    }
  }

  function setDragState($dropzone, state) {
    $dropzone.toggleClass('is-dragover', !!state);
  }

  function syncSectionTitle() {
    var $active = $('.vendor-account-menu .nav.nav-tabs > li.active > a, .vendor-account-menu .nav.nav-tabs > li.ui-state-active > a, .vendor-account-menu .nav.nav-tabs > li.ui-tabs-active > a, .vendor-account-menu .nav.nav-tabs > li[aria-selected="true"] > a')
      .first();

    if (!$active.length) {
      $active = $('.vendor-account-menu .nav.nav-tabs > li > a[aria-selected="true"]').first();
    }

    if ($active.length) {
      var title = $.trim($active.text() || $active.attr('title') || '');
      $('[data-section-title]').text(title);
      syncBusinessAddressMap(title);
    }
  }

  function getBusinessAddressMapQuery() {
    var parts = [
      $('#vendor_street').val(),
      $('#vendor_city').val(),
      $('#vendor_region').val(),
      $('#vendor_postcode').val(),
      $('#vendor_country_id option:selected').text()
    ];
    var query = [];

    $.each(parts, function (_, value) {
      value = $.trim(value || '');
      if (value) {
        query.push(value);
      }
    });

    return query.length ? query.join(', ') : 'United Arab Emirates';
  }

  function updateBusinessAddressMap() {
    var $map = $('[data-business-address-map].is-visible');

    if (!$map.length) {
      return;
    }

    var query = getBusinessAddressMapQuery();
    var linkUrl = 'https://www.google.com/maps/search/?api=1&query=' + encodeURIComponent(query);
    var $frame = $map.find('[data-business-address-map-frame]');
    var $link = $map.find('[data-business-address-map-link]');

    if ($frame.length) {
      $frame.attr('data-map-query', query);
      $frame.attr('title', query ? query + ' - ' + <?= json_encode(__('Business Address Map')) ?> : <?= json_encode(__('Business Address Map')) ?>);
    }

    if ($link.length) {
      $link.attr('href', linkUrl);
    }
  }

  function syncBusinessAddressMap(title) {
    var isAddressTab = /Business Address/i.test(title || '');
    var $map = $('[data-business-address-map]');

    if (!$map.length) {
      return;
    }

    if (isAddressTab) {
      $map.addClass('is-visible');
      $map.attr('aria-hidden', 'false');
      window.setTimeout(updateBusinessAddressMap, 50);
    } else {
      $map.removeClass('is-visible');
      $map.attr('aria-hidden', 'true');
    }
  }

  syncSectionTitle();

  $(document).on('click', '.vendor-account-menu .nav.nav-tabs > li > a', function () {
    window.setTimeout(syncSectionTitle, 50);
  });

  $(document).on('tabsactivate shown.bs.tab', syncSectionTitle);
  $(document).on('input change', '#vendor_street, #vendor_city, #vendor_region, #vendor_postcode, #vendor_country_id', updateBusinessAddressMap);

  $(document)
    .on('change', '.vendor-upload-field__input', function () {
      var fileName = '';

      if (this.files && this.files.length) {
        fileName = this.files[0].name || '';
      } else if (this.value) {
        fileName = this.value.split('\\').pop().split('/').pop();
      }

      setSelectedName($(this).closest('.vendor-upload-field'), fileName);
    })
    .on('dragenter dragover', '[data-upload-dropzone]', function (event) {
      event.preventDefault();
      event.stopPropagation();
      setDragState($(this), true);
    })
    .on('dragleave dragend', '[data-upload-dropzone]', function (event) {
      event.preventDefault();
      event.stopPropagation();
      setDragState($(this), false);
    })
    .on('drop', '[data-upload-dropzone]', function (event) {
      var originalEvent = event.originalEvent || event;
      var dataTransfer = originalEvent.dataTransfer;
      var files = dataTransfer && dataTransfer.files ? dataTransfer.files : null;
      var input = this.querySelector('.vendor-upload-field__input');

      event.preventDefault();
      event.stopPropagation();
      setDragState($(this), false);

      if (!input || !files || !files.length) {
        return;
      }

      try {
        if (window.DataTransfer) {
          var transfer = new DataTransfer();
          Array.prototype.forEach.call(files, function (file) {
            transfer.items.add(file);
          });
          input.files = transfer.files;
        } else {
          input.files = files;
        }
      } catch (error) {
        return;
      }

      $(input).trigger('change');
    });
});
</script>
