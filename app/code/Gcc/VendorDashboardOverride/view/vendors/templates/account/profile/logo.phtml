d<?php
$objectManager = \Magento\Framework\App\ObjectManager::getInstance();
$storeManager = $objectManager->get(\Magento\Store\Model\StoreManagerInterface::class);
$mediaUrl = $storeManager->getStore()->getBaseUrl(\Magento\Framework\UrlInterface::URL_TYPE_MEDIA);

$logoUrl = $block->getLogoUrl();
$vendor = $block->getVendor();

if ($vendor && $vendor->getId()) {
    $uploadLogo = trim((string) $vendor->getData('upload_logo'));
    if ($uploadLogo !== '') {
        if (preg_match('#^https?://#i', $uploadLogo)) {
            $logoUrl = $uploadLogo;
        } else {
            $logoUrl = $mediaUrl . ltrim($uploadLogo, '/');
        }
    }
}
?>

<img class="profile-user-img img-responsive img-circle"
     title="<?= $block->escapeHtmlAttr($block->getStoreName()) ?>"
     alt="<?= $block->escapeHtmlAttr($block->getStoreName()) ?>"
     src="<?= $block->escapeUrl($logoUrl) ?>" />
