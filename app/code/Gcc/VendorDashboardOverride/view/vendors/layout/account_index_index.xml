<?xml version="1.0"?>
<page xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
layout="vendor-1column"
xsi:noNamespaceSchemaLocation="urn:magento:framework:View/Layout/etc/page_configuration.xsd">

    <body>

        <referenceBlock name="vendor.myaccount.left.profile.logo">
            <action method="setTemplate">
                <argument name="template" xsi:type="string">
                    Gcc_VendorDashboardOverride::account/profile/logo.phtml
                </argument>
            </action>
        </referenceBlock>
         <!-- Sales override -->
        <referenceBlock name="vendor.myaccount.left.profile.salescount">
            <action method="setTemplate">
                <argument name="template" xsi:type="string">
                    Gcc_VendorDashboardOverride::account/profile/sales.phtml
                </argument>
            </action>
        </referenceBlock>
          <!-- title override -->
        <referenceBlock name="vendor.myaccount.left.profile.title">
            <action method="setTemplate">
                <argument name="template" xsi:type="string">
                    Gcc_VendorDashboardOverride::account/profile/title.phtml
                </argument>
            </action>
        </referenceBlock>
    </body>

</page>