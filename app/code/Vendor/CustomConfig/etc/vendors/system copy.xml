<?xml version="1.0"?>
<config xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
        xsi:noNamespaceSchemaLocation="urn:magento:module:Magento_Config:etc/system_file.xsd">

    <system>
        <tab id="general" translate="label" sortOrder="10">
            <label>General</label>
        </tab>

        <!-- Store Information Section -->
        <section id="general" translate="label" type="text" sortOrder="10" showInDefault="1" showInStore="1">
            <label>General</label>
            <tab>general</tab>
            <resource>Vnecoms_VendorsConfig::general</resource>

            <group id="store_information" translate="label tooltip" type="text" sortOrder="10" showInDefault="1" showInStore="1">
                <label>Store Information</label>

                <!-- Banner (reuse Vnecoms "logo" field but rename) -->
                <field id="logo" translate="label" type="image" sortOrder="10" showInDefault="1">
                    <label>Banner</label>
                    <comment>Allowed file types: PNG, GIF, JPG, JPEG</comment>
                     <backend_model>Vendor\CustomConfig\Model\Config\Backend\SyncVendorData</backend_model>
                    <upload_dir config="system/filesystem/media" scope_info="1">ves_vendors/logo</upload_dir>
                    <base_url type="media">ves_vendors/logo</base_url>
                </field>

                <!-- Business Name (reuse "name") -->
                <field id="name" translate="label" type="text" sortOrder="20" showInDefault="1" showInStore="1">
                    <label>Business Name</label>
                     <backend_model>Vendor\CustomConfig\Model\Config\Backend\SyncVendorData</backend_model>
                </field>

               <field id="short_description" translate="label" type="textarea" sortOrder="30" showInDefault="1" showInStore="1">
    <label>About Store</label>
     <backend_model>Vendor\CustomConfig\Model\Config\Backend\SyncVendorData</backend_model>
</field>


                <!-- Business Website (reuse "phone" field, just relabel) -->
                <field id="phone" translate="label" type="text" sortOrder="40" showInDefault="1" showInStore="1">
                    <label>Business Website</label>
                     <backend_model>Vendor\CustomConfig\Model\Config\Backend\SyncVendorData</backend_model>
                </field>

                <!-- Contact Information (new textarea) -->
                <field id="contact_information" translate="label" type="textarea" sortOrder="50" showInDefault="1" showInStore="1">
                    <label>Contact Information</label>
                    <comment>Enter details like Contact Name, Phone, Email</comment>
                </field>
               <field id="hours" translate="label" type="hidden" sortOrder="999" showInDefault="0" showInStore="0">
    <label>Hidden</label>
</field>

            </group>
           <group id="locale" translate="label" sortOrder="20"
       showInDefault="0" showInWebsite="0" showInStore="0" >
    <label>Hidden</label>
</group>
        </section>
    
    </system>
</config>
