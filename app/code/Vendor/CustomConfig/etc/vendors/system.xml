        <section id="vendor_language" translate="label" sortOrder="20" showInDefault="1" showInStore="1">
            <label>Language</label>
            <tab>vendor_local</tab>
            <resource>Vnecoms_VendorsConfig::general</resource>
            <group id="locale" translate="label" sortOrder="10" showInDefault="1" showInStore="1">
                <label>Locale Options</label>
                <field id="locale_code" translate="label" type="select" sortOrder="10" showInDefault="1" showInStore="1">
                    <label>Locale</label>
                    <source_model>Vnecoms\VendorsLanguage\Model\Config\Source\Locale</source_model>
                </field>
            </group>
