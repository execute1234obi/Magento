<?xml version="1.0"?>
<config xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
        xsi:noNamespaceSchemaLocation="urn:magento:module:Magento_Config:etc/system_file.xsd">

    <system>

        <!-- MOVE ORIGINAL SECTION under NEW TAB -->
         <tab id="vendor_config" translate="label" sortOrder="200">
            <label>Vendor</label>
        </tab>
         <!-- CREATE LANGUAGE TAB -->
        <tab id="vendor_local" translate="label" sortOrder="300">
            <label>Language</label>
        </tab>
        <tab id="general" remove="true"/>
        <!-- 
             NEW GENERAL SECTION (UNDER VENDOR TAB)
             -->
        <section id="vendor_general" translate="label" sortOrder="10"
                 showInDefault="1" showInStore="1">
            <label>Seller's Page</label>
            <tab>vendor_config</tab>
            <resource>Vnecoms_VendorsConfig::general</resource>

            <!-- =====================
                 GROUP: GENERAL INFO
                 ===================== -->
            <group id="general_info" translate="label" sortOrder="10"
                   showInDefault="1" showInStore="1">
                <label>General</label>

                <!-- Logo -->
                <field id="upload_logo" translate="label" type="image"
                       sortOrder="10" showInDefault="1" showInStore="1">
                    <label>Logo</label>
                    <comment>Allowed file types: PNG, GIF, JPG, JPEG</comment>
                    <backend_model>Vendor\CustomConfig\Model\Config\Backend\VendorLogo</backend_model>
                    <upload_dir config="system/filesystem/media" scope_info="1">
                        ves_vendors/attribute/upload_logo
                    </upload_dir>
                </field>

                <!-- Business Name -->
                <field id="b_name" translate="label" type="text"
                       sortOrder="20" showInDefault="1" showInStore="1">
                    <label>Business Name</label>
                    <backend_model>Vendor\CustomConfig\Model\Config\Backend\StoreBusinessName</backend_model>
                </field>

                <!-- Banner -->
                <field id="upload_banner" translate="label" type="image"
                       sortOrder="30" showInDefault="1" showInStore="1">
                    <label>Banner</label>
                    <comment>Allowed file types: PNG, GIF, JPG, JPEG</comment>
                    <backend_model>Vnecoms\VendorsConfig\Model\Config\Backend\Image</backend_model>
                    <upload_dir config="system/filesystem/media" scope_info="1">ves_vendors/banner</upload_dir>
                    <base_url type="media">ves_vendors/banner</base_url>
                </field>

                <!-- About Store -->
                <field id="short_description" translate="label" type="textarea"
                       sortOrder="40" showInDefault="1" showInStore="1">
                    <label>About Store</label>
                    <backend_model>Vendor\CustomConfig\Model\Config\Backend\StoreDescription</backend_model>
                </field>

                <!-- Website -->
                <field id="website" translate="label" type="text"
                       sortOrder="50" showInDefault="1" showInStore="1">
                    <label>Business Website</label>
                    <backend_model>Vendor\CustomConfig\Model\Config\Backend\Website</backend_model>
                </field>

                <!-- Contact Information -->
                <field id="contact_information" translate="label" type="textarea"
                       sortOrder="60" showInDefault="1" showInStore="1">
                    <label>Contact Information</label>
                    <comment>Enter details like Contact Name, Phone, Email</comment>
                </field>

            </group>

            <!-- =====================
                 GROUP: UPLOAD CERTIFICATES
                 ===================== -->
            <group id="upload_certificates" translate="label" sortOrder="20"
                   showInDefault="1" showInStore="1">
                <label>Upload Certificates</label>

                <field id="certificate_pdf" translate="label" type="image"
                       sortOrder="10" showInDefault="1" showInStore="1">
                    <label>Upload Certificate PDF</label>
                    <backend_model>Vendor\CustomConfig\Model\Config\Backend\VendorPdf</backend_model>
                    <frontend_model>Vendor\CustomConfig\Block\Adminhtml\System\Config\Form\Field\PdfDownload</frontend_model>
                    <upload_dir config="system/filesystem/media" scope_info="1">
                        ves_vendors/attribute/certificate
                    </upload_dir>
                    <base_url type="media" scope_info="1">ves_vendors/attribute/certificate</base_url>
                </field>

            </group>

            <!-- =====================
                 GROUP: UPLOAD CATALOG
                 ===================== -->
           <group id="upload_catalog" translate="label" sortOrder="30"
    showInDefault="1" showInStore="1">
    <label>Upload Catalog</label>

     <!-- <field id="catalog_title" translate="label" type="text"
           sortOrder="5" showInDefault="1" showInStore="1">
        <label>Catalog Title</label>
        <backend_model>Vendor\CustomConfig\Model\Config\Backend\VendorCatalogTitle</backend_model>
    </field> -->

    <field id="catalog_file" translate="label" type="image"
            sortOrder="10" showInDefault="1" showInStore="1">
        <label>Upload Catalog</label>
        <comment>Allowed file types: PDF</comment>
        <backend_model>Vendor\CustomConfig\Model\Config\Backend\VendorCatalogPdf</backend_model>
        <upload_dir config="system/filesystem/media" scope_info="1">
            ves_vendors/attribute/catalog
        </upload_dir>
        <base_url type="media" scope_info="1">ves_vendors/attribute/catalog</base_url>
    </field>

</group>
            <!-- =====================
                 GROUP: LOCATION MAP
                 ===================== -->
            <group id="location_map" translate="label" sortOrder="40"
                   showInDefault="1" showInStore="1">
                <label>Location Map</label>

                <field id="map" translate="label" type="text"
                       sortOrder="10" showInDefault="1" showInStore="1">
                    <label>Location Map</label>
                </field>
            </group>

        </section>
       <!-- 
             MASS IMPORT/EXPORT SECTION
             -->
             <section id="vendor_import" translate="label" sortOrder="10" showInDefault="1" showInStore="1">
<label>Mass Import/Export</label>
<tab>vendor_config</tab>
 <resource>Vnecoms_VendorsConfig::vendor_import</resource>
<group id="general_info1" translate="label" sortOrder="10" showInDefault="1" showInStore="1">
<label>General</label>
<field id="multiple_value_separator" translate="label" type="text" sortOrder="10" showInDefault="1">
 <label>Multiple value separator</label>
  <frontend_class>required-entry</frontend_class>
</field>
 </group> 
</section>       <!-- 
             CATALOG SEARCH SECTION
              -->
        <section id="vendor_catalog" translate="label" sortOrder="30"
                 showInDefault="1" showInStore="1">
            <label>Catalog Search</label>
            <tab>vendor_config</tab>
            <resource>Vnecoms_VendorsConfig::vendor_catalog</resource>

           <group id="general" translate="label tooltip" type="text" sortOrder="10" showInDefault="1">
                <label>General</label>
                
                <field id="show_bread_crumb" translate="label" type="select" sortOrder="40" showInDefault="1">
                    <label>Show Bread Crumb</label>
                    <source_model>Magento\Config\Model\Config\Source\Yesno</source_model>
                </field>
            </group>
            
        </section>
          <!-- ======================
             LANGUAGE SECTION
        ======================= -->
        <section id="vendor_language" translate="label" sortOrder="20"
                 showInDefault="1" showInStore="1">
            <label>Language</label>
            <tab>vendor_local</tab>
            <resource>Vnecoms_VendorsConfig::general</resource>

            <group id="locale" translate="label" sortOrder="10" showInDefault="1" showInStore="1">
                <label>Locale Options</label>

                <field id="locale_code" translate="label" type="select"
                       sortOrder="10" showInDefault="1" showInStore="1">
                    <label>Locale</label>
                    <source_model>Vnecoms\VendorsLanguage\Model\Config\Source\Locale</source_model>
                </field>

            </group>

        </section>
    </system>
</config>
