         <tab id="general">
            <label>Vendor</label>
        </tab>

        <tab id="vendor_local" translate="label" sortOrder="300">
            <label>Language</label>
        </tab>


        <section id="vendor_general" translate="label" sortOrder="10" showInDefault="1" showInStore="1">
            <label>Seller's Page</label>
            <tab>general</tab>
            <resource>Vnecoms_VendorsConfig::general</resource>

            <group id="general_info" translate="label" sortOrder="10" showInDefault="1" showInStore="1">
                <label>General</label>
                <field id="upload_logo" translate="label" type="image" sortOrder="10" showInDefault="1" showInStore="1">
                    <label>Logo</label>
                    <backend_model>Vendor\CustomConfig\Model\Config\Backend\VendorLogo</backend_model>
                    <upload_dir config="system/filesystem/media" scope_info="1">ves_vendors/attribute/upload_logo</upload_dir>
                </field>
                <field id="b_name" translate="label" type="text" sortOrder="20" showInDefault="1" showInStore="1">
                    <label>Business Name</label>
                    <backend_model>Vendor\CustomConfig\Model\Config\Backend\StoreBusinessName</backend_model>
                </field>
                <field id="upload_banner" translate="label" type="image" sortOrder="30" showInDefault="1" showInStore="1">
                    <label>Banner</label>
                    <backend_model>Vnecoms\VendorsConfig\Model\Config\Backend\Image</backend_model>
                    <upload_dir config="system/filesystem/media" scope_info="1">ves_vendors/banner</upload_dir>
                    <base_url type="media">ves_vendors/banner</base_url>
                </field>
                <field id="short_description" translate="label" type="textarea" sortOrder="40" showInDefault="1" showInStore="1">
                    <label>About Store</label>
                    <backend_model>Vendor\CustomConfig\Model\Config\Backend\StoreDescription</backend_model>
                </field>
                <field id="website" translate="label" type="text" sortOrder="50" showInDefault="1" showInStore="1">
                    <label>Business Website</label>
                    <backend_model>Vendor\CustomConfig\Model\Config\Backend\Website</backend_model>
                </field>
                <field id="contact_information" translate="label" type="textarea" sortOrder="60" showInDefault="1" showInStore="1">
                    <label>Contact Information</label>
                </field>
            </group>

            <group id="upload_certificates" translate="label" sortOrder="20" showInDefault="1" showInStore="1">
                <label>Upload Certificates</label>
                <field id="certificate_pdf" translate="label" type="image" sortOrder="10" showInDefault="1" showInStore="1">
                    <label>Upload Certificate PDF</label>
                    <backend_model>Vendor\CustomConfig\Model\Config\Backend\VendorPdf</backend_model>
                    <frontend_model>Vendor\CustomConfig\Block\Adminhtml\System\Config\Form\Field\PdfDownload</frontend_model>
                    <upload_dir config="system/filesystem/media" scope_info="1">ves_vendors/attribute/certificate</upload_dir>
                    <base_url type="media" scope_info="1">ves_vendors/attribute/certificate</base_url>
                </field>
            </group>

            <group id="upload_catalog" translate="label" sortOrder="30" showInDefault="1" showInStore="1">
                <label>Upload Catalog</label>
                <field id="catalog_file" translate="label" type="image" sortOrder="10" showInDefault="1" showInStore="1">
                    <label>Upload Catalog</label>
                    <backend_model>Vendor\CustomConfig\Model\Config\Backend\VendorCatalogPdf</backend_model>
                    <upload_dir config="system/filesystem/media" scope_info="1">ves_vendors/attribute/catalog</upload_dir>
                    <base_url type="media" scope_info="1">ves_vendors/attribute/catalog</base_url>
                </field>
            </group>

            <group id="location_map" translate="label" sortOrder="40" showInDefault="1" showInStore="1">
                <label>Location Map</label>
                <field id="map" translate="label" type="text" sortOrder="10" showInDefault="1" showInStore="1">
                    <label>Location Map</label>
                </field>
            </group>
        </section>

