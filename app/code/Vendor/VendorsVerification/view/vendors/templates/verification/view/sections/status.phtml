<?php
/** @var $block \Vendor\VendorsVerification\Block\Vendors\Verification\View\Verification */

$vendorVerification = $block->getVendorVerification();

if (!$vendorVerification || !$vendorVerification->getId()) {
    return;
}

$verificationId = (int)$vendorVerification->getId();
$summaryData = $block->getVerificationSectionData(
    $verificationId,
    \Vendor\VendorsVerification\Model\Source\InfoGroup::VENDOR_VERIFICATION_DATAGROUP_BUSINESS_INFORMATION
);

$summaryDetailId = ($summaryData && $summaryData->getId())
    ? (int)$summaryData->getDetailId()
    : 0;

$summaryComments = $summaryDetailId
    ? (int)$block->getCommentsCounts(
        $verificationId,
        $summaryDetailId,
        \Vendor\VendorsVerification\Model\Source\InfoGroup::VENDOR_VERIFICATION_DATAGROUP_BUSINESS_INFORMATION
    )
    : 0;

$verificationStatus  = (int) $vendorVerification->getIsVerified();
$paymentStatus       = (int) $vendorVerification->getIsPaid();
$verificationAmount  = $vendorVerification->getAmount();
$verificationMonths  = $vendorVerification->getMonthsBooked();
$verificationFromDate = $vendorVerification->getFromDate();
$verificationToDate   = $vendorVerification->getToDate();

$summaryRowStyle = 'style="border:0 !important;background-color:#f5f8fd !important;background-image:none !important;"';
$summaryLabelCellStyle = 'style="border:0 !important;background-color:#f5f8fd !important;background-image:none !important;color:#7f8fb3;font-weight:500;"';
$summaryValueCellStyle = 'style="border:0 !important;background-color:#f5f8fd !important;background-image:none !important;color:#17315f;font-size:14px;font-weight:700;"';
?>

<section class="verification-card verification-card--summary" style="background-color:#f5f8fd !important;background-image:none !important;border-color:#d8e2ef;">
    <div class="verification-card__head" style="background-color:#f5f8fd !important;background-image:none !important;border-bottom-color:#d8e2ef;">
        <h3><?= __('Verification Details') ?></h3>

        <?php if ($summaryDetailId): ?>
            <button type="button"
                    class="verification-showcomment verification-comments-link"
                    data-verificationid="<?= $verificationId ?>"
                    data-verifidtlid="<?= $summaryDetailId ?>"
                    data-verifigroupid="<?= \Vendor\VendorsVerification\Model\Source\InfoGroup::VENDOR_VERIFICATION_DATAGROUP_BUSINESS_INFORMATION ?>">
                <i class="fa fa-comment"></i>
                <span><?= __('%1 Comments', $summaryComments) ?></span>
            </button>
        <?php endif; ?>
    </div>

    <div class="verification-card__body" style="background-color:#f5f8fd !important;background-image:none !important;">
        <table class="verification-table verification-table--summary" style="border-collapse:separate;border-spacing:0;background-color:#f5f8fd !important;background-image:none !important;">
            <tbody>
                <tr <?= /* @noEscape */ $summaryRowStyle; ?>>
                    <td <?= /* @noEscape */ $summaryLabelCellStyle; ?>><?= __('Verification Status') ?></td>
                    <td <?= /* @noEscape */ $summaryValueCellStyle; ?>><?= /* @noEscape */ $block->getvendorVerificationStatusLabel($verificationStatus); ?></td>
                </tr>
                <tr <?= /* @noEscape */ $summaryRowStyle; ?>>
                    <td <?= /* @noEscape */ $summaryLabelCellStyle; ?>><?= __('Verification Payment Status') ?></td>
                    <td <?= /* @noEscape */ $summaryValueCellStyle; ?>><?= /* @noEscape */ $block->getPaymentStatusLabel($paymentStatus); ?></td>
                </tr>
                <tr <?= /* @noEscape */ $summaryRowStyle; ?>>
                    <td <?= /* @noEscape */ $summaryLabelCellStyle; ?>><?= __('Verification Fees') ?></td>
                    <td <?= /* @noEscape */ $summaryValueCellStyle; ?>><?= /* @noEscape */ $block->getFormatedPrice($verificationAmount); ?></td>
                </tr>
                <tr <?= /* @noEscape */ $summaryRowStyle; ?>>
                    <td <?= /* @noEscape */ $summaryLabelCellStyle; ?>><?= __('Verification Duration') ?></td>
                    <td <?= /* @noEscape */ $summaryValueCellStyle; ?>><?= $block->escapeHtml($block->getVerificationMonthsLabel($verificationMonths)); ?></td>
                </tr>
                <tr <?= /* @noEscape */ $summaryRowStyle; ?>>
                    <td <?= /* @noEscape */ $summaryLabelCellStyle; ?>><?= __('Verification Start Date') ?></td>
                    <td <?= /* @noEscape */ $summaryValueCellStyle; ?>><?= $verificationFromDate ? $block->escapeHtml($block->getFormatedDate($verificationFromDate)) : __('N/A'); ?></td>
                </tr>
                <tr <?= /* @noEscape */ $summaryRowStyle; ?>>
                    <td <?= /* @noEscape */ $summaryLabelCellStyle; ?>><?= __('Verification Expire Date') ?></td>
                    <td <?= /* @noEscape */ $summaryValueCellStyle; ?>><?= $verificationToDate ? $block->escapeHtml($block->getFormatedDate($verificationToDate)) : __('N/A'); ?></td>
                </tr>
            </tbody>
        </table>
    </div>
</section>
