<div class="page-main-actions" style="margin-right:0;margin-left:0;">	 
	<input type="hidden" id="is-certselected" name="is-certselected" value="" /> 		                
 <span class="pull-right" id="verifi-pageno">1/2</span>							
		                   
</div>	

<script>
require(['jquery','Magento_Ui/js/modal/alert','mage/translate','mage/mage'], 
   function ($, uiAlert, $t,$mage) {	
	
	var dataForm = jQuery('#verification-form');
	var ignore = null;	
    dataForm.mage('validation', {});
    $('#mysubmit-button').click( function() { //can be replaced with any event
		var validationFailed = false;		
		if($("#is-certselected").val() == ''){// check Commercial Registration Certificate upload
			validationFailed = true;
			var data = {
                content: $t('Please upload Commercial Registration Certificate.')
            };
            data.modalClass = '_image-box';	 
			uiAlert(data);			
		}
		if(validationFailed){
			return;
		}
       validationFailed = dataForm.validation('isValid'); //validates form and returns boolean
       if(validationFailed){		
		   dataForm.submit();	   	
	   } 
    });	
	   		 
    $(document).ready(function(){
	
	 $(document).on('shown.bs.tab', 'a[data-toggle="tab"]', function (e) {		
		var targetUrl = '' +  e.target;		
		var arrTarget = targetUrl.split("#");
        switch (arrTarget[1]){
         case "section1":{
              $("#verifi-pageno").html("1/2");
              break;
         }
         case "section2":{
              $("#verifi-pageno").html("2/2");
              break;
           }
        }
     })
	     
    $(".verification-nextpage").click(function(){		 
	    var next = jQuery('.nav-tabs > .active').next('li');
         if(next.length){
           next.find('a').trigger('click');           
         }else{
           $('#myTabs a:first').tab('show');
         }		 
	  })
	  
	$(".verification-prevpage").click(function(){		 
		 var prev = jQuery('.nav-tabs > .active').prev('li')
         if(prev.length){
            prev.find('a').trigger('click');            
         }else{
            jQuery('#myTabs a:last').tab('show');
         }
	   }) 
		
     //Business Country drop-down change
     $("#business-country").change(function(){
		 var countryCode =  $(this).val();
		 $("#business-countrycode").val(countryCode);
		 $("#contact-countrycode").val(countryCode);
	  });
  
  });

});

</script>


<script type="text/x-magento-init">
{
".upload-wrapper": {
   "Magento_Ui/js/core/app": {
       "components": {
           "vendorregistcert": {
			   "dataScope": "vendorregistcert",
                "source": "vendorregistcert",                
                "component": "Business_VendorsVerification/js/custom-file-uploader",
                "template": "ui/form/element/uploader/uploader",                
                "previewTmpl":"Business_VendorsVerification/uploader/preview",
                "allowedExtensions": ["png", "jpg", "jpeg", "gif","pdf","doc","docx","pdf"],                
                "isMultipleFiles":false,                 
                "required":true,
                "inputName":"vendorregistcert",
                "maxFileAllow":1,
                "myUploadId":"vendorcert",
               "uploaderConfig": {
                    "url": "<?php echo $block->getUrl('vendorverification/uploader/ajax/',['fldname'=>'vendorregistcert']); ?>"
               },
               "savedFiles":<?php echo $uploaedCertificate;?>               
               
            }
        }
   }
 }
}
</script>
