<?php
$vendor =  $this->getVendor();
$vendorCustomer =  $vendor->getCustomer();
$uploaedCertificate = json_encode([]);
$uploaedLogoOthers = json_encode([]);
$registrationCertificate =  ($vendor->getRegistrationCertificate()!='')? $vendor->getRegistrationCertificate():'';
if($registrationCertificate!=''){
   $attachements = $block->populateAttachements(array($registrationCertificate ));
   //echo "<pre>".print_r($attachements,1)."</pre>";
   $uploaedCertificate =  json_encode($attachements);
}
$registrationLogo =  ($vendor->getLogo()!='')? $vendor->getLogo():'';
if($registrationLogo!=''){
   $otherFiles = $block->populateAttachements(array($registrationLogo));   
   $uploaedLogoOthers =  json_encode($otherFiles);   
}
