<?php
/** @var $block \Vendor\VendorsVerification\Block\Vendors\Verification\View\Verification */

$vendorVerification = $block->getVendorVerification();

if (!$vendorVerification || !$vendorVerification->getId()) {
    return;
}

$verificationId = (int)$vendorVerification->getId();
$verificationData = $block->getVerificationSectionData(
    $verificationId,
    \Vendor\VendorsVerification\Model\Source\InfoGroup::VENDOR_VERIFICATION_DATAGROUP_BUSINESS_INFORMATION
);

if (!$verificationData || !$verificationData->getId()) {
    return;
}

$detail_id = (int)$verificationData->getDetailId();
$arrData = $block->convertVerificationData($verificationData->getData('vendor_data'));

$business_country     = $arrData['country_id'] ?? '';
$business_name        = $arrData['business-name'] ?? '';
$business_description = $arrData['business-description'] ?? '';
$business_website     = $arrData['business-website'] ?? '';
$business_phone       = $arrData['business-phone'] ?? '';
$business_email       = $arrData['business-email'] ?? '';
$businessType         = $arrData['business-type'] ?? ($arrData['business_type'] ?? '');
$businessCategory     = $arrData['business-category'] ?? ($arrData['business_category'] ?? '');
$status               = (int)$verificationData->getStatus();

$businessTypeLabel = $businessType ? $block->getVendorTypeLabelById($businessType) : '';
if ($businessTypeLabel === '') {
    $businessTypeLabel = $businessType;
}

$businessCategoryLabel = $businessCategory ? $block->getVendorCategoryLabelById($businessCategory) : '';
if ($businessCategoryLabel === '') {
    $businessCategoryLabel = $businessCategory;
}

$commentsCount = $block->getCommentsCounts(
    $verificationId,
    $detail_id,
    \Vendor\VendorsVerification\Model\Source\InfoGroup::VENDOR_VERIFICATION_DATAGROUP_BUSINESS_INFORMATION
);
?>

