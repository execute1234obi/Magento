<?php
/** @var $block \Vendor\VendorsVerification\Block\Vendors\Verification\View\Verification */

$vendorVerification = $block->getVendorVerification();

if (!$vendorVerification || !$vendorVerification->getId()) {
    return;
}

$verificationId = (int)$vendorVerification->getId();
$verificationData = $block->getVerificationSectionData(
    $verificationId,
    \Vendor\VendorsVerification\Model\Source\InfoGroup::VENDOR_VERIFICATION_DATAGROUP_BUSINESS_CONTACT
);

if (!$verificationData || !$verificationData->getId()) {
    return;
}

$detail_id = (int)$verificationData->getDetailId();
$arrData = $block->convertVerificationData($verificationData->getData('vendor_data'));

$contact_name  = $arrData['contact_name'] ?? '';
$contact_phone = $arrData['contact_phone'] ?? '';
$contact_email = $arrData['contact_email'] ?? '';
$status        = $verificationData->getStatus();

$commentsCount = $detail_id
    ? (int)$block->getCommentsCounts(
        $verificationId,
        $detail_id,
        \Vendor\VendorsVerification\Model\Source\InfoGroup::VENDOR_VERIFICATION_DATAGROUP_BUSINESS_CONTACT
    )
    : 0;

$sectionRowStyle = 'style="border:0 !important;box-shadow:none !important;background:#ffffff !important;"';
$sectionCellStyle = 'style="border:0 !important;border-top:0 !important;border-bottom:0 !important;box-shadow:none !important;background:#ffffff !important;"';
?>

<section class="verification-card verification-card--section verification-card--contact" style="background-color:#ffffff !important;background-image:none !important;border-color:#d8e2ef !important;">
    <div class="verification-card__head" style="background-color:#ffffff !important;background-image:none !important;border-bottom-color:#dfe8f2 !important;">
        <h3><?= __('Business Contact') ?></h3>

        <div class="verification-card__actions">
            <?php if ($status == \Vendor\VendorsVerification\Model\Source\Status::VENDOR_VERIFICATION_STATUS__RESUBMIT): ?>
                <button type="button"
                        class="verification-edit verification-action-button verification-action-button--edit"
                        data-modal-id="verification-contact-modal">
                    <i class="fa fa-pencil"></i>
                    <span><?= __('Edit') ?></span>
                </button>
            <?php endif; ?>

            <button type="button"
                    class="verification-showcomment verification-comments-link"
                    data-verificationid="<?= $verificationId ?>"
                    data-verifidtlid="<?= $detail_id ?>"
                    data-verifigroupid="<?= \Vendor\VendorsVerification\Model\Source\InfoGroup::VENDOR_VERIFICATION_DATAGROUP_BUSINESS_CONTACT ?>">
                <i class="fa fa-comment"></i>
                <span><?= __('%1 Comments', $commentsCount) ?></span>
            </button>
        </div>
    </div>

    <div class="verification-card__body" style="background-color:#ffffff !important;background-image:none !important;">
        <table class="verification-table" style="border-collapse:separate;border-spacing:0;background:#ffffff !important;border:0 !important;box-shadow:none !important;">
            <tbody>
                <tr <?= /* @noEscape */ $sectionRowStyle; ?>>
                    <td <?= /* @noEscape */ $sectionCellStyle; ?>><?= __('Status') ?></td>
                    <td <?= /* @noEscape */ $sectionCellStyle; ?>><?= $status ? $block->getStatusLabel($status) : __('Not Submitted'); ?></td>
                </tr>
                <tr <?= /* @noEscape */ $sectionRowStyle; ?>>
                    <td <?= /* @noEscape */ $sectionCellStyle; ?>><?= __('Contact Name') ?></td>
                    <td <?= /* @noEscape */ $sectionCellStyle; ?>><?= $contact_name; ?></td>
                </tr>
                <tr <?= /* @noEscape */ $sectionRowStyle; ?>>
                    <td <?= /* @noEscape */ $sectionCellStyle; ?>><?= __('Phone') ?></td>
                    <td <?= /* @noEscape */ $sectionCellStyle; ?>><?= $contact_phone; ?></td>
                </tr>
                <tr <?= /* @noEscape */ $sectionRowStyle; ?>>
                    <td <?= /* @noEscape */ $sectionCellStyle; ?>><?= __('Email') ?></td>
                    <td <?= /* @noEscape */ $sectionCellStyle; ?>><?= $contact_email; ?></td>
                </tr>
            </tbody>
        </table>
    </div>
</section>

<div id="verification-contact-modal" style="display:none;">
    <form class="form verification"
          action="<?php echo $block->getEditActionUrl(
              $verificationId,
              $detail_id,
              \Vendor\VendorsVerification\Model\Source\InfoGroup::VENDOR_VERIFICATION_DATAGROUP_BUSINESS_CONTACT
          ); ?>"
          method="post"
          data-mage-init='{"validation":{}}'>
        <input type="hidden" name="form_key" value="<?= $block->getFormKey() ?>" />
        <legend class="legend"><span><?php echo __('Business Contact') ?></span></legend><br/>

        <div class="row g-3">
            <div class="col-md-6">
                <label for="contact-name"><?php echo __('Contact Name') ?></label>
                <input name="contact_name" id="contact-name"
                       value="<?php echo $contact_name; ?>"
                       class="input-text"
                       type="text"
                       data-validate="{required:true}" />
            </div>
        </div>

        <div class="row g-3">
            <div class="col-md-6">
                <label for="contact-phone"><?php echo __('Phone') ?></label>
                <input name="contact_phone" id="contact-phone"
                       value="<?php echo $contact_phone; ?>"
                       class="input-text"
                       type="text"
                       data-validate="{required:true}" />
            </div>

            <div class="col-md-6">
                <label for="contact-email"><?php echo __('Email') ?></label>
                <input name="contact_email" id="contact-email"
                       value="<?php echo $block->escapeHtml($contact_email); ?>"
                       class="input-text"
                       type="text"
                       data-validate="{required:true,'validate-email':true}" />
            </div>
        </div>

        <div class="page-main-actions">
            <button type="submit" class="btn btn-primary">
                <?php echo __('Update'); ?>
            </button>
        </div>
    </form>
</div>
