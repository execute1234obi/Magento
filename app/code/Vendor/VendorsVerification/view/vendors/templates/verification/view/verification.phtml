<script type="text/javascript">
require(['jquery','Magento_Ui/js/modal/modal'], function ($, modal) {

    $(".verification-edit").on('click', function () {
        var popupDivId = $(this).data('modal-id');
        modal({
            type: 'popup',
            modalClass: 'verification-modal',
            title: $.mage.__('Verification'),
            buttons: [{
                text: $.mage.__('Cancel'),
                click: function () {
                    this.closeModal();
                }
            }]
        }, $('#' + popupDivId)).openModal();
    });

    $(".verification-showcomment").on('click', function () {
        var param = {
            id: $(this).data('verificationid'),
            dataid: $(this).data('verifidtlid'),
            grouptype: $(this).data('verifigroupid'),
            form_key: window.FORM_KEY
        };

        $.ajax({
            showLoader: true,
            url: "<?= $block->getCommentsViewUrl(); ?>",
            data: param,
            type: "GET",
            dataType: 'json',
            success: function (response) {
                if (response.success) {
                    var html = '<h4>' + response.message + '</h4><table class="table">';
                    $.each(response.data, function (k, v) {
                        html += '<tr><td>' + v.comment  + '</td></tr>';
                        
                    });
                    html += '</table>';
                    $("#commentslist_popup").html(html).modal({
                        title: $.mage.__('Admin Comments'),
                        modalClass: 'verification-modal'
                    }).modal('openModal');
                }
            }
        });
    });

});
</script>
