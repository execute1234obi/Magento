<script>
(function () {
    function equalizeVerificationCardHeights() {
        var rows = document.querySelectorAll('.verification-grid--two');

        rows.forEach(function (row) {
            var cards = row.querySelectorAll('.verification-grid__item > .verification-card--section');

            if (!cards.length) {
                return;
            }

            cards.forEach(function (card) {
                card.style.height = 'auto';
            });

            var maxHeight = 0;

            cards.forEach(function (card) {
                maxHeight = Math.max(maxHeight, card.getBoundingClientRect().height);
            });

            cards.forEach(function (card) {
                card.style.height = Math.ceil(maxHeight) + 'px';
            });
        });
    }

    var resizeFrame = null;

    function scheduleEqualize() {
        if (resizeFrame) {
            window.cancelAnimationFrame(resizeFrame);
        }

        resizeFrame = window.requestAnimationFrame(equalizeVerificationCardHeights);
    }

    if (document.readyState === 'loading') {
        document.addEventListener('DOMContentLoaded', scheduleEqualize);
    } else {
        scheduleEqualize();
    }

    window.addEventListener('load', scheduleEqualize);
    window.addEventListener('resize', scheduleEqualize);
})();
</script>

