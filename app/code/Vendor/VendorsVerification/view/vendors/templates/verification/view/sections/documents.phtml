<?php
$certificateFiles = [];
$documentFiles = [];

if (!empty($arrCertDocsData['certificate'])) {
    //'url'  => $mediaUrl . $folderName . $arrCertDocsData['certificate'],
    $certificateFiles[] = [
        'name' => basename($arrCertDocsData['certificate']),
         'url'  => $mediaUrl . $arrCertDocsData['certificate'],
        'size' => 0
    ];
}

if (!empty($arrCertDocsData['documents'])) {
    $docs = is_array($arrCertDocsData['documents'])
        ? $arrCertDocsData['documents']
        : explode(',', $arrCertDocsData['documents']);

    foreach ($docs as $doc) {
        if (trim($doc)) {
            $documentFiles[] = [
                'name' => basename(trim($doc)),
                'url'  => $mediaUrl . trim($doc),
                'size' => 0
            ];
        }
    }
}
?>

<!-- ================= FILE UPLOADER INIT ================= -->
<script type="text/x-magento-init">
{
    "*": {
        "Magento_Ui/js/core/app": {
            "components": {

                "vendor_certificate": {
                    "component": "Vendor_VendorsVerification/js/custom-file-uploader",
                    "template": "ui/form/element/uploader/uploader",
                    "uploaderTmpl": "ui/form/element/uploader/uploader",
                    "dataScope": "certificate",
                    "formElement": "fileUploader",
                    "isMultipleFiles": false,
                    "savedFiles": <?= json_encode($certificateFiles) ?>,
                    "uploaderConfig": {
                        "url": "<?= $block->getUrl(
                            'vendorverification/uploader/ajax',
                            ['fldname' => 'certificate']
                        ) ?>",
                        "fileField": "files"
                    }
                },

                "vendor_documents": {
                    "component": "Vendor_VendorsVerification/js/custom-file-uploader",
                    "template": "ui/form/element/uploader/uploader",
                    "uploaderTmpl": "ui/form/element/uploader/uploader",
                    "dataScope": "documents",
                    "formElement": "fileUploader",
                    "isMultipleFiles": true,
                    "savedFiles": <?= json_encode($documentFiles) ?>,
                    "uploaderConfig": {
                        "url": "<?= $block->getUrl(
                            'vendorverification/uploader/ajax',
                            ['fldname' => 'documents']
                        ) ?>",
                        "fileField": "files"
                    }
                }

            }
        }
    }
}
</script>
<script>
require([
    'jquery',
    'uiRegistry'
], function ($, registry) {

    $('#verification-doc-form').on('submit', function () {

        var cert = registry.get('vendor_certificate');
        var docs = registry.get('vendor_documents');

        // CERTIFICATE (single)
        if (cert && cert.value().length) {
            $('#hidden_certificate').val(cert.value()[0].file);
        }

        // DOCUMENTS (multiple)
        if (docs && docs.value().length) {
            var files = [];
            docs.value().forEach(function (item) {
                files.push(item.file);
            });
            $('#hidden_documents').val(files.join(','));
        }

        return true;
    });
});
</script>

