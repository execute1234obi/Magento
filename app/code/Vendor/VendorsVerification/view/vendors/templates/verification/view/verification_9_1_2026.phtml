<?php
/** ---------------- SAFE VERIFICATION LOAD ---------------- */
$vendorVerification = null;
$verificationIncId  = '';
$hasActiveVerification = false;
$isEntireRejected = false;

try {
    if ($block->isActiveVerificationExit()) {
        $verification = $block->getVendorVerification();
        //echo "Haa exist";die();
        if ($verification && is_object($verification) && $verification->getId()) {
          //  echo "me hu na";die();
            $vendorVerification     = $verification;
            $verificationIncId      = $verification->getIncId();
            $hasActiveVerification  = true;
           if ($vendorVerification->getStatus() == 5) {
            //echo "entire";die();
                $isEntireRejected = true;
                $hasActiveVerification = false;
            } else {
              //  echo "pending"; die();
                // Agar status 1 (Pending) ya kuch aur hai, toh form dikhao
                $isEntireRejected = false;
                $hasActiveVerification = true;
            }
        }
    }
} catch (\Exception $e) {
    $hasActiveVerification = false;
}
