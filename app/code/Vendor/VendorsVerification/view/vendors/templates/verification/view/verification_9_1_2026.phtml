require(['jquery','Magento_Ui/js/modal/modal'], function ($, modal) {

    //console.log('Verification JS loaded');

    /* ================= EDIT MODAL ================= */
    $(document).on('click', '.verification-edit', function () {

        console.log('Edit button clicked');

        var popupDivId = $(this).data('modal-id');
        console.log('Popup Div ID:', popupDivId);

        modal({
            type: 'popup',
            modalClass: 'verification-modal',
            title: $.mage.__('Verification'),
            buttons: [{
                text: $.mage.__('Cancel'),
                click: function () {
                    this.closeModal();
                }
            }]
        }, $('#' + popupDivId)).openModal();
    });

    /* ================= COMMENTS MODAL ================= */
    $(document).on('click', '.verification-showcomment', function () {

      //  console.log('Comment button clicked');

        var param = {
            id: $(this).data('verificationid'),
            dataid: $(this).data('verifidtlid'),
            grouptype: $(this).data('verifigroupid'),
            form_key: window.FORM_KEY
        };

       // console.log('AJAX Params:', param);
        //console.log("Comments URL:", "<?= $block->getCommentsViewUrl(); ?>");

       $.ajax({
    showLoader: true,
    url: "<?= $block->getCommentsViewUrl(); ?>",
    data: param,
    type: "GET",
    dataType: 'json',
    success: function (response) {
        if (response.success) {
            var html = '<h4>' + response.message + '</h4><table class="table">';
              // Reverse array so latest comment appears first
            var reversedData = response.data.slice().reverse();
            $.each(response.data, function (k, v) {
                // v ab ek object hai: {date: "...", comment: "..."}
                html += '<tr><td><strong>' + v.date + ':</strong> ' + v.comment + '</td></tr>';
            });
            html += '</table>';
            $("#commentslist_popup").html(html).modal({
                title: $.mage.__('Admin Comments'),
                modalClass: 'verification-modal'
            }).modal('openModal');
        }
    }
});
    });

});

</script>
