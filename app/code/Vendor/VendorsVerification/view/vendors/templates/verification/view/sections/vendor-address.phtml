<?php
/** @var $block \Vendor\VendorsVerification\Block\Vendors\Verification\View\Verification */

$vendor = $block->getVendor();

if (!$vendor || !$vendor->getId()) {
    return;
}

$vendorVerification = $block->getVendorVerification();

if (!$vendorVerification || !$vendorVerification->getId()) {
    return;
}

$verificationId = (int)$vendorVerification->getId();

$verificationData = $block->getVerificationSectionData(
    $verificationId,
    \Vendor\VendorsVerification\Model\Source\InfoGroup::VENDOR_VERIFICATION_DATAGROUP_BUSINESS_ADDRESS
);

if (!$verificationData || !$verificationData->getId()) {
    return;
}

$detail_id = (int)$verificationData->getDetailId();
$status    = $verificationData->getStatus();
$address   = $block->convertVerificationData($verificationData->getData('vendor_data'));

$streetRaw = trim((string)($address['street'] ?? ''));
$streetParts = preg_split('/\r\n|\r|\n/', $streetRaw, 2);
$addressLine1 = trim($streetParts[0] ?? '');
$addressLine2 = trim($streetParts[1] ?? '');
$city     = $address['city'] ?? '';
$state    = $address['state'] ?? '';
$postcode = $address['postcode'] ?? '';
$map      = $address['map'] ?? '';
$commentsCount = $detail_id
    ? (int)$block->getCommentsCounts(
        $verificationId,
        $detail_id,
        \Vendor\VendorsVerification\Model\Source\InfoGroup::VENDOR_VERIFICATION_DATAGROUP_BUSINESS_ADDRESS
    )
    : 0;
?>

<section class="verification-card verification-card--section verification-card--address">
    <div class="verification-card__head">
        <h3><?= __('Business Address') ?></h3>

        <div class="verification-card__actions">
            <?php if ($status == \Vendor\VendorsVerification\Model\Source\Status::VENDOR_VERIFICATION_STATUS__RESUBMIT): ?>
                <button type="button"
                        class="verification-edit verification-action-button verification-action-button--edit"
                        data-modal-id="verification-address-modal">
                    <i class="fa fa-pencil"></i>
                    <span><?= __('Edit') ?></span>
                </button>
            <?php endif; ?>

            <button type="button"
                    class="verification-showcomment verification-comments-link"
                    data-verificationid="<?= $verificationId ?>"
                    data-verifidtlid="<?= $detail_id ?>"
                    data-verifigroupid="<?= \Vendor\VendorsVerification\Model\Source\InfoGroup::VENDOR_VERIFICATION_DATAGROUP_BUSINESS_ADDRESS ?>">
                <i class="fa fa-comment"></i>
                <span><?= __('%1 Comments', $commentsCount) ?></span>
            </button>
        </div>
    </div>

    <div class="verification-card__body">
        <table class="verification-table">
            <tbody>
                <tr>
                    <td><?= __('Status') ?></td>
                    <td><?= $block->getStatusLabel($status); ?></td>
                </tr>
                <tr>
                    <td><?= __('Address Line 1') ?></td>
                    <td><?= $block->escapeHtml($addressLine1 ?: $streetRaw ?: __('N/A')); ?></td>
                </tr>
                <?php if ($addressLine2 !== ''): ?>
                    <tr>
                        <td><?= __('Address Line 2') ?></td>
                        <td><?= $block->escapeHtml($addressLine2); ?></td>
                    </tr>
                <?php endif; ?>
                <tr>
                    <td><?= __('City') ?></td>
                    <td><?= $block->escapeHtml($city ?: __('N/A')); ?></td>
                </tr>
                <tr>
                    <td><?= __('State') ?></td>
                    <td><?= $block->escapeHtml($state ?: __('N/A')); ?></td>
                </tr>
                <tr>
                    <td><?= __('Post Code') ?></td>
                    <td><?= $block->escapeHtml($postcode ?: __('N/A')); ?></td>
                </tr>
            </tbody>
        </table>
    </div>
</section>

<div id="verification-address-modal" style="display:none;">
    <form class="form verification"
          method="post"
          action="<?= $block->getEditActionUrl(
              $verificationId,
              $detail_id,
              \Vendor\VendorsVerification\Model\Source\InfoGroup::VENDOR_VERIFICATION_DATAGROUP_BUSINESS_ADDRESS
          ); ?>"
          data-mage-init='{"validation":{}}'>

        <input type="hidden" name="form_key" value="<?= $block->getFormKey() ?>" />

        <legend class="legend">
            <span><?= __('Edit Business Address') ?></span>
        </legend>

        <div class="row g-3">
            <div class="col-md-12">
                <label><?= __('Street') ?></label>
                <input type="text" name="street" value="<?= $block->escapeHtmlAttr($streetRaw) ?>" class="input-text" required />
            </div>

            <div class="col-md-6">
                <label><?= __('City') ?></label>
                <input type="text" name="city" value="<?= $city ?>" class="input-text" required />
            </div>

            <div class="col-md-6">
                <label><?= __('State') ?></label>
                <input type="text" name="state" value="<?= $state ?>" class="input-text" required />
            </div>

            <div class="col-md-6">
                <label><?= __('Postcode') ?></label>
                <input type="text" name="postcode" value="<?= $postcode ?>" class="input-text" required />
            </div>

            <div class="col-md-12">
                    <label><?= __('Map Location') ?></label>
                <input type="text" name="map" value="<?= $block->escapeHtmlAttr($map) ?>" class="input-text" />
            </div>
        </div>

        <div class="page-main-actions">
            <button type="submit" class="btn btn-primary">
                <?= __('Update') ?>
            </button>
        </div>
    </form>
</div>
