  <div class="verification-tbl">
    <table class="table table-striped">
        <tbody>

        <!-- STATUS -->
        <tr>
            <td><?= __('Status') ?></td>
            <td>
                <span class="status-badge">
                    <?= $certVerificationData && $certVerificationData->getId()
                        ? $block->getStatusLabel($certVerificationData->getStatus())
                        : __('Pending'); ?>
                </span>
            </td>
        </tr>

        <!-- COMMERCIAL CERTIFICATE -->
        <tr>
            <td><?= __('Commercial Registration Certificate') ?></td>
            <td>
                <?php if (!empty($arrCertDocsData['certificate'])): ?>
                    <a target="_blank"
                       class="doc-link"
                       href="<?= $block->getMediaUrl() . $folderName . '/' . $arrCertDocsData['certificate']; ?>">
                        <i class="fa fa-file-text-o"></i>
                        <?= basename($arrCertDocsData['certificate']); ?>
                    </a>
                <?php else: ?>
                    <span class="doc-empty"><?= __('Not Uploaded') ?></span>
                <?php endif; ?>
            </td>
        </tr>

        <!-- OTHER DOCUMENTS -->
        <tr>
            <td><?= __('Other Documents') ?></td>
            <td>
                <?php if (!empty($arrCertDocsData['documents'])): ?>
                    <?php
                    $docs = $arrCertDocsData['documents'];
                    if (is_string($docs)) {
                        $docs = explode(',', $docs);
                    }
                    ?>
                    <ul class="doc-list">
                        <?php foreach ($docs as $doc): ?>
                            <li>
                                <a target="_blank"
                                   class="doc-link"
                                   href="<?= $block->getMediaUrl() . $folderName . '/' . trim($doc); ?>">
                                    <i class="fa fa-file-text-o"></i>
                                    <?= basename($doc); ?>
                                </a>
                            </li>
                        <?php endforeach; ?>
                    </ul>
                <?php else: ?>
                    <span class="doc-empty"><?= __('Not Uploaded') ?></span>
                <?php endif; ?>
            </td>
        </tr>

        </tbody>
    </table>
