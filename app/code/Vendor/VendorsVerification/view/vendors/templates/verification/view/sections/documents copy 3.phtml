<?php
   /** @var $block \Vendor\VendorsVerification\Block\Vendors\Verification\View */
   
   $vendorVerification = $block->getVendorVerification();
   $verificationId = $vendorVerification ? (int)$vendorVerification->getId() : 0;
   
   /** ============================
    * CERTIFICATE & DOCUMENT DATA
    * ============================ */
   $certVerificationData = null;
   $certDetailId = 0;
   $arrCertDocsData = [];
   
   if ($verificationId) {
       $certVerificationData = $block->getVerificationSectionData(
           $verificationId,
           \Vendor\VendorsVerification\Model\Source\InfoGroup::VENDOR_VERIFICATION_DATAGROUP_CERTI_DOCS
       );
   
       if ($certVerificationData && $certVerificationData->getId()) {
           $certDetailId = (int)$certVerificationData->getDetailId();
           $arrCertDocsData = $block->convertVerificationData(
               $certVerificationData->getData('vendor_data')
           );
       }
   }
   //echo '<pre>';
   //print_r($arrCertDocsData);
   //exit;
   $folderName = 'vendor-verification-documents/';
   ?>
