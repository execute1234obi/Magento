<?php
$vendor = $block->getVendor();
if (!$vendor || !$vendor->getId()) {
    echo '<div class="message error">Vendor session expired. Please login again.</div>';
    return;
}

$uploaedCertificate = json_encode([]);
$uploaedLogoOthers  = json_encode([]);

$registrationCertificate = $vendor->getData('certificate') ?: '';
if ($registrationCertificate) {
    $attachements = $block->populateAttachements([$registrationCertificate]);
    $uploaedCertificate = json_encode($attachements);
}

$registrationLogo = $vendor->getLogo() ?: '';
if ($registrationLogo) {
    $otherFiles = $block->populateAttachements([$registrationLogo]);
    $uploaedLogoOthers = json_encode($otherFiles);
}
?>

