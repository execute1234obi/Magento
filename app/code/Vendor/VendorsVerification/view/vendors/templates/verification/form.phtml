<!-- ================= JS (UNCHANGED) ================= -->
<script>
require(['jquery','Magento_Ui/js/modal/alert','mage/translate','mage/mage'],
function ($, uiAlert, $t,$mage) {

    var dataForm = jQuery('#verification-form');
    dataForm.mage('validation', {});

    $('#mysubmit-button').click(function() {
        var validationFailed = false;

        if($("#is-certselected").val() == ''){
            validationFailed = true;
            var data = { content: $t('Please upload Commercial Registration Certificate.') };
            data.modalClass = '_image-box';
            uiAlert(data);
        }

        if(validationFailed){ return; }

        validationFailed = dataForm.validation('isValid');
        if(validationFailed){
            dataForm.submit();
        }
    });

    $(document).ready(function(){

        $(".verification-nextpage").click(function(){
            var next = jQuery('.nav-tabs > .active').next('li');
            if(next.length){
                next.find('a').trigger('click');
            }else{
                $('#myTabs a:first').tab('show');
            }
        });

        $(".verification-prevpage").click(function(){
            var prev = jQuery('.nav-tabs > .active').prev('li');
            if(prev.length){
                prev.find('a').trigger('click');
            }else{
                jQuery('#myTabs a:last').tab('show');
            }
        });

        $("#business-country").change(function(){
            var countryCode = $(this).val();
            $("#business-countrycode").val(countryCode);
            $("#contact-countrycode").val(countryCode);
        });

    });

});
</script>

