<?php
/** @var $block \Vendor\VendorsVerification\Block\Vendors\Verification\View */

$vendor = $block->getVendor();
if (!$vendor || !$vendor->getId()) {
    return;
}

$vendorVerification = $block->getVendorVerification();
$verificationId = $vendorVerification->getId();
//echo $verificationId;
/** Verification data (status + comments only) */
$verificationData = $block->getVerificationSectionData(
    $verificationId,
    \Vendor\VendorsVerification\Model\Source\InfoGroup::VENDOR_VERIFICATION_DATAGROUP_BUSINESS_ADDRESS
);

$detail_id = $verificationData->getDetailId();
//echo $detail_id;
/** ✅ Vendor Address (SOURCE OF TRUTH) */
$address = $block->convertVerificationData(
            $verificationData->getData('vendor_data')
        );
//$address = $block->getVendorAddress();

$vendorStreet   = $address['street']   ?? '';
$vendorCity     = $address['city']     ?? '';
$vendorRegion   = $address['state']    ?? '';
$vendorPostCode = $address['postcode'] ?? '';
$vendorCountry  = $address['country']  ?? '';

$businessName = $vendor->getData('b_name');

/** Google Map */
$gmap_lat = $vendor->getGmapLat() ?: '24.7136';
$gmap_lng = $vendor->getGmapLng() ?: '46.6753';

$_address = $block->escapeHtml($businessName . ' ' . $vendorStreet);
?>

<div class="verification-section">

    <!-- HEADER -->
    <div class="header">
        <h2><?= __('Business Address') ?></h2>

        <?php
        $commentsCount = $block->getCommentsCounts(
            $verificationId,
            $detail_id,
            \Vendor\VendorsVerification\Model\Source\InfoGroup::VENDOR_VERIFICATION_DATAGROUP_BUSINESS_ADDRESS
        );
        ?>

        <button type="button"
                title="<?= __('Show Admin Comments') ?>"
                class="btn btn-link pull-right verification-showcomment"
                data-verificationid="<?= $verificationId ?>"
                data-verifidtlid="<?= $detail_id ?>"
                data-verifigroupid="<?= \Vendor\VendorsVerification\Model\Source\InfoGroup::VENDOR_VERIFICATION_DATAGROUP_BUSINESS_ADDRESS ?>">
            <i class="fa fa-comment"></i>
            <span><?= __('%1 Comments', $commentsCount) ?></span>
        </button>
    </div>

    <!-- TABLE -->
    <div class="verification-tbl">
        <table class="table table-striped">
            <tbody>
                <tr>
                    <td><?= __('Status') ?></td>
                    <td><?= $block->getStatusLabel($verificationData->getStatus()); ?></td>
                </tr>
                <tr>
                    <td><?= __('Address') ?></td>
                    <td><?= $vendorStreet ?></td>
                </tr>
                <tr>
                    <td><?= __('City') ?></td>
                    <td><?= $vendorCity ?></td>
                </tr>
                <tr>
