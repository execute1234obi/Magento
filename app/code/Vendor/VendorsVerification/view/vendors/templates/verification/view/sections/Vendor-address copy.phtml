</div>

<!-- GOOGLE MAP -->
<style>
#map {
    width: 100%;
    height: 480px;
    border: 1px solid #d8dee9;
    display: none;
    margin-top: 15px;
}
</style>

<div class="verification-section">
    <div class="header">
        <h2><?= __('Google Map Location') ?></h2>
        <button type="button"
                id="showmap-button"
                onclick="displayMap()"
                class="btn btn-success btn-flat pull-right">
            <?= __('Show Map') ?> <i class="fa fa-map-marker"></i>
        </button>
    </div>

    <div class="verification-tbl">
        <div id="map"></div>
    </div>
</div>

<input type="hidden" id="lat" value="<?= $gmap_lat ?>">
<input type="hidden" id="lng" value="<?= $gmap_lng ?>">

<script src="https://maps.googleapis.com/maps/api/js"></script>
<script>
function displayMap() {
    document.getElementById('map').style.display = 'block';
    document.getElementById('showmap-button').style.display = 'none';

    var pos = {
        lat: <?= $gmap_lat ?>,
        lng: <?= $gmap_lng ?>
    };

    var map = new google.maps.Map(document.getElementById('map'), {
        center: pos,
        zoom: 15,
        draggable: false
    });

    new google.maps.Marker({
        position: pos,
        map: map,
        title: "<?= $_address ?>"
    });
}
</script>

