            <div class="col-md-6">
                <label><?= __('State') ?></label>
                <input type="text" name="state" value="<?= $state ?>" class="input-text" required />
            </div>

            <div class="col-md-6">
                <label><?= __('Postcode') ?></label>
                <input type="text" name="postcode" value="<?= $postcode ?>" class="input-text" required />
            </div>

            <div class="col-md-12">
                <label><?= __('Map Location') ?></label>
                <input type="text" name="map" value="<?= $map ?>" class="input-text_extract" />
            </div>
        </div>

        <div class="page-main-actions">
            <button type="submit" class="btn btn-primary">
                <?= __('Update') ?>
            </button>
        </div>
    </form>
