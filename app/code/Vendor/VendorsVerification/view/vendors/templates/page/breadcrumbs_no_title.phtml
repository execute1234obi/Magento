<?php
// @codingStandardsIgnoreFile
/** @var $block \Vnecoms\Vendors\Block\Page\Breadcrumbs */

if (empty($links) || !is_array($links)) {
    return;
}
?>

<style>
  .vendor-pagehead {
    margin: 0 0 16px;
    padding-top: 6px;
  }

  .vendor-breadcrumb {
    margin: 0;
    padding: 0;
    list-style: none;
    display: flex;
    align-items: center;
    flex-wrap: wrap;
    gap: 8px;
    font-size: 13px;
    line-height: 18px;
    color: #94A3B8;
    font-weight: 400;
  }

  .vendor-breadcrumb__item {
    display: inline-flex;
    align-items: center;
    gap: 8px;
  }

  .vendor-breadcrumb__sep {
    color: #CBD5E1;
  }

  .vendor-breadcrumb__link {
    color: #94A3B8;
    text-decoration: none;
    transition: color .15s ease;
  }

  .vendor-breadcrumb__link:hover {
    color: #1E56A0;
    text-decoration: none;
  }

  .vendor-breadcrumb__current {
    color: #1E56A0;
    font-weight: 600;
  }
</style>

<div class="vendor-pagehead">
  <ol class="vendor-breadcrumb" aria-label="<?= $block->escapeHtmlAttr(__('Breadcrumb')) ?>">
    <li class="vendor-breadcrumb__item">
      <a class="vendor-breadcrumb__link" href="<?= $block->escapeUrl($this->getHomeLink()) ?>">
        <?= $block->escapeHtml(__('Home')) ?>
      </a>
    </li>

    <?php foreach ($links as $_index => $_link): ?>
      <?php $isLast = ($_index === count($links) - 1); ?>
      <li class="vendor-breadcrumb__item<?php if ($isLast): ?> is-active<?php endif; ?>">
        <span class="vendor-breadcrumb__sep" aria-hidden="true">/</span>

        <?php if (!empty($_link['url']) && !$isLast): ?>
          <a class="vendor-breadcrumb__link"
             href="<?= $block->escapeUrl($_link['url']) ?>"
             title="<?= $block->escapeHtmlAttr($_link['title']) ?>">
            <?= $block->escapeHtml($_link['label']) ?>
          </a>
        <?php else: ?>
          <span class="vendor-breadcrumb__current">
            <?= $block->escapeHtml($_link['label']) ?>
          </span>
        <?php endif; ?>
      </li>
    <?php endforeach; ?>
  </ol>
</div>
