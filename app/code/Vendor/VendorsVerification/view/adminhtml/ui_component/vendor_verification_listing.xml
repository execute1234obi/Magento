<?xml version="1.0" encoding="UTF-8"?>
<listing xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
         xsi:noNamespaceSchemaLocation="urn:magento:module:Magento_Ui:etc/ui_configuration.xsd">

    <argument name="data" xsi:type="array">
        <item name="js_config" xsi:type="array">
            <item name="provider" xsi:type="string">vendor_verification_listing.vendor_verification_admin_data_source</item>
            <item name="deps" xsi:type="string">vendor_verification_listing.vendor_verification_admin_data_source</item>
        </item>
        <item name="spinner" xsi:type="string">vendorverification_columns</item>
    </argument>

    <dataSource name="vendor_verification_admin_data_source">
        <argument name="dataProvider" xsi:type="configurableObject">
            <argument name="class" xsi:type="string">Magento\Framework\View\Element\UiComponent\DataProvider\DataProvider</argument>
            <argument name="name" xsi:type="string">vendor_verification_admin_data_source</argument>
            <argument name="primaryFieldName" xsi:type="string">verification_id</argument>
            <argument name="requestFieldName" xsi:type="string">verification_id</argument>
            <argument name="data" xsi:type="array">
                <item name="config" xsi:type="array">
                    <item name="component" xsi:type="string">Magento_Ui/js/grid/provider</item>
                    <item name="update_url" xsi:type="url" path="mui/index/render"/>
                    <item name="storageConfig" xsi:type="array">
                        <item name="indexField" xsi:type="string">verification_id</item>
                    </item>
                </item>
            </argument>
        </argument>
    </dataSource>

    <listingToolbar name="listing_top">
        <settings>
            <sticky>true</sticky>
        </settings>
        <bookmark name="bookmarks"/>
        <columnsControls name="columns_controls"/>
        <filters name="listing_filters"/>
        <paging name="listing_paging"/>
    </listingToolbar>

    <columns name="vendorverification_columns">
        <settings>
            <editorConfig>
                <param name="selectProvider" xsi:type="string">vendor_verification_listing.vendor_verification_listing.vendorverification_columns.ids</param>
                <param name="enabled" xsi:type="boolean">true</param>
                <param name="indexField" xsi:type="string">verification_id</param>
            </editorConfig>
            <childDefaults>
                <param name="provider" xsi:type="string">vendor_verification_listing.vendor_verification_listing.vendorverification_columns_editor</param>
                <param name="target" xsi:type="string">startEdit</param>
                <param name="params" xsi:type="array">
                    <item name="0" xsi:type="string">${ $.$data.rowIndex }</item>
                    <item name="1" xsi:type="boolean">true</item>
                </param>
                <param name="imports" xsi:type="array">
                    <item name="visible" xsi:type="string">vendor_verification_listing.vendor_verification_listing.vendorverification_columns_editor:visible</item>
                </param>
            </childDefaults>
        </settings>

        <column name="verification_id" sortOrder="10">
            <settings>
                <filter>textRange</filter>
                <label translate="true">ID</label>
                <visible>false</visible>
            </settings>
        </column>

        <column name="inc_id" sortOrder="20">
            <settings>
                <filter>text</filter>
                <label translate="true">Verification ID</label>
                <sorting>desc</sorting>
            </settings>
        </column>

        <column name="salesorder_incid" sortOrder="30">
            <settings>
                <filter>text</filter>
                <label translate="true">Order ID</label>
            </settings>
        </column>

        <column name="seller_name" sortOrder="40">
            <settings>
                <filter>text</filter>
                <label translate="true">Seller Name</label>
            </settings>
        </column>

        <column name="seller_country" sortOrder="50">
            <settings>
                <filter>text</filter>
                <label translate="true">Seller Country</label>
            </settings>
        </column>
<column name="amount" class="Magento\Catalog\Ui\Component\Listing\Columns\Price">
    <argument name="data" xsi:type="array">
        <item name="config" xsi:type="array">
            <item name="filter" xsi:type="string">textRange</item>
            <item name="label" xsi:type="string" translate="true">Fees</item>
            <item name="sortOrder" xsi:type="number">50</item>
        </item>
    </argument>
</column>
        <column name="created_at" class="Magento\Ui\Component\Listing\Columns\Date" component="Magento_Ui/js/grid/columns/date" sortOrder="60">
            <settings>
                <filter>dateRange</filter>
                <dataType>date</dataType>
                <label translate="true">Created At</label>
            </settings>
        </column>

        <column name="from_date" class="Magento\Ui\Component\Listing\Columns\Date" component="Magento_Ui/js/grid/columns/date" sortOrder="70">
            <settings>
                <filter>dateRange</filter>
                <dataType>date</dataType>
                <label translate="true">Start Date</label>
            </settings>
        </column>

        <column name="to_date" class="Magento\Ui\Component\Listing\Columns\Date" component="Magento_Ui/js/grid/columns/date" sortOrder="80">
            <settings>
                <filter>dateRange</filter>
                <dataType>date</dataType>
                <label translate="true">Expire Date</label>
            </settings>
        </column>
<column name="is_paid" component="Magento_Ui/js/grid/columns/select" sortOrder="90">
    <settings>
        <label translate="true">Payment</label>
        <filter>select</filter>
        <dataType>select</dataType>
        <options class="Vendor\VendorsVerification\Model\Source\PaymentStatus"/>
    </settings>
</column>

<column name="is_verified" component="Vendor_VendorsVerification/js/grid/columns/verificationstatus" sortOrder="110">
    <settings>
        <label translate="true">Status</label>
        <filter>select</filter>
        <dataType>select</dataType>
        <options class="Vendor\VendorsVerification\Model\Source\VerificationStatus"/>
    </settings>
</column>
<column name="verification_status"
        class="Vendor\VendorsVerification\Ui\Component\Listing\Columns\Admin\VerificationStatus"
        sortOrder="105">
    <settings>
        <label translate="true">Verification Status</label>
        <filter>select</filter>
    </settings>
</column>

<actionsColumn name="actions" class="Vendor\VendorsVerification\Ui\Component\Listing\Columns\Admin\VerificationActions">
    <argument name="data" xsi:type="array">
        <item name="config" xsi:type="array">
            <item name="indexField" xsi:type="string">verification_id</item> <item name="sortOrder" xsi:type="number">120</item> <item name="label" xsi:type="string" translate="true">Actions</item>
        </item>
    </argument>
</actionsColumn>

    </columns>
    
</listing>