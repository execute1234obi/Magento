<!-- ================= JS ================= -->
<script type="text/javascript">
require(['jquery', 'Magento_Ui/js/modal/modal', 'domReady!'], function ($, modal) {

    $('.verification-action').on('click', function () {
        var modalId = '#' + $(this).data('modal-id');
        modal({type: 'popup', responsive: true}, $(modalId));
        $(modalId).modal('openModal');
    });

    function initMap() {
        var pos = {lat: parseFloat('<?= $lat ?>'), lng: parseFloat('<?= $lng ?>')};
        if (isNaN(pos.lat) || isNaN(pos.lng)) return;

        var map = new google.maps.Map(document.getElementById('store_map'), {
            center: pos,
            zoom: 15
        });

        new google.maps.Marker({position: pos, map: map});
    }

    if (typeof google === 'undefined') {
        $.getScript('https://maps.googleapis.com/maps/api/js?key=<?= $apiKey ?>')
            .done(initMap);
    } else {
        initMap();
    }
});
</script>
