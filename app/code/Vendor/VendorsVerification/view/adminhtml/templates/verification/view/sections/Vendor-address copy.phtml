<script type="text/javascript">
    require(['jquery', 'domReady!'], function($) {
        function initializeMap() {
            var lat = parseFloat('<?php echo $gmap_lat; ?>');
            var lng = parseFloat('<?php echo $gmap_lng; ?>');
            
            if (isNaN(lat) || isNaN(lng)) return;

            var pos = {lat: lat, lng: lng};
            var map = new google.maps.Map(document.getElementById("store_map"), {
                center: pos,
                zoom: <?php echo $_zoom; ?>,
                scrollwheel: false
            });
            var marker = new google.maps.Marker({
                position: pos,
                map: map,
                title: '<?php echo $vendorStreet; ?>'
            });
        }

        // Load Google Maps API if not already loaded
        if (typeof google === 'undefined' || typeof google.maps === 'undefined') {
            $.getScript('https://maps.googleapis.com/maps/api/js?key=<?php echo $_apikey; ?>')
                .done(function() {
                    initializeMap();
                });
        } else {
            initializeMap();
        }
    });
</script>