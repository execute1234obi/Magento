<?php
/** @var $block \Vendor\VendorsVerification\Block\Adminhtml\Verification */

$vendorVerification = $block->getVendorVerification();
if (!$vendorVerification) { return; }

$verificationId = $vendorVerification->getId();
$groupId = \Vendor\VendorsVerification\Model\Source\InfoGroup::VENDOR_VERIFICATION_DATAGROUP_BUSINESS_ADDRESS;
$verificationData = $block->getVerificationSectionData($verificationId, $groupId);

if (!$verificationData) {
    echo __("No address data submitted for verification.");
    return;
}

$detail_id = $verificationData->getDetailId();
// Database se raw data nikal kar array mein convert karna
$arrData = $block->convertVerificationData($verificationData->getData('vendor_data'));

// --- AAPKI FIELDS YAHAN FETCH HO RAHI HAIN ---
$vendorStreet   = isset($arrData['street']) ? $arrData['street'] : '';
$vendorCity     = isset($arrData['city']) ? $arrData['city'] : '';
$vendorRegion   = isset($arrData['state']) ? $arrData['state'] : '';
$vendorPostCode = isset($arrData['postcode']) ? $arrData['postcode'] : '';
$vendorCountry  = isset($arrData['country']) ? $arrData['country'] : '';

// Map Coordinates logic (Agar DB mein lat/lng hain toh wo use honge)
$_zoom = 15;
$gmap_lat = (!empty($arrData['lat'])) ? $arrData['lat'] : '24.7136';
$gmap_lng = (!empty($arrData['lng'])) ? $arrData['lng'] : '46.6753';

// Google API Key fetching
$porto_contacts = $block->getConfig('porto_settings/contacts');
$_apikey = isset($porto_contacts['api_key']) ? $porto_contacts['api_key'] : '';
?>

