], function ($, confirmation) {

    $('#delete_verification_admin').on('click', function () {

        var verificationId = $(this).data('id');

        confirmation({
            title: $.mage.__('Delete Verification'),
            content: $.mage.__(
                'This verification will be permanently deleted. Are you sure?'
            ),
            buttons: [
                {
                    text: $.mage.__('Cancel'),
                    class: 'action-secondary',
                    click: function (event) {
                        this.closeModal(event);
                    }
                },
                {
                    text: $.mage.__('Delete'),
                    class: 'action-primary',
                    click: function () {
                        setLocation(
                            '<?= $block->getUrl(
                                "vendorverification/index/delete",
                                [
                                    "id" => $verificationId,
                                    "form_key" => $block->getFormKey()
                                ]
                            ); ?>'
                        );
                    }
                }
            ]
        });

    });

});
</script>

