<script>
    require(
        [
            'jquery',
            'Magento_Ui/js/modal/modal',
            'mage/url',
            'Magento_Ui/js/modal/confirm',
            'jquery/ui'            
        ],
        function(
            $,
            modal,
            urlBuilder,
            confirmation
        ) {			
			
			$("#delete_verification").on('click',function(){
				
               confirmation({
                      title: $.mage.__('Reject Entire Verification Request'),
                      content: $.mage.__('Verification entry will be remove from system and vendor need to go through the whole verification process again '),                                            
                      buttons: [
                        {
                        text: $.mage.__('Cancel'),
                        class: 'action',
                        click: function (event) {
                               this.closeModal(event, true);
                              }
                         },
                         {
                         text: $.mage.__('Reject Entire Verification'),
                         class: 'action primary action',
                         click: function (event) {
                               //setLocation('<?php //echo $block->getDeleteActionUrl($verificationId); ?>');
                               setLocation('<?php echo $block->getUrl('vendorverification/index/rejectEntire', ['id' => $verificationId]); ?>');
                              }
                        }]
                });   
    				
		});
            
			
            var options = {
                type: 'popup',
                responsive: true,
                innerScroll: false,
                title: $.mage.__('Verification'),
                buttons: [{
                    text: $.mage.__('Cancel'),
                    class: '',
                    click: function () {
                        this.closeModal();
                    }
                }]
            };            
            
            $(".verification-action").on('click',function(){				
				var popupDivId =  $(this).data('modal-id');	
				var actionType =  $(this).data('modal-action');	
				options.title = $.mage.__('Verification') + ' :: ' + actionType.toUpperCase();
				/*if( actionType=== 'approve'){
				} else {
                   var popup = modal(options, $('#'+popupDivId));
                   $('#'+popupDivId).modal('openModal');
			   }*/
			   var popup = modal(options, $('#'+popupDivId));
                   $('#'+popupDivId).modal('openModal');
                
            });
            
           $(".verification-showcomment").on('click',function(){
			   var verificationId = $(this).data('verificationid');	
			   var dataid = $(this).data('verifidtlid');
			   var dataGroupType = $(this).data('verifigroupid');
			   param = {
				   id : verificationId,
				   dataid : dataid,
				   grouptype: dataGroupType,
				   form_key: window.FORM_KEY
			   };
			   
			   var options = {
				       title: $.mage.__('Admin Comments'),
                       type: 'popup',
                       responsive: true,
                       innerScroll: true,
                       buttons: [{
                           text: $.mage.__('Cancel'),
                           class: 'primary action  btn btn-default',
                           click: function () {
                               this.closeModal();
                           }
                       }]
                   };
                  
			    $.ajax({
					showLoader: true,
					url: <?php echo '"'. $block->getCommentsViewUrl().'"' ;?>,
					data: param,
					type: "GET",
					dataType: 'json',
					success: function(response) { 
						if(response.success){
							 //console.log(response.data);
							var count = 0;
							var htmlout;
                             var commentsTbl = '<table>';                             
                             $.each(response.data, function(k, v) {
								 count++;
								 commentsTbl +='<tr>'								 
								commentsTbl += '<td><strong>' + v.date + '</strong></td>'; // show date
                                commentsTbl += '<td>' + v.comment + '</td>';             // show comment								 
								 commentsTbl +='</tr>';
						     });
                             commentsTbl +='</table>';                             
                             if(count>0){
                                htmlout   =  '<span style="color:#2f9e44;" >' + response.message + '</span><br />';
                                htmlout += commentsTbl;
						     } else {
								  htmlout   =  '<span style="color:red;" >' + response.message + '</span><br />';
							 }
                             
                             $("#commentslist_popup").html('');
                             $("#commentslist_popup").html(htmlout).modal(options).modal('openModal');
						}else {
							alert(response.message);
						}
                    },
                    error: function (xhr, status, errorThrown) {
                        console.log(errorThrown);
                     }
					})
			   
		   })
        
        }
    );    
   </script>
<script>
