<?php
/** @var $block \Vendor\VendorsVerification\Block\Adminhtml\Verification */

$vendorVerification = $block->getVendorVerification();
if (!$vendorVerification) { return; }

$verificationId = $vendorVerification->getId();
$groupId = \Vendor\VendorsVerification\Model\Source\InfoGroup::VENDOR_VERIFICATION_DATAGROUP_CERTI_DOCS;
$certdocsData = $block->getVerificationSectionData($verificationId, $groupId);

if (!$certdocsData) {
    echo __("No documents submitted for verification.");
    return;
}

$detail_id = $certdocsData->getDetailId();
$rawData = $certdocsData->getData('vendor_data');
$arrCertDocsData = $block->convertVerificationData($rawData);

/**
 * Naya Fetch Logic: Jo aapne 'certificate' field ke liye manga tha
 */
$mainCertificate = isset($arrCertDocsData['certificate']) ? $arrCertDocsData['certificate'] : (isset($arrCertDocsData['vendorregistcert']) ? $arrCertDocsData['vendorregistcert'] : '');
$additionalDocs = isset($arrCertDocsData['vendoradditionaldocs']) ? $arrCertDocsData['vendoradditionaldocs'] : [];

//$folderName = 'vendor-verification-documents/';
$mediaUrl = $block->getMediaUrl() ;
?>

<div class="admin__page-section-content">
    <div class="admin__page-section-item">
        <div class="admin__page-section-item-title">
            <span class="title">
                <span><?php echo __('Certificates and Documents') ?></span>
                
            </span>
        </div>
        
        <div class="admin__page-section-item-content">
            <div style="margin-bottom: 20px;">
                <button title="<?php echo __('Approve') ?>" type="button" class="action-default verification-action primary" style="background:#66a80f; color:#fff;" data-modal-id="verification-docsapproval-modal" data-modal-action="approve">
                    <span><?php echo __('Approve') ?></span>
                </button>
                <button title="<?php echo __('Resubmit') ?>" type="button" class="action-default verification-action" style="background:#ffb300; color:#fff;" data-modal-id="verification-docsresubmit-modal" data-modal-action="resubmit">
                    <span><?php echo __('Request Re-submit') ?></span>
                </button>
                <button title="<?php echo __('Reject') ?>" type="button" class="action-default verification-action" style="background:#ff2500; color:#fff;" data-modal-id="verification-docsreject-modal" data-modal-action="reject">
                    <span><?php echo __('Reject') ?></span>
                </button>
                
                <button type="button" class="action-default verification-showcomment pull-right" 
                        data-verificationid="<?php echo $verificationId; ?>" 
                        data-verifidtlid="<?php echo $detail_id; ?>" 
                        data-verifigroupid="<?php echo $groupId; ?>">
                    <span><?php echo __("Comments"); ?></span>
                </button>
            </div>

            <table class="admin__table-secondary">
                <tbody>
                    <tr>
                        <td><strong><?php echo __('Status') ?></strong></td>
                        <td><span class="grid-severity-notice"><?php echo $block->getStatusLabel($certdocsData->getStatus()); ?></span></td>
                    </tr>
                    <tr>
                        <td><strong><?php echo __('Commercial Registration Certificate') ?></strong></td>
                        <td>
                            <?php if ($mainCertificate): ?>
                                <?php 
                                    // Handling agar certificate array format mein ho (Uploader output)
                                    $certFile = is_array($mainCertificate) ? (isset($mainCertificate[0]['file']) ? $mainCertificate[0]['file'] : '') : $mainCertificate;
                                    $certName = is_array($mainCertificate) ? (isset($mainCertificate[0]['name']) ? $mainCertificate[0]['name'] : $certFile) : $certFile;
                                ?>
                                <a href="<?= $mediaUrl . $certFile ?>" target="_blank" style="color:#1979c3; text-decoration: underline;">
                                    <strong>View Document: <?= $certName ?></strong>
                                </a>
                            <?php else: ?>
                                <span style="color:red;"><?php echo __('Not Uploaded'); ?></span>
                            <?php  endif; ?>
                        </td>
                    </tr>
                    
                    <?php if (!empty($additionalDocs) && is_array($additionalDocs)): ?>
                    <tr>
                        <td><strong><?php echo __('Other Documents') ?></strong></td>
                        <td>
                            <ul style="list-style: disc; margin-left: 20px;">
                                <?php foreach ($additionalDocs as $doc): ?>
                                    <?php 
                                        $docFile = is_array($doc) ? $doc['file'] : $doc; 
                                        $docName = is_array($doc) ? $doc['name'] : $doc;
                                    ?>
                                    <li>
                                        <a href="<?= $mediaUrl . $docFile ?>" target="_blank"><?= $docName ?></a>
                                    </li>
                                <?php endforeach; ?>
                            </ul>
                        </td>
                    </tr>
                    <?php endif; ?>
                </tbody>
            </table>
        </div>
    </div>
</div>
