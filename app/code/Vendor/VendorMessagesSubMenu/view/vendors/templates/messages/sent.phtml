<script>
require(['jquery', 'Magento_Ui/js/modal/alert', 'mage/translate'], function ($, alert, $t) {
    var searchBox = $('#vendorMessageSearch');
    var threadsWrap = $('#vendorMessageThreadList');
    var replyForm = $('#vendorMessageReplyForm');
    var replyBox = $('#reply_msg_box');
    var messagesWrap = $('#vendorMessageMessages');

    if (searchBox.length && threadsWrap.length) {
        searchBox.on('input', function () {
            var query = String($(this).val() || '').toLowerCase().trim();

            threadsWrap.find('.vendor-message-sent__thread').each(function () {
                var searchText = String($(this).attr('data-search') || '').toLowerCase();
                $(this).toggle(!query || searchText.indexOf(query) !== -1);
            });
        });
    }

    if (messagesWrap.length) {
        messagesWrap.scrollTop(messagesWrap[0].scrollHeight);
    }

    if (replyForm.length && replyBox.length) {
        replyForm.on('submit', function (event) {
            event.preventDefault();

            var message = String(replyBox.val() || '').trim();
            if (!message) {
                alert({
                    title: $t('Error'),
                    content: $t('Please enter the message.')
                });
                return;
            }

            $.ajax({
                url: replyForm.attr('action'),
                method: 'POST',
                dataType: 'json',
                data: {
                    id: replyForm.find('input[name="id"]').val(),
                    message: message
                },
                showLoader: true
            }).done(function (response) {
                if (response && !response.error) {
                    window.location.reload();
                    return;
                }

                alert({
                    title: $t('Error'),
                    content: response && (response.msg || response.message) ? (response.msg || response.message) : $t('Something wrong. Please try to refresh the page.')
                });
            }).fail(function () {
                alert({
                    title: $t('Error'),
                    content: $t('Something wrong. Please try to refresh the page.')
                });
            });
        });
    }
});
</script>
