    color: #94A3B8;
    white-space: nowrap;
  }

  .vendor-msg__contentBody {
    padding: 16px;
    overflow: auto;
    flex: 1;
    background: #fbfdff;
  }

  /* Placeholder when no message selected */
  .vendor-msg__empty {
    height: 100%;
    display: grid;
    place-items: center;
    color: #64748b;
    font-size: 14px;
    padding: 40px;
    text-align: center;
  }

  /* Responsive */
  @media (max-width: 1024px) {
    .vendor-msg { flex-direction: column; }
    .vendor-msg__sidebar,
    .vendor-msg__content {
      width: 100%;
      height: auto;
      min-height: 420px;
    }
