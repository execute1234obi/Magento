</style>
<div class="vendor-msg">

  <!-- LEFT: Thread list -->
  <aside class="vendor-msg__sidebar">
    <div class="vendor-msg__sidebarHeader">
      <h3 class="vendor-msg__sidebarTitle"><?php echo $block->getTitle();?></h3>
    </div>

    <div class="vendor-msg__searchWrap">
      <input class="vendor-msg__search" id="vendorMsgSearch" type="text"
             placeholder="<?php echo __("Search messages..."); ?>" />
    </div>

    <div class="vendor-msg__folders">
      <?php echo $block->getChildHtml('folders') ?>
    </div>

    <!-- ✅ Recommended: render inbox grid here via layout as="message_list" -->
    <div class="vendor-msg__threadList" id="vendorThreadList">
      <?php echo $block->getChildHtml('message_list') ?>
    </div>
  </aside>

  <!-- RIGHT: Conversation (your existing view/communication output) -->
  <section class="vendor-msg__content" id="vendorMsgRight">
    <div class="vendor-msg__contentHeader">
      <h3 class="vendor-msg__contentTitle">
        <?php echo $block->escapeHtml($block->getTitle()); ?>
      </h3>
      <div class="vendor-msg__contentMeta"></div>
    </div>

    <div class="vendor-msg__contentBody" id="vendorMsgContentBody">
      <?php echo $block->getChildHtml('message_content') ?>
    </div>
  </section>

</div>

<script>
(function () {
  const threadList = document.getElementById('vendorThreadList');
  const rightBody  = document.getElementById('vendorMsgContentBody');
  const rightWrap  = document.getElementById('vendorMsgRight');
  const searchBox  = document.getElementById('vendorMsgSearch');

  // 1) If you did NOT render message_list, but message_content contains the inbox grid,
  //    auto-move it from RIGHT to LEFT (Inbox page).
  const hasLeftList = threadList && threadList.innerText.trim().length > 0;
  const rightHasGrid = rightBody && rightBody.querySelector('table');

  if (!hasLeftList && rightHasGrid) {
    // Move the table/grid to the left
    const table = rightBody.querySelector('table');
    threadList.innerHTML = '';
    threadList.appendChild(table);

    // Show empty placeholder on the right (Inbox page should not show the grid anymore)
    rightBody.innerHTML = '<div class="vendor-msg__empty">Select a message from the left to view full communication.</div>';
  }

  // 2) Convert grid rows into "thread cards" UI + click row => existing View link
  const table = threadList ? threadList.querySelector('table') : null;
  if (table) {
    const rows = Array.from(table.querySelectorAll('tbody tr'));

    rows.forEach(tr => {
      const tds = tr.querySelectorAll('td');
      if (!tds || tds.length < 3) return;

      // Try to find a "View" link inside the row (existing functionality)
      const viewA = tr.querySelector('a[href]');
      const href  = viewA ? viewA.getAttribute('href') : null;

      // Your grid order (from screenshot): checkbox | Sender | Subject | Created at | Action(View)
      // We'll attempt based on indexes:
      const sender  = (tds[1] ? tds[1].innerText : '').trim();
      const subject = (tds[2] ? tds[2].innerText : '').trim();
      const dateTxt = (tds[3] ? tds[3].innerText : '').trim();

      // Build card UI in the Subject column
      const card = document.createElement('div');
      card.className = 'vendor-msg__threadCard';
      card.innerHTML = `
        <div class="vendor-msg__threadSubject"></div>
        <div class="vendor-msg__threadDate"></div>
        <div class="vendor-msg__threadSender"></div>
      `;
      card.querySelector('.vendor-msg__threadSubject').textContent = subject || '(No subject)';
      card.querySelector('.vendor-msg__threadSender').textContent  = sender || '';
      card.querySelector('.vendor-msg__threadDate').textContent    = dateTxt || '';

      if (tds[2]) {
        tds[2].innerHTML = '';
        tds[2].appendChild(card);
      }

      // Make row clickable to open the existing view page
      if (href) {
        tr.addEventListener('click', (e) => {
          const tag = (e.target && e.target.tagName) ? e.target.tagName.toLowerCase() : '';
          if (tag === 'a' || tag === 'button' || tag === 'input' || tag === 'select' || tag === 'textarea') return;
          window.location.href = href;
        });

        // Highlight active thread if current URL matches
        const current = window.location.href;
        if (current && current.indexOf(href) !== -1) {
          tr.classList.add('is-active');
        }
      }

      // Store search text
      tr.setAttribute('data-search', (sender + ' ' + subject + ' ' + dateTxt).toLowerCase());
    });

    // 3) Search filter
    if (searchBox) {
      searchBox.addEventListener('input', function () {
        const q = (this.value || '').toLowerCase().trim();
        const rows = Array.from(table.querySelectorAll('tbody tr'));
        rows.forEach(tr => {
          const hay = tr.getAttribute('data-search') || '';
          tr.style.display = (!q || hay.includes(q)) ? '' : 'none';
        });
      });
    }
  }

  // 4) On view page: auto-scroll conversation to bottom
  if (rightBody) rightBody.scrollTop = rightBody.scrollHeight;
})();
</script>