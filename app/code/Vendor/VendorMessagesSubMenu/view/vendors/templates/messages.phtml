<style>
  /* ===== Vendor Messages: Gmail-like split UI ===== */
  .vendor-msg {
    display: flex;
    gap: 16px;
    align-items: stretch;
    margin-top: 10px;
  }

  /* LEFT: Thread list panel */
  .vendor-msg__sidebar {
    width: 360px;
    min-width: 320px;
    background: #ffffff;
    border: 1px solid #e9eef6;
    border-radius: 14px;
    overflow: hidden;
    height: calc(100vh - 210px);
    display: flex;
    flex-direction: column;
  }

  .vendor-msg__sidebarHeader {
    padding: 14px 16px;
    border-bottom: 1px solid #eef2f7;
    display: flex;
    align-items: center;
    justify-content: space-between;
  }

  .vendor-msg__sidebarTitle {
    margin: 0;
    font-size: 16px;
    font-weight: 800;
    color: #0B1F44;
  }

  .vendor-msg__searchWrap {
    padding: 12px 16px;
    border-bottom: 1px solid #eef2f7;
    background: #fff;
  }

  .vendor-msg__search {
    width: 100%;
    height: 40px;
    border: 1px solid #e2e8f0;
    border-radius: 12px;
    padding: 0 12px;
    font-size: 13px;
    outline: none;
    background: #fbfdff;
  }
  .vendor-msg__search:focus {
    border-color: #1E56A0;
    box-shadow: 0 0 0 3px rgba(30, 86, 160, 0.10);
    background: #fff;
  }

  /* folders (optional) */
  .vendor-msg__folders {
    padding: 10px 8px;
    border-bottom: 1px solid #eef2f7;
  }
  .vendor-msg__folders a { text-decoration: none; }

  /* THREAD LIST container */
  .vendor-msg__threadList {
    padding: 8px;
    overflow: auto;
    flex: 1;
    background: #fff;
  }

  /* === Convert Magento inbox TABLE to thread list cards === */
  .vendor-msg__threadList table {
    width: 100%;
    border: 0 !important;
    border-collapse: separate !important;
    border-spacing: 0 10px !important;
    background: transparent !important;
  }

  .vendor-msg__threadList thead,
  .vendor-msg__threadList .admin__data-grid-header,
  .vendor-msg__threadList .admin__data-grid-pager,
  .vendor-msg__threadList .data-grid-filters,
  .vendor-msg__threadList .col-actions,
  .vendor-msg__threadList .action-select,
  .vendor-msg__threadList .action-menu,
  .vendor-msg__threadList .action-multicheck-wrap,
  .vendor-msg__threadList .data-grid-th,
  .vendor-msg__threadList .data-grid-checkbox-cell {
    display: none !important;
  }

  .vendor-msg__threadList tbody tr {
    background: #ffffff;
    border: 1px solid #eef2f7;
    border-radius: 14px;
    overflow: hidden;
    cursor: pointer;
    transition: background .15s ease, transform .15s ease;
  }

  .vendor-msg__threadList tbody tr:hover {
    background: #f4f8ff;
    transform: translateY(-1px);
  }

  .vendor-msg__threadList tbody tr.is-active {
    background: rgba(30, 86, 160, 0.10);
    border-color: rgba(30, 86, 160, 0.20);
    box-shadow: inset 3px 0 0 #1E56A0;
  }

  .vendor-msg__threadList td {
    border: 0 !important;
    padding: 0 !important;
    vertical-align: top;
  }

  /* Thread row layout (subject + sender + date) */
  .vendor-msg__threadCard {
    padding: 14px 12px;
    display: grid;
    grid-template-columns: 1fr auto;
    gap: 6px 10px;
    align-items: start;
  }

  .vendor-msg__threadSubject {
    font-size: 15px;
    font-weight: 900;
    color: #173A73;
    line-height: 1.2;
  }

  .vendor-msg__threadSender {
    grid-column: 1 / 2;
    font-size: 13px;
    color: #64748b;
    margin-top: 2px;
  }

  .vendor-msg__threadDate {
    grid-column: 2 / 3;
    font-size: 13px;
    color: #94A3B8;
    white-space: nowrap;
    margin-left: 10px;
  }

  /* RIGHT: Conversation area */
  .vendor-msg__content {
    flex: 1;
    background: #ffffff;
    border: 1px solid #e9eef6;
    border-radius: 14px;
    overflow: hidden;
    height: calc(100vh - 210px);
    display: flex;
    flex-direction: column;
    min-width: 0;
  }

  .vendor-msg__contentHeader {
    padding: 12px 16px;
    border-bottom: 1px solid #eef2f7;
