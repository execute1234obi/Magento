<?xml version="1.0"?>
<page xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
      xsi:noNamespaceSchemaLocation="urn:magento:framework:View/Layout/etc/page_configuration.xsd">
    <head>
        <css src="Vnecoms_VendorsMessage::css/icons.css"/>
        <css src="Vnecoms_VendorsMessage::css/message.css"/>
        <css src="Vnecoms_VendorsMessage::css/attachments.css"/>
        <css src="Vnecoms_VendorsMessage::css/fileuploader.css"/>
    </head>
    <body>
        <referenceBlock name="seller.messages" remove="true"/>
        <referenceContainer name="content">
            <block class="Vendor\VendorMessagesSubMenu\Block\Vendors\Messages\Sent"
                   name="vendor.messages.sent"
                   template="Vendor_VendorMessagesSubMenu::messages/sent.phtml">
                <arguments>
                    <argument name="block_title" xsi:type="string">Sent</argument>
                </arguments>
            </block>
        </referenceContainer>
    </body>
</page>
