<script>
/* ---------- City data per country code ---------- */
var citiesData = {
    'SA': ['Jeddah','Mecca','Abha','Riyadh','Madina','Yanbu','Qassim','Taif','Dammam','Tabuk'],
    'AE': ['Dubai','Abu Dhabi','Sharjah','Ajman','Ras Al Khaimah','Fujairah','Umm Al Quwain'],
    'QA': ['Doha','Al Rayyan','Al Wakrah','Al Khor','Lusail','Mesaieed'],
    'BH': ['Manama','Riffa','Muharraq','Hamad Town','Isa Town','Sitra'],
    'KW': ['Kuwait City','Hawalli','Salmiya','Farwaniya','Ahmadi','Jahra'],
    'OM': ['Muscat','Salalah','Sohar','Nizwa','Sur','Ibri'],
    'ID': ['Jakarta','Surabaya','Bandung','Medan','Bali','Yogyakarta'],
    'MY': ['Kuala Lumpur','Penang','Johor Bahru','Ipoh','Kota Kinabalu','Kuching'],
    'SG': ['Singapore'],
    'TH': ['Bangkok','Chiang Mai','Phuket','Pattaya','Hua Hin','Chiang Rai'],
    'PH': ['Manila','Cebu','Davao','Quezon City','Makati','Pasig']
};

/* ---------- Toggle open/close ---------- */
function toggleCustomSelect(type) {
    var wrapper = document.getElementById(type + '-wrapper');
    var isOpen  = wrapper.classList.contains('open');
    // close all first
    document.querySelectorAll('.custom-select-wrapper').forEach(function(w){
        w.classList.remove('open');
    });
    if (!isOpen) {
        wrapper.classList.add('open');
        // focus search box
        var search = document.getElementById(type + '-search');
        if (search) setTimeout(function(){ search.focus(); }, 50);
    }
}

/* ---------- Close on outside click ---------- */
document.addEventListener('click', function(e) {
    if (!e.target.closest('.custom-select-wrapper')) {
        document.querySelectorAll('.custom-select-wrapper').forEach(function(w){
            w.classList.remove('open');
        });
    }
});

/* ---------- Select country ---------- */
function selectCountry(code, label) {
    // Update trigger label
    var lbl = document.getElementById('country-label');
    lbl.textContent = label;
    lbl.style.color = '#111827';

    // Set hidden input for form submit
    document.getElementById('country').value = code;

    // Mark selected option
    document.querySelectorAll('#country-options .custom-option').forEach(function(opt) {
        opt.classList.toggle('selected', opt.dataset.value === code);
        var radio = opt.querySelector('input[type="radio"]');
        if (radio) radio.checked = (opt.dataset.value === code);
    });

    // Close dropdown
    document.getElementById('country-wrapper').classList.remove('open');

    // Load cities for selected country
    loadCities(code);
}

/* ---------- Load cities ---------- */
function loadCities(countryCode) {
    var cities    = citiesData[countryCode] || [];
    var container = document.getElementById('city-options');

    // Reset city
    document.getElementById('city-label').textContent = 'Select Your City';
    document.getElementById('city-label').style.color  = '#9ca3af';
    document.getElementById('region').value    = '';
    document.getElementById('region_id').value = '';

    if (cities.length === 0) {
        container.innerHTML = '<p class="city-placeholder-msg">No cities available for this country</p>';
        return;
    }

    var html = '';
    cities.forEach(function(city) {
        html += '<label class="custom-option" data-value="' + city + '" data-label="' + city + '" onclick="selectCity(\'' + city + '\')">' +
                    '<span>' + city + '</span>' +
                    '<input type="radio" name="city_radio" value="' + city + '">' +
                    '<span class="custom-radio"></span>' +
                '</label>';
    });
    container.innerHTML = html;
}

/* ---------- Select city ---------- */
function selectCity(city) {
    var lbl = document.getElementById('city-label');
    lbl.textContent = city;
    lbl.style.color = '#111827';

    document.getElementById('region').value    = city;
    document.getElementById('region_id').value = city;

    // Mark selected
    document.querySelectorAll('#city-options .custom-option').forEach(function(opt) {
        opt.classList.toggle('selected', opt.dataset.value === city);
        var radio = opt.querySelector('input[type="radio"]');
        if (radio) radio.checked = (opt.dataset.value === city);
    });

    document.getElementById('city-wrapper').classList.remove('open');
}

/* ---------- Toggle group collapse ---------- */
function toggleGroup(groupId) {
    var group = document.querySelector('[data-group="' + groupId + '"]');
    if (group) group.classList.toggle('collapsed');
}

/* ---------- Search/filter options ---------- */
function filterOptions(type) {
    var search  = document.getElementById(type + '-search').value.toLowerCase().trim();
    var options = document.querySelectorAll('#' + type + '-options .custom-option');

    options.forEach(function(opt) {
        var label = (opt.dataset.label || '').toLowerCase();
        opt.style.display = label.includes(search) ? '' : 'none';
    });

    // Expand all groups while searching
    if (search) {
        document.querySelectorAll('#' + type + '-options .option-group').forEach(function(g) {
            g.classList.remove('collapsed');
        });
    }
}
</script>

<script>
require(['jquery'], function($) {
    $(document).ready(function() {

        /* Submit validation */
        $(document).on('click', '#submit-quote', function(e) {
            e.preventDefault();
            var country = $('#country').val();
            var note    = $('.quote-textarea').val().trim();
            if (!country) { alert('<?= __('Please select a country.') ?>'); return false; }
            if (!note)    { alert('<?= __('Please write a message.') ?>');   return false; }
            $('#form-validate').submit();
        });

        /* Select-all checkbox */
        $(document).on('change', '#select-all-products', function() {
            $('.product-item-checkbox').prop('checked', $(this).is(':checked'));
        });

        /* Qty stepper */
        $(document).on('click', '.qty-btn.plus', function() {
            var input = $(this).siblings('.qty-input');
            input.val(parseInt(input.val()) + 1);
        });
        $(document).on('click', '.qty-btn.minus', function() {
            var input = $(this).siblings('.qty-input');
            var val   = parseInt(input.val());
            if (val > 1) input.val(val - 1);
        });

        /* Vendor trash button */
        $(document).on('click', '.vendor-trash', function() {
            if (confirm('<?= __('Remove this product from quotation?') ?>')) {
                $(this).closest('.vendor-block').fadeOut(200, function(){ $(this).remove(); });
            }
        });

    });
});
</script>


