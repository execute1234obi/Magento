<script>
require(['jquery'], function($){
    $(document).ready(function(){

        // Sabse pehle purane events clear karein taaki double increment na ho
        $(document).off('click', '.qty-btn.plus');
        $(document).off('click', '.qty-btn.minus');
        $(document).off('click', '.vendor-trash');

        // 1. PLUS Button logic
        $(document).on('click', '.qty-btn.plus', function(e){
            e.preventDefault();
            var input = $(this).siblings('.qty-input');
            var currentVal = parseInt(input.val());
            if (!isNaN(currentVal)) {
                input.val(currentVal + 1);
            }
        });

        // 2. MINUS Button logic
        $(document).on('click', '.qty-btn.minus', function(e){
            e.preventDefault();
            var input = $(this).siblings('.qty-input');
            var currentVal = parseInt(input.val());
            if (!isNaN(currentVal) && currentVal > 1) {
                input.val(currentVal - 1);
            }
        });

        // 3. REMOVE (Trash) logic
        $(document).on('click', '.vendor-trash', function(){
            var productId = $(this).data('id');
            var removeUrl = '<?= $block->getUrl("quoterequest/index/remove") ?>' + 'id/' + productId;
            
            if(confirm('<?= __("Are you sure you want to remove this product?") ?>')) {
                window.location.href = removeUrl;
            }
        });
        
        // 4. Select All Logic (Optional but good to have)
        $(document).on('change', '.quote-select-all input', function(){
            $('.product-check input').prop('checked', $(this).prop('checked'));
        });
    });
});
</script>