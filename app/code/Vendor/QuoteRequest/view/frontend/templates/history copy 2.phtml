<?php $rfqs = $block->getRfqs(); ?>

<div class="rfq-history">

    <h2 class="text-2xl font-semibold mb-4">My RFQs</h2>

    <?php if (!$rfqs || count($rfqs) === 0): ?>
        <div class="p-4 bg-gray-100 rounded">
            <p>No RFQs found.</p>
        </div>
    <?php else: ?>

        <div class="overflow-x-auto">
            <table class="min-w-full border border-gray-200 text-sm">
                <thead class="bg-gray-50">
                    <tr>
                        <th class="p-3 border">Sr. no.</th>
                        <th class="p-3 border">Product</th>
                        <th class="p-3 border">SKU</th>
                        <th class="p-3 border">Price</th>
                        <th class="p-3 border">Qty</th>
                        <th class="p-3 border">Status</th>
                        <th class="p-3 border">Date</th>
                        <th class="p-3 border">Action</th>
                    </tr>
                </thead>

                <tbody>
                    <?php $count = 1; ?>
                    <?php foreach ($rfqs as $rfq): ?>

                        <?php
                            $product = $block->getProduct($rfq['product_id']);
                        ?>

                        <tr class="border-t hover:bg-gray-50">

                            <!-- RFQ ID -->
                            <td class="p-3 border font-medium">
                                #<?= $count++; ?>
                            </td>

                            <!-- Product -->
                            <td class="p-3 border">
                                <?php if ($product && $product->getId()): ?>

                                    <div class="flex items-center gap-3">

                                        <!-- Image -->
                                        <div class="w-16 flex-shrink-0">
                                           <?php $imageUrl = $block->getImageUrl($product); ?>

<?php if ($imageUrl): ?>
    <img 
        src="<?= $block->escapeUrl($imageUrl); ?>"
        alt="<?= $block->escapeHtml($product->getName()); ?>"
        class="rounded w-16 h-16 object-cover"
    />
<?php endif; ?>

                                        </div>

                                        <!-- Name -->
                                        <div>
                                            <div class="font-medium text-gray-800">
                                                <?= $block->escapeHtml($product->getName()); ?>
                                            </div>

                                            <?php if ($product->isSaleable()): ?>
                                                <span class="text-green-600 text-xs">In Stock</span>
                                            <?php else: ?>
                                                <span class="text-red-500 text-xs">Out of Stock</span>
                                            <?php endif; ?>
                                        </div>

                                    </div>

                                <?php else: ?>
                                    <span class="text-red-500">Product not available</span>
                                <?php endif; ?>
                            </td>

                            <!-- SKU -->
                            <td class="p-3 border">
                                <?= $product ? $block->escapeHtml($product->getSku()) : '-'; ?>
                            </td>

                            <!-- Price -->
                            <td class="p-3 border">
                                <?php if ($product): ?>
                                    <?= $block->formatPrice($product->getFinalPrice()); ?>
                                <?php else: ?>
                                    -
                                <?php endif; ?>
                            </td>

                            <!-- Qty -->
                            <td class="p-3 border">
                                <?= (int)$rfq['qty']; ?>
                            </td>

                            <!-- Status -->
                            <td class="p-3 border">
                                <?php
                                    $status = strtolower($rfq['status']);
                                    $badgeClass = 'bg-gray-200 text-gray-800';

                                    if ($status === 'pending') {
                                        $badgeClass = 'bg-yellow-100 text-yellow-800';
                                    } elseif ($status === 'approved') {
                                        $badgeClass = 'bg-green-100 text-green-800';
                                    } elseif ($status === 'rejected') {
                                        $badgeClass = 'bg-red-100 text-red-800';
                                    }
                                ?>

                                <span class="px-2 py-1 rounded text-xs font-medium <?= $badgeClass; ?>">
                                    <?= ucfirst($rfq['status']); ?>
                                </span>
                            </td>

                            <!-- Date -->
                            <td class="p-3 border">
                                <?= date('d M Y', strtotime($rfq['created_at'])); ?>
                            </td>

                            <!-- Action -->
                            <td class="p-3 border">
                                <?php if ($product): ?>
                                    <a href="<?= $product->getProductUrl(); ?>"
                                       class="text-blue-600 hover:underline">
                                        View Product
                                    </a>
                                <?php else: ?>
                                    -
                                <?php endif; ?>
                            </td>

                        </tr>

                    <?php endforeach; ?>
                </tbody>
            </table>
        </div>

    <?php endif; ?>

</div>
