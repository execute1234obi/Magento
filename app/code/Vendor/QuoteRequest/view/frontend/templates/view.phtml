        var count = $('.product-item-checkbox:checked').length;
        $('.product-count').text(count + ' ' + (count === 1 ? productLabelSingular : productLabelPlural));
        $('.quote-card-title span').text('(Select the products you wish to inquire about)');
    }

    var moreLabel = <?= /* @noEscape */ json_encode((string) __('More')); ?>;
    var lessLabel = <?= /* @noEscape */ json_encode((string) __('Show less')); ?>;

    $(document).on('click', '.desc-toggle', function(e){
        e.preventDefault();
        var $button = $(this);
        var $descText = $button.closest('.product-desc').find('.desc-text').first();
        var shortText = $descText.data('short') || '';
        var fullText = $descText.data('full') || shortText;
        var isExpanded = $button.attr('aria-expanded') === 'true';

        if (isExpanded) {
            $descText.text(shortText + (fullText.length > shortText.length ? '...' : ''));
            $button.text(moreLabel).attr('aria-expanded', 'false');
            return;
        }

        $descText.text(fullText);
        $button.text(lessLabel).attr('aria-expanded', 'true');
    });

    $(document).ready(function(){

        updateCount(); // page load pe call

        // SELECT ALL
        $(document).on('change', '#select-all-products', function () {
            var isChecked = $(this).is(':checked');
            $('.product-item-checkbox').prop('checked', isChecked);
            updateCount();
        });

        // INDIVIDUAL
        $(document).on('change', '.product-item-checkbox', function () {
            var total   = $('.product-item-checkbox').length;
            var checked = $('.product-item-checkbox:checked').length;

            $('#select-all-products').prop('checked', total === checked);
            updateCount();
        });

    });

});

</script>

