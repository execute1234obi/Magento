/* ════════════════════════════════════════════════════
   CUSTOM SELECT DROPDOWN  (prefix: csd-)
   ════════════════════════════════════════════════════ */

.csd-wrapper { position:relative; width:100%; }

/* ── Trigger button ─────────────────────────────────── */
.csd-trigger {
    display:flex; align-items:center; justify-content:space-between;
    height:52px; padding:0 16px;
    border:1px solid #d1d5db; border-radius:12px;
    background:#fff; cursor:pointer;
    user-select:none;
    transition:border-color .2s, box-shadow .2s;
}
.csd-trigger:hover,
.csd-wrapper.csd-open .csd-trigger {
    border-color:#93c5fd;
    box-shadow:0 0 0 4px rgba(59,130,246,.10);
}
.csd-label {
    flex:1; font-size:14px; color:#9ca3af;
    white-space:nowrap; overflow:hidden; text-overflow:ellipsis;
}
.csd-label--chosen { color:#111827; }
.csd-arrow { flex-shrink:0; transition:transform .2s; }
.csd-wrapper.csd-open .csd-arrow { transform:rotate(180deg); }

/* ── Panel ──────────────────────────────────────────── */
.csd-panel {
    display:none;
    position:absolute; top:calc(100% + 6px); left:0; right:0;
    background:#fff; border:1px solid #e5e7eb; border-radius:14px;
    box-shadow:0 10px 36px rgba(0,0,0,.13); z-index:9999; overflow:hidden;
}
.csd-wrapper.csd-open .csd-panel { display:block; }

/* ── Search row ─────────────────────────────────────── */
.csd-search-row {
    display:flex; align-items:center; gap:10px;
    padding:12px 14px; border-bottom:1px solid #f3f4f6;
}
.csd-search-input {
    flex:1; border:none; outline:none;
    font-size:13px; color:#374151; background:transparent;
}
.csd-search-input::placeholder { color:#9ca3af; }

/* ── Scrollable list ────────────────────────────────── */
.csd-list { max-height:290px; overflow-y:auto; padding:6px 0; }
.csd-list::-webkit-scrollbar { width:4px; }
.csd-list::-webkit-scrollbar-thumb { background:#e5e7eb; border-radius:4px; }

/* ── Group header ───────────────────────────────────── */
.csd-group-hd {
    display:flex; align-items:center; justify-content:space-between;
    padding:10px 16px 6px;
    font-size:13px; font-weight:700; color:#111827;
    cursor:pointer; user-select:none;
}
.csd-group-hd:hover { background:#f9fafb; }
.csd-group-arrow { transition:transform .2s; }
.csd-group--collapsed .csd-group-arrow { transform:rotate(-90deg); }
.csd-group--collapsed .csd-group-body  { display:none; }

/* ── Individual item ────────────────────────────────── */
.csd-item {
    display:flex; align-items:center;
    padding:10px 16px 10px 30px;
    font-size:14px; color:#374151;
    cursor:pointer; transition:background .12s;
    gap:0;
}
.csd-item span:first-child { flex:1; }
.csd-item:hover { background:#f0f7ff; }
.csd-item input[type=radio] { display:none; }

/* ── Radio circle ───────────────────────────────────── */
.csd-radio {
    width:18px; height:18px; border-radius:50%;
    border:2px solid #d1d5db; flex-shrink:0;
    transition:border-color .15s, background .15s;
    box-sizing:border-box;
}
/* selected state */
.csd-item--active .csd-radio,
.csd-item--active:hover .csd-radio {
    border-color:#2563eb;
    background:#2563eb;
    box-shadow:inset 0 0 0 3px #fff;
}
.csd-item--active {
    background:#eff6ff;
    color:#1d4ed8;
    font-weight:600;
}

/* ── Empty / placeholder ────────────────────────────── */
.csd-empty {
    padding:18px 16px; margin:0;
    font-size:13px; color:#9ca3af; text-align:center;
}


