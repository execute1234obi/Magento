<script>
/* ── City data ─────────────────────────────────────── */
var CSD_CITIES = {
    SA: ['Jeddah','Mecca','Abha','Riyadh','Madina','Yanbu','Qassim','Taif','Dammam','Tabuk'],
    AE: ['Dubai','Abu Dhabi','Sharjah','Ajman','Ras Al Khaimah','Fujairah','Umm Al Quwain'],
    QA: ['Doha','Al Rayyan','Al Wakrah','Al Khor','Lusail','Mesaieed'],
    BH: ['Manama','Riffa','Muharraq','Hamad Town','Isa Town','Sitra'],
    KW: ['Kuwait City','Hawalli','Salmiya','Farwaniya','Ahmadi','Jahra'],
    OM: ['Muscat','Salalah','Sohar','Nizwa','Sur','Ibri'],
    ID: ['Jakarta','Surabaya','Bandung','Medan','Bali','Yogyakarta'],
    MY: ['Kuala Lumpur','Penang','Johor Bahru','Ipoh','Kota Kinabalu','Kuching'],
    SG: ['Singapore'],
    TH: ['Bangkok','Chiang Mai','Phuket','Pattaya','Hua Hin','Chiang Rai'],
    PH: ['Manila','Cebu','Davao','Quezon City','Makati','Pasig']
};

/* ── Open / close toggle ───────────────────────────── */
function csdToggle(type) {
    var wrapper = document.getElementById(type + '-wrapper');
    var isOpen  = wrapper.classList.contains('csd-open');
    /* close all */
    document.querySelectorAll('.csd-wrapper').forEach(function(w){ w.classList.remove('csd-open'); });
    if (!isOpen) {
        wrapper.classList.add('csd-open');
        var inp = document.getElementById(type + '-search');
        if (inp) setTimeout(function(){ inp.focus(); }, 60);
    }
}

/* close on outside click */
document.addEventListener('click', function(e){
    if (!e.target.closest('.csd-wrapper')) {
        document.querySelectorAll('.csd-wrapper').forEach(function(w){ w.classList.remove('csd-open'); });
    }
});

/* ── Pick country ──────────────────────────────────── */
function csdPickCountry(code, label) {
    /* update trigger */
    var lbl = document.getElementById('country-label');
    lbl.textContent = label;
    lbl.classList.add('csd-label--chosen');

    /* hidden input */
    document.getElementById('country').value = code;

    /* mark selected */
    document.querySelectorAll('#country-list .csd-item').forEach(function(item){
        var active = item.dataset.val === code;
        item.classList.toggle('csd-item--active', active);
        var r = item.querySelector('input[type=radio]');
        if (r) r.checked = active;
    });

    /* close */
    document.getElementById('country-wrapper').classList.remove('csd-open');

    /* load cities */
    csdLoadCities(code);
}

/* ── Load city list ────────────────────────────────── */
function csdLoadCities(code) {
    var cities = CSD_CITIES[code] || [];
    var list   = document.getElementById('city-list');

    /* reset city selection */
    var cityLbl = document.getElementById('city-label');
    cityLbl.textContent = 'Select Your City';
    cityLbl.classList.remove('csd-label--chosen');
    document.getElementById('region').value    = '';
    document.getElementById('region_id').value = '';

    if (!cities.length) {
        list.innerHTML = '<p class="csd-empty">No cities available for this country</p>';
        return;
    }

    var html = '';
    cities.forEach(function(city){
        html += '<label class="csd-item" data-val="' + city + '" data-lbl="' + city + '" onclick="csdPickCity(\'' + city.replace(/'/g,"\\'") + '\')">' +
                    '<span>' + city + '</span>' +
                    '<span class="csd-radio"></span>' +
                    '<input type="radio" name="_cityR" value="' + city + '">' +
                '</label>';
    });
    list.innerHTML = html;
}

/* ── Pick city ─────────────────────────────────────── */
function csdPickCity(city) {
    var lbl = document.getElementById('city-label');
    lbl.textContent = city;
    lbl.classList.add('csd-label--chosen');

    document.getElementById('region').value    = city;
    document.getElementById('region_id').value = city;

    document.querySelectorAll('#city-list .csd-item').forEach(function(item){
        var active = item.dataset.val === city;
        item.classList.toggle('csd-item--active', active);
        var r = item.querySelector('input[type=radio]');
        if (r) r.checked = active;
    });

    document.getElementById('city-wrapper').classList.remove('csd-open');
}

/* ── Group collapse ────────────────────────────────── */
function csdGroupToggle(gid) {
    var g = document.querySelector('.csd-group[data-gid="' + gid + '"]');
    if (g) g.classList.toggle('csd-group--collapsed');
}

/* ── Search / filter ───────────────────────────────── */
function csdFilter(type) {
    var q    = document.getElementById(type + '-search').value.toLowerCase().trim();
    var list = document.getElementById(type === 'country' ? 'country-list' : 'city-list');

    list.querySelectorAll('.csd-item').forEach(function(item){
        var lbl = (item.dataset.lbl || '').toLowerCase();
        item.style.display = lbl.includes(q) ? '' : 'none';
    });

    /* expand all groups while searching */
    if (q) {
        list.querySelectorAll('.csd-group').forEach(function(g){ g.classList.remove('csd-group--collapsed'); });
    }
}
</script>

<script>
require(['jquery', 'js/gcc-feedback'], function($, feedback){
    $(document).ready(function(){
        feedback.showPendingToast();

        /* submit */
        $(document).on('click','#submit-quote',function(e){
            e.preventDefault();
            var country = $('#country').val();
            var note    = $('.quote-textarea').val().trim();
            var selectedProducts = $('.product-item-checkbox:checked').length;
            // console.log('Selected:', selectedProducts);

            if (!country) {
                feedback.toast(<?= /* @noEscape */ json_encode((string) __('Please select a country.')) ?>, 'warning', <?= /* @noEscape */ json_encode((string) __('Country required')) ?>);
                return;
            }
            if (!note) {
                feedback.toast(<?= /* @noEscape */ json_encode((string) __('Please write a message.')) ?>, 'warning', <?= /* @noEscape */ json_encode((string) __('Message required')) ?>);
                return;
            }
             // 🔥 NEW VALIDATION
            if (selectedProducts === 0) {
                feedback.toast(<?= /* @noEscape */ json_encode((string) __('Please select at least one product.')) ?>, 'warning', <?= /* @noEscape */ json_encode((string) __('Select products')) ?>);
                return;
            }
            $('#form-validate').submit();
        });

        /* select all */
        // $(document).on('change','#select-all-products',function(){
        //     $('.product-item-checkbox').prop('checked', $(this).is(':checked'));
        // });

        /* qty */
        $(document).on('click','.qty-btn.plus',function(){
            var i = $(this).siblings('.qty-input');
            i.val(parseInt(i.val()) + 1);
        });
        $(document).on('click','.qty-btn.minus',function(){
            var i = $(this).siblings('.qty-input');
            var v = parseInt(i.val());
            if (v > 1) i.val(v - 1);
        });

    });
});
</script>
