<?php $rfqs = $block->getRfqs(); ?>

<h2>My RFQs</h2>

<?php if (!$rfqs): ?>
    <p>No RFQs found.</p>
<?php else: ?>
    <table>
        <tr>
            <th>ID</th>
            <th>Status</th>
            <th>Date</th>
        </tr>

        <?php foreach ($rfqs as $rfq): ?>
            
            <tr>
                <td><?= $rfq['quote_id']; ?></td>
                <td><?= $rfq['status']; ?></td>
                <td><?= $rfq['created_at']; ?></td>
            </tr>
        <?php endforeach; ?>
    </table>
<?php endif; ?>
