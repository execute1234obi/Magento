            $statusClass = in_array($status, ['pending', 'approved', 'rejected'], true) ? $status : 'default';
            $statusLabel = ucfirst($status ?: 'pending');
            $requestDate = !empty($rfq['created_at'])
                ? date('d M Y, h:i A', strtotime((string) $rfq['created_at']))
                : '-';
            $vendorId = (int) ($rfq['vendor_id'] ?? 0);
            $vendorName = $vendorId > 0 ? $block->getVendorCompanyName($vendorId) : '';
            $requestTitle = $vendorName !== '' ? $vendorName : 'RFQ Request';
            $customerNote = trim((string) ($rfq['customer_note'] ?? ''));
