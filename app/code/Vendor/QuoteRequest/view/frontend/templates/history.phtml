<?php
/** @var \Vendor\QuoteRequest\Block\Customer\History $block */
$totalCount = $block->getRfqCount();
$limit = (int)$block->getRequest()->getParam('limit', 10);
$currentPage = (int)$block->getRequest()->getParam('p', 1);
$totalPages = ceil($totalCount / $limit);
$rfqs = (array) $block->getRfqs();
?>

<div class="rfq-history-wrap">
  <div class="rfq-history-head">
    <div>
      <h2 class="rfq-history-title">My RFQs</h2>
      <p class="rfq-history-subtitle"><?= $totalCount ?> request(s)</p>
    </div>
  </div>

  <?php if (!count($rfqs)): ?>
    <div class="rfq-empty">No RFQs found.</div>
  <?php else: ?>
    <div class="rfq-table-shell">
      <table class="rfq-table">
        <thead>
          <tr>
            <th class="rfq-col-id">#</th>
            <th>Product</th>
            <th>SKU</th>
            <th>Price</th>
            <th class="rfq-col-qty">Qty</th>
            <th class="rfq-col-status">Status</th>
            <th class="rfq-col-date">Date</th>
            <th class="rfq-col-action">Action</th>
          </tr>
        </thead>

        <tbody>
          <?php $i = (($currentPage - 1) * $limit) + 1;
                foreach ($rfqs as $rfq): ?>
            <?php
              $product = $block->getProduct($rfq['product_id']);
              $status = strtolower(trim((string)($rfq['status'] ?? '')));
              $badge = 'rfq-badge--default';
              if ($status === 'pending') $badge = 'rfq-badge--pending';
              if ($status === 'approved') $badge = 'rfq-badge--approved';
              if ($status === 'rejected') $badge = 'rfq-badge--rejected';
            ?>
            <tr>
              <td class="rfq-col-id" data-label="#">#<?= $i++ ?></td>

              <td data-label="Product">
                <?php if ($product && $product->getId()): ?>
                  <div class="rfq-product">
                    <div class="rfq-product-img">
                      <img src="<?= $block->escapeUrl($block->getImageUrl($product)) ?>"
                           alt="<?= $block->escapeHtmlAttr($product->getName()) ?>" />
                    </div>
                    <div>
                      <p class="rfq-product-name"><?= $block->escapeHtml($product->getName()) ?></p>
                      <p class="rfq-product-meta"><?= $product->isSaleable() ? 'In stock' : 'Out of stock' ?></p>
                    </div>
                  </div>
                <?php else: ?>
                  <span>Product not available</span>
                <?php endif; ?>
              </td>

              <td data-label="SKU"><?= $product ? $block->escapeHtml($product->getSku()) : '-' ?></td>
              <td data-label="Price"><?= $product ? $block->escapeHtml($block->formatPrice($product->getFinalPrice())) : '-' ?></td>
              <td class="rfq-col-qty" data-label="Qty"><?= (int)($rfq['qty'] ?? 0) ?></td>

              <td class="rfq-col-status" data-label="Status">
                <span class="rfq-badge <?= $badge ?>"><?= $block->escapeHtml(ucfirst($status ?: 'N/A')) ?></span>
              </td>

              <td class="rfq-col-date" data-label="Date">
                <?= !empty($rfq['created_at']) ? date('d M Y', strtotime($rfq['created_at'])) : '-' ?>
              </td>

              <td class="rfq-col-action" data-label="Action">
                <?php if ($product && $product->getId()): ?>
                  <a class="rfq-btn" href="<?= $block->escapeUrl($product->getProductUrl()) ?>">View product</a>
                <?php else: ?>
                  -
                <?php endif; ?>
              </td>
            </tr>
          <?php endforeach; ?>
        </tbody>
      </table>
      <?php //echo "pagination block here";
      if ($totalPages > 1): ?>
  <div class="custom-manual-pager">
    <ul class="pager-items">

      <?php for ($page = 1; $page <= $totalPages; $page++): ?>

        <li class="item <?= ($page == $currentPage) ? 'current' : '' ?>">

          <?php if ($page == $currentPage): ?>
            <strong><?= $page ?></strong>

          <?php else: ?>

            <a href="<?= $block->getUrl('*/*/*', ['_current' => true, 'p' => $page]) ?>">
              <?= $page ?>
            </a>

          <?php endif; ?>

        </li>

      <?php endfor; ?>

    </ul>
  </div>
<?php endif; ?>
    </div>
  <?php endif; ?>
</div>

