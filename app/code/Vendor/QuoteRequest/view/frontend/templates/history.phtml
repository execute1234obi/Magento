<script>
(function () {
  const filterRoot = document.querySelector('[data-rfq-filter]');
  const cards = Array.from(document.querySelectorAll('[data-rfq-card]'));
  const filterEmpty = document.querySelector('[data-rfq-filter-empty]');
  const printButtons = document.querySelectorAll('.rfq-print-btn');

  printButtons.forEach((button) => {
    button.addEventListener('click', () => {
      window.print();
    });
  });

  if (!filterRoot) {
    return;
  }

  const toggle = filterRoot.querySelector('[data-rfq-filter-toggle]');
  const menu = filterRoot.querySelector('[data-rfq-filter-menu]');
  const options = Array.from(filterRoot.querySelectorAll('[data-filter-status]'));
  let activeStatus = 'all';

  const setMenuState = (open) => {
    if (!toggle || !menu) {
      return;
    }

    menu.hidden = !open;
    toggle.setAttribute('aria-expanded', open ? 'true' : 'false');
  };

  const applyFilter = (status) => {
    activeStatus = status;

    cards.forEach((card) => {
      const cardStatus = card.dataset.status || 'default';
      const visible = status === 'all' || cardStatus === status;
      card.hidden = !visible;
    });

    if (filterEmpty) {
      const hasCards = cards.length > 0;
      const anyVisible = cards.some((card) => !card.hidden);
      filterEmpty.hidden = !hasCards || anyVisible;
      filterEmpty.classList.toggle('is-visible', hasCards && !anyVisible);
    }

    options.forEach((option) => {
      option.classList.toggle('is-active', option.dataset.filterStatus === status);
    });

    if (label) {
    }
  };

  toggle?.addEventListener('click', (event) => {
    event.stopPropagation();
    setMenuState(menu.hidden);
  });

  options.forEach((option) => {
    option.addEventListener('click', () => {
      const status = option.dataset.filterStatus || 'all';
      applyFilter(status);
      setMenuState(false);
    });
  });

  document.addEventListener('click', (event) => {
    if (!filterRoot.contains(event.target)) {
      setMenuState(false);
    }
  });

  applyFilter(activeStatus);
})();
</script>
