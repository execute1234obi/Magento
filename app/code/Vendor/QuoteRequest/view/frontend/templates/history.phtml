                      </p>
                    </div>
                  </div>
                <?php endforeach; ?>

                <?php if ($itemCount > 2): ?>
                  <div class="rfq-product-card rfq-product-card--more">
                    <strong>+<?= (int) ($itemCount - 2) ?></strong>
                    <span><?= $block->escapeHtml(__('more items')) ?></span>
                  </div>
                <?php endif; ?>
              <?php else: ?>
                <div class="rfq-product-card rfq-product-card--empty">
