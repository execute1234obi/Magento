<?php
/** @var \Vendor\QuoteRequest\Block\Customer\History $block */

$totalCount = $block->getRfqCount();
$limit = max(1, (int) $block->getRequest()->getParam('limit', 10));
$currentPage = max(1, (int) $block->getRequest()->getParam('p', 1));
$totalPages = (int) ceil($totalCount / $limit);
$rfqs = (array) $block->getRfqs();
$newRequestUrl = $block->getUrl('quoterequest/view/index');

$buildPageUrl = static function (int $page) use ($block): string {
    return $block->getUrl('*/*/*', ['_current' => true, 'p' => $page]);
};

$paginationPages = [];
if ($totalPages > 0) {
    if ($totalPages <= 5) {
        $paginationPages = range(1, $totalPages);
    } else {
        $paginationPages[] = 1;

        $start = max(2, $currentPage - 1);
        $end = min($totalPages - 1, $currentPage + 1);

        if ($start > 2) {
            $paginationPages[] = '...';
        }

        for ($page = $start; $page <= $end; $page++) {
            $paginationPages[] = $page;
        }

        if ($end < $totalPages - 1) {
            $paginationPages[] = '...';
        }

        $paginationPages[] = $totalPages;
    }
}
