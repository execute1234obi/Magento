      <?php if ($totalPages > 1): ?>
        <nav class="rfq-pagination" aria-label="<?= $block->escapeHtmlAttr(__('RFQ pagination')) ?>">
          <?php if ($currentPage > 1): ?>
            <a class="rfq-page-link rfq-page-link--nav" href="<?= $block->escapeUrl($buildPageUrl($currentPage - 1)) ?>">
              <span aria-hidden="true">←</span>
