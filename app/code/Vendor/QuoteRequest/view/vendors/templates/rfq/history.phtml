<?php $quotes = $block->getQuoteHistory(); ?>

<div class="vendor-quote-history">
    <div class="block-title">
        <h2><?= $block->escapeHtml(__('My Quote Requests')); ?></h2>
    </div>

    <div class="rfq-history-table-wrap">
        <table class="data table rfq-history-table">
            <thead>
                <tr>
                    <th scope="col"><?= $block->escapeHtml(__('Quote #')); ?></th>
                    <th scope="col"><?= $block->escapeHtml(__('Customer')); ?></th>
                    <th scope="col"><?= $block->escapeHtml(__('Products')); ?></th>
                    <th scope="col"><?= $block->escapeHtml(__('Status')); ?></th>
                </tr>
            </thead>
            <tbody>

            <?php if ($quotes && $quotes->getSize()): ?>
                <?php foreach ($quotes as $quote): ?>

                    <tr>
                        <td data-th="<?= $block->escapeHtmlAttr(__('Quote #')); ?>">
                            <?= $block->escapeHtml($quote->getQuoteId()); ?>
                        </td>
                        <td data-th="<?= $block->escapeHtmlAttr(__('Customer')); ?>">
                            <?= $block->escapeHtml($quote->getCustomerName()); ?>
                        </td>
                        <td data-th="<?= $block->escapeHtmlAttr(__('Products')); ?>">
                            <a
                                class="rfq-history-link"
                                href="<?= $block->escapeUrl($block->getUrl('quoterequest/rfq/productview', ['id' => $quote->getQuoteId()])); ?>"
                            >
                                <?= $block->escapeHtml(__('View Products')); ?>
                            </a>
                        </td>
                        <td data-th="<?= $block->escapeHtmlAttr(__('Status')); ?>">
                            <span class="rfq-status rfq-status-<?= $block->escapeHtmlAttr(strtolower((string) $quote->getStatus())); ?>">
                                <?= $block->escapeHtml(ucfirst((string) $quote->getStatus())); ?>
                            </span>
                        </td>
                    </tr>

                <?php endforeach; ?>
            <?php else: ?>
                <tr>
                    <td class="rfq-history-empty" colspan="4">
                        <?= $block->escapeHtml(__('No RFQs Found')); ?>
                    </td>
                </tr>
            <?php endif; ?>

            </tbody>
        </table>
    </div>
</div>
