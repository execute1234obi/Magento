<?php 
    // Block se data fetch karein
    $quotes = $block->getQuoteHistory(); 
    $pager = $block->getPagerData();
?>

<div class="vendor-quote-history">
    <table class="data table">
        <thead>
            <tr>
                <th>Quote #</th>
                <th>Customer</th>
                <th>Status</th>
                <th scope="col" class="col action"><?php echo __('Action') ?></th>
            </tr>
        </thead>
        <tbody>
            <?php if ($quotes && $quotes->getSize() > 0): ?>
                <?php foreach ($quotes as $quote): ?>
                    <tr>
                        <td><?= $quote->getQuoteId(); ?></td>
                        <td><?= $quote->getCustomerName(); ?></td>
                        <td><?= ucfirst($quote->getStatus()); ?></td>
                    </tr>
                      <td data-th="Action" class="col action">
                            <a href="#" class="action view"><span>View Details</span></a>
                        </td>
                <?php endforeach; ?>
            <?php else: ?>
                <tr><td colspan="3">No Records Found</td></tr>
            <?php endif; ?>
        </tbody>
    </table>

    <?php if (isset($pager['total_pages']) && $pager['total_pages'] > 1): ?>
        <div class="custom-pager-container">
            <ul class="custom-pager">
                <?php if ($pager['has_prev']): ?>
                    <li><a href="?p=<?= $pager['current_page'] - 1 ?>">&laquo; Prev</a></li>
                <?php endif; ?>

                <?php for ($i = 1; $i <= $pager['total_pages']; $i++): ?>
                    <li class="<?= ($i == $pager['current_page']) ? 'active' : '' ?>">
                        <a href="?p=<?= $i ?>"><?= $i ?></a>
                    </li>
                <?php endfor; ?>

                <?php if ($pager['has_next']): ?>
                    <li><a href="?p=<?= $pager['current_page'] + 1 ?>">Next &raquo;</a></li>
                <?php endif; ?>
            </ul>
        </div>
    <?php endif; ?>
</div>

<style>
    .custom-pager { display: inline-flex; list-style: none; padding: 10px 0; gap: 5px; }
    .custom-pager li a { padding: 5px 10px; border: 1px solid #ccc; text-decoration: none; color: #333; }
    .custom-pager li.active a { background: #007dbd; color: #fff; border-color: #007dbd; }
</style>