<?php
// @codingStandardsIgnoreFile
/** @var $block \Vnecoms\Vendors\Block\Page\Breadcrumbs */
?>


<?php if (!empty($links)): ?>
<?php
  $_size = count($links);
  $last = $links[$_size - 1];
  $pageTitle = isset($last['label']) ? $last['label'] : '';
?>


<style>
  /* ===== Match Figma header spacing + colors ===== */
  .vendor-pagehead {
    margin: 0 0 16px;          /* less top gap, more clean */
    padding-top: 6px;
  }


  /* Breadcrumb row */
  .vendor-breadcrumb {
    margin: 0;
    padding: 0;
    list-style: none;


    display: flex;
    align-items: center;
    flex-wrap: wrap;
    gap: 8px;


    font-size: 13px;          /* slightly bigger like figma */
    line-height: 18px;
    color: #94A3B8;           /* lighter gray like design */
    font-weight: 400;
  }


  .vendor-breadcrumb__item {
    display: inline-flex;
    align-items: center;
    gap: 8px;
  }


  .vendor-breadcrumb__sep {
    color: #CBD5E1;           /* soft divider */
  }


  .vendor-breadcrumb__link {
    color: #94A3B8;           /* same as breadcrumb text */
    text-decoration: none;
    transition: color .15s ease;
  }


  .vendor-breadcrumb__link:hover {
    color: #1E56A0;
    text-decoration: none;    /* figma style is no underline */
  }


  .vendor-breadcrumb__current {
    color: #1E56A0;           /* primary blue */
    font-weight: 600;
  }


  /* ✅ Title below breadcrumb (match catalog style) */
  .vendor-page-title {
    margin: 10px 0 0;
    font-size: 13px;
    line-height: 26px;
    font-weight: 700;
    color: #163172;
  }
  .vendor-page-title-gap{
padding-top: 10px;
  }


  /* ✅ Hide Magento default title inside header to avoid duplicate */
  .content-header > h1 {
    display: none !important;
  }
</style>




<div class="vendor-pagehead">
  <ol class="vendor-breadcrumb" aria-label="Breadcrumb">
    <!-- Home -->
    <li class="vendor-breadcrumb__item">
      <a class="vendor-breadcrumb__link" href="<?php echo $this->getHomeLink() ?>">
        <?php echo __("Home") ?>
      </a>
    </li>


    <?php foreach ($links as $_index => $_link): ?>
      <?php $isLast = ($_index == $_size - 1); ?>


      <li class="vendor-breadcrumb__item<?php if ($isLast): ?> is-active<?php endif; ?>">
        <span class="vendor-breadcrumb__sep">/</span>


        <?php if (!empty($_link['url']) && !$isLast): ?>
          <a class="vendor-breadcrumb__link"
             href="<?php /* @escapeNotVerified */ echo $_link['url'] ?>"
             title="<?php echo $block->escapeHtml($_link['title']) ?>">
            <?php echo $block->escapeHtml($_link['label']) ?>
          </a>
        <?php else: ?>
          <span class="vendor-breadcrumb__current">
            <?php echo $block->escapeHtml($_link['label']) ?>
          </span>
        <?php endif; ?>
      </li>
    <?php endforeach; ?>
  </ol>


  <!-- ✅ Page title shown below breadcrumb like Figma -->
  <?php if (!empty($pageTitle)): ?>
    <div class="vendor-page-title-gap">
    <div class="vendor-page-title">
      <?php echo $block->escapeHtml($pageTitle) ?>
    </div>
  </div>
  <?php endif; ?>
</div>


<?php endif; ?>