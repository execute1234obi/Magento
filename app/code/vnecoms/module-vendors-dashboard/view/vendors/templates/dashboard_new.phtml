// Custom Block Initialization
try {
    $mostViewedBlock = $block->getLayout()->createBlock(\Vendor\MostViewed\Block\Dashboard\MostViewed::class);
    $mostViewedProducts = $mostViewedBlock->getMostViewedProducts();
} catch (\Exception $e) {
    $mostViewedProducts = [];
}
?>
<?php
$pageSize   = (int)($this->getRequest()->getParam('limit') ?? 10);
$page       = (int)($this->getRequest()->getParam('p') ?? 1);
$page       = max(1, $pageSize ? $page : 1);

$totalItems = is_array($mostViewedProducts) ? count($mostViewedProducts) : 0;
$totalPages = $pageSize ? (int)ceil($totalItems / $pageSize) : 1;

$offset = ($page - 1) * $pageSize;
$pagedProducts = $pageSize
    ? array_slice($mostViewedProducts, $offset, $pageSize)
    : $mostViewedProducts;
?>
