<?php
use Magento\Framework\App\Action\Action;

/** @var $block \Vnecoms\VendorsMembership\Block\Vendors\Dashboard\Membership */
$_package = $block->getCurrentPackageProduct();

/**
 * Try to compute "time left" text from expiry date string.
 * We keep the old behavior (description), and just add this display.
 */
$timeLeftText = '';
try {
    $expiryText = trim((string)$block->getExpiryDate());
    if ($expiryText) {
        $expiryDate = new \DateTime($expiryText);
        $now = new \DateTime('now');

        if ($expiryDate > $now) {
            $diff = $now->diff($expiryDate);
            $months = ($diff->y * 12) + $diff->m;

            if ($months > 0) {
                $timeLeftText = $months . ' ' . ($months === 1 ? 'Month left' : 'Months left');
            } else {
                $days = (int)$diff->days;
                $timeLeftText = $days . ' ' . ($days === 1 ? 'Day left' : 'Days left');
            }
        } else {
            $timeLeftText = __('Expired');
        }
    }
} catch (\Exception $e) {
    // If parsing fails, just skip time-left text (do not break old UI).
    $timeLeftText = '';
}

$packageDesc = '';
if ($_package && $_package->getDescription()) {
    // Keep previous function: show description (may contain HTML)
    //$packageDesc = htmlspecialchars_decode($_package->getDescription());
}
