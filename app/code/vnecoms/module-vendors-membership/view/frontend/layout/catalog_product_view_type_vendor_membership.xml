<page xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xsi:noNamespaceSchemaLocation="urn:magento:framework:View/Layout/etc/page_configuration.xsd">
<!-- 	<head>
   		<css src="Vnecoms_VendorsMembership::css/membership.css"/>
   	</head> -->
    <body>
    	<attribute name="class" value="page-product-vendor-membership"/>
        <referenceContainer name="product.info.type">
            <block class="Vnecoms\VendorsMembership\Block\Product\View\Type\Membership" name="product.info.membership" as="product_type_data" template="Magento_Catalog::product/view/type/default.phtml"/>
            <container name="product.info.membership.extra" after="product.info.membership" as="product_type_data_extra" label="Product Extra Info"/>
        </referenceContainer>
        <referenceBlock name="product.info.options.wrapper">
            <block class="Vnecoms\VendorsMembership\Block\Product\View\Type\Membership" name="product.info.options.membership" as="options_membership" before="-" template="Vnecoms_VendorsMembership::product/view/type/options/membership.phtml" />
        </referenceBlock>
    </body>
</page>
