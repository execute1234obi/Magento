<schema xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
        xsi:noNamespaceSchemaLocation="urn:magento:framework:Setup/Declaration/Schema/etc/schema.xsd">
    <table name="ves_vendor_membership_transaction" resource="default" engine="innodb" comment="Membership Transaction Table">
        <column xsi:type="int" name="transaction_id" unsigned="true" nullable="false" identity="true"
                comment="Transaction Id"/>
        <column xsi:type="int" name="vendor_id" unsigned="true" nullable="false" comment="Vendor Id"/>
        <column xsi:type="varchar" name="package" length="255" comment="Package name"/>
        <column xsi:type="decimal" name="amount" scale="4" precision="12" comment="Transaction amount"/>
        <column xsi:type="int" name="duration" comment="Duration"/>
        <column xsi:type="smallint" name="duration_unit" comment="Duration Unit"/>
        <column xsi:type="text" name="additional_info" comment="Additional Info"/>
        <column xsi:type="timestamp" name="created_at" on_update="false" nullable="false" default="CURRENT_TIMESTAMP"
                comment="Created At"/>
        <constraint xsi:type="primary" referenceId="PRIMARY">
            <column name="transaction_id"/>
        </constraint>
        <constraint xsi:type="foreign" referenceId="VES_VENDOR_MEMBERSHIP_TRANSACTION_ENTITY_ID" table="ves_vendor_membership_transaction"
                    column="vendor_id" referenceTable="ves_vendor_entity" referenceColumn="entity_id"/>
    </table>

    <table name="ves_vendor_entity">
        <column xsi:type="date" name="expiry_date" nullable="true" comment="Expiry date"/>
    </table>

    <table name="ves_vendor_group">
        <column xsi:type="smallint" name="rank" nullable="false" default="0" comment="Rank"/>
    </table>
</schema>
